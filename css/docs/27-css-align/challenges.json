{
  "module": "CSS Alignment",
  "challenges": [
    {
      "id": 1,
      "difficulty": "easy",
      "title": "Center Text in a Box",
      "description": "Create a box with centered text both horizontally and vertically using multiple methods.",
      "requirements": [
        "Box with width 300px and height 150px",
        "Text centered horizontally",
        "Text centered vertically",
        "Show 3 different methods in 3 boxes"
      ],
      "solution": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  body { font-family: sans-serif; display: flex; gap: 20px; padding: 40px; flex-wrap: wrap; }\n  .box { width: 300px; height: 150px; border: 2px solid #333; border-radius: 8px; }\n  .method1 { text-align: center; line-height: 150px; }\n  .method2 { display: flex; align-items: center; justify-content: center; }\n  .method3 { position: relative; }\n  .method3 span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }\n</style>\n</head>\n<body>\n  <div class=\"box method1\">Method 1: line-height</div>\n  <div class=\"box method2\">Method 2: Flexbox</div>\n  <div class=\"box method3\"><span>Method 3: Absolute + transform</span></div>\n</body>\n</html>",
        "explanation": "Three different centering methods: line-height for single line text, Flexbox (align-items + justify-content), and absolute positioning with transform."
      }
    },
    {
      "id": 2,
      "difficulty": "easy",
      "title": "Centered Navigation Links",
      "description": "Create a horizontal navigation bar where all links are centered within the nav bar.",
      "requirements": [
        "Nav bar with dark background",
        "Nav links centered horizontally",
        "Links have padding and hover effects",
        "The entire nav bar should be centered on the page"
      ],
      "solution": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  body { font-family: sans-serif; }\n  nav { background: #1a1a2e; text-align: center; }\n  nav a {\n    display: inline-block;\n    padding: 15px 25px;\n    color: white;\n    text-decoration: none;\n  }\n  nav a:hover { background: #e94560; }\n</style>\n</head>\n<body>\n  <nav>\n    <a href=\"#\">Home</a>\n    <a href=\"#\">About</a>\n    <a href=\"#\">Services</a>\n    <a href=\"#\">Contact</a>\n  </nav>\n</body>\n</html>",
        "explanation": "text-align: center on the nav centers its inline-block child elements (the links)."
      }
    },
    {
      "id": 3,
      "difficulty": "medium",
      "title": "Vertical and Horizontal Center Card",
      "description": "Create a card that is centered both vertically and horizontally within a full-viewport container.",
      "requirements": [
        "Container takes full viewport height",
        "Card centered both vertically and horizontally",
        "Card has a title, description, and a button",
        "Use Flexbox for centering"
      ],
      "solution": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: sans-serif; }\n  .container {\n    height: 100vh;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: linear-gradient(135deg, #667eea, #764ba2);\n  }\n  .card {\n    background: white;\n    padding: 40px;\n    border-radius: 16px;\n    max-width: 400px;\n    text-align: center;\n    box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n  }\n  .card h2 { margin-bottom: 15px; color: #333; }\n  .card p { color: #666; margin-bottom: 25px; line-height: 1.6; }\n  .card button {\n    padding: 12px 30px;\n    background: #667eea;\n    color: white;\n    border: none;\n    border-radius: 6px;\n    font-size: 16px;\n    cursor: pointer;\n  }\n  .card button:hover { background: #5a6fd6; }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"card\">\n      <h2>Welcome!</h2>\n      <p>This card is centered both vertically and horizontally using Flexbox.</p>\n      <button>Get Started</button>\n    </div>\n  </div>\n</body>\n</html>",
        "explanation": "The full-viewport container uses display: flex, align-items: center, and justify-content: center to perfectly center the card."
      }
    },
    {
      "id": 4,
      "difficulty": "medium",
      "title": "Profile Card with Proper Alignment",
      "description": "Create a profile card where the avatar, name, and stats are all properly aligned using various alignment techniques.",
      "requirements": [
        "Circular avatar image centered at top",
        "Name and title centered below",
        "Stats (posts, followers, following) horizontally centered",
        "Social links centered at bottom",
        "Use at least 3 different alignment methods"
      ],
      "solution": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: sans-serif; padding: 40px; background: #f0f0f0; }\n  .card {\n    max-width: 400px;\n    margin: 0 auto;\n    background: white;\n    border-radius: 16px;\n    padding: 40px;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n    text-align: center;\n  }\n  .avatar {\n    width: 100px;\n    height: 100px;\n    border-radius: 50%;\n    background: #4a90d9;\n    color: white;\n    margin: 0 auto 20px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 36px;\n  }\n  .name { font-size: 24px; font-weight: bold; margin-bottom: 5px; }\n  .title { color: #999; margin-bottom: 25px; }\n  .stats { font-size: 0; }\n  .stat {\n    display: inline-block;\n    font-size: 14px;\n    padding: 0 20px;\n    vertical-align: top;\n  }\n  .stat-value { font-size: 22px; font-weight: bold; display: block; }\n  .stat-label { color: #999; }\n  .social { margin-top: 25px; }\n  .social a {\n    display: inline-block;\n    width: 40px; height: 40px;\n    line-height: 40px;\n    border-radius: 50%;\n    background: #f0f0f0;\n    margin: 0 5px;\n    text-decoration: none;\n    color: #555;\n  }\n  .social a:hover { background: #4a90d9; color: white; }\n</style>\n</head>\n<body>\n  <div class=\"card\">\n    <div class=\"avatar\">JD</div>\n    <div class=\"name\">John Doe</div>\n    <div class=\"title\">Web Developer</div>\n    <div class=\"stats\">\n      <div class=\"stat\"><span class=\"stat-value\">42</span><span class=\"stat-label\">Posts</span></div>\n      <div class=\"stat\"><span class=\"stat-value\">1.2K</span><span class=\"stat-label\">Followers</span></div>\n      <div class=\"stat\"><span class=\"stat-value\">340</span><span class=\"stat-label\">Following</span></div>\n    </div>\n    <div class=\"social\">\n      <a href=\"#\">T</a>\n      <a href=\"#\">F</a>\n      <a href=\"#\">I</a>\n      <a href=\"#\">G</a>\n    </div>\n  </div>\n</body>\n</html>",
        "explanation": "Uses: text-align: center for overall centering, margin: 0 auto for avatar, Flexbox (display: flex + align/justify) for avatar content, inline-block for stats, and line-height for social link vertical centering."
      }
    },
    {
      "id": 5,
      "difficulty": "hard",
      "title": "Responsive Dashboard with Mixed Alignment",
      "description": "Build a dashboard layout that uses multiple alignment techniques for different components. Include a header, sidebar, main content area with aligned cards, and a footer.",
      "requirements": [
        "Fixed header with centered title and right-aligned user menu",
        "Sidebar with left-aligned navigation items",
        "Main content with a hero section (centered), card grid (center), and stats row (space-between)",
        "Footer with centered text",
        "Use at least 5 different alignment methods",
        "Responsive to mobile"
      ],
      "solution": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: sans-serif; min-height: 100vh; }\n\n  .header {\n    background: #1a1a2e; color: white; padding: 0 30px;\n    display: flex; align-items: center; justify-content: space-between;\n    height: 60px; position: fixed; top: 0; left: 0; right: 0; z-index: 100;\n  }\n  .header h1 { font-size: 20px; }\n  .user-menu { display: flex; align-items: center; gap: 15px; }\n  .user-menu span { cursor: pointer; }\n  .user-menu span:hover { color: #e94560; }\n\n  .layout { display: flex; margin-top: 60px; min-height: calc(100vh - 60px); }\n\n  .sidebar {\n    width: 220px; background: #16213e; color: white; padding: 20px;\n  }\n  .sidebar a {\n    display: block; padding: 12px 15px; color: #ccc;\n    text-decoration: none; border-radius: 4px; margin-bottom: 5px;\n  }\n  .sidebar a:hover { background: #0f3460; color: white; }\n\n  .main { flex: 1; padding: 30px; background: #f5f5f5; }\n\n  .hero {\n    background: linear-gradient(135deg, #667eea, #764ba2);\n    color: white; border-radius: 12px; padding: 50px;\n    text-align: center; margin-bottom: 30px;\n  }\n  .hero h2 { font-size: 2em; margin-bottom: 10px; }\n  .hero p { font-size: 1.1em; opacity: 0.9; }\n\n  .card-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));\n    gap: 20px; margin-bottom: 30px;\n  }\n  .card {\n    background: white; border-radius: 8px; padding: 20px;\n  }\n  .card h3 { margin-bottom: 10px; }\n\n  .stats {\n    display: flex; justify-content: space-around;\n    background: white; border-radius: 8px; padding: 25px;\n    margin-bottom: 30px;\n  }\n  .stat { text-align: center; }\n  .stat-value { font-size: 28px; font-weight: bold; color: #4a90d9; }\n  .stat-label { color: #999; margin-top: 5px; }\n\n  footer {\n    text-align: center; padding: 20px; color: #999;\n  }\n\n  @media (max-width: 768px) {\n    .layout { flex-direction: column; }\n    .sidebar { width: 100%; }\n    .stats { flex-direction: column; gap: 20px; }\n  }\n</style>\n</head>\n<body>\n  <header class=\"header\">\n    <h1>Dashboard</h1>\n    <div class=\"user-menu\">\n      <span>Notifications</span>\n      <span>Profile</span>\n    </div>\n  </header>\n  <div class=\"layout\">\n    <aside class=\"sidebar\">\n      <a href=\"#\">Dashboard</a>\n      <a href=\"#\">Analytics</a>\n      <a href=\"#\">Users</a>\n      <a href=\"#\">Settings</a>\n    </aside>\n    <main class=\"main\">\n      <div class=\"hero\">\n        <h2>Welcome Back!</h2>\n        <p>Here's what's happening with your projects today.</p>\n      </div>\n      <div class=\"card-grid\">\n        <div class=\"card\"><h3>Total Users</h3><p style=\"font-size:2em; font-weight:bold;color:#4a90d9;\">1,234</p></div>\n        <div class=\"card\"><h3>Revenue</h3><p style=\"font-size:2em; font-weight:bold;color:#2ecc71;\">$12,345</p></div>\n        <div class=\"card\"><h3>Orders</h3><p style=\"font-size:2em; font-weight:bold;color:#e94560;\">456</p></div>\n      </div>\n      <div class=\"stats\">\n        <div class=\"stat\"><div class=\"stat-value\">85%</div><div class=\"stat-label\">Completion</div></div>\n        <div class=\"stat\"><div class=\"stat-value\">1.2K</div><div class=\"stat-label\">Visitors</div></div>\n        <div class=\"stat\"><div class=\"stat-value\">24</div><div class=\"stat-label\">New Users</div></div>\n      </div>\n    </main>\n  </div>\n  <footer>&copy; 2026 Dashboard. All rights reserved.</footer>\n</body>\n</html>",
        "explanation": "Uses: Flexbox (header with space-between, user-menu alignment), text-align: center (hero, stats, footer), CSS Grid (card grid), display: block with margins (sidebar links), flex: 1 (main content fill)."
      }
    }
  ]
}