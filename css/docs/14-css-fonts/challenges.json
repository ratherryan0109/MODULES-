    {"id":"easy-1","difficulty":"easy","title":"Create a Typography Scale","description":"Create a typography scale with proper heading hierarchy using rem units.","starterCode":{"html":"<h1>Heading 1</h1><h2>Heading 2</h2><h3>Heading 3</h3><p>Body text</p><small>Small text</small>"},"requirements":["Set html font-size to 62.5% (10px base)","Use rem for all font sizes","h1: 3.2rem, h2: 2.4rem, h3: 1.8rem, p: 1.6rem, small: 1.2rem"],"solution":{"css":"html{font-size:62.5%}body{font-family:Arial,sans-serif;font-size:1.6rem;line-height:1.6;color:#333}h1{font-size:3.2rem;margin-bottom:1rem}h2{font-size:2.4rem}h3{font-size:1.8rem}p{font-size:1.6rem}small{font-size:1.2rem}"}}
