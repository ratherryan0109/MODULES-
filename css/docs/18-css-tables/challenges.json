{"module":"18-css-tables","challenges":[
  {"id":"easy-1","difficulty":"easy","title":"Style a Pricing Table","description":"Create a styled pricing table with 3 tiers.","starterCode":{"html":"<table class=\"pricing\"><tr><th>Feature</th><th>Basic</th><th>Pro</th><th>Enterprise</th></tr><tr><td>Users</td><td>1</td><td>10</td><td>Unlimited</td></tr><tr><td>Storage</td><td>5GB</td><td>50GB</td><td>500GB</td></tr><tr><td>Price</td><td>$9</td><td>$29</td><td>$99</td></tr></table>"},"requirements":["Collapse borders","Zebra stripe rows","Highlight the 'Pro' column","Responsive with horizontal scroll"],"solution":{"css":".pricing{width:100%;border-collapse:collapse;font-family:Arial}.pricing th,.pricing td{padding:15px;text-align:center;border:1px solid #e2e8f0}.pricing th{background:#2d3748;color:white}.pricing tr:nth-child(even){background:#f7fafc}.pricing td:nth-child(3){background:#ebf8ff;font-weight:bold}"}}
]}
