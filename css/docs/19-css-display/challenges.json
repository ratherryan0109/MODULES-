{"module":"19-css-display","challenges":[
  {"id":"easy-1","difficulty":"easy","title":"Fix Layout with Display","description":"A navigation list is showing vertically. Fix it to display horizontally.","starterCode":{"html":"<ul class=\"nav\"><li>Home</li><li>About</li><li>Services</li><li>Contact</li></ul>","css":".nav{background:#2d3748;padding:15px}.nav li{background:#4299e1;color:white;padding:10px 20px;margin:5px}"},"requirements":["Make list items display horizontally","Remove default list styling","Add hover effects","Don't change the HTML"],"solution":{"css":".nav{background:#2d3748;padding:15px;list-style:none;display:flex;gap:10px}.nav li{background:#4299e1;color:white;padding:10px 20px;border-radius:5px;cursor:pointer}.nav li:hover{background:#2b6cb0}"}}
