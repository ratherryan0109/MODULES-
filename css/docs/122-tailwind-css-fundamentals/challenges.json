{
  "easy": {
    "title": "Build a Card with Tailwind Utilities",
    "description": "Create a card component using only Tailwind utility classes. The card should include an image area, a title, description text, and a button. Use bg-white, rounded-xl, shadow-md, p-6, and typography utilities. No custom CSS allowed.",
    "starterCode": "<div>\n  <h2>Card Title</h2>\n  <p>Card description goes here</p>\n  <button>Click Me</button>\n</div>",
    "solution": "<div class=\"max-w-sm mx-auto bg-white rounded-xl shadow-md overflow-hidden\">\n  <div class=\"h-48 bg-gray-200 flex items-center justify-center text-gray-400 text-sm\">\n    Image Placeholder\n  </div>\n  <div class=\"p-6\">\n    <div class=\"uppercase tracking-wide text-sm text-indigo-500 font-semibold\">Category</div>\n    <h2 class=\"block mt-1 text-lg leading-tight font-medium text-black hover:underline\">\n      Card Title\n    </h2>\n    <p class=\"mt-2 text-gray-500 text-base\">\n      Card description goes here. Built entirely with Tailwind utility classes.\n    </p>\n    <button class=\"mt-4 bg-indigo-500 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded transition duration-150\">\n      Click Me\n    </button>\n  </div>\n</div>"
  },
  "medium": {
    "title": "Create a Responsive Sidebar Layout with Tailwind",
    "description": "Build a responsive sidebar + main content layout using Tailwind's responsive prefix utilities. On mobile the sidebar should stack above the content; on md screens and above it should sit on the left. Use flex-col on mobile and md:flex-row, with responsive width classes (w-full, md:w-64).",
    "starterCode": "<div>\n  <aside>Sidebar Navigation</aside>\n  <main>Main Content Area</main>\n</div>",
    "solution": "<div class=\"flex flex-col md:flex-row min-h-screen bg-gray-100\">\n  <aside class=\"w-full md:w-64 bg-gray-900 text-white p-6\">\n    <h3 class=\"text-xl font-bold mb-6\">My App</h3>\n    <nav class=\"flex flex-col gap-2\">\n      <a href=\"#\" class=\"block px-3 py-2 rounded bg-gray-700 text-white font-medium hover:bg-gray-600\">Dashboard</a>\n      <a href=\"#\" class=\"block px-3 py-2 rounded text-gray-300 hover:bg-gray-700 hover:text-white\">Analytics</a>\n      <a href=\"#\" class=\"block px-3 py-2 rounded text-gray-300 hover:bg-gray-700 hover:text-white\">Settings</a>\n      <a href=\"#\" class=\"block px-3 py-2 rounded text-gray-300 hover:bg-gray-700 hover:text-white\">Profile</a>\n    </nav>\n  </aside>\n  <main class=\"flex-1 p-8\">\n    <h1 class=\"text-3xl font-bold text-gray-900 mb-4\">Dashboard</h1>\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n      <div class=\"bg-white rounded-lg shadow p-6\">\n        <p class=\"text-sm text-gray-500\">Total Users</p>\n        <p class=\"text-2xl font-bold text-gray-900\">12,847</p>\n      </div>\n      <div class=\"bg-white rounded-lg shadow p-6\">\n        <p class=\"text-sm text-gray-500\">Revenue</p>\n        <p class=\"text-2xl font-bold text-gray-900\">$48,290</p>\n      </div>\n      <div class=\"bg-white rounded-lg shadow p-6\">\n        <p class=\"text-sm text-gray-500\">Active Now</p>\n        <p class=\"text-2xl font-bold text-gray-900\">384</p>\n      </div>\n    </div>\n  </main>\n</div>"
  },
  "hard": {
    "title": "Implement Dark Mode Toggle with Tailwind",
    "description": "Add a dark mode toggle to a page built with Tailwind. Use the dark: prefix on utility classes, toggle a class on the html element via JavaScript, and persist the user preference in localStorage. The page should include a header, cards, and text that adapt to both themes with smooth transitions.",
    "starterCode": "<body class=\"bg-white text-black\">\n  <header class=\"p-4 bg-gray-100\">\n    <h1 class=\"text-2xl font-bold\">My App</h1>\n    <button id=\"theme-toggle\">Toggle Dark Mode</button>\n  </header>\n  <main class=\"p-4\">\n    <div class=\"bg-white shadow p-6 rounded\">\n      <h2 class=\"text-xl font-semibold\">Welcome</h2>\n      <p>This is a sample page that needs dark mode support.</p>\n    </div>\n  </main>\n</body>",
    "solution": "<body class=\"bg-white dark:bg-gray-900 text-black dark:text-white transition-colors duration-300\">\n  <header class=\"p-4 bg-gray-100 dark:bg-gray-800 border-b dark:border-gray-700\">\n    <div class=\"max-w-6xl mx-auto flex items-center justify-between\">\n      <h1 class=\"text-2xl font-bold text-gray-900 dark:text-white\">My App</h1>\n      <button id=\"theme-toggle\" class=\"px-4 py-2 rounded bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-600 transition\">\n        Toggle Theme\n      </button>\n    </div>\n  </header>\n  <main class=\"p-4 max-w-6xl mx-auto\">\n    <div class=\"bg-white dark:bg-gray-800 shadow dark:shadow-gray-700/20 p-6 rounded-lg\">\n      <h2 class=\"text-xl font-semibold text-gray-900 dark:text-white mb-2\">Welcome</h2>\n      <p class=\"text-gray-600 dark:text-gray-300\">\n        This page now supports dark mode with Tailwind's dark: prefix utilities.\n      </p>\n    </div>\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-4 mt-6\">\n      <div class=\"bg-white dark:bg-gray-800 shadow dark:shadow-gray-700/20 p-4 rounded\">\n        <h3 class=\"font-bold text-gray-900 dark:text-white\">Card One</h3>\n        <p class=\"text-gray-500 dark:text-gray-400 text-sm\">Content here</p>\n      </div>\n      <div class=\"bg-white dark:bg-gray-800 shadow dark:shadow-gray-700/20 p-4 rounded\">\n        <h3 class=\"font-bold text-gray-900 dark:text-white\">Card Two</h3>\n        <p class=\"text-gray-500 dark:text-gray-400 text-sm\">Content here</p>\n      </div>\n      <div class=\"bg-white dark:bg-gray-800 shadow dark:shadow-gray-700/20 p-4 rounded\">\n        <h3 class=\"font-bold text-gray-900 dark:text-white\">Card Three</h3>\n        <p class=\"text-gray-500 dark:text-gray-400 text-sm\">Content here</p>\n      </div>\n    </div>\n  </main>\n  <script>\n    const toggle = document.getElementById('theme-toggle');\n    const html = document.documentElement;\n    if (localStorage.getItem('theme') === 'dark') html.classList.add('dark');\n    toggle.addEventListener('click', () => {\n      html.classList.toggle('dark');\n      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');\n    });\n  </script>\n</body>"
  }
}
