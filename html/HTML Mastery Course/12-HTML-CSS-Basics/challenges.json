{
  "easy": {
    "title": "Style a Personal Profile Card",
    "description": "Create a simple profile card using HTML and CSS. The card should have a profile picture (use a placeholder), name, short bio, and a button. Center it on the page and give it a subtle shadow and rounded corners.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Profile Card</title>\n  <style>\n    /* Add your CSS here */\n  </style>\n</head>\n<body>\n  <!-- Build your profile card here -->\n  <div class=\"profile-card\">\n    <img src=\"https://via.placeholder.com/120\" alt=\"Profile\">\n    <h2>Jane Doe</h2>\n    <p>Web Developer & Designer</p>\n    <button>Contact Me</button>\n  </div>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Profile Card</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', sans-serif;\n      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n    }\n    .profile-card {\n      background: white;\n      border-radius: 20px;\n      padding: 40px;\n      text-align: center;\n      box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n      max-width: 350px;\n    }\n    .profile-card img {\n      border-radius: 50%;\n      border: 4px solid #667eea;\n      margin-bottom: 20px;\n    }\n    .profile-card h2 {\n      color: #333;\n      margin-bottom: 8px;\n    }\n    .profile-card p {\n      color: #666;\n      margin-bottom: 20px;\n      font-size: 18px;\n    }\n    .profile-card button {\n      background: #667eea;\n      color: white;\n      border: none;\n      padding: 12px 30px;\n      border-radius: 50px;\n      font-size: 16px;\n      cursor: pointer;\n      transition: transform 0.2s;\n    }\n    .profile-card button:hover {\n      transform: scale(1.05);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"profile-card\">\n    <img src=\"https://via.placeholder.com/120\" alt=\"Profile\">\n    <h2>Jane Doe</h2>\n    <p>Web Developer & Designer</p>\n    <button>Contact Me</button>\n  </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a CSS-only Pricing Table",
    "description": "Create a responsive pricing table with three columns (Basic, Pro, Enterprise). Each column should have a title, price, features list, and a sign-up button. Highlight the 'Pro' plan with a different color and make it slightly larger. Use flexbox for layout.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Pricing Table</title>\n  <style>\n    /* Add your CSS here */\n  </style>\n</head>\n<body>\n  <section class=\"pricing\">\n    <h1>Choose Your Plan</h1>\n    <div class=\"plans\">\n      <!-- Basic Plan -->\n      <div class=\"plan\">\n        <h3>Basic</h3>\n        <p class=\"price\">$9<span>/mo</span></p>\n        <ul>\n          <li>10GB Storage</li>\n          <li>1 User</li>\n          <li>Basic Support</li>\n        </ul>\n        <button>Get Started</button>\n      </div>\n      <!-- Pro Plan -->\n      <div class=\"plan featured\">\n        <h3>Pro</h3>\n        <p class=\"price\">$29<span>/mo</span></p>\n        <ul>\n          <li>100GB Storage</li>\n          <li>5 Users</li>\n          <li>Priority Support</li>\n        </ul>\n        <button>Get Started</button>\n      </div>\n      <!-- Enterprise Plan -->\n      <div class=\"plan\">\n        <h3>Enterprise</h3>\n        <p class=\"price\">$99<span>/mo</span></p>\n        <ul>\n          <li>Unlimited Storage</li>\n          <li>Unlimited Users</li>\n          <li>24/7 Support</li>\n        </ul>\n        <button>Contact Us</button>\n      </div>\n    </div>\n  </section>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Pricing Table</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', sans-serif;\n      background: #f0f2f5;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      padding: 20px;\n    }\n    .pricing {\n      text-align: center;\n      max-width: 1100px;\n      width: 100%;\n    }\n    .pricing h1 {\n      font-size: 2.5rem;\n      color: #333;\n      margin-bottom: 40px;\n    }\n    .plans {\n      display: flex;\n      gap: 25px;\n      justify-content: center;\n      flex-wrap: wrap;\n    }\n    .plan {\n      background: white;\n      border-radius: 16px;\n      padding: 40px 30px;\n      flex: 1;\n      min-width: 250px;\n      max-width: 320px;\n      box-shadow: 0 8px 30px rgba(0,0,0,0.08);\n      transition: transform 0.3s;\n    }\n    .plan:hover {\n      transform: translateY(-8px);\n    }\n    .plan.featured {\n      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n      color: white;\n      transform: scale(1.05);\n      box-shadow: 0 12px 40px rgba(102,126,234,0.4);\n    }\n    .plan.featured:hover {\n      transform: scale(1.05) translateY(-8px);\n    }\n    .plan h3 {\n      font-size: 1.5rem;\n      margin-bottom: 15px;\n    }\n    .plan .price {\n      font-size: 3rem;\n      font-weight: 700;\n      margin-bottom: 25px;\n    }\n    .plan .price span {\n      font-size: 1rem;\n      font-weight: 400;\n      opacity: 0.7;\n    }\n    .plan ul {\n      list-style: none;\n      margin-bottom: 30px;\n    }\n    .plan ul li {\n      padding: 10px 0;\n      border-bottom: 1px solid #eee;\n    }\n    .plan.featured ul li {\n      border-bottom-color: rgba(255,255,255,0.2);\n    }\n    .plan button {\n      background: #667eea;\n      color: white;\n      border: none;\n      padding: 14px 35px;\n      border-radius: 50px;\n      font-size: 16px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: all 0.3s;\n      width: 100%;\n    }\n    .plan button:hover {\n      background: #5a6fd6;\n    }\n    .plan.featured button {\n      background: white;\n      color: #667eea;\n    }\n    .plan.featured button:hover {\n      background: #f0f0f0;\n    }\n  </style>\n</head>\n<body>\n  <section class=\"pricing\">\n    <h1>Choose Your Plan</h1>\n    <div class=\"plans\">\n      <div class=\"plan\">\n        <h3>Basic</h3>\n        <p class=\"price\">$9<span>/mo</span></p>\n        <ul>\n          <li>10GB Storage</li>\n          <li>1 User</li>\n          <li>Basic Support</li>\n        </ul>\n        <button>Get Started</button>\n      </div>\n      <div class=\"plan featured\">\n        <h3>Pro</h3>\n        <p class=\"price\">$29<span>/mo</span></p>\n        <ul>\n          <li>100GB Storage</li>\n          <li>5 Users</li>\n          <li>Priority Support</li>\n        </ul>\n        <button>Get Started</button>\n      </div>\n      <div class=\"plan\">\n        <h3>Enterprise</h3>\n        <p class=\"price\">$99<span>/mo</span></p>\n        <ul>\n          <li>Unlimited Storage</li>\n          <li>Unlimited Users</li>\n          <li>24/7 Support</li>\n        </ul>\n        <button>Contact Us</button>\n      </div>\n    </div>\n  </section>\n</body>\n</html>"
  },
  "hard": {
    "title": "Recreate a Hero Section from a Modern Website",
    "description": "Build a full hero section similar to a modern startup landing page. Include: a full-viewport background with gradient overlay, a heading with text shadow, a subheading, two call-to-action buttons (primary and outline), and a floating illustration or icon. Use flexbox for alignment, transitions for hover effects, and ensure it looks great at all screen sizes with media queries.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Hero Section</title>\n  <style>\n    /* Add your CSS here */\n  </style>\n</head>\n<body>\n  <section class=\"hero\">\n    <div class=\"hero-content\">\n      <h1>Build the Future</h1>\n      <p>Create amazing web experiences with modern tools.</p>\n      <div class=\"hero-buttons\">\n        <a href=\"#\" class=\"btn btn-primary\">Get Started</a>\n        <a href=\"#\" class=\"btn btn-outline\">Learn More</a>\n      </div>\n    </div>\n    <div class=\"hero-visual\">\n      <!-- Placeholder for an illustration -->\n      <div class=\"floating-icon\">&#x1F680;</div>\n    </div>\n  </section>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Hero Section</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n      overflow-x: hidden;\n    }\n    .hero {\n      min-height: 100vh;\n      background: linear-gradient(\n        135deg,\n        #0f0c29 0%,\n        #302b63 50%,\n        #24243e 100%\n      );\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 40px 20px;\n      position: relative;\n      overflow: hidden;\n    }\n    .hero::before {\n      content: '';\n      position: absolute;\n      top: 0; left: 0;\n      width: 100%; height: 100%;\n      background:\n        radial-gradient(circle at 20% 50%, rgba(255,255,255,0.05) 0%, transparent 50%),\n        radial-gradient(circle at 80% 50%, rgba(102,126,234,0.1) 0%, transparent 50%);\n      pointer-events: none;\n    }\n    .hero-content {\n      position: relative;\n      z-index: 2;\n      text-align: center;\n      max-width: 700px;\n      padding: 40px;\n    }\n    .hero-content h1 {\n      font-size: clamp(2.5rem, 8vw, 5rem);\n      font-weight: 800;\n      color: white;\n      margin-bottom: 20px;\n      text-shadow: 0 4px 30px rgba(0,0,0,0.3);\n      letter-spacing: -1px;\n      line-height: 1.1;\n    }\n    .hero-content p {\n      font-size: clamp(1.1rem, 2.5vw, 1.4rem);\n      color: rgba(255,255,255,0.7);\n      margin-bottom: 40px;\n      line-height: 1.6;\n    }\n    .hero-buttons {\n      display: flex;\n      gap: 16px;\n      justify-content: center;\n      flex-wrap: wrap;\n    }\n    .btn {\n      display: inline-block;\n      padding: 16px 36px;\n      border-radius: 50px;\n      font-size: 1rem;\n      font-weight: 600;\n      text-decoration: none;\n      transition: all 0.3s ease;\n      letter-spacing: 0.5px;\n    }\n    .btn-primary {\n      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n      color: white;\n      box-shadow: 0 8px 25px rgba(102,126,234,0.4);\n    }\n    .btn-primary:hover {\n      transform: translateY(-3px);\n      box-shadow: 0 12px 35px rgba(102,126,234,0.6);\n    }\n    .btn-outline {\n      background: transparent;\n      color: white;\n      border: 2px solid rgba(255,255,255,0.3);\n    }\n    .btn-outline:hover {\n      border-color: white;\n      background: rgba(255,255,255,0.1);\n      transform: translateY(-3px);\n    }\n    .hero-visual {\n      position: relative;\n      z-index: 2;\n      margin-top: 40px;\n    }\n    .floating-icon {\n      font-size: 6rem;\n      animation: float 3s ease-in-out infinite;\n      text-align: center;\n    }\n    @keyframes float {\n      0%, 100% { transform: translateY(0px); }\n      50% { transform: translateY(-20px); }\n    }\n\n    /* Responsive */\n    @media (min-width: 768px) {\n      .hero { flex-direction: row; }\n      .hero-content { text-align: left; }\n      .hero-buttons { justify-content: flex-start; }\n      .hero-visual { margin-top: 0; margin-left: 60px; }\n    }\n  </style>\n</head>\n<body>\n  <section class=\"hero\">\n    <div class=\"hero-content\">\n      <h1>Build the Future</h1>\n      <p>Create amazing web experiences with modern tools and technologies. Start building today.</p>\n      <div class=\"hero-buttons\">\n        <a href=\"#\" class=\"btn btn-primary\">Get Started</a>\n        <a href=\"#\" class=\"btn btn-outline\">Learn More</a>\n      </div>\n    </div>\n    <div class=\"hero-visual\">\n      <div class=\"floating-icon\">&#x1F680;</div>\n    </div>\n  </section>\n</body>\n</html>"
  }
}
