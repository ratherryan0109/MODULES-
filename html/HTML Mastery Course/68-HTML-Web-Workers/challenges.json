{
    "easy": {
        "title": "Prime Number Calculator with Worker",
        "description": "Create a page with a Web Worker that calculates prime numbers up to a given limit. The UI should remain responsive during calculation. Show the progress (how many primes found so far) and display the results when complete. Include a button to cancel the operation mid-way.",
        "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Prime Calculator</title>\n</head>\n<body>\n    <h1>Prime Number Calculator</h1>\n    <input type=\"number\" id=\"limitInput\" value=\"100000\" min=\"1000\" max=\"10000000\">\n    <button onclick=\"startCalculation()\">Calculate Primes</button>\n    <button onclick=\"cancelCalculation()\">Cancel</button>\n    <div id=\"status\">Ready</div>\n    <div id=\"results\"></div>\n    \n    <script>\n        // TODO: Create and manage a Web Worker that calculates prime numbers\n        // The worker should send progress updates\n        // Include a cancel mechanism\n    </script>\n</body>\n</html>",
        "solution": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Prime Calculator</title>\n    <style>\n        body { font-family: Arial; max-width: 800px; margin: 0 auto; padding: 20px; }\n        #status { padding: 10px; margin: 10px 0; background: #e9ecef; border-radius: 5px; }\n        #results { margin-top: 20px; }\n        .prime-info { background: #d4edda; padding: 10px; border-radius: 5px; }\n        progress { width: 100%; height: 20px; }\n        button { padding: 8px 16px; margin: 5px; cursor: pointer; }\n    </style>\n</head>\n<body>\n    <h1>Prime Number Calculator</h1>\n    <input type=\"number\" id=\"limitInput\" value=\"100000\" min=\"1000\" max=\"10000000\">\n    <button onclick=\"startCalculation()\">Calculate Primes</button>\n    <button onclick=\"cancelCalculation()\">Cancel</button>\n    <progress id=\"progressBar\" value=\"0\" max=\"100\"></progress>\n    <div id=\"status\">Ready</div>\n    <div id=\"results\"></div>\n    \n    <script>\n        let worker = null;\n\n        function getWorkerUrl() {\n            const code = `\n                let cancelled = false;\n\n                self.onmessage = function(e) {\n                    if (e.data === 'cancel') {\n                        cancelled = true;\n                        return;\n                    }\n                    \n                    const limit = e.data;\n                    const primes = [];\n                    const chunkSize = Math.max(1, Math.floor(limit / 100));\n                    \n                    for (let i = 2; i <= limit && !cancelled; i++) {\n                        let isPrime = true;\n                        const sqrt = Math.sqrt(i);\n                        for (let j = 2; j <= sqrt; j++) {\n                            if (i % j === 0) {\n                                isPrime = false;\n                                break;\n                            }\n                        }\n                        if (isPrime) {\n                            primes.push(i);\n                        }\n                        \n                        if (i % chunkSize === 0) {\n                            self.postMessage({ \n                                type: 'progress', \n                                percent: Math.round(i / limit * 100),\n                                found: primes.length\n                            });\n                        }\n                    }\n                    \n                    if (!cancelled) {\n                        self.postMessage({ \n                            type: 'complete', \n                            primes: primes,\n                            count: primes.length,\n                            lastTen: primes.slice(-10)\n                        });\n                    } else {\n                        self.postMessage({ type: 'cancelled' });\n                    }\n                };\n            `;\n            const blob = new Blob([code], { type: 'application/javascript' });\n            return URL.createObjectURL(blob);\n        }\n\n        function startCalculation() {\n            const limit = parseInt(document.getElementById('limitInput').value);\n            const status = document.getElementById('status');\n            const results = document.getElementById('results');\n            const bar = document.getElementById('progressBar');\n            \n            if (worker) {\n                worker.terminate();\n            }\n            \n            bar.value = 0;\n            results.innerHTML = '';\n            status.textContent = 'Calculating primes up to ' + limit.toLocaleString() + '...';\n            \n            worker = new Worker(getWorkerUrl());\n            \n            worker.onmessage = function(e) {\n                const data = e.data;\n                if (data.type === 'progress') {\n                    bar.value = data.percent;\n                    status.textContent = data.percent + '% - Found ' + data.found.toLocaleString() + ' primes so far';\n                } else if (data.type === 'complete') {\n                    status.textContent = 'Complete! Found ' + data.count.toLocaleString() + ' primes';\n                    results.innerHTML = '<div class=\"prime-info\">' +\n                        '<h3>Results</h3>' +\n                        '<p>Total primes found: <strong>' + data.count.toLocaleString() + '</strong></p>' +\n                        '<p>Largest prime: <strong>' + data.primes[data.primes.length - 1].toLocaleString() + '</strong></p>' +\n                        '<p>Last 10 primes: ' + data.lastTen.join(', ') + '</p>' +\n                        '</div>';\n                    bar.value = 100;\n                    worker.terminate();\n                    worker = null;\n                } else if (data.type === 'cancelled') {\n                    status.textContent = 'Cancelled';\n                    bar.value = 0;\n                }\n            };\n            \n            worker.onerror = function(e) {\n                status.textContent = 'Error: ' + e.message;\n                e.preventDefault();\n            };\n            \n            worker.postMessage(limit);\n        }\n\n        function cancelCalculation() {\n            if (worker) {\n                worker.postMessage('cancel');\n                setTimeout(() => {\n                    if (worker) {\n                        worker.terminate();\n                        worker = null;\n                    }\n                }, 1000);\n                document.getElementById('status').textContent = 'Cancelling...';\n            }\n        }\n    </script>\n</body>\n</html>"
    },
    "medium": {
        "title": "Image Filter App with Web Workers",
        "description": "Build an application that applies image filters (grayscale, sepia, blur, invert) using a Web Worker for processing. Users can upload an image, select a filter, and see the result. The worker handles pixel manipulation without freezing the UI. Show processing progress and allow cancelling the filter operation.",
        "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Image Filters with Web Workers</title>\n</head>\n<body>\n    <h1>Image Filter App</h1>\n    <input type=\"file\" id=\"imageInput\" accept=\"image/*\">\n    <div>\n        <button onclick=\"applyFilter('grayscale')\">Grayscale</button>\n        <button onclick=\"applyFilter('sepia')\">Sepia</button>\n        <button onclick=\"applyFilter('invert')\">Invert</button>\n    </div>\n    <canvas id=\"canvas\"></canvas>\n    <div id=\"status\">Upload an image to start</div>\n    \n    <script>\n        // TODO: Implement image filtering using Web Workers\n        // The worker should process ImageData pixel by pixel\n        // Show progress updates and maintain UI responsiveness\n    </script>\n</body>\n</html>",
        "solution": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Image Filters with Web Workers</title>\n    <style>\n        body { font-family: Arial; max-width: 900px; margin: 0 auto; padding: 20px; text-align: center; }\n        #canvas { max-width: 100%; border: 1px solid #ddd; margin: 20px 0; }\n        button { padding: 10px 20px; margin: 5px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px; }\n        button:hover { background: #0056b3; }\n        button:disabled { background: #6c757d; cursor: not-allowed; }\n        #status { padding: 10px; background: #f8f9fa; border-radius: 5px; margin: 10px 0; }\n        progress { width: 100%; height: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Image Filter App (Worker-Based)</h1>\n    <input type=\"file\" id=\"imageInput\" accept=\"image/*\"><br><br>\n    <div>\n        <button onclick=\"applyFilter('grayscale')\" id=\"btnGray\">Grayscale</button>\n        <button onclick=\"applyFilter('sepia')\" id=\"btnSepia\">Sepia</button>\n        <button onclick=\"applyFilter('invert')\" id=\"btnInvert\">Invert</button>\n        <button onclick=\"applyFilter('brightness')\" id=\"btnBright\">Brightness +50%</button>\n        <button onclick=\"resetImage()\">Reset</button>\n    </div>\n    <progress id=\"progressBar\" value=\"0\" max=\"100\" style=\"display:none\"></progress>\n    <canvas id=\"canvas\"></canvas>\n    <div id=\"status\">Upload an image to start</div>\n\n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        let originalImageData = null;\n        let worker = null;\n\n        document.getElementById('imageInput').addEventListener('change', function(e) {\n            const file = e.target.files[0];\n            if (!file) return;\n            const img = new Image();\n            img.onload = function() {\n                canvas.width = Math.min(img.width, 600);\n                canvas.height = Math.min(img.height, 600);\n                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);\n                originalImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);\n                document.getElementById('status').textContent = 'Image loaded: ' + canvas.width + 'x' + canvas.height;\n                enableButtons(true);\n            };\n            img.src = URL.createObjectURL(file);\n        });\n\n        function enableButtons(enabled) {\n            document.querySelectorAll('button[id^=\"btn\"]').forEach(b => b.disabled = !enabled);\n        }\n\n        function getWorkerCode() {\n            return `\n                self.onmessage = function(e) {\n                    const { data, filterType, width, height } = e.data;\n                    const pixels = new Uint8ClampedArray(data);\n                    const totalPixels = pixels.length / 4;\n                    \n                    for (let i = 0; i < pixels.length; i += 4) {\n                        const r = pixels[i];\n                        const g = pixels[i + 1];\n                        const b = pixels[i + 2];\n                        \n                        switch (filterType) {\n                            case 'grayscale':\n                                const gray = 0.299 * r + 0.587 * g + 0.114 * b;\n                                pixels[i] = gray;\n                                pixels[i + 1] = gray;\n                                pixels[i + 2] = gray;\n                                break;\n                            case 'sepia':\n                                pixels[i] = Math.min(255, (r * 0.393) + (g * 0.769) + (b * 0.189));\n                                pixels[i + 1] = Math.min(255, (r * 0.349) + (g * 0.686) + (b * 0.168));\n                                pixels[i + 2] = Math.min(255, (r * 0.272) + (g * 0.534) + (b * 0.131));\n                                break;\n                            case 'invert':\n                                pixels[i] = 255 - r;\n                                pixels[i + 1] = 255 - g;\n                                pixels[i + 2] = 255 - b;\n                                break;\n                            case 'brightness':\n                                pixels[i] = Math.min(255, r * 1.5);\n                                pixels[i + 1] = Math.min(255, g * 1.5);\n                                pixels[i + 2] = Math.min(255, b * 1.5);\n                                break;\n                        }\n                        \n                        if (i % 4000 === 0) {\n                            self.postMessage({ \n                                type: 'progress', \n                                percent: Math.round(i / pixels.length * 100)\n                            });\n                        }\n                    }\n                    \n                    self.postMessage({ \n                        type: 'complete', \n                        data: pixels.buffer \n                    }, [pixels.buffer]);\n                };\n            `;\n        }\n\n        function applyFilter(filterType) {\n            if (!originalImageData) return;\n            \n            if (worker) {\n                worker.terminate();\n            }\n            \n            const bar = document.getElementById('progressBar');\n            bar.style.display = 'block';\n            bar.value = 0;\n            \n            const blob = new Blob([getWorkerCode()], { type: 'application/javascript' });\n            worker = new Worker(URL.createObjectURL(blob));\n            \n            worker.onmessage = function(e) {\n                const data = e.data;\n                if (data.type === 'progress') {\n                    bar.value = data.percent;\n                } else if (data.type === 'complete') {\n                    const imageData = new ImageData(\n                        new Uint8ClampedArray(data.data),\n                        canvas.width,\n                        canvas.height\n                    );\n                    ctx.putImageData(imageData, 0, 0);\n                    bar.style.display = 'none';\n                    document.getElementById('status').textContent = 'Filter applied: ' + filterType;\n                    enableButtons(true);\n                    worker.terminate();\n                    worker = null;\n                }\n            };\n            \n            worker.onerror = function(e) {\n                document.getElementById('status').textContent = 'Worker error: ' + e.message;\n                bar.style.display = 'none';\n                enableButtons(true);\n                e.preventDefault();\n            };\n            \n            enableButtons(false);\n            document.getElementById('status').textContent = 'Applying ' + filterType + ' filter...';\n            \n            // Convert to a regular array (clonable) and transfer the buffer back\n            const data = new Uint8ClampedArray(originalImageData.data);\n            worker.postMessage({\n                data: data,\n                filterType: filterType,\n                width: canvas.width,\n                height: canvas.height\n            });\n        }\n\n        function resetImage() {\n            if (originalImageData) {\n                ctx.putImageData(originalImageData, 0, 0);\n                document.getElementById('status').textContent = 'Image reset to original';\n            }\n        }\n    </script>\n</body>\n</html>"
    },
    "hard": {
        "title": "Real-Time Data Dashboard with Worker Pool",
        "description": "Build a real-time data dashboard that uses a pool of Web Workers to process streaming financial data. Workers parse incoming data, calculate statistics (moving averages, volatility, RSI), and the main thread renders charts. Implement worker health monitoring, load balancing across the pool, graceful degradation, and a UI that shows per-worker metrics.",
        "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Data Dashboard with Worker Pool</title>\n</head>\n<body>\n    <h1>Real-Time Data Dashboard</h1>\n    <div id=\"dashboard\"></div>\n    <div id=\"workerMetrics\"></div>\n    <script>\n        // TODO: Implement a worker pool system that:\n        // - Creates workers based on CPU cores\n        // - Distributes incoming data across workers\n        // - Monitors worker health via heartbeat\n        // - Handles worker failures gracefully\n        // - Calculates real-time statistics\n        // - Renders metrics on the dashboard\n    </script>\n</body>\n</html>",
        "solution": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Data Dashboard with Worker Pool</title>\n    <style>\n        body { font-family: 'Segoe UI', sans-serif; max-width: 1200px; margin: 0 auto; padding: 20px; background: #1a1a2e; color: #eee; }\n        h1 { color: #4da6ff; }\n        .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin: 20px 0; }\n        .metric-card { background: #16213e; border-radius: 10px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); border: 1px solid #2a2a4a; }\n        .metric-value { font-size: 2em; font-weight: bold; color: #4da6ff; }\n        .metric-label { font-size: 0.9em; color: #8899aa; text-transform: uppercase; letter-spacing: 1px; }\n        .metric-card.positive { border-left: 4px solid #2ecc71; }\n        .metric-card.negative { border-left: 4px solid #e74c3c; }\n        .worker-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin: 20px 0; }\n        .worker-card { background: #1a1a2e; border: 1px solid #333; border-radius: 5px; padding: 10px; font-size: 0.8em; }\n        .worker-card.alive { border-color: #2ecc71; }\n        .worker-card.dead { border-color: #e74c3c; }\n        .controls button { padding: 8px 16px; margin: 5px; cursor: pointer; border: none; border-radius: 5px; }\n        .btn-start { background: #2ecc71; color: white; }\n        .btn-stop { background: #e74c3c; color: white; }\n        #log { background: #0d0d1a; padding: 10px; border-radius: 5px; max-height: 200px; overflow-y: auto; font-family: monospace; font-size: 12px; margin-top: 20px; }\n        .log-entry { margin: 2px 0; }\n        .log-info { color: #4da6ff; }\n        .log-error { color: #e74c3c; }\n        .log-success { color: #2ecc71; }\n    </style>\n</head>\n<body>\n    <h1>⚡ Real-Time Data Dashboard</h1>\n    <div class=\"controls\">\n        <button class=\"btn-start\" onclick=\"startStream()\">▶ Start Data Stream</button>\n        <button class=\"btn-stop\" onclick=\"stopStream()\">⏹ Stop Stream</button>\n        <span id=\"streamStatus\" style=\"margin-left:10px;\">Stopped</span>\n    </div>\n\n    <div id=\"dashboardGrid\" class=\"dashboard-grid\">\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">Average Price</div>\n            <div class=\"metric-value\" id=\"avgPrice\">—</div>\n        </div>\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">Moving Avg (20)</div>\n            <div class=\"metric-value\" id=\"movingAvg\">—</div>\n        </div>\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">Volatility</div>\n            <div class=\"metric-value\" id=\"volatility\">—</div>\n        </div>\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">RSI (14)</div>\n            <div class=\"metric-value\" id=\"rsi\">—</div>\n        </div>\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">Data Points</div>\n            <div class=\"metric-value\" id=\"dataPoints\">0</div>\n        </div>\n        <div class=\"metric-card\">\n            <div class=\"metric-label\">Updates/sec</div>\n            <div class=\"metric-value\" id=\"updatesPerSec\">0</div>\n        </div>\n    </div>\n\n    <h2>Worker Pool</h2>\n    <div id=\"workerGrid\" class=\"worker-grid\"></div>\n\n    <h2>Activity Log</h2>\n    <div id=\"log\"><div class=\"log-entry log-info\">System initialized. Click Start to begin.</div></div>\n\n    <script>\n        class WorkerPool {\n            constructor(workerCreator, poolSize) {\n                this.size = poolSize || (navigator.hardwareConcurrency || 4);\n                this.workers = [];\n                this.taskQueue = [];\n                this.availableWorkers = [];\n                this.results = new Map();\n                this.metrics = { processed: 0, errors: 0, totalTime: 0 };\n                this.creator = workerCreator;\n                this.init();\n            }\n\n            init() {\n                for (let i = 0; i < this.size; i++) {\n                    this.addWorker(i);\n                }\n                this.updateWorkerUI();\n            }\n\n            addWorker(id) {\n                const worker = this.creator();\n                const entry = {\n                    id,\n                    worker,\n                    alive: true,\n                    tasksCompleted: 0,\n                    totalTime: 0,\n                    lastHeartbeat: Date.now()\n                };\n\n                worker.onmessage = (e) => {\n                    const data = e.data;\n                    if (data.type === 'heartbeat') {\n                        entry.lastHeartbeat = Date.now();\n                        return;\n                    }\n                    if (data.type === 'result') {\n                        entry.tasksCompleted++;\n                        entry.totalTime += data.processingTime || 0;\n                        this.metrics.processed++;\n                        this.metrics.totalTime += data.processingTime || 0;\n                        this.handleResult(data);\n                    }\n                    this.availableWorkers.push(entry);\n                    this.processQueue();\n                    this.updateWorkerUI();\n                };\n\n                worker.onerror = (e) => {\n                    entry.alive = false;\n                    this.metrics.errors++;\n                    this.log('Worker ' + id + ' crashed: ' + e.message, 'error');\n                    // Replace worker after delay\n                    setTimeout(() => {\n                        if (this.running) {\n                            this.log('Replacing worker ' + id, 'info');\n                            entry.worker.terminate();\n                            this.addWorker(id);\n                            this.updateWorkerUI();\n                        }\n                    }, 2000);\n                    e.preventDefault();\n                };\n\n                this.workers.push(entry);\n                this.availableWorkers.push(entry);\n                \n                // Start heartbeat\n                entry.heartbeatInterval = setInterval(() => {\n                    if (this.running) {\n                        try { worker.postMessage({ type: 'heartbeat' }); } catch(e) {}\n                    }\n                }, 5000);\n            }\n\n            postTask(task) {\n                this.taskQueue.push(task);\n                this.processQueue();\n            }\n\n            processQueue() {\n                while (this.taskQueue.length > 0 && this.availableWorkers.length > 0) {\n                    const task = this.taskQueue.shift();\n                    const entry = this.availableWorkers.shift();\n                    if (entry.alive) {\n                        entry.worker.postMessage(task);\n                    } else {\n                        this.taskQueue.unshift(task);\n                    }\n                }\n            }\n\n            handleResult(data) {\n                if (this.onResult) {\n                    this.onResult(data);\n                }\n            }\n\n            terminate() {\n                this.workers.forEach(entry => {\n                    clearInterval(entry.heartbeatInterval);\n                    entry.worker.terminate();\n                });\n                this.workers = [];\n                this.availableWorkers = [];\n            }\n\n            updateWorkerUI() {\n                // Handled externally\n            }\n\n            log(msg, type = 'info') {\n                if (this.onLog) this.onLog(msg, type);\n            }\n        }\n\n        // Dashboard state\n        const state = {\n            dataPoints: [],\n            streamActive: false,\n            streamInterval: null,\n            updateCount: 0,\n            lastSecond: Date.now()\n        };\n\n        let pool = null;\n\n        function createWorker() {\n            const code = `\n                let dataBuffer = [];\n                \n                self.onmessage = function(e) {\n                    const data = e.data;\n                    if (data.type === 'heartbeat') {\n                        self.postMessage({ type: 'heartbeat' });\n                        return;\n                    }\n                    \n                    const startTime = performance.now();\n                    const price = data.price;\n                    \n                    dataBuffer.push(price);\n                    if (dataBuffer.length > 100) dataBuffer.shift();\n                    \n                    // Calculate metrics\n                    const avg = dataBuffer.reduce((a, b) => a + b, 0) / dataBuffer.length;\n                    \n                    // Moving average (20)\n                    const recent20 = dataBuffer.slice(-20);\n                    const ma20 = recent20.reduce((a, b) => a + b, 0) / recent20.length;\n                    \n                    // Volatility (standard deviation)\n                    const variance = dataBuffer.reduce((sum, v) => sum + Math.pow(v - avg, 2), 0) / dataBuffer.length;\n                    const vol = Math.sqrt(variance);\n                    \n                    // RSI (14)\n                    let gains = 0, losses = 0;\n                    const recent14 = dataBuffer.slice(-15);\n                    for (let i = 1; i < recent14.length; i++) {\n                        const diff = recent14[i] - recent14[i-1];\n                        if (diff > 0) gains += diff;\n                        else losses -= diff;\n                    }\n                    const avgGain = gains / 14;\n                    const avgLoss = losses / 14;\n                    const rsi = avgLoss === 0 ? 100 : 100 - (100 / (1 + avgGain / avgLoss));\n                    \n                    const processingTime = performance.now() - startTime;\n                    \n                    self.postMessage({\n                        type: 'result',\n                        price,\n                        average: avg,\n                        movingAverage: ma20,\n                        volatility: vol,\n                        rsi: isNaN(rsi) ? 50 : rsi,\n                        bufferSize: dataBuffer.length,\n                        processingTime\n                    });\n                };\n            `;\n            const blob = new Blob([code], { type: 'application/javascript' });\n            return new Worker(URL.createObjectURL(blob));\n        }\n\n        function initPool() {\n            pool = new WorkerPool(createWorker);\n            \n            pool.onResult = function(data) {\n                state.updateCount++;\n                state.dataPoints.push(data);\n                if (state.dataPoints.length > 500) state.dataPoints.shift();\n                updateDashboard();\n            };\n\n            pool.onLog = function(msg, type) {\n                addLog(msg, type);\n            };\n        }\n\n        function updateDashboard() {\n            const dp = state.dataPoints;\n            if (dp.length === 0) return;\n\n            const latest = dp[dp.length - 1];\n            const avgPrice = dp.reduce((s, d) => s + d.average, 0) / dp.length;\n            \n            document.getElementById('avgPrice').textContent = latest.average.toFixed(2);\n            document.getElementById('movingAvg').textContent = latest.movingAverage.toFixed(2);\n            document.getElementById('volatility').textContent = latest.volatility.toFixed(4);\n            document.getElementById('rsi').textContent = latest.rsi.toFixed(1);\n            document.getElementById('dataPoints').textContent = dp.length;\n\n            // Updates per second\n            const now = Date.now();\n            if (now - state.lastSecond >= 1000) {\n                const ups = state.updateCount / ((now - state.lastSecond) / 1000);\n                document.getElementById('updatesPerSec').textContent = ups.toFixed(0);\n                state.updateCount = 0;\n                state.lastSecond = now;\n            }\n\n            // Color cards based on trend\n            if (dp.length > 1) {\n                const prev = dp[dp.length - 2];\n                const cards = document.querySelectorAll('.metric-card');\n                cards[0].className = 'metric-card ' + (latest.average >= prev.average ? 'positive' : 'negative');\n            }\n\n            // Update worker UI\n            updateWorkerUI();\n        }\n\n        function updateWorkerUI() {\n            if (!pool) return;\n            const grid = document.getElementById('workerGrid');\n            grid.innerHTML = pool.workers.map(w => `\n                <div class=\"worker-card ${w.alive ? 'alive' : 'dead'}\">\n                    <strong>Worker #${w.id}</strong>\n                    <div>Status: ${w.alive ? '✅ Alive' : '❌ Dead'}</div>\n                    <div>Tasks: ${w.tasksCompleted}</div>\n                    <div>Avg time: ${w.tasksCompleted > 0 ? (w.totalTime / w.tasksCompleted).toFixed(2) : '—'}ms</div>\n                    <div>Heartbeat: ${Math.floor((Date.now() - w.lastHeartbeat) / 1000)}s ago</div>\n                </div>\n            `).join('');\n        }\n\n        function generateDataPoint() {\n            const basePrice = 150 + Math.random() * 50;\n            const noise = (Math.random() - 0.5) * 4;\n            return { price: basePrice + noise };\n        }\n\n        function startStream() {\n            if (state.streamActive) return;\n            state.streamActive = true;\n            document.getElementById('streamStatus').textContent = '🟢 Running';\n            document.getElementById('streamStatus').style.color = '#2ecc71';\n            \n            initPool();\n            \n            state.streamInterval = setInterval(() => {\n                if (!pool) return;\n                const dataPoint = generateDataPoint();\n                pool.postTask(dataPoint);\n            }, 50); // 20 updates/sec\n\n            addLog('Data stream started with ' + pool.size + ' workers', 'success');\n        }\n\n        function stopStream() {\n            state.streamActive = false;\n            document.getElementById('streamStatus').textContent = '⏹ Stopped';\n            document.getElementById('streamStatus').style.color = '#e74c3c';\n            \n            if (state.streamInterval) {\n                clearInterval(state.streamInterval);\n                state.streamInterval = null;\n            }\n            \n            if (pool) {\n                pool.terminate();\n                pool = null;\n            }\n            \n            addLog('Data stream stopped', 'info');\n            updateWorkerUI();\n        }\n\n        function addLog(msg, type = 'info') {\n            const logEl = document.getElementById('log');\n            const entry = document.createElement('div');\n            entry.className = 'log-entry log-' + type;\n            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\n            logEl.appendChild(entry);\n            logEl.scrollTop = logEl.scrollHeight;\n        }\n\n        // Cleanup on page unload\n        window.addEventListener('beforeunload', stopStream);\n    </script>\n</body>\n</html>"
    }
}
