{
  "easy": {
    "title": "Weekly Class Schedule Table",
    "description": "Create an HTML table that displays a weekly class schedule. The table should have days of the week as column headers and time slots as row headers. Include at least 5 time slots and 5 days (Mon-Fri). Use <th> for headers, <td> for data cells, and add a caption.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Weekly Class Schedule</title>\n  <style>\n    /* Add your styles here */\n  </style>\n</head>\n<body>\n  <h1>Weekly Class Schedule</h1>\n  <!-- Create your table here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Weekly Class Schedule</title>\n  <style>\n    body { font-family: Arial; max-width: 800px; margin: 20px auto; }\n    table { width: 100%; border-collapse: collapse; }\n    th, td { border: 1px solid #333; padding: 10px; text-align: center; }\n    th { background: #4CAF50; color: white; }\n    td { background: #f9f9f9; }\n    td:first-child { background: #e8f5e9; font-weight: bold; }\n    caption { font-size: 1.3em; font-weight: bold; margin-bottom: 10px; }\n  </style>\n</head>\n<body>\n  <h1>Weekly Class Schedule</h1>\n  <table>\n    <caption>Spring Semester 2025 - Weekly Schedule</caption>\n    <tr>\n      <th>Time</th><th>Monday</th><th>Tuesday</th><th>Wednesday</th><th>Thursday</th><th>Friday</th>\n    </tr>\n    <tr><td>8:00 - 9:00</td><td>Math</td><td>Physics</td><td>Math</td><td>Physics</td><td>Math</td></tr>\n    <tr><td>9:15 - 10:15</td><td>English</td><td>Chemistry</td><td>English</td><td>Chemistry</td><td>English</td></tr>\n    <tr><td>10:30 - 11:30</td><td>History</td><td>Biology</td><td>History</td><td>Biology</td><td>Art</td></tr>\n    <tr><td>12:00 - 13:00</td><td>PE</td><td>Computer Science</td><td>PE</td><td>Computer Science</td><td>Music</td></tr>\n    <tr><td>13:30 - 14:30</td><td>Physics Lab</td><td>Math Tutoring</td><td>Chemistry Lab</td><td>Study Hall</td><td>Sports</td></tr>\n  </table>\n</body>\n</html>"
  },
  "medium": {
    "title": "Employee Directory with Styled Table",
    "description": "Create a styled employee directory table with 8+ employees. Include columns: ID, Name, Department, Position, Email, Phone, Hire Date, and Status. Use thead, tbody, tfoot with a summary row. Apply alternating row colors, hover effects, and column grouping with colgroup.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Employee Directory</title>\n  <style>\n    /* Add your styles */\n  </style>\n</head>\n<body>\n  <h1>Employee Directory</h1>\n  <!-- Create your table here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Employee Directory</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 1000px; margin: 30px auto; padding: 0 20px; background: #f0f2f5; }\n    h1 { text-align: center; color: #1a1a2e; }\n    .table-wrapper { overflow-x: auto; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }\n    table { width: 100%; border-collapse: collapse; background: white; }\n    th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #ddd; white-space: nowrap; }\n    thead th { background: #1a1a2e; color: white; position: sticky; top: 0; }\n    tbody tr:nth-child(even) { background: #f8f9fa; }\n    tbody tr:hover { background: #e8f4f8; }\n    tfoot td { background: #16213e; color: white; font-weight: bold; }\n    .status-active { color: #28a745; font-weight: bold; }\n    .status-inactive { color: #dc3545; }\n  </style>\n</head>\n<body>\n  <h1>Employee Directory</h1>\n  <div class=\"table-wrapper\">\n    <table>\n      <colgroup>\n        <col style=\"width: 60px\">\n        <col style=\"width: 160px\">\n        <col style=\"width: 120px\">\n        <col style=\"width: 140px\">\n        <col style=\"width: 180px\">\n        <col style=\"width: 120px\">\n        <col style=\"width: 110px\">\n        <col style=\"width: 90px\">\n      </colgroup>\n      <thead>\n        <tr><th>ID</th><th>Name</th><th>Department</th><th>Position</th><th>Email</th><th>Phone</th><th>Hire Date</th><th>Status</th></tr>\n      </thead>\n      <tbody>\n        <tr><td>101</td><td>Alice Johnson</td><td>Engineering</td><td>Senior Dev</td><td>alice@co.com</td><td>555-0101</td><td>2022-03-15</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>102</td><td>Bob Smith</td><td>Design</td><td>UI Designer</td><td>bob@co.com</td><td>555-0102</td><td>2023-01-10</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>103</td><td>Carol Davis</td><td>Marketing</td><td>Marketing Lead</td><td>carol@co.com</td><td>555-0103</td><td>2021-11-20</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>104</td><td>David Wilson</td><td>Engineering</td><td>Backend Dev</td><td>david@co.com</td><td>555-0104</td><td>2024-06-01</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>105</td><td>Eve Martinez</td><td>HR</td><td>HR Manager</td><td>eve@co.com</td><td>555-0105</td><td>2020-09-12</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>106</td><td>Frank Lee</td><td>Engineering</td><td>DevOps</td><td>frank@co.com</td><td>555-0106</td><td>2023-08-05</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>107</td><td>Grace Kim</td><td>Design</td><td>UX Researcher</td><td>grace@co.com</td><td>555-0107</td><td>2024-02-18</td><td class=\"status-active\">Active</td></tr>\n        <tr><td>108</td><td>Henry Brown</td><td>Sales</td><td>Sales Rep</td><td>henry@co.com</td><td>555-0108</td><td>2022-07-22</td><td class=\"status-inactive\">Inactive</td></tr>\n      </tbody>\n      <tfoot>\n        <tr><td colspan=\"8\">Total Employees: 8 | Active: 7 | Inactive: 1</td></tr>\n      </tfoot>\n    </table>\n  </div>\n</body>\n</html>"
  },
  "hard": {
    "title": "Interactive Product Comparison Table",
    "description": "Create a fully styled, responsive product comparison table for 4 products across 10+ features. Use colspan and rowspan for grouping features by category (e.g., General, Display, Performance, Camera, Battery). Use thead, tbody, scope attributes, and colgroup. Add a feature where the 'best' value in each row is highlighted in green. Make it responsive with horizontal scroll.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Product Comparison</title>\n  <style>\n    /* Add your styles */\n  </style>\n</head>\n<body>\n  <h1>Smartphone Comparison</h1>\n  <!-- Create your comparison table here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Product Comparison</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: 'Segoe UI', sans-serif; background: #f4f6f9; padding: 30px 20px; }\n    h1 { text-align: center; color: #1a1a2e; margin-bottom: 25px; }\n    .table-wrapper { overflow-x: auto; border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.12); }\n    table { width: 100%; min-width: 700px; border-collapse: collapse; background: white; font-size: 15px; }\n    caption { font-size: 1.3em; font-weight: bold; padding: 15px; background: #1a1a2e; color: white; text-align: center; }\n    th, td { padding: 14px 16px; text-align: center; border: 1px solid #e2e8f0; }\n    thead th { background: #2d3748; color: white; font-weight: 600; }\n    thead th:first-child { background: #1a202c; }\n    tbody th { background: #edf2f7; color: #2d3748; text-align: left; font-weight: 600; }\n    tbody td { color: #4a5568; }\n    tbody tr:nth-child(even) td { background: #f7fafc; }\n    tbody tr:hover td { background: #e2e8f0; }\n    .category-header th { background: #4a5568 !important; color: #f7fafc; font-weight: 700; text-align: left; padding-left: 20px; }\n    .best { background: #c6f6d5 !important; color: #22543d !important; font-weight: bold; }\n    .feature-icon { margin-right: 8px; }\n  </style>\n</head>\n<body>\n  <h1>Smartphone Comparison - 2025 Flagships</h1>\n  <div class=\"table-wrapper\">\n    <table>\n      <caption>Flagship Smartphone Comparison</caption>\n      <colgroup>\n        <col style=\"width: 180px; background: #f8fafc;\">\n        <col style=\"width: 160px;\">\n        <col style=\"width: 160px;\">\n        <col style=\"width: 160px;\">\n        <col style=\"width: 160px;\">\n      </colgroup>\n      <thead>\n        <tr><th scope=\"col\">Feature</th><th scope=\"col\">Phone A</th><th scope=\"col\">Phone B</th><th scope=\"col\">Phone C</th><th scope=\"col\">Phone D</th></tr>\n      </thead>\n      <tbody>\n        <tr class=\"category-header\"><th colspan=\"5\" scope=\"colgroup\">General</th></tr>\n        <tr><th scope=\"row\">Price</th><td class=\"best\">$799</td><td>$899</td><td>$999</td><td>$1,099</td></tr>\n        <tr><th scope=\"row\">Weight</th><td>189g</td><td class=\"best\">171g</td><td>204g</td><td>196g</td></tr>\n        <tr><th scope=\"row\">Water Resistant</th><td>IP68</td><td>IP67</td><td class=\"best\">IP69</td><td>IP68</td></tr>\n\n        <tr class=\"category-header\"><th colspan=\"5\" scope=\"colgroup\">Display</th></tr>\n        <tr><th scope=\"row\">Size</th><td>6.7\"</td><td>6.5\"</td><td class=\"best\">6.9\"</td><td>6.8\"</td></tr>\n        <tr><th scope=\"row\">Resolution</th><td>1440x3200</td><td>1080x2400</td><td class=\"best\">1440x3200</td><td>1280x2800</td></tr>\n        <tr><th scope=\"row\">Refresh Rate</th><td class=\"best\">120Hz</td><td>90Hz</td><td class=\"best\">120Hz</td><td class=\"best\">120Hz</td></tr>\n\n        <tr class=\"category-header\"><th colspan=\"5\" scope=\"colgroup\">Performance</th></tr>\n        <tr><th scope=\"row\">Processor</th><td>Snapdragon 8 Gen 3</td><td>Exynos 2400</td><td>A18 Bionic</td><td>Snapdragon 8 Gen 3</td></tr>\n        <tr><th scope=\"row\">RAM</th><td>12GB</td><td>8GB</td><td class=\"best\">16GB</td><td>12GB</td></tr>\n        <tr><th scope=\"row\">Storage</th><td class=\"best\">512GB</td><td>128GB</td><td class=\"best\">512GB</td><td>256GB</td></tr>\n\n        <tr class=\"category-header\"><th colspan=\"5\" scope=\"colgroup\">Camera</th></tr>\n        <tr><th scope=\"row\">Main Camera</th><td>50MP</td><td>64MP</td><td class=\"best\">108MP</td><td>50MP</td></tr>\n        <tr><th scope=\"row\">Ultrawide</th><td>12MP</td><td>12MP</td><td>12MP</td><td class=\"best\">48MP</td></tr>\n        <tr><th scope=\"row\">Zoom</th><td>3x Optical</td><td>2x Optical</td><td class=\"best\">5x Optical</td><td>3x Optical</td></tr>\n\n        <tr class=\"category-header\"><th colspan=\"5\" scope=\"colgroup\">Battery</th></tr>\n        <tr><th scope=\"row\">Capacity</th><td>4700mAh</td><td>4300mAh</td><td class=\"best\">5200mAh</td><td>4850mAh</td></tr>\n        <tr><th scope=\"row\">Charging</th><td>65W</td><td>45W</td><td class=\"best\">80W</td><td>55W</td></tr>\n        <tr><th scope=\"row\">Wireless</th><td>15W</td><td class=\"best\">25W</td><td>20W</td><td>15W</td></tr>\n      </tbody>\n    </table>\n  </div>\n  <p style=\"text-align: center; margin-top: 15px; color: #718096; font-size: 14px;\">Green cells indicate the best value in each category.</p>\n</body>\n</html>"
  }
}
