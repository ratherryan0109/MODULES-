{
  "easy": {
    "title": "Label All the Inputs",
    "description": "Take a form with unlabeled inputs and add proper labels using all three techniques: explicit (for/id), implicit (wrapping), and aria-label. Add required indicators to mandatory fields.",
    "starterCode": "<form>\n  <input type=\"text\" id=\"name\" placeholder=\"Your name\">\n  <input type=\"email\" placeholder=\"Email\">\n  <input type=\"search\" placeholder=\"Search\">\n  <input type=\"checkbox\"> I agree\n  <button>Submit</button>\n</form>",
    "solution": "<form>\n  <label for=\"name\">Full Name <span style=\"color:red;\">*</span></label>\n  <input type=\"text\" id=\"name\" required placeholder=\"Your name\">\n  \n  <label>Email Address <span style=\"color:red;\">*</span>\n    <input type=\"email\" required placeholder=\"Email\">\n  </label>\n  \n  <input type=\"search\" aria-label=\"Search the site\" placeholder=\"Search\">\n  \n  <label><input type=\"checkbox\"> I agree to the terms</label>\n  <button>Submit</button>\n</form>"
  },
  "medium": {
    "title": "Accessible Registration Form with Group Labels",
    "description": "Build a registration form with proper labeling for all inputs. Use fieldset/legend for radio and checkbox groups. Include required indicators, help text with aria-describedby, and a visually hidden label for a search field.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build an accessible form with proper labels -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Register</title><style>body{font-family:system-ui;max-width:600px;margin:40px auto;padding:20px;}.visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0;}form{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.1);}.form-group{margin-bottom:16px;}label{display:block;margin-bottom:4px;font-weight:600;}.req::after{content:\" *\";color:#e53e3e;}input,select{width:100%;padding:10px;border:2px solid #ddd;border-radius:6px;box-sizing:border-box;font-size:15px;}input:focus{border-color:#4a6cf7;outline:none;}fieldset{border:2px solid #e2e8f0;border-radius:8px;padding:16px;margin-bottom:16px;}legend{font-weight:700;padding:0 8px;}.help{font-size:13px;color:#718096;margin-top:2px;}.inline-label{display:inline-flex;align-items:center;gap:6px;margin-right:12px;font-weight:400;cursor:pointer;}button{width:100%;padding:12px;background:#4a6cf7;color:white;border:none;border-radius:6px;font-size:16px;cursor:pointer;}</style></head>\n<body>\n  <form>\n    <div class=\"form-group\"><label for=\"name\" class=\"req\">Full Name</label><input type=\"text\" id=\"name\" required aria-describedby=\"nameHelp\"><div id=\"nameHelp\" class=\"help\">Enter your legal name as shown on ID.</div></div>\n    <div class=\"form-group\"><label for=\"email\" class=\"req\">Email</label><input type=\"email\" id=\"email\" required></div>\n    <fieldset><legend>Experience Level</legend><label class=\"inline-label\"><input type=\"radio\" name=\"exp\" value=\"beginner\"> Beginner</label><label class=\"inline-label\"><input type=\"radio\" name=\"exp\" value=\"intermediate\"> Intermediate</label><label class=\"inline-label\"><input type=\"radio\" name=\"exp\" value=\"advanced\"> Advanced</label></fieldset>\n    <fieldset><legend>Interests</legend><label class=\"inline-label\"><input type=\"checkbox\" value=\"web\"> Web Dev</label><label class=\"inline-label\"><input type=\"checkbox\" value=\"ai\"> AI</label><label class=\"inline-label\"><input type=\"checkbox\" value=\"mobile\"> Mobile</label></fieldset>\n    <label for=\"search\" class=\"visually-hidden\">Search</label><input type=\"search\" id=\"search\" placeholder=\"Search\">\n    <label class=\"inline-label\" style=\"margin:12px 0;\"><input type=\"checkbox\" required> I accept the Terms</label>\n    <button type=\"submit\">Register</button>\n  </form>\n</body>\n</html>"
  },
  "hard": {
    "title": "Dynamic Label Builder with Validation",
    "description": "Build a form where users can dynamically add new inputs with labels. Each input must have: a unique auto-generated ID, a label with for attribute, a delete button, and real-time validation. Show how labels update when IDs change.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <div id=\"formBuilder\"></div>\n  <script>\n    // Build dynamic label generator\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Dynamic Labels</title><style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:system-ui;background:#f0f2f5;padding:30px;}.app{max-width:600px;margin:0 auto;background:white;border-radius:12px;padding:30px;box-shadow:0 2px 12px rgba(0,0,0,0.1);}h1{margin-bottom:20px;}.field-row{display:flex;gap:8px;align-items:center;margin-bottom:12px;padding:12px;background:#f8f9fa;border-radius:8px;border:1px solid #e2e8f0;}.field-row label{flex:0 0 120px;font-weight:600;font-size:14px;}.field-row input{flex:1;padding:8px 12px;border:2px solid #e2e8f0;border-radius:6px;font-size:14px;}.field-row input:focus{border-color:#4a6cf7;outline:none;}.field-row .id-badge{font-family:monospace;font-size:11px;background:#e2e8f0;padding:2px 8px;border-radius:4px;color:#666;}.field-row .del-btn{padding:6px 12px;background:#e74c3c;color:white;border:none;border-radius:4px;cursor:pointer;font-size:13px;}.add-btn{padding:10px 20px;background:#4a6cf7;color:white;border:none;border-radius:6px;cursor:pointer;font-size:15px;margin-bottom:16px;}.gen-info{font-family:monospace;font-size:12px;background:#1a1a2e;color:#2ecc71;padding:12px;border-radius:6px;white-space:pre-wrap;margin-top:16px;line-height:1.5;}</style></head>\n<body>\n  <div class=\"app\">\n    <h1>Dynamic Label Builder</h1>\n    <button class=\"add-btn\" onclick=\"addField()\">+ Add Input with Label</button>\n    <div id=\"container\"></div>\n    <div class=\"gen-info\" id=\"info\">Click \"Add Input\" to start building. Each input gets a unique ID and its label's for attribute tracks it.</div>\n  </div>\n  <script>\n    let count = 0;\n    function addField() {\n      count++;\n      const id = 'field_' + Date.now() + '_' + count;\n      const container = document.getElementById('container');\n      const row = document.createElement('div');\n      row.className = 'field-row';\n      row.innerHTML = `<label for=\"${id}\">Field ${count}:</label><span class=\"id-badge\">${id}</span><input type=\"text\" id=\"${id}\" placeholder=\"Type here...\" required><button class=\"del-btn\" onclick=\"removeField(this)\">✕</button>`;\n      container.appendChild(row);\n      updateInfo();\n    }\n    function removeField(btn) {\n      btn.parentElement.remove();\n      updateInfo();\n    }\n    function updateInfo() {\n      const fields = document.querySelectorAll('.field-row');\n      let info = 'Generated Labels:\\n';\n      fields.forEach(f => {\n        const labelFor = f.querySelector('label').getAttribute('for');\n        const labelText = f.querySelector('label').textContent.trim();\n        info += `  <label for=\"${labelFor}\">${labelText}</label>  →  <input id=\"${labelFor}\">\\n`;\n      });\n      document.getElementById('info').textContent = info || 'No fields yet. Add some!\\nEach label\\'s @for matches the input\\'s @id exactly.';\n    }\n  </script>\n</body>\n</html>"
  }
}
