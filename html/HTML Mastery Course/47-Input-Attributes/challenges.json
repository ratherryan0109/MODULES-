{
  "easy": {
    "title": "Form with Attribute-Based Validation",
    "description": "Create a registration form that uses only HTML attributes (no JavaScript) for validation. Include fields for username (required, 3-15 chars, alphanumeric), email (required, valid format), age (required, 13-120), password (required, min 8 chars), and confirm password. Use appropriate attributes for each.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <form>\n    <!-- Add fields with validation attributes -->\n  </form>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><title>Register</title><style>body{font-family:system-ui;max-width:400px;margin:40px auto;padding:20px;}input{width:100%;padding:8px;margin:4px 0 12px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;}label{font-weight:600;}button{width:100%;padding:10px;background:#4a6cf7;color:white;border:none;border-radius:4px;cursor:pointer;}</style></head>\n<body>\n  <form onsubmit=\"event.preventDefault(); alert('Valid!')\">\n    <label>Username</label><input type=\"text\" name=\"username\" required minlength=\"3\" maxlength=\"15\" pattern=\"[A-Za-z0-9]+\" title=\"3-15 alphanumeric chars\">\n    <label>Email</label><input type=\"email\" name=\"email\" required>\n    <label>Age</label><input type=\"number\" name=\"age\" required min=\"13\" max=\"120\">\n    <label>Password</label><input type=\"password\" name=\"password\" required minlength=\"8\" autocomplete=\"new-password\">\n    <label>Confirm Password</label><input type=\"password\" name=\"confirm\" required minlength=\"8\" autocomplete=\"off\">\n    <button type=\"submit\">Register</button>\n  </form>\n</body>\n</html>"
  },
  "medium": {
    "title": "Payment Form with Form Association Attributes",
    "description": "Build a payment form with fields for card number, expiry (month), CVV, and cardholder name. Use the `form` attribute to keep the cardholder name input outside the form but still associated. Add two submit buttons with different `formaction` values (one for processing, one for saving).",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build payment form with form association attributes -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><title>Payment</title><style>body{font-family:system-ui;max-width:500px;margin:40px auto;padding:20px;background:#f5f5f5;}form{background:white;padding:24px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}input{width:100%;padding:10px;margin:4px 0 12px;border:2px solid #ddd;border-radius:6px;box-sizing:border-box;}label{font-weight:600;}button{padding:10px 20px;border:none;border-radius:6px;cursor:pointer;font-weight:600;margin-right:8px;}.pay{background:#2ecc71;color:white;}.save{background:#f39c12;color:white;}.reset{background:#e74c3c;color:white;}</style></head>\n<body>\n  <form id=\"paymentForm\" action=\"/process\" method=\"POST\">\n    <h2>Payment Details</h2>\n    <label>Card Number</label><input type=\"text\" name=\"cardnum\" pattern=\"[0-9]{13,16}\" maxlength=\"16\" required placeholder=\"1234567890123456\">\n    <div style=\"display:flex;gap:12px;\"><div style=\"flex:1;\"><label>Expiry (Month)</label><input type=\"month\" name=\"expiry\" required></div><div style=\"flex:1;\"><label>CVV</label><input type=\"number\" name=\"cvv\" min=\"100\" max=\"9999\" required placeholder=\"123\"></div></div>\n  </form>\n  <input type=\"text\" form=\"paymentForm\" name=\"cardholder\" required placeholder=\"Cardholder Name\" style=\"width:100%;padding:10px;margin-top:8px;border:2px solid #ddd;border-radius:6px;box-sizing:border-box;\">\n  <div style=\"margin-top:16px;\">\n    <button type=\"submit\" form=\"paymentForm\" class=\"pay\" formaction=\"/process\" formmethod=\"POST\">Pay Now</button>\n    <button type=\"submit\" form=\"paymentForm\" class=\"save\" formaction=\"/save\" formmethod=\"POST\">Save for Later</button>\n    <button type=\"reset\" form=\"paymentForm\" class=\"reset\">Clear</button>\n  </div>\n</body>\n</html>"
  },
  "hard": {
    "title": "Dynamic Attribute Builder",
    "description": "Build a tool that lets users dynamically add and configure HTML input attributes on a live preview input. Include checkboxes for boolean attributes (required, disabled, readonly, multiple, autofocus), text inputs for string attributes (placeholder, pattern, title, autocomplete), and number inputs for numeric attributes (min, max, step, minlength, maxlength). Show the live rendered input and the generated HTML code.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build dynamic attribute configuration tool -->\n  <script>\n    // Implement attribute configuration logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><title>Attribute Builder</title><style>*{box-sizing:border-box;margin:0;padding:0;}body{font-family:system-ui;background:#1a1a2e;color:#eee;padding:20px;}.app{display:grid;grid-template-columns:350px 1fr;gap:24px;max-width:1200px;margin:0 auto;}.panel{background:#16213e;border-radius:12px;padding:20px;}.panel h2{font-size:16px;margin-bottom:12px;color:#4fc3f7;}.group{margin-bottom:12px;}.group label{font-size:13px;color:#aaa;display:block;margin-bottom:3px;}input[type=text],input[type=number],select{width:100%;padding:6px 10px;border:1px solid #2a3a5e;border-radius:4px;background:#0f3460;color:#eee;font-size:13px;margin-bottom:6px;}input:focus{border-color:#4fc3f7;outline:none;}.bool-group{display:grid;grid-template-columns:1fr 1fr;gap:6px;}.bool-group label{display:flex;align-items:center;gap:6px;font-size:12px;color:#ccc;cursor:pointer;}.preview-area{background:#0f3460;border-radius:8px;padding:30px;min-height:300px;display:flex;align-items:center;}.preview-area input{width:100%;padding:10px 14px;border:2px solid #2a3a5e;border-radius:6px;background:#16213e;color:#eee;font-size:15px;transition:all 0.3s;}.html-output{background:#1a1a2e;color:#e2e8f0;padding:12px;border-radius:6px;font-family:monospace;font-size:12px;margin-top:12px;white-space:pre-wrap;word-break:break-all;}.row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}.btn{padding:8px 16px;background:#4fc3f7;color:#1a1a2e;border:none;border-radius:4px;cursor:pointer;font-weight:600;margin-top:8px;}.btn:hover{background:#29b6f6;}h1{color:#eee;margin-bottom:24px;}</style></head>\n<body>\n  <h1>Input Attribute Builder</h1>\n  <div class=\"app\">\n    <div class=\"panel\">\n      <h2>Type</h2>\n      <select id=\"attrType\" onchange=\"updatePreview()\"><option value=\"text\">text</option><option value=\"email\">email</option><option value=\"tel\">tel</option><option value=\"number\">number</option><option value=\"password\">password</option><option value=\"url\">url</option><option value=\"date\">date</option><option value=\"file\">file</option><option value=\"color\">color</option><option value=\"range\">range</option></select>\n      <h2>String Attributes</h2>\n      <div class=\"group\"><label>placeholder</label><input type=\"text\" id=\"attrPlaceholder\" oninput=\"updatePreview()\"></div>\n      <div class=\"group\"><label>value</label><input type=\"text\" id=\"attrValue\" oninput=\"updatePreview()\"></div>\n      <div class=\"group\"><label>pattern</label><input type=\"text\" id=\"attrPattern\" placeholder=\"[A-Za-z]+\" oninput=\"updatePreview()\"></div>\n      <div class=\"group\"><label>title</label><input type=\"text\" id=\"attrTitle\" placeholder=\"Error message\" oninput=\"updatePreview()\"></div>\n      <div class=\"group\"><label>autocomplete</label><input type=\"text\" id=\"attrAutocomplete\" placeholder=\"name, email, etc.\" oninput=\"updatePreview()\"></div>\n      <h2>Number Attributes</h2>\n      <div class=\"row\">\n        <div class=\"group\"><label>min</label><input type=\"number\" id=\"attrMin\" oninput=\"updatePreview()\"></div>\n        <div class=\"group\"><label>max</label><input type=\"number\" id=\"attrMax\" oninput=\"updatePreview()\"></div>\n      </div>\n      <div class=\"row\">\n        <div class=\"group\"><label>step</label><input type=\"number\" id=\"attrStep\" oninput=\"updatePreview()\"></div>\n        <div class=\"group\"><label>minlength</label><input type=\"number\" id=\"attrMinlen\" oninput=\"updatePreview()\"></div>\n      </div>\n      <div class=\"group\"><label>maxlength</label><input type=\"number\" id=\"attrMaxlen\" oninput=\"updatePreview()\"></div>\n      <h2>Boolean Attributes</h2>\n      <div class=\"bool-group\">\n        <label><input type=\"checkbox\" id=\"attrRequired\" onchange=\"updatePreview()\"> required</label>\n        <label><input type=\"checkbox\" id=\"attrDisabled\" onchange=\"updatePreview()\"> disabled</label>\n        <label><input type=\"checkbox\" id=\"attrReadonly\" onchange=\"updatePreview()\"> readonly</label>\n        <label><input type=\"checkbox\" id=\"attrMultiple\" onchange=\"updatePreview()\"> multiple</label>\n        <label><input type=\"checkbox\" id=\"attrAutofocus\" onchange=\"updatePreview()\"> autofocus</label>\n        <label><input type=\"checkbox\" id=\"attrChecked\" onchange=\"updatePreview()\"> checked</label>\n      </div>\n      <button class=\"btn\" onclick=\"copyHTML()\">📋 Copy HTML</button>\n    </div>\n    <div>\n      <div class=\"panel\">\n        <h2>Live Preview</h2>\n        <div class=\"preview-area\"><input type=\"text\" id=\"previewInput\"></div>\n      </div>\n      <div class=\"panel\">\n        <h2>Generated HTML</h2>\n        <div class=\"html-output\" id=\"htmlOutput\">&lt;input&gt;</div>\n      </div>\n    </div>\n  </div>\n  <script>\n    function updatePreview() {\n      const type = document.getElementById('attrType').value;\n      const preview = document.getElementById('previewInput');\n      preview.type = type;\n      const attrs = ['placeholder','value','pattern','title','autocomplete','min','max','step','minlength','maxlength'];\n      attrs.forEach(a => {\n        const val = document.getElementById('attr' + a.charAt(0).toUpperCase() + a.slice(1)).value;\n        if (val) preview.setAttribute(a, val);\n        else preview.removeAttribute(a);\n      });\n      ['required','disabled','readonly','multiple','autofocus','checked'].forEach(a => {\n        if (document.getElementById('attr' + a.charAt(0).toUpperCase() + a.slice(1)).checked) preview.setAttribute(a, '');\n        else preview.removeAttribute(a);\n      });\n      generateHTML();\n    }\n    function generateHTML() {\n      const type = document.getElementById('attrType').value;\n      let html = '&lt;input type=\"' + type + '\"';\n      ['placeholder','value','pattern','title','autocomplete','min','max','step','minlength','maxlength'].forEach(a => {\n        const val = document.getElementById('attr' + a.charAt(0).toUpperCase() + a.slice(1)).value;\n        if (val) html += ' ' + a + '=\"' + val + '\"';\n      });\n      ['required','disabled','readonly','multiple','autofocus','checked'].forEach(a => {\n        if (document.getElementById('attr' + a.charAt(0).toUpperCase() + a.slice(1)).checked) html += ' ' + a;\n      });\n      html += '&gt;';\n      document.getElementById('htmlOutput').textContent = html;\n    }\n    function copyHTML() { navigator.clipboard.writeText(document.getElementById('htmlOutput').textContent).then(() => alert('Copied!')); }\n    updatePreview();\n  </script>\n</body>\n</html>"
  }
}
