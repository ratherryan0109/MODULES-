{
  "easy": {
    "title": "Build a Login Form",
    "description": "Create a simple login form with username and password inputs. Include labels, placeholders, a submit button, and basic styling. The form should have proper input types, required validation, and a show/hide password toggle.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Login Form</title>\n  <style>\n    /* Add your styles here */\n  </style>\n</head>\n<body>\n  <!-- Create a login form with username and password -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Login Form</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; }\n    .login-form { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); width: 100%; max-width: 400px; }\n    .login-form h1 { margin-bottom: 24px; font-size: 28px; color: #1a1a2e; text-align: center; }\n    .form-group { margin-bottom: 20px; }\n    .form-group label { display: block; margin-bottom: 6px; font-weight: 600; color: #333; }\n    .form-group input { width: 100%; padding: 12px 14px; border: 2px solid #ddd; border-radius: 8px; font-size: 15px; transition: border-color 0.3s; }\n    .form-group input:focus { border-color: #4a6cf7; outline: none; box-shadow: 0 0 0 3px rgba(74,108,247,0.15); }\n    .password-wrapper { position: relative; }\n    .toggle-pwd { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #666; font-size: 14px; padding: 4px 8px; }\n    .toggle-pwd:hover { color: #4a6cf7; }\n    .submit-btn { width: 100%; padding: 12px; background: #4a6cf7; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.3s; }\n    .submit-btn:hover { background: #3b5de7; }\n    .error { color: #e74c3c; font-size: 13px; margin-top: 4px; display: none; }\n    input:invalid:not(:placeholder-shown) { border-color: #e74c3c; }\n    input:valid { border-color: #2ecc71; }\n  </style>\n</head>\n<body>\n  <form class=\"login-form\" onsubmit=\"event.preventDefault(); alert('Logged in successfully!')\">\n    <h1>Welcome Back</h1>\n    <div class=\"form-group\">\n      <label for=\"username\">Username</label>\n      <input type=\"text\" id=\"username\" name=\"username\" placeholder=\"Enter your username\" required autocomplete=\"username\">\n      <div class=\"error\" id=\"username-error\">Username is required</div>\n    </div>\n    <div class=\"form-group\">\n      <label for=\"password\">Password</label>\n      <div class=\"password-wrapper\">\n        <input type=\"password\" id=\"password\" name=\"password\" placeholder=\"Enter your password\" required minlength=\"6\" autocomplete=\"current-password\">\n        <button type=\"button\" class=\"toggle-pwd\" onclick=\"togglePasswordVisibility()\">Show</button>\n      </div>\n      <div class=\"error\" id=\"password-error\">Password must be at least 6 characters</div>\n    </div>\n    <button type=\"submit\" class=\"submit-btn\">Sign In</button>\n  </form>\n  <script>\n    function togglePasswordVisibility() {\n      const pwd = document.getElementById('password');\n      const btn = event.target;\n      if (pwd.type === 'password') { pwd.type = 'text'; btn.textContent = 'Hide'; }\n      else { pwd.type = 'password'; btn.textContent = 'Show'; }\n    }\n  </script>\n</body>\n</html>"
  },
  "medium": {
    "title": "User Registration Form with File Upload",
    "description": "Build a complete user registration form with the following fields: full name, email, password, confirm password, date of birth, gender (radio buttons), interests (checkboxes), profile picture (file upload with preview), and a terms acceptance checkbox. Include form validation with visual feedback for each field. The confirm password must match the password field.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Registration</title>\n  <style>\n    /* Add your styles */\n  </style>\n</head>\n<body>\n  <!-- Build registration form -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>User Registration</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; justify-content: center; padding: 40px 20px; }\n    .container { background: white; border-radius: 16px; padding: 40px; width: 100%; max-width: 600px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }\n    h1 { font-size: 28px; margin-bottom: 8px; color: #2d3748; }\n    .subtitle { color: #718096; margin-bottom: 30px; }\n    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n    .form-group { margin-bottom: 20px; }\n    .form-group label { display: block; margin-bottom: 6px; font-weight: 600; color: #4a5568; font-size: 14px; }\n    .form-group input, .form-group select { width: 100%; padding: 10px 14px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 15px; transition: all 0.3s; }\n    .form-group input:focus { border-color: #667eea; outline: none; box-shadow: 0 0 0 3px rgba(102,126,234,0.15); }\n    .form-group input.error { border-color: #fc8181; }\n    .form-group input.success { border-color: #68d391; }\n    .error-msg { color: #e53e3e; font-size: 13px; margin-top: 4px; display: none; }\n    .radio-group, .checkbox-group { display: flex; gap: 16px; flex-wrap: wrap; }\n    .radio-group label, .checkbox-group label { display: inline-flex; align-items: center; gap: 6px; font-weight: 400; cursor: pointer; }\n    .file-area { position: relative; }\n    .file-area input[type=\"file\"] { position: absolute; opacity: 0; width: 100%; height: 100%; cursor: pointer; }\n    .file-area .file-label { display: flex; align-items: center; gap: 8px; padding: 10px 14px; border: 2px dashed #cbd5e0; border-radius: 8px; color: #718096; cursor: pointer; transition: all 0.3s; }\n    .file-area .file-label:hover { border-color: #667eea; color: #667eea; }\n    #preview { max-width: 80px; max-height: 80px; border-radius: 50%; object-fit: cover; margin-top: 8px; display: none; }\n    .terms { display: flex; align-items: center; gap: 8px; margin: 20px 0; }\n    .terms label { font-weight: 400; }\n    .submit-btn { width: 100%; padding: 14px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: opacity 0.3s; }\n    .submit-btn:hover { opacity: 0.9; }\n    fieldset { border: 2px solid #e2e8f0; border-radius: 8px; padding: 16px; margin-bottom: 20px; }\n    legend { font-weight: 700; color: #4a5568; padding: 0 8px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Create Account</h1>\n    <p class=\"subtitle\">Fill in your details to get started</p>\n    <form id=\"regForm\" onsubmit=\"event.preventDefault(); if(validateForm()) alert('Registration successful!')\">\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label for=\"fname\">First Name</label>\n          <input type=\"text\" id=\"fname\" name=\"firstname\" required minlength=\"2\" autocomplete=\"given-name\">\n          <div class=\"error-msg\" id=\"fname-error\">First name required (min 2 chars)</div>\n        </div>\n        <div class=\"form-group\">\n          <label for=\"lname\">Last Name</label>\n          <input type=\"text\" id=\"lname\" name=\"lastname\" required minlength=\"2\" autocomplete=\"family-name\">\n          <div class=\"error-msg\" id=\"lname-error\">Last name required (min 2 chars)</div>\n        </div>\n      </div>\n      <div class=\"form-group\">\n        <label for=\"email\">Email Address</label>\n        <input type=\"email\" id=\"email\" name=\"email\" required autocomplete=\"email\" placeholder=\"you@example.com\">\n        <div class=\"error-msg\" id=\"email-error\">Valid email required</div>\n      </div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label for=\"pass\">Password</label>\n          <input type=\"password\" id=\"pass\" name=\"password\" required minlength=\"8\" autocomplete=\"new-password\">\n          <div class=\"error-msg\" id=\"pass-error\">Min 8 characters required</div>\n        </div>\n        <div class=\"form-group\">\n          <label for=\"confirm\">Confirm Password</label>\n          <input type=\"password\" id=\"confirm\" name=\"confirmpwd\" required>\n          <div class=\"error-msg\" id=\"confirm-error\">Passwords must match</div>\n        </div>\n      </div>\n      <div class=\"form-group\">\n        <label>Date of Birth</label>\n        <input type=\"date\" id=\"dob\" name=\"dob\" required min=\"1900-01-01\" max=\"2010-01-01\">\n        <div class=\"error-msg\" id=\"dob-error\">Date of birth required</div>\n      </div>\n      <fieldset>\n        <legend>Gender</legend>\n        <div class=\"radio-group\">\n          <label><input type=\"radio\" name=\"gender\" value=\"male\" required> Male</label>\n          <label><input type=\"radio\" name=\"gender\" value=\"female\"> Female</label>\n          <label><input type=\"radio\" name=\"gender\" value=\"other\"> Other</label>\n          <label><input type=\"radio\" name=\"gender\" value=\"prefer-not\"> Prefer not to say</label>\n        </div>\n      </fieldset>\n      <fieldset>\n        <legend>Interests</legend>\n        <div class=\"checkbox-group\">\n          <label><input type=\"checkbox\" name=\"interests\" value=\"tech\"> Technology</label>\n          <label><input type=\"checkbox\" name=\"interests\" value=\"design\"> Design</label>\n          <label><input type=\"checkbox\" name=\"interests\" value=\"music\"> Music</label>\n          <label><input type=\"checkbox\" name=\"interests\" value=\"sports\"> Sports</label>\n          <label><input type=\"checkbox\" name=\"interests\" value=\"travel\"> Travel</label>\n        </div>\n      </fieldset>\n      <div class=\"form-group\">\n        <label>Profile Picture</label>\n        <div class=\"file-area\">\n          <input type=\"file\" id=\"avatar\" name=\"avatar\" accept=\"image/*\">\n          <div class=\"file-label\"><span>📁</span> Choose a file...</div>\n        </div>\n        <img id=\"preview\" alt=\"Preview\">\n      </div>\n      <div class=\"terms\">\n        <input type=\"checkbox\" id=\"terms\" name=\"terms\" required>\n        <label for=\"terms\">I accept the Terms &amp; Conditions</label>\n      </div>\n      <button type=\"submit\" class=\"submit-btn\">Create Account</button>\n    </form>\n  </div>\n  <script>\n    document.getElementById('avatar').addEventListener('change', function(e) {\n      const file = e.target.files[0];\n      if (file) {\n        const reader = new FileReader();\n        reader.onload = function(ev) {\n          const img = document.getElementById('preview');\n          img.src = ev.target.result;\n          img.style.display = 'block';\n        };\n        reader.readAsDataURL(file);\n      }\n    });\n    function validateForm() {\n      let valid = true;\n      const nameRegex = /^[A-Za-z]{2,}$/;\n      ['fname', 'lname'].forEach(id => {\n        const el = document.getElementById(id);\n        const err = document.getElementById(id + '-error');\n        if (!nameRegex.test(el.value)) { el.classList.add('error'); err.style.display = 'block'; valid = false; }\n        else { el.classList.remove('error'); el.classList.add('success'); err.style.display = 'none'; }\n      });\n      const email = document.getElementById('email');\n      const emailErr = document.getElementById('email-error');\n      if (!email.validity.valid) { email.classList.add('error'); emailErr.style.display = 'block'; valid = false; }\n      else { email.classList.remove('error'); email.classList.add('success'); emailErr.style.display = 'none'; }\n      const pass = document.getElementById('pass');\n      const confirm = document.getElementById('confirm');\n      const passErr = document.getElementById('pass-error');\n      const confirmErr = document.getElementById('confirm-error');\n      if (pass.value.length < 8) { pass.classList.add('error'); passErr.style.display = 'block'; valid = false; }\n      else { pass.classList.remove('error'); pass.classList.add('success'); passErr.style.display = 'none'; }\n      if (confirm.value !== pass.value) { confirm.classList.add('error'); confirmErr.style.display = 'block'; valid = false; }\n      else { confirm.classList.remove('error'); confirm.classList.add('success'); confirmErr.style.display = 'none'; }\n      return valid;\n    }\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Dynamic Form Builder with Validation Engine",
    "description": "Build a JavaScript-powered dynamic form builder that allows users to add, remove, and configure input fields. Users should be able to: add text, email, number, checkbox, radio, select, and file inputs; configure field properties (label, required, placeholder, min/max, pattern); reorder fields via drag and drop; preview the generated form in real-time; export the form configuration as JSON; and submit the generated form with full validation.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dynamic Form Builder</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #eee; padding: 20px; }\n    .app { display: grid; grid-template-columns: 400px 1fr; gap: 24px; max-width: 1400px; margin: 0 auto; }\n    /* Complete styling */\n  </style>\n</head>\n<body>\n  <!-- Build dynamic form builder interface -->\n  <script>\n    // Build the dynamic form builder logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dynamic Form Builder</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #eee; padding: 20px; }\n    .app { display: grid; grid-template-columns: 380px 1fr; gap: 24px; max-width: 1400px; margin: 0 auto; }\n    .panel { background: #16213e; border-radius: 12px; padding: 20px; }\n    .panel h2 { font-size: 18px; margin-bottom: 16px; color: #4fc3f7; border-bottom: 1px solid #2a3a5e; padding-bottom: 8px; }\n    .field-config { display: flex; flex-direction: column; gap: 12px; }\n    .field-config label { font-size: 13px; color: #aaa; }\n    .field-config input, .field-config select { padding: 8px 12px; border: 1px solid #2a3a5e; border-radius: 6px; background: #0f3460; color: #eee; font-size: 14px; }\n    .field-config input:focus, .field-config select:focus { outline: none; border-color: #4fc3f7; }\n    .field-config .row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }\n    .checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #aaa; }\n    .checkbox-label input { width: auto; }\n    .add-btn { padding: 10px; background: #4fc3f7; color: #1a1a2e; border: none; border-radius: 6px; font-weight: 700; cursor: pointer; margin-top: 8px; }\n    .add-btn:hover { background: #29b6f6; }\n    .remove-btn { padding: 4px 8px; background: #e74c3c; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; }\n    .preview-area { background: #0f3460; border-radius: 8px; padding: 24px; min-height: 400px; }\n    .preview-area .form-field { margin-bottom: 16px; }\n    .preview-area .form-field label { display: block; margin-bottom: 4px; color: #4fc3f7; font-weight: 500; }\n    .preview-area .form-field input, .preview-area .form-field select { width: 100%; padding: 8px 12px; border: 1px solid #2a3a5e; border-radius: 6px; background: #16213e; color: #eee; }\n    .preview-area .form-field input:focus { border-color: #4fc3f7; outline: none; }\n    .preview-area .form-field .field-actions { margin-top: 4px; display: flex; gap: 4px; }\n    .preview-area .form-field .field-actions button { font-size: 11px; padding: 2px 6px; background: #2a3a5e; border: none; border-radius: 3px; color: #ccc; cursor: pointer; }\n    .preview-area .form-field .field-actions button:hover { background: #e74c3c; color: white; }\n    .export-btn { padding: 8px 16px; background: #2ecc71; color: #1a1a2e; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; margin-top: 12px; }\n    .export-btn:hover { background: #27ae60; }\n    .json-output { margin-top: 12px; padding: 12px; background: #1a1a2e; border-radius: 6px; font-family: monospace; font-size: 12px; max-height: 200px; overflow: auto; white-space: pre; }\n    .drag-handle { cursor: grab; color: #666; margin-right: 8px; }\n    .drag-handle:active { cursor: grabbing; }\n    .form-field.dragging { opacity: 0.5; }\n    .form-field.drag-over { border-top: 2px solid #4fc3f7; }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"panel\">\n      <h2>Field Builder</h2>\n      <div class=\"field-config\">\n        <label>Field Type</label>\n        <select id=\"fieldType\">\n          <option value=\"text\">Text</option>\n          <option value=\"email\">Email</option>\n          <option value=\"password\">Password</option>\n          <option value=\"number\">Number</option>\n          <option value=\"tel\">Telephone</option>\n          <option value=\"url\">URL</option>\n          <option value=\"date\">Date</option>\n          <option value=\"color\">Color</option>\n          <option value=\"range\">Range</option>\n          <option value=\"checkbox\">Checkbox</option>\n          <option value=\"radio\">Radio</option>\n          <option value=\"file\">File</option>\n        </select>\n        <label>Label</label>\n        <input type=\"text\" id=\"fieldLabel\" placeholder=\"Enter field label\">\n        <label>Name</label>\n        <input type=\"text\" id=\"fieldName\" placeholder=\"field_name\">\n        <label>Placeholder</label>\n        <input type=\"text\" id=\"fieldPlaceholder\" placeholder=\"Placeholder text\">\n        <div class=\"row\">\n          <div><label>Min</label><input type=\"text\" id=\"fieldMin\" placeholder=\"e.g. 0\"></div>\n          <div><label>Max</label><input type=\"text\" id=\"fieldMax\" placeholder=\"e.g. 100\"></div>\n        </div>\n        <div class=\"row\">\n          <div><label>Pattern (regex)</label><input type=\"text\" id=\"fieldPattern\" placeholder=\"[A-Za-z]+\"></div>\n          <div><label>Step</label><input type=\"text\" id=\"fieldStep\" placeholder=\"e.g. 1\"></div>\n        </div>\n        <label>Options (for radio/select, comma-separated)</label>\n        <input type=\"text\" id=\"fieldOptions\" placeholder=\"Option 1, Option 2, Option 3\">\n        <div style=\"display:flex; gap:16px;\">\n          <label class=\"checkbox-label\"><input type=\"checkbox\" id=\"fieldRequired\"> Required</label>\n          <label class=\"checkbox-label\"><input type=\"checkbox\" id=\"fieldMultiple\"> Multiple</label>\n        </div>\n        <button class=\"add-btn\" onclick=\"addField()\">+ Add Field</button>\n      </div>\n      <button class=\"export-btn\" onclick=\"exportForm()\">Export JSON</button>\n      <div class=\"json-output\" id=\"jsonOutput\">{}</div>\n    </div>\n    <div class=\"panel\" style=\"max-height: 90vh; overflow-y: auto;\">\n      <h2>Form Preview</h2>\n      <form id=\"previewForm\" class=\"preview-area\" onsubmit=\"event.preventDefault(); alert('Form submitted! Check console for data.'); console.log(new FormData(this))\"></form>\n    </div>\n  </div>\n  <script>\n    let fields = [];\n    let dragIndex = null;\n\n    function addField() {\n      const type = document.getElementById('fieldType').value;\n      const label = document.getElementById('fieldLabel').value || 'Unnamed Field';\n      const name = document.getElementById('fieldName').value || 'field_' + Date.now();\n      const placeholder = document.getElementById('fieldPlaceholder').value;\n      const min = document.getElementById('fieldMin').value;\n      const max = document.getElementById('fieldMax').value;\n      const pattern = document.getElementById('fieldPattern').value;\n      const step = document.getElementById('fieldStep').value;\n      const options = document.getElementById('fieldOptions').value.split(',').map(s => s.trim()).filter(Boolean);\n      const required = document.getElementById('fieldRequired').checked;\n      const multiple = document.getElementById('fieldMultiple').checked;\n\n      fields.push({ type, label, name, placeholder, min, max, pattern, step, options, required, multiple });\n      renderForm();\n      clearConfig();\n    }\n\n    function removeField(index) {\n      fields.splice(index, 1);\n      renderForm();\n    }\n\n    function moveField(from, to) {\n      const [moved] = fields.splice(from, 1);\n      fields.splice(to, 0, moved);\n      renderForm();\n    }\n\n    function clearConfig() {\n      ['fieldLabel','fieldName','fieldPlaceholder','fieldMin','fieldMax','fieldPattern','fieldStep','fieldOptions'].forEach(id => document.getElementById(id).value = '');\n      document.getElementById('fieldRequired').checked = false;\n      document.getElementById('fieldMultiple').checked = false;\n    }\n\n    function renderForm() {\n      const form = document.getElementById('previewForm');\n      form.innerHTML = '';\n      fields.forEach((f, i) => {\n        const div = document.createElement('div');\n        div.className = 'form-field';\n        div.draggable = true;\n        div.dataset.index = i;\n\n        const label = document.createElement('label');\n        label.textContent = f.label + (f.required ? ' *' : '');\n        div.appendChild(label);\n\n        if (f.type === 'select') {\n          const select = document.createElement('select');\n          select.name = f.name;\n          if (f.multiple) select.multiple = true;\n          f.options.forEach(opt => {\n            const o = document.createElement('option');\n            o.value = opt; o.textContent = opt;\n            select.appendChild(o);\n          });\n          div.appendChild(select);\n        } else if (f.type === 'radio') {\n          f.options.forEach(opt => {\n            const l = document.createElement('label');\n            l.style.display = 'inline-flex'; l.style.alignItems = 'center'; l.style.gap = '4px'; l.style.marginRight = '8px';\n            const inp = document.createElement('input');\n            inp.type = 'radio'; inp.name = f.name; inp.value = opt;\n            if (f.required) inp.required = true;\n            l.appendChild(inp);\n            l.appendChild(document.createTextNode(opt));\n            div.appendChild(l);\n          });\n        } else if (f.type === 'checkbox' && f.options.length) {\n          f.options.forEach(opt => {\n            const l = document.createElement('label');\n            l.style.display = 'inline-flex'; l.style.alignItems = 'center'; l.style.gap = '4px'; l.style.marginRight = '8px';\n            const inp = document.createElement('input');\n            inp.type = 'checkbox'; inp.name = f.name + '[]'; inp.value = opt;\n            l.appendChild(inp);\n            l.appendChild(document.createTextNode(opt));\n            div.appendChild(l);\n          });\n        } else {\n          const inp = document.createElement('input');\n          inp.type = f.type;\n          inp.name = f.name;\n          inp.placeholder = f.placeholder;\n          if (f.min) inp.min = f.min;\n          if (f.max) inp.max = f.max;\n          if (f.pattern) inp.pattern = f.pattern;\n          if (f.step) inp.step = f.step;\n          if (f.required) inp.required = true;\n          if (f.multiple && f.type === 'file') inp.multiple = true;\n          div.appendChild(inp);\n        }\n\n        const actions = document.createElement('div');\n        actions.className = 'field-actions';\n        const upBtn = document.createElement('button');\n        upBtn.textContent = '↑'; upBtn.onclick = () => { if (i > 0) moveField(i, i-1); };\n        const downBtn = document.createElement('button');\n        downBtn.textContent = '↓'; downBtn.onclick = () => { if (i < fields.length-1) moveField(i, i+1); };\n        const delBtn = document.createElement('button');\n        delBtn.textContent = '✕'; delBtn.onclick = () => removeField(i);\n        actions.appendChild(upBtn); actions.appendChild(downBtn); actions.appendChild(delBtn);\n        div.appendChild(actions);\n\n        div.addEventListener('dragstart', () => { dragIndex = i; div.classList.add('dragging'); });\n        div.addEventListener('dragend', () => { div.classList.remove('dragging'); dragIndex = null; document.querySelectorAll('.drag-over').forEach(e => e.classList.remove('drag-over')); });\n        div.addEventListener('dragover', e => { e.preventDefault(); div.classList.add('drag-over'); });\n        div.addEventListener('dragleave', () => div.classList.remove('drag-over'));\n        div.addEventListener('drop', e => {\n          e.preventDefault();\n          div.classList.remove('drag-over');\n          if (dragIndex !== null && dragIndex !== i) moveField(dragIndex, i);\n        });\n\n        form.appendChild(div);\n      });\n    }\n\n    function exportForm() {\n      document.getElementById('jsonOutput').textContent = JSON.stringify(fields, null, 2);\n    }\n  </script>\n</body>\n</html>"
  }
}
