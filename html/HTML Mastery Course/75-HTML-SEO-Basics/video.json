    "duration": "40 minutes",
    "difficulty": "Beginner",
    "prerequisites": [
      "Basic HTML knowledge",
      "No SEO experience needed"
    ],
    "segments": [
      {
        "title": "Introduction to SEO",
        "duration": "5 min",
        "topics": [
          "What is SEO?",
          "How search engines work",
          "Why HTML is foundational for SEO",
          "On-page vs off-page vs technical SEO"
        ]
      },
      {
        "title": "Essential HTML SEO Elements",
        "duration": "10 min",
        "topics": [
          "Title tag optimization (length, keywords, uniqueness)",
          "Meta descriptions (compelling copy, CTAs, length)",
          "Heading hierarchy and keyword placement",
          "Image SEO (filenames, alt text, optimization)"
