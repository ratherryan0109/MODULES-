          "XML sitemaps and robots.txt"
        ]
      },
      {
        "title": "Auditing and Tools",
        "duration": "7 min",
        "topics": [
          "Google Search Console",
          "Lighthouse audits",
          "PageSpeed Insights",
          "SEO audit workflow"
        ]
      }
