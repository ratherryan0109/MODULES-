{
  "easy": {
    "title": "Build a Contact Form with Various Input Types",
    "description": "Create a contact form that uses text, email, tel, number, and textarea input types. Include proper labels, placeholders, required validation, and a submit button.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Contact Us</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #f5f5f5; }\n  </style>\n</head>\n<body>\n  <!-- Build a contact form with name, email, phone, age, and message fields -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Contact Us</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #f5f5f5; }\n    .form { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }\n    .form h1 { margin-top: 0; color: #333; }\n    .form-group { margin-bottom: 16px; }\n    label { display: block; margin-bottom: 4px; font-weight: 600; color: #555; }\n    input, textarea { width: 100%; padding: 10px 12px; border: 2px solid #ddd; border-radius: 6px; font-size: 15px; box-sizing: border-box; transition: border-color 0.3s; }\n    input:focus, textarea:focus { border-color: #4a6cf7; outline: none; }\n    textarea { resize: vertical; min-height: 80px; }\n    button { background: #4a6cf7; color: white; border: none; padding: 12px 24px; border-radius: 6px; font-size: 16px; cursor: pointer; transition: background 0.3s; }\n    button:hover { background: #3b5de7; }\n  </style>\n</head>\n<body>\n  <form class=\"form\" onsubmit=\"event.preventDefault(); alert('Form submitted!')\">\n    <h1>Contact Us</h1>\n    <div class=\"form-group\">\n      <label for=\"name\">Full Name</label>\n      <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"John Doe\" required>\n    </div>\n    <div class=\"form-group\">\n      <label for=\"email\">Email Address</label>\n      <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"john@example.com\" required>\n    </div>\n    <div class=\"form-group\">\n      <label for=\"phone\">Phone Number</label>\n      <input type=\"tel\" id=\"phone\" name=\"phone\" placeholder=\"555-000-0000\" pattern=\"[0-9\\-\\s\\(\\)]+\">\n    </div>\n    <div class=\"form-group\">\n      <label for=\"age\">Age</label>\n      <input type=\"number\" id=\"age\" name=\"age\" min=\"1\" max=\"120\" placeholder=\"25\">\n    </div>\n    <div class=\"form-group\">\n      <label for=\"message\">Message</label>\n      <textarea id=\"message\" name=\"message\" placeholder=\"How can we help you?\" required></textarea>\n    </div>\n    <button type=\"submit\">Send Message</button>\n  </form>\n</body>\n</html>"
  },
  "medium": {
    "title": "Event Registration Form with Date/Time Inputs",
    "description": "Build an event registration form that uses date, time, datetime-local, month, week, number, range, color, checkboxes, and radio inputs. The form should include event details, attendee preferences, and ticket selection.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Event Registration</title>\n  <style>\n    body { font-family: system-ui, sans-serif; background: #f0f2f5; padding: 30px; }\n  </style>\n</head>\n<body>\n  <!-- Build event registration form with date/time/special inputs -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Event Registration</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; background: linear-gradient(135deg, #667eea, #764ba2); min-height: 100vh; padding: 30px; }\n    .container { max-width: 700px; margin: 0 auto; background: white; border-radius: 16px; padding: 40px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }\n    h1 { margin-bottom: 8px; color: #2d3748; }\n    .subtitle { color: #718096; margin-bottom: 30px; }\n    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n    .form-group { margin-bottom: 20px; }\n    label { display: block; margin-bottom: 4px; font-weight: 600; color: #4a5568; font-size: 14px; }\n    input, select { width: 100%; padding: 10px 14px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 15px; transition: all 0.3s; }\n    input:focus, select:focus { border-color: #667eea; outline: none; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); }\n    fieldset { border: 2px solid #e2e8f0; border-radius: 8px; padding: 16px; margin-bottom: 20px; }\n    legend { font-weight: 700; color: #4a5568; padding: 0 8px; font-size: 15px; }\n    .checkbox-group, .radio-group { display: flex; gap: 12px; flex-wrap: wrap; }\n    .checkbox-group label, .radio-group label { display: flex; align-items: center; gap: 6px; font-weight: 400; cursor: pointer; }\n    .btn { width: 100%; padding: 14px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; }\n    .btn:hover { opacity: 0.9; }\n    .range-display { float: right; color: #667eea; font-weight: 700; }\n    .color-preview { display: inline-block; width: 30px; height: 30px; border-radius: 50%; vertical-align: middle; margin-left: 8px; border: 2px solid #e2e8f0; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Event Registration</h1>\n    <p class=\"subtitle\">Register for the 2025 Tech Conference</p>\n    <form onsubmit=\"event.preventDefault(); alert('Registration submitted!')\">\n      <div class=\"form-row\">\n        <div class=\"form-group\"><label>First Name</label><input type=\"text\" placeholder=\"Jane\" required></div>\n        <div class=\"form-group\"><label>Last Name</label><input type=\"text\" placeholder=\"Doe\" required></div>\n      </div>\n      <div class=\"form-group\"><label>Email</label><input type=\"email\" placeholder=\"jane@example.com\" required></div>\n      <div class=\"form-row\">\n        <div class=\"form-group\"><label>Event Date</label><input type=\"date\" required></div>\n        <div class=\"form-group\"><label>Start Time</label><input type=\"time\" step=\"900\" required></div>\n      </div>\n      <div class=\"form-row\">\n        <div class=\"form-group\"><label>End Time</label><input type=\"time\" step=\"900\" required></div>\n        <div class=\"form-group\"><label>Preferred Month</label><input type=\"month\"></div>\n      </div>\n      <div class=\"form-group\"><label>Full Event (date + time)</label><input type=\"datetime-local\"></div>\n      <div class=\"form-row\">\n        <div class=\"form-group\"><label>Number of Tickets</label><input type=\"number\" min=\"1\" max=\"10\" value=\"1\"></div>\n        <div class=\"form-group\"><label>Sprint Week</label><input type=\"week\"></div>\n      </div>\n      <div class=\"form-group\"><label>Comfort Level: <span class=\"range-display\" id=\"comfortVal\">5</span></label><input type=\"range\" min=\"1\" max=\"10\" value=\"5\" oninput=\"document.getElementById('comfortVal').textContent=this.value\"></div>\n      <div class=\"form-group\"><label>Favorite Color: <span id=\"colorHex\">#667eea</span> <span class=\"color-preview\" id=\"colorPreview\" style=\"background:#667eea;\"></span></label><input type=\"color\" value=\"#667eea\" oninput=\"document.getElementById('colorHex').textContent=this.value; document.getElementById('colorPreview').style.background=this.value\"></div>\n      <fieldset><legend>Sessions</legend><div class=\"checkbox-group\"><label><input type=\"checkbox\" value=\"web\"> Web Dev</label><label><input type=\"checkbox\" value=\"ai\"> AI/ML</label><label><input type=\"checkbox\" value=\"cloud\"> Cloud</label><label><input type=\"checkbox\" value=\"security\"> Security</label></div></fieldset>\n      <fieldset><legend>Meal Preference</legend><div class=\"radio-group\"><label><input type=\"radio\" name=\"meal\" value=\"veg\" checked> Vegetarian</label><label><input type=\"radio\" name=\"meal\" value=\"vegan\"> Vegan</label><label><input type=\"radio\" name=\"meal\" value=\"nonveg\"> Non-Vegetarian</label></div></fieldset>\n      <button class=\"btn\" type=\"submit\">Register Now</button>\n    </form>\n  </div>\n</body>\n</html>"
  },
  "hard": {
    "title": "Interactive Color Theme Customizer",
    "description": "Build an interactive color theme customizer that uses range, color, number, and checkbox inputs. Users should be able to: adjust RGB values using range sliders, pick a color from the color picker, see real-time preview updates, copy hex/RGB values to clipboard, save themes to localStorage, toggle dark/light mode, and export theme as CSS variables.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Theme Customizer</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; transition: background 0.3s, color 0.3s; }\n  </style>\n</head>\n<body>\n  <!-- Build interactive theme customizer with multiple input types -->\n  <script>\n    // Implement theme customization logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Theme Customizer</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; transition: background 0.3s, color 0.3s; min-height: 100vh; background: var(--bg, #ffffff); color: var(--text, #333333); }\n    .app { max-width: 1200px; margin: 0 auto; padding: 30px; }\n    h1 { margin-bottom: 30px; }\n    .grid { display: grid; grid-template-columns: 400px 1fr; gap: 30px; }\n    .panel { background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 16px; padding: 24px; border: 1px solid rgba(255,255,255,0.2); }\n    .panel h2 { margin-bottom: 20px; font-size: 18px; }\n    .form-group { margin-bottom: 16px; }\n    .form-group label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 14px; }\n    .form-group input[type=\"range\"] { width: 100%; margin: 8px 0; }\n    .form-group input[type=\"color\"] { width: 60px; height: 40px; padding: 2px; border: 1px solid #ccc; border-radius: 6px; }\n    .color-row { display: flex; gap: 12px; align-items: center; }\n    .color-row input[type=\"number\"] { width: 70px; }\n    .value-display { font-family: monospace; font-size: 13px; color: #666; }\n    .preview-box { background: var(--preview-bg, #3498db); width: 100%; height: 200px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 20px; font-weight: 700; margin-bottom: 20px; transition: background 0.3s; }\n    .preview-card { background: var(--card-bg, #f0f2f5); padding: 20px; border-radius: 12px; margin-top: 16px; border: 1px solid var(--card-border, #ddd); }\n    .preview-card button { padding: 8px 16px; border-radius: 6px; border: none; background: var(--btn-bg, #4a6cf7); color: white; cursor: pointer; margin: 4px; }\n    .css-output { background: #1a1a2e; color: #e2e8f0; padding: 16px; border-radius: 8px; font-family: monospace; font-size: 13px; margin-top: 12px; white-space: pre; overflow-x: auto; }\n    .theme-list { margin-top: 12px; }\n    .theme-item { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 20px; background: rgba(255,255,255,0.1); margin: 4px; cursor: pointer; border: 1px solid rgba(255,255,255,0.2); font-size: 13px; }\n    .theme-item:hover { background: rgba(255,255,255,0.2); }\n    .btn-icon { background: none; border: 1px solid #ccc; border-radius: 6px; padding: 4px 10px; cursor: pointer; font-size: 13px; }\n    .btn-icon:hover { background: rgba(0,0,0,0.05); }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <h1>🎨 Theme Customizer</h1>\n    <div class=\"grid\">\n      <div class=\"panel\" style=\"background:#f8f9fa; border-color:#ddd;\">\n        <h2>Colors</h2>\n        <div class=\"form-group\"><label>Primary Color</label><div class=\"color-row\"><input type=\"color\" id=\"primary\" value=\"#3498db\" oninput=\"updateTheme()\"> <span class=\"value-display\" id=\"primaryHex\">#3498db</span></div></div>\n        <div class=\"form-group\"><label>Background</label><div class=\"color-row\"><input type=\"color\" id=\"bg\" value=\"#ffffff\" oninput=\"updateTheme()\"> <span class=\"value-display\" id=\"bgHex\">#ffffff</span></div></div>\n        <div class=\"form-group\"><label>Text Color</label><div class=\"color-row\"><input type=\"color\" id=\"text\" value=\"#333333\" oninput=\"updateTheme()\"> <span class=\"value-display\" id=\"textHex\">#333333</span></div></div>\n        <div class=\"form-group\"><label>Card Background</label><div class=\"color-row\"><input type=\"color\" id=\"card\" value=\"#f0f2f5\" oninput=\"updateTheme()\"> <span class=\"value-display\" id=\"cardHex\">#f0f2f5</span></div></div>\n        <h2 style=\"margin-top:24px;\">Adjustments</h2>\n        <div class=\"form-group\"><label>Border Radius: <span id=\"radiusVal\">12</span>px</label><input type=\"range\" id=\"radius\" min=\"0\" max=\"30\" value=\"12\" oninput=\"updateTheme()\"></div>\n        <div class=\"form-group\"><label>Opacity: <span id=\"opacityVal\">100</span>%</label><input type=\"range\" id=\"opacity\" min=\"20\" max=\"100\" value=\"100\" oninput=\"updateTheme()\"></div>\n        <div class=\"form-group\"><label>Font Size: <span id=\"fontVal\">16</span>px</label><input type=\"range\" id=\"fontsize\" min=\"12\" max=\"24\" value=\"16\" oninput=\"updateTheme()\"></div>\n        <div class=\"form-group\"><label><input type=\"checkbox\" id=\"darkmode\" onchange=\"updateTheme()\"> Dark Mode</label></div>\n        <div style=\"display:flex; gap:8px; margin-top:16px;\">\n          <button class=\"btn-icon\" onclick=\"saveTheme()\">💾 Save Theme</button>\n          <button class=\"btn-icon\" onclick=\"copyCSS()\">📋 Copy CSS</button>\n          <button class=\"btn-icon\" onclick=\"resetTheme()\">↺ Reset</button>\n        </div>\n        <div id=\"savedThemes\" class=\"theme-list\"></div>\n      </div>\n      <div>\n        <div class=\"panel\" style=\"background:var(--card-bg, #f0f2f5); border-color:var(--card-border, #ddd);\">\n          <h2>Preview</h2>\n          <div class=\"preview-box\" id=\"previewBox\" style=\"background:var(--primary, #3498db); border-radius:var(--radius, 12px); opacity:var(--opacity, 1);\">Sample Text</div>\n          <div class=\"preview-card\" style=\"border-radius:var(--radius, 12px);\">\n            <p style=\"margin-bottom:12px; font-size:var(--fontsize, 16px);\">This is a preview card showing how your theme looks. Buttons, text, and backgrounds all update in real-time.</p>\n            <button style=\"background:var(--primary, #3498db); border-radius:calc(var(--radius, 12px) / 2);\">Primary Button</button>\n            <button style=\"background:transparent; border:2px solid var(--primary, #3498db); color:var(--text, #333); border-radius:calc(var(--radius, 12px) / 2);\">Outline Button</button>\n          </div>\n          <div class=\"css-output\" id=\"cssOutput\">/* CSS Variables will appear here */</div>\n        </div>\n      </div>\n    </div>\n  </div>\n  <script>\n    function updateTheme() {\n      const primary = document.getElementById('primary').value;\n      const bg = document.getElementById('bg').value;\n      const text = document.getElementById('text').value;\n      const card = document.getElementById('card').value;\n      const radius = document.getElementById('radius').value;\n      const opacity = document.getElementById('opacity').value / 100;\n      const fontsize = document.getElementById('fontsize').value;\n      const dark = document.getElementById('darkmode').checked;\n\n      document.documentElement.style.setProperty('--primary', primary);\n      document.documentElement.style.setProperty('--bg', dark ? '#1a1a2e' : bg);\n      document.documentElement.style.setProperty('--text', dark ? '#e2e8f0' : text);\n      document.documentElement.style.setProperty('--card-bg', dark ? '#16213e' : card);\n      document.documentElement.style.setProperty('--card-border', dark ? '#2a3a5e' : '#ddd');\n      document.documentElement.style.setProperty('--radius', radius + 'px');\n      document.documentElement.style.setProperty('--opacity', opacity);\n      document.documentElement.style.setProperty('--fontsize', fontsize + 'px');\n      document.getElementById('previewBox').style.background = primary;\n      document.getElementById('previewBox').style.borderRadius = radius + 'px';\n\n      document.getElementById('primaryHex').textContent = primary;\n      document.getElementById('bgHex').textContent = dark ? '#1a1a2e' : bg;\n      document.getElementById('textHex').textContent = dark ? '#e2e8f0' : text;\n      document.getElementById('cardHex').textContent = dark ? '#16213e' : card;\n      document.getElementById('radiusVal').textContent = radius;\n      document.getElementById('opacityVal').textContent = Math.round(opacity * 100);\n      document.getElementById('fontVal').textContent = fontsize;\n\n      document.getElementById('cssOutput').textContent = `:root {\\n  --primary: ${primary};\\n  --bg: ${dark ? '#1a1a2e' : bg};\\n  --text: ${dark ? '#e2e8f0' : text};\\n  --card-bg: ${dark ? '#16213e' : card};\\n  --radius: ${radius}px;\\n  --opacity: ${opacity};\\n  --fontsize: ${fontsize}px;\\n}`;\n    }\n    function saveTheme() {\n      const theme = { primary: document.getElementById('primary').value, bg: document.getElementById('bg').value, text: document.getElementById('text').value, card: document.getElementById('card').value, radius: document.getElementById('radius').value, opacity: document.getElementById('opacity').value, fontsize: document.getElementById('fontsize').value, dark: document.getElementById('darkmode').checked };\n      const themes = JSON.parse(localStorage.getItem('themes') || '[]');\n      themes.push(theme);\n      localStorage.setItem('themes', JSON.stringify(themes));\n      renderSavedThemes();\n    }\n    function loadTheme(theme) {\n      document.getElementById('primary').value = theme.primary;\n      document.getElementById('bg').value = theme.bg;\n      document.getElementById('text').value = theme.text;\n      document.getElementById('card').value = theme.card;\n      document.getElementById('radius').value = theme.radius;\n      document.getElementById('opacity').value = theme.opacity;\n      document.getElementById('fontsize').value = theme.fontsize;\n      document.getElementById('darkmode').checked = theme.dark;\n      updateTheme();\n    }\n    function resetTheme() {\n      document.getElementById('primary').value = '#3498db';\n      document.getElementById('bg').value = '#ffffff';\n      document.getElementById('text').value = '#333333';\n      document.getElementById('card').value = '#f0f2f5';\n      document.getElementById('radius').value = '12';\n      document.getElementById('opacity').value = '100';\n      document.getElementById('fontsize').value = '16';\n      document.getElementById('darkmode').checked = false;\n      updateTheme();\n    }\n    function copyCSS() {\n      navigator.clipboard.writeText(document.getElementById('cssOutput').textContent).then(() => alert('CSS copied!'));\n    }\n    function renderSavedThemes() {\n      const container = document.getElementById('savedThemes');\n      container.innerHTML = '';\n      const themes = JSON.parse(localStorage.getItem('themes') || '[]');\n      themes.forEach((t, i) => {\n        const el = document.createElement('span');\n        el.className = 'theme-item';\n        el.innerHTML = `<span style=\"display:inline-block;width:12px;height:12px;border-radius:50%;background:${t.primary}\"></span> Theme ${i+1}`;\n        el.onclick = () => loadTheme(t);\n        container.appendChild(el);\n      });\n    }\n    updateTheme();\n    renderSavedThemes();\n  </script>\n</body>\n</html>"
  }
}
