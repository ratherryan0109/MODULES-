{
  "easy": {
    "title": "Simple Site Navigation",
    "description": "Create a basic horizontal navigation bar using <nav>. Include 4 links: Home, About, Blog, Contact. Use <ul> for the list structure, add aria-label on the <nav>, and mark the 'Home' link with aria-current='page'. Style it with a dark background, white text, and hover effect.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Simple Navigation</title>\n  <style>\n    /* Add your styles */\n  </style>\n</head>\n<body>\n  <!-- Create your nav here -->\n  <main>\n    <p>Page content.</p>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Simple Navigation</title>\n  <style>\n    body { margin: 0; font-family: 'Segoe UI', sans-serif; }\n    nav { background: #1e293b; padding: 0 20px; }\n    ul { display: flex; gap: 0; list-style: none; margin: 0; padding: 0; }\n    a {\n      display: block; padding: 14px 24px; color: #cbd5e1;\n      text-decoration: none; transition: background 0.2s;\n    }\n    a:hover { background: #334155; color: white; }\n    [aria-current=\"page\"] { background: #3b82f6; color: white; }\n    main { padding: 40px; }\n  </style>\n</head>\n<body>\n  <nav aria-label=\"Main navigation\">\n    <ul>\n      <li><a href=\"#\" aria-current=\"page\">Home</a></li>\n      <li><a href=\"#\">About</a></li>\n      <li><a href=\"#\">Blog</a></li>\n      <li><a href=\"#\">Contact</a></li>\n    </ul>\n  </nav>\n  <main>\n    <h1>Welcome!</h1>\n    <p>This is the homepage.</p>\n  </main>\n</body>\n</html>"
  },
  "medium": {
    "title": "Vertical Dashboard Sidebar with Icons",
    "description": "Create a vertical sidebar navigation for a dashboard. Include 6 links: Dashboard, Profile, Messages, Settings, Billing, Logout. Use <nav> inside an <aside>, add aria-label, mark 'Dashboard' as active. Use Unicode or emoji icons before each link text. Style with a dark sidebar, left-aligned text, border-left accent on hover/active, and proper spacing.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Dashboard</title>\n  <style>\n    /* Add your styles */\n  </style>\n</head>\n<body>\n  <aside>\n    <!-- Create sidebar nav here -->\n  </aside>\n  <main>\n    <h1>Dashboard</h1>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Dashboard</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { display: flex; min-height: 100vh; font-family: 'Segoe UI', sans-serif; background: #f8fafc; }\n    aside { width: 250px; background: #1e293b; display: flex; flex-direction: column; }\n    .sidebar-header { padding: 20px; color: white; font-size: 1.2em; font-weight: bold; border-bottom: 1px solid #334155; }\n    nav { flex: 1; padding: 10px 0; }\n    ul { list-style: none; }\n    a {\n      display: flex; align-items: center; gap: 12px;\n      padding: 12px 24px; color: #94a3b8; text-decoration: none;\n      border-left: 3px solid transparent; transition: all 0.2s;\n    }\n    a:hover { background: #334155; color: white; border-left-color: #475569; }\n    [aria-current=\"page\"] {\n      background: #334155; color: white; border-left-color: #3b82f6; font-weight: 600;\n    }\n    main { flex: 1; padding: 40px; }\n    main h1 { margin-bottom: 20px; color: #1e293b; }\n  </style>\n</head>\n<body>\n  <aside>\n    <div class=\"sidebar-header\">📊 My Dashboard</div>\n    <nav aria-label=\"Sidebar navigation\">\n      <ul>\n        <li><a href=\"#\" aria-current=\"page\">📈 Dashboard</a></li>\n        <li><a href=\"#\">👤 Profile</a></li>\n        <li><a href=\"#\">✉️ Messages</a></li>\n        <li><a href=\"#\">⚙️ Settings</a></li>\n        <li><a href=\"#\">💳 Billing</a></li>\n        <li style=\"margin-top: 20px; border-top: 1px solid #334155; padding-top: 8px;\"><a href=\"#\">🚪 Logout</a></li>\n      </ul>\n    </nav>\n  </aside>\n  <main>\n    <h1>Dashboard</h1>\n    <p>Welcome back, User! Here is your activity overview.</p>\n  </main>\n</body>\n</html>"
  },
  "hard": {
    "title": "Full Responsive Navigation with Dropdown and Hamburger Menu",
    "description": "Create a complete responsive navigation system. Desktop: horizontal nav bar with dropdown sub-menu on 'Services' (showing Web Design, Development, SEO, Consulting). Mobile: hamburger menu that expands to a full vertical nav. Use CSS checkbox hack for both the hamburger toggle and dropdown. Include aria-labels, aria-current on 'Home', and proper semantic HTML. Style with modern design, transitions, and a sticky header.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Responsive Nav</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    /* Build your responsive navigation */\n  </style>\n</head>\n<body>\n  <header>\n    <!-- Build nav here -->\n  </header>\n  <main>\n    <h1>Responsive Navigation Demo</h1>\n    <p>Resize the browser to see the navigation change.</p>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Responsive Nav</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: 'Segoe UI', sans-serif; padding-top: 60px; }\n\n    header { position: fixed; top: 0; width: 100%; z-index: 1000; }\n    .header-inner {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 0 30px; background: #1e293b; height: 60px;\n    }\n    .logo { color: white; font-size: 1.4em; font-weight: 800; }\n\n    /* Desktop nav */\n    .desktop-nav { display: flex; align-items: center; }\n    .desktop-nav ul { display: flex; list-style: none; gap: 0; }\n    .desktop-nav a {\n      display: block; padding: 18px 20px; color: #cbd5e1;\n      text-decoration: none; transition: background 0.2s; font-size: 0.95em;\n    }\n    .desktop-nav a:hover { background: #334155; color: white; }\n    .desktop-nav [aria-current=\"page\"] { background: #3b82f6; color: white; }\n\n    /* Dropdown */\n    .dropdown { position: relative; }\n    .dropdown-content {\n      display: none; position: absolute; top: 100%; left: 0;\n      background: #1e293b; min-width: 200px; box-shadow: 0 8px 16px rgba(0,0,0,0.3);\n    }\n    .dropdown-content a { padding: 12px 20px; border-bottom: 1px solid #334155; }\n    .dropdown:hover .dropdown-content { display: block; }\n\n    /* Hamburger controls */\n    #hamburger-toggle, #dropdown-toggle { display: none; }\n    .hamburger-label { display: none; cursor: pointer; color: white; font-size: 1.5em; padding: 10px; }\n\n    /* Mobile styles */\n    @media (max-width: 768px) {\n      .hamburger-label { display: block; }\n      .desktop-nav { display: none; }\n      #hamburger-toggle:checked ~ .desktop-nav { display: block; }\n\n      .desktop-nav { position: absolute; top: 60px; left: 0; width: 100%; background: #1e293b; }\n      .desktop-nav ul { flex-direction: column; }\n      .desktop-nav a { padding: 14px 30px; border-bottom: 1px solid #334155; }\n\n      .dropdown-content {\n        position: static; display: none; box-shadow: none;\n      }\n      .dropdown-content a { padding-left: 50px; }\n\n      /* Mobile dropdown */\n      #dropdown-toggle:checked ~ .dropdown-content { display: block; }\n      .dropdown-label { cursor: pointer; display: flex; justify-content: space-between; align-items: center; }\n      .dropdown-label::after { content: ' ▼'; font-size: 0.7em; }\n    }\n\n    @media (min-width: 769px) {\n      .dropdown-label { display: inline; }\n      .mobile-dropdown-label { display: none; }\n    }\n\n    main { padding: 60px 30px; max-width: 800px; margin: 0 auto; }\n    main h1 { margin-bottom: 16px; color: #1e293b; }\n    main p { line-height: 1.8; color: #475569; }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"header-inner\">\n      <div class=\"logo\">🌟 MySite</div>\n\n      <input type=\"checkbox\" id=\"hamburger-toggle\">\n      <label for=\"hamburger-toggle\" class=\"hamburger-label\" aria-label=\"Toggle navigation menu\">☰</label>\n\n      <nav class=\"desktop-nav\" aria-label=\"Main navigation\">\n        <ul>\n          <li><a href=\"#\" aria-current=\"page\">Home</a></li>\n          <li><a href=\"#\">About</a></li>\n          <li class=\"dropdown\">\n            <input type=\"checkbox\" id=\"dropdown-toggle\">\n            <label for=\"dropdown-toggle\" class=\"dropdown-label\" style=\"color: #cbd5e1; padding: 18px 20px; cursor: pointer; display: inline-block;\">Services</label>\n            <div class=\"dropdown-content\">\n              <a href=\"#\">Web Design</a>\n              <a href=\"#\">Development</a>\n              <a href=\"#\">SEO</a>\n              <a href=\"#\">Consulting</a>\n            </div>\n          </li>\n          <li><a href=\"#\">Portfolio</a></li>\n          <li><a href=\"#\">Contact</a></li>\n        </ul>\n      </nav>\n    </div>\n  </header>\n\n  <main>\n    <h1>Responsive Navigation Demo</h1>\n    <p>This navigation bar is fully responsive. Resize the browser window to see it switch from a horizontal menu to a hamburger menu on mobile. The 'Services' link has a dropdown sub-menu on desktop.</p>\n    <p>The navigation uses semantic HTML5 elements, ARIA attributes, and a CSS-only approach for toggling menus.</p>\n  </main>\n</body>\n</html>"
  }
}
