{
  "easy": {
    "title": "Create a Top 10 Ranking List",
    "description": "Create a top 10 list of your favorite movies, books, or songs using an ordered list. Style it with CSS to make the numbers stand out.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>Top 10</title></head>\n<body>\n  <h1>Top 10 Movies</h1>\n  <ol>\n    <!-- Add items -->\n  </ol>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Top 10 Movies</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 500px; margin: 0 auto; padding: 30px; background: #1a1a2e; color: white; }\n    h1 { text-align: center; color: #e94560; }\n    ol { font-size: 1.2em; }\n    li { padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.1); }\n    li::marker { color: #e94560; font-weight: bold; font-size: 1.3em; }\n  </style>\n</head>\n<body>\n  <h1>Top 10 Movies</h1>\n  <ol>\n    <li>The Shawshank Redemption</li>\n    <li>The Godfather</li>\n    <li>The Dark Knight</li>\n    <li>Pulp Fiction</li>\n    <li>Schindler's List</li>\n    <li>The Lord of the Rings: The Return of the King</li>\n    <li>Fight Club</li>\n    <li>Forrest Gump</li>\n    <li>Inception</li>\n    <li>The Matrix</li>\n  </ol>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Recipe with Timed Steps",
    "description": "Create a recipe page where each step is numbered. Use type attributes for different sections (main steps with numbers, sub-steps with letters). Include prep time, cook time, and ingredients.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>Recipe</title></head>\n<body>\n  <h1>Chocolate Cake Recipe</h1>\n  <ol>\n    <!-- Main steps with sub-steps using letters -->\n  </ol>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Chocolate Cake Recipe</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 700px; margin: 0 auto; padding: 30px; background: #f8f9fa; }\n    h1 { color: #1a1a2e; text-align: center; }\n    dl { display: flex; gap: 20px; justify-content: center; margin: 20px 0; }\n    dt { font-weight: bold; color: #e94560; }\n    dd { margin: 0; }\n    ol { background: white; padding: 20px 20px 20px 40px; border-radius: 10px; line-height: 2; }\n    li::marker { font-weight: bold; color: #2563eb; }\n    .ingredients { background: white; padding: 20px; border-radius: 10px; margin-bottom: 20px; }\n  </style>\n</head>\n<body>\n  <h1>🍫 Chocolate Cake</h1>\n  <dl>\n    <dt>Prep</dt><dd>20 mins</dd>\n    <dt>Cook</dt><dd>30 mins</dd>\n    <dt>Servings</dt><dd>8</dd>\n  </dl>\n  <div class=\"ingredients\">\n    <h2>Ingredients</h2>\n    <ul>\n      <li>1.5 cups all-purpose flour</li>\n      <li>1 cup sugar</li>\n      <li>0.5 cup cocoa powder</li>\n      <li>1 tsp baking soda</li>\n      <li>2 eggs</li>\n      <li>1 cup milk</li>\n    </ul>\n  </div>\n  <h2>Instructions</h2>\n  <ol>\n    <li>Prepare the batter\n      <ol type=\"a\">\n        <li>Sift together flour, cocoa, and baking soda</li>\n        <li>In a separate bowl, whisk eggs and sugar</li>\n        <li>Combine dry and wet ingredients gradually</li>\n        <li>Add milk and mix until smooth</li>\n      </ol>\n    </li>\n    <li>Preheat oven to 350°F (175°C)</li>\n    <li>Grease and line a 9-inch cake pan</li>\n    <li>Pour batter into the pan</li>\n    <li>Bake for 28-32 minutes\n      <ol type=\"a\">\n        <li>Test with toothpick at 28 minutes</li>\n        <li>Cool in pan for 10 minutes</li>\n        <li>Transfer to wire rack</li>\n      </ol>\n    </li>\n    <li>Frost and serve</li>\n  </ol>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build a Collapsible Table of Contents with Legal Numbering",
    "description": "Create a legal document table of contents with CSS counter-based numbering (Article 1, 1.1, 1.1.1). Implement JavaScript collapsible sections that expand/collapse on click.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>Legal TOC</title></head>\n<body>\n  <h1>Terms & Conditions</h1>\n  <nav class=\"toc\">\n    <!-- CSS-counter numbered TOC with collapsible sections -->\n  </nav>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Terms & Conditions — Table of Contents</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Georgia', serif; max-width: 800px; margin: 0 auto; padding: 40px 20px; background: #fafafa; }\n    h1 { color: #1a1a2e; margin-bottom: 30px; font-size: 2em; }\n    .toc { background: white; border-radius: 12px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }\n    .toc ol { list-style: none; counter-reset: article; padding-left: 0; }\n    .toc > ol > li { counter-increment: article; margin: 12px 0; }\n    .toc > ol > li > a::before { content: \"Article \" counter(article) \" — \"; font-weight: bold; color: #8B5CF6; }\n    .toc ol ol { counter-reset: section; padding-left: 25px; margin: 8px 0; }\n    .toc ol ol li { counter-increment: section; margin: 5px 0; }\n    .toc ol ol li a::before { content: counter(article) \".\" counter(section) \" \"; color: #666; }\n    .toc ol ol ol { counter-reset: subsection; padding-left: 25px; }\n    .toc ol ol ol li { counter-increment: subsection; }\n    .toc ol ol ol li a::before { content: counter(article) \".\" counter(section) \".\" counter(subsection) \" \"; color: #999; }\n    .toc a { color: #333; text-decoration: none; transition: color 0.2s; }\n    .toc a:hover { color: #8B5CF6; }\n    .toggle-btn { cursor: pointer; background: none; border: none; color: #8B5CF6; font-size: 13px; margin-left: 8px; }\n    .collapsible { overflow: hidden; transition: max-height 0.3s ease; max-height: 500px; }\n    .collapsible.collapsed { max-height: 0; }\n  </style>\n</head>\n<body>\n  <h1>Terms & Conditions</h1>\n  <nav class=\"toc\">\n    <ol>\n      <li><a href=\"#article1\">Definitions</a>\n        <button class=\"toggle-btn\" onclick=\"toggle(this)\">[−]</button>\n        <div class=\"collapsible\">\n          <ol>\n            <li><a href=\"#sec1.1\">Agreement</a></li>\n            <li><a href=\"#sec1.2\">Parties</a>\n              <button class=\"toggle-btn\" onclick=\"toggle(this)\">[−]</button>\n              <div class=\"collapsible\">\n                <ol>\n                  <li><a href=\"#sec1.2.1\">Provider</a></li>\n                  <li><a href=\"#sec1.2.2\">Client</a></li>\n                </ol>\n              </div>\n            </li>\n            <li><a href=\"#sec1.3\">Effective Date</a></li>\n          </ol>\n        </div>\n      </li>\n      <li><a href=\"#article2\">Services</a>\n        <button class=\"toggle-btn\" onclick=\"toggle(this)\">[−]</button>\n        <div class=\"collapsible\">\n          <ol>\n            <li><a href=\"#sec2.1\">Scope of Work</a></li>\n            <li><a href=\"#sec2.2\">Deliverables</a></li>\n          </ol>\n        </div>\n      </li>\n      <li><a href=\"#article3\">Payment Terms</a>\n        <button class=\"toggle-btn\" onclick=\"toggle(this)\">[−]</button>\n        <div class=\"collapsible\">\n          <ol>\n            <li><a href=\"#sec3.1\">Fees</a></li>\n            <li><a href=\"#sec3.2\">Payment Schedule</a></li>\n          </ol>\n        </div>\n      </li>\n    </ol>\n  </nav>\n  <script>\n    function toggle(btn) {\n      const div = btn.nextElementSibling;\n      div.classList.toggle('collapsed');\n      btn.textContent = div.classList.contains('collapsed') ? '[+]' : '[−]';\n    }\n  </script>\n</body>\n</html>"
  }
}
