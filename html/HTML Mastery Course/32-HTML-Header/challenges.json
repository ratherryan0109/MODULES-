{
  "easy": {
    "title": "Simple Blog Page Header",
    "description": "Create a basic page-level <header> for a blog. Include the blog name as an <h1>, a short tagline in a <p>, and a simple navigation with three links: Home, About, and Contact. No CSS styling required — focus on correct semantic HTML structure.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>My Blog</title>\n</head>\n<body>\n  <!-- Create your header here -->\n\n  <main>\n    <p>Blog content goes here.</p>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>My Blog</title>\n</head>\n<body>\n  <header>\n    <h1>My Blog</h1>\n    <p>Thoughts, stories, and ideas.</p>\n    <nav>\n      <a href=\"/\">Home</a> |\n      <a href=\"/about\">About</a> |\n      <a href=\"/contact\">Contact</a>\n    </nav>\n  </header>\n\n  <main>\n    <p>Blog content goes here.</p>\n  </main>\n</body>\n</html>"
  },
  "medium": {
    "title": "E-Commerce Store Header with Search",
    "description": "Create a styled e-commerce site header. Include: a logo placeholder (use a <div> with text), site name in <h1>, a navigation with 4 links (Home, Shop, Deals, Support), a search form with input and button, and a cart icon link. Style the header with Flexbox, background color, and padding. Make the navigation links change color on hover.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>ShopZone</title>\n  <style>\n    /* Add your styles here */\n  </style>\n</head>\n<body>\n  <header>\n    <!-- Build the header here -->\n  </header>\n  <main>\n    <p>Welcome to ShopZone!</p>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>ShopZone</title>\n  <style>\n    body { margin: 0; font-family: 'Segoe UI', Tahoma, sans-serif; }\n    .site-header {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 15px 40px; background: #fff; border-bottom: 1px solid #e5e7eb;\n    }\n    .brand { display: flex; align-items: center; gap: 12px; }\n    .logo-placeholder {\n      width: 40px; height: 40px; background: #f59e0b;\n      border-radius: 8px; display: flex; align-items: center; justify-content: center;\n      color: white; font-weight: bold; font-size: 1.3em;\n    }\n    .brand h1 { margin: 0; font-size: 1.4em; color: #1e293b; }\n    nav ul { display: flex; gap: 25px; list-style: none; margin: 0; padding: 0; }\n    nav a { text-decoration: none; color: #475569; font-weight: 500; transition: color 0.2s; }\n    nav a:hover { color: #f59e0b; }\n    .header-actions { display: flex; align-items: center; gap: 15px; }\n    .search-form input {\n      padding: 7px 12px; border: 1px solid #d1d5db; border-radius: 4px;\n    }\n    .search-form button {\n      padding: 7px 14px; background: #f59e0b; color: white;\n      border: none; border-radius: 4px; cursor: pointer;\n    }\n    .cart-link { text-decoration: none; color: #1e293b; font-size: 1.2em; }\n  </style>\n</head>\n<body>\n  <header class=\"site-header\">\n    <div class=\"brand\">\n      <div class=\"logo-placeholder\">S</div>\n      <h1>ShopZone</h1>\n    </div>\n    <nav aria-label=\"Main navigation\">\n      <ul>\n        <li><a href=\"#\">Home</a></li>\n        <li><a href=\"#\">Shop</a></li>\n        <li><a href=\"#\">Deals</a></li>\n        <li><a href=\"#\">Support</a></li>\n      </ul>\n    </nav>\n    <div class=\"header-actions\">\n      <form class=\"search-form\" role=\"search\">\n        <input type=\"search\" placeholder=\"Search products...\">\n        <button type=\"submit\">Search</button>\n      </form>\n      <a href=\"#\" class=\"cart-link\">🛒 Cart (0)</a>\n    </div>\n  </header>\n  <main style=\"padding: 40px;\">\n    <p>Welcome to ShopZone! Browse our amazing products.</p>\n  </main>\n</body>\n</html>"
  },
  "hard": {
    "title": "Multi-Level Header with Mega Menu and Sticky Behavior",
    "description": "Create a complex page header with: a top bar (announcement bar), a main header bar with logo, search, and user actions (login/signup), a navigation bar with a mega menu (dropdown with columns), and sticky behavior so the main nav sticks to the top on scroll. Use CSS for all styling and layout. The header must be fully responsive — collapse into a hamburger menu on mobile (use simple CSS checkbox hack).",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Mega Store</title>\n  <style>\n    /* Challenge: Build a complete multi-level header */\n  </style>\n</head>\n<body>\n  <!-- Build your header here -->\n  <main>\n    <p>Page content here.</p>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Mega Store</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: 'Segoe UI', sans-serif; }\n\n    /* Top announcement bar */\n    .top-bar {\n      background: #1e293b; color: #f8fafc; text-align: center;\n      padding: 8px; font-size: 0.85em;\n    }\n    .top-bar a { color: #3b82f6; }\n\n    /* Main header */\n    .main-header {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 12px 40px; background: #fff;\n      border-bottom: 1px solid #e5e7eb;\n    }\n    .main-header .logo { font-size: 1.5em; font-weight: 800; color: #1e293b; }\n    .main-header .search-bar input {\n      padding: 8px 16px; width: 300px; border: 2px solid #e5e7eb;\n      border-radius: 6px; font-size: 14px;\n    }\n    .main-header .user-actions { display: flex; gap: 12px; }\n    .main-header .user-actions a {\n      text-decoration: none; padding: 8px 16px; border-radius: 6px;\n      font-weight: 500; font-size: 14px;\n    }\n    .main-header .user-actions .login { color: #475569; }\n    .main-header .user-actions .signup {\n      background: #3b82f6; color: white;\n    }\n\n    /* Sticky navigation */\n    .nav-bar {\n      background: #1e293b; position: sticky; top: 0; z-index: 100;\n    }\n    .nav-bar > ul {\n      display: flex; list-style: none; padding: 0 40px; margin: 0;\n    }\n    .nav-bar > ul > li { position: relative; }\n    .nav-bar > ul > li > a {\n      display: block; padding: 14px 20px; color: #cbd5e1;\n      text-decoration: none; font-weight: 500; transition: color 0.2s;\n    }\n    .nav-bar > ul > li > a:hover { color: white; }\n\n    /* Mega menu dropdown */\n    .mega-menu {\n      display: none; position: absolute; top: 100%; left: 0;\n      background: white; box-shadow: 0 8px 20px rgba(0,0,0,0.15);\n      border-radius: 0 0 8px 8px; padding: 25px;\n      grid-template-columns: repeat(3, 200px); gap: 30px;\n      min-width: 700px;\n    }\n    .nav-bar > ul > li:hover .mega-menu { display: grid; }\n    .mega-menu .col h4 { color: #1e293b; margin-bottom: 10px; font-size: 0.9em; text-transform: uppercase; letter-spacing: 1px; }\n    .mega-menu .col a { display: block; padding: 5px 0; color: #64748b; text-decoration: none; font-size: 0.9em; }\n    .mega-menu .col a:hover { color: #3b82f6; }\n\n    /* Hamburger (responsive) */\n    .menu-toggle { display: none; }\n    .hamburger { display: none; cursor: pointer; padding: 14px 20px; color: #cbd5e1; font-size: 1.3em; }\n\n    main { padding: 60px 40px; min-height: 1200px; background: #f8fafc; }\n    main h2 { margin-bottom: 20px; }\n    main p { line-height: 1.8; color: #475569; margin-bottom: 16px; }\n\n    @media (max-width: 768px) {\n      .hamburger { display: block; }\n      .main-header { flex-wrap: wrap; gap: 10px; padding: 12px 20px; }\n      .main-header .search-bar input { width: 100%; }\n      #menu-toggle:checked ~ .nav-bar ul { display: flex; }\n      .nav-bar > ul {\n        display: none; flex-direction: column; padding: 0;\n      }\n      .mega-menu {\n        position: static; display: none !important; grid-template-columns: 1fr;\n        min-width: auto; box-shadow: none; padding: 10px 20px;\n      }\n      .nav-bar > ul > li:hover .mega-menu { display: grid !important; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"top-bar\">\n    🎉 Free shipping on orders over $50! <a href=\"#\">Shop Now</a>\n  </div>\n\n  <div class=\"main-header\">\n    <div class=\"logo\">📦 MegaStore</div>\n    <div class=\"search-bar\">\n      <input type=\"search\" placeholder=\"Search thousands of products...\">\n    </div>\n    <div class=\"user-actions\">\n      <a href=\"#\" class=\"login\">Log In</a>\n      <a href=\"#\" class=\"signup\">Sign Up</a>\n    </div>\n  </div>\n\n  <input type=\"checkbox\" id=\"menu-toggle\" class=\"menu-toggle\" hidden>\n  <label for=\"menu-toggle\" class=\"hamburger\">☰ Menu</label>\n\n  <nav class=\"nav-bar\" aria-label=\"Main navigation\">\n    <ul>\n      <li><a href=\"#\">Home</a></li>\n      <li>\n        <a href=\"#\">Electronics</a>\n        <div class=\"mega-menu\">\n          <div class=\"col\">\n            <h4>Computers</h4>\n            <a href=\"#\">Laptops</a>\n            <a href=\"#\">Desktops</a>\n            <a href=\"#\">Tablets</a>\n            <a href=\"#\">Monitors</a>\n          </div>\n          <div class=\"col\">\n            <h4>Audio</h4>\n            <a href=\"#\">Headphones</a>\n            <a href=\"#\">Speakers</a>\n            <a href=\"#\">Earbuds</a>\n            <a href=\"#\">Microphones</a>\n          </div>\n          <div class=\"col\">\n            <h4>Accessories</h4>\n            <a href=\"#\">Keyboards</a>\n            <a href=\"#\">Mice</a>\n            <a href=\"#\">Cables</a>\n            <a href=\"#\">Chargers</a>\n          </div>\n        </div>\n      </li>\n      <li>\n        <a href=\"#\">Clothing</a>\n        <div class=\"mega-menu\">\n          <div class=\"col\">\n            <h4>Men</h4>\n            <a href=\"#\">Shirts</a>\n            <a href=\"#\">Pants</a>\n            <a href=\"#\">Jackets</a>\n          </div>\n          <div class=\"col\">\n            <h4>Women</h4>\n            <a href=\"#\">Dresses</a>\n            <a href=\"#\">Tops</a>\n            <a href=\"#\">Skirts</a>\n          </div>\n          <div class=\"col\">\n            <h4>Kids</h4>\n            <a href=\"#\">T-Shirts</a>\n            <a href=\"#\">Jeans</a>\n            <a href=\"#\">Shoes</a>\n          </div>\n        </div>\n      </li>\n      <li><a href=\"#\">Deals</a></li>\n      <li><a href=\"#\">Support</a></li>\n    </ul>\n  </nav>\n\n  <main>\n    <h2>Welcome to MegaStore</h2>\n    <p>Scroll down to see the sticky navigation bar effect. The main navigation sticks to the top of the viewport when you scroll past it.</p>\n    <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>\n  </main>\n</body>\n</html>"
  }
}
