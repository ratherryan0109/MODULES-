{
  "easy": {
    "title": "Add a Favicon to Your Website",
    "description": "Take any existing HTML page and add a proper favicon. Create or download a simple square icon (use an SVG or PNG), add the correct <link> tag in the <head>, and verify it appears in the browser tab.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Page with Favicon</title>\n  <!-- Add your favicon link here -->\n</head>\n<body>\n  <h1>Check the browser tab!</h1>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Page with Favicon</title>\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232563eb'/><text y='.8em' font-size='70' text-anchor='middle' x='50' fill='white' font-weight='bold'>M</text></svg>\">\n</head>\n<body>\n  <h1>Check the browser tab — you should see a blue 'M' icon!</h1>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Complete Favicon Pack",
    "description": "Generate a complete favicon set for a fictional brand called 'DevStudio'. Create SVG, PNG (16×16 and 32×32), Apple touch icon (180×180), and a web manifest. Write the HTML head section with all necessary link and meta tags.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>DevStudio</title>\n  <!-- Add all favicon links here -->\n</head>\n<body>\n  <h1>DevStudio — Check all your devices!</h1>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>DevStudio</title>\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\">\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\">\n  <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\">\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon.png\">\n  <link rel=\"manifest\" href=\"/site.webmanifest\">\n  <meta name=\"msapplication-TileColor\" content=\"#2563eb\">\n  <meta name=\"msapplication-TileImage\" content=\"/mstile-144x144.png\">\n  <meta name=\"theme-color\" content=\"#ffffff\">\n\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; background: linear-gradient(135deg, #667eea, #764ba2); color: white; text-align: center; padding: 20px; }\n    h1 { font-size: 2.5em; }\n  </style>\n</head>\n<body>\n  <h1>DevStudio — Check your browser tab, bookmark, and mobile home screen!</h1>\n</body>\n</html>"
  },
  "hard": {
    "title": "Create a Dynamic Favicon System",
    "description": "Build a page that dynamically changes its favicon based on user interaction or page state. Use JavaScript to switch between multiple favicons (e.g., a notification badge counter, dark/light mode toggle, or status indicator).",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dynamic Favicon</title>\n  <link id=\"favicon\" rel=\"icon\" type=\"image/svg+xml\" href=\"\">\n</head>\n<body>\n  <h1>Dynamic Favicon Demo</h1>\n  <button onclick=\"changeFavicon()\">Change Favicon</button>\n  <script>\n    // Add JavaScript to change favicon dynamically\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dynamic Favicon</title>\n  <link id=\"favicon\" rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='80'>⚪</text></svg>\">\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: #f0f2f5; gap: 20px; }\n    h1 { color: #1a1a2e; }\n    .controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }\n    button { padding: 12px 24px; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; transition: transform 0.2s; }\n    button:hover { transform: translateY(-2px); }\n    .status { font-size: 14px; color: #666; }\n    .badge-input { padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; width: 80px; text-align: center; }\n  </style>\n</head>\n<body>\n  <h1>Dynamic Favicon Demo</h1>\n  <p>See the browser tab icon change based on your actions!</p>\n  <div class=\"controls\">\n    <button onclick=\"setFaviconEmoji('✅')\" style=\"background:#2ecc71;color:white;\">Success</button>\n    <button onclick=\"setFaviconEmoji('❌')\" style=\"background:#e74c3c;color:white;\">Error</button>\n    <button onclick=\"setFaviconEmoji('⚡')\" style=\"background:#f39c12;color:white;\">Alert</button>\n    <button onclick=\"setFaviconEmoji('🔔')\" style=\"background:#3498db;color:white;\">Notification</button>\n    <button onclick=\"resetFavicon()\" style=\"background:#95a5a6;color:white;\">Reset</button>\n  </div>\n  <div style=\"margin-top:20px;\">\n    <p>Notification Badge: <input type=\"number\" id=\"badgeCount\" class=\"badge-input\" value=\"3\" min=\"0\" max=\"99\"></p>\n    <button onclick=\"setBadge()\" style=\"background:#9b59b6;color:white;margin-top:10px;\">Set Badge</button>\n  </div>\n  <p class=\"status\" id=\"status\">Current favicon: ⚪</p>\n\n  <script>\n    function setFaviconEmoji(emoji) {\n      const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='80'>${emoji}</text></svg>`;\n      document.getElementById('favicon').href = 'data:image/svg+xml,' + encodeURIComponent(svg);\n      document.getElementById('status').textContent = `Current favicon: ${emoji}`;\n    }\n\n    function resetFavicon() {\n      setFaviconEmoji('⚪');\n    }\n\n    function setBadge() {\n      const count = document.getElementById('badgeCount').value;\n      const displayCount = count > 0 ? count : '';\n      const svgCount = count > 0 ? count : '';\n      const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>\n        <text y='.8em' font-size='70'>🔔</text>\n        ${count > 0 ? `<rect x='50' y='5' width='45' height='30' rx='15' fill='#e74c3c'/>\n        <text x='72' y='26' font-size='20' fill='white' text-anchor='middle' font-weight='bold'>${displayCount}</text>` : ''}\n      </svg>`;\n      document.getElementById('favicon').href = 'data:image/svg+xml,' + encodeURIComponent(svg);\n      document.getElementById('status').textContent = `Notification badge: ${count}`;\n    }\n\n    // Change favicon when page visibility changes (simulate tab switch)\n    document.addEventListener('visibilitychange', () => {\n      if (document.hidden) {\n        setFaviconEmoji('💤');\n      } else {\n        setFaviconEmoji('👋');\n        setTimeout(() => resetFavicon(), 2000);\n      }\n    });\n  </script>\n</body>\n</html>"
  }
}
