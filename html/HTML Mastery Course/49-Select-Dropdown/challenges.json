{
  "easy": {
    "title": "Country-Selector Dropdown",
    "description": "Create a country selector with optgroups for continents, a placeholder option, and a live display of the selected country's code and name.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build a select with country options grouped by continent -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Countries</title><style>body{font-family:system-ui;max-width:400px;margin:40px auto;padding:20px;}select{width:100%;padding:10px;border:2px solid #ddd;border-radius:6px;font-size:15px;}button{margin-top:12px;padding:10px 20px;background:#4a6cf7;color:white;border:none;border-radius:6px;cursor:pointer;}.output{margin-top:12px;padding:12px;background:#f0f4ff;border-radius:6px;font-family:monospace;}</style></head>\n<body>\n  <form onsubmit=\"event.preventDefault();\">\n    <label for=\"country\">Choose a country:</label>\n    <select id=\"country\" onchange=\"document.getElementById('show').textContent = 'Value: ' + this.value + ', Text: ' + this.options[this.selectedIndex].text\">\n      <option value=\"\">— Select a country —</option>\n      <optgroup label=\"North America\"><option value=\"US\">United States</option><option value=\"CA\">Canada</option><option value=\"MX\">Mexico</option></optgroup>\n      <optgroup label=\"Europe\"><option value=\"UK\">United Kingdom</option><option value=\"DE\">Germany</option><option value=\"FR\">France</option></optgroup>\n      <optgroup label=\"Asia\"><option value=\"JP\">Japan</option><option value=\"CN\">China</option><option value=\"IN\">India</option></optgroup>\n    </select>\n    <div class=\"output\" id=\"show\">Select a country...</div>\n  </form>\n</body>\n</html>"
  },
  "medium": {
    "title": "Dynamic Cascading Selects",
    "description": "Build three-level cascading selects: Category → Subcategory → Item. Populate each level dynamically based on the previous selection. Disable unselected levels.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build three-level cascading selects -->\n  <script>\n    const data = {};\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Cascading Selects</title><style>body{font-family:system-ui;max-width:500px;margin:40px auto;padding:20px;}select{width:100%;padding:10px;margin-bottom:12px;border:2px solid #ddd;border-radius:6px;font-size:15px;}label{font-weight:600;display:block;margin-bottom:4px;}.output{padding:12px;background:#f0f4ff;border-radius:6px;margin-top:12px;}</style></head>\n<body>\n  <form onsubmit=\"event.preventDefault(); show('o','Selected: ' + document.getElementById('item').value)\">\n    <label for=\"category\">Category</label>\n    <select id=\"category\" onchange=\"updateSub()\"><option value=\"\">Select category</option></select>\n    <label for=\"subcategory\">Subcategory</label>\n    <select id=\"subcategory\" onchange=\"updateItem()\" disabled><option value=\"\">Select category first</option></select>\n    <label for=\"item\">Item</label>\n    <select id=\"item\" disabled><option value=\"\">Select subcategory first</option></select>\n    <button type=\"submit\" style=\"padding:10px 20px;background:#4a6cf7;color:white;border:none;border-radius:6px;cursor:pointer;\">Submit</button>\n    <div class=\"output\" id=\"o\">Selection will appear here...</div>\n  </form>\n  <script>\n    const data = {\n      electronics: { label:'Electronics', subs: { phones:{ label:'Phones', items:['iPhone','Samsung','Pixel'] }, laptops:{ label:'Laptops', items:['MacBook','ThinkPad','Surface'] }}},\n      clothing: { label:'Clothing', subs: { men:{ label:'Men', items:['Shirts','Pants','Jackets'] }, women:{ label:'Women', items:['Dresses','Skirts','Blouses'] }}}\n    };\n    const cat = document.getElementById('category');\n    const sub = document.getElementById('subcategory');\n    const item = document.getElementById('item');\n    Object.entries(data).forEach(([k,v]) => cat.innerHTML += `<option value=\"${k}\">${v.label}</option>`);\n    function updateSub() {\n      sub.innerHTML = '<option value=\"\">Select subcategory</option>';\n      item.innerHTML = '<option value=\"\">Select subcategory first</option>';\n      item.disabled = true;\n      if (!cat.value) { sub.disabled = true; return; }\n      sub.disabled = false;\n      Object.entries(data[cat.value].subs).forEach(([k,v]) => sub.innerHTML += `<option value=\"${k}\">${v.label}</option>`);\n    }\n    function updateItem() {\n      item.innerHTML = '<option value=\"\">Select item</option>';\n      if (!sub.value) { item.disabled = true; return; }\n      item.disabled = false;\n      data[cat.value].subs[sub.value].items.forEach(i => item.innerHTML += `<option value=\"${i.toLowerCase()}\">${i}</option>`);\n    }\n    function show(id, msg) { document.getElementById(id).textContent = msg; }\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Custom VirtualSelect Component",
    "description": "Build a custom select component that: supports search/filter, keyboard navigation, multi-select with chips/tags, option groups, custom dropdown rendering with icons, and virtual scrolling for 10,000+ options. Make it fully accessible with ARIA.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build a custom select component with search and virtual scrolling -->\n  <script>\n    // Implement VirtualSelect\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>VirtualSelect</title><style>*{box-sizing:border-box;margin:0;padding:0;}body{font-family:system-ui;background:#1a1a2e;padding:30px;color:#eee;}.app{max-width:500px;margin:0 auto;}.vs-container{position:relative;}.vs-trigger{width:100%;padding:12px 16px;background:#16213e;border:2px solid #2a3a5e;border-radius:8px;color:#eee;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-size:15px;}.vs-trigger:focus{border-color:#4fc3f7;}.vs-trigger .arrow{transition:transform 0.3s;}.vs-trigger.open .arrow{transform:rotate(180deg);}.vs-dropdown{display:none;position:absolute;top:100%;left:0;right:0;max-height:300px;background:#16213e;border:1px solid #2a3a5e;border-radius:8px;margin-top:4px;overflow:auto;z-index:100;}.vs-dropdown.open{display:block;}.vs-search{width:100%;padding:10px 14px;border:none;border-bottom:1px solid #2a3a5e;background:#0f3460;color:#eee;font-size:14px;}.vs-search:focus{outline:none;}.vs-option{padding:10px 14px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:background 0.2s;font-size:14px;}.vs-option:hover,.vs-option.highlighted{background:#0f3460;}.vs-option.selected{background:#1a3a6e;color:#4fc3f7;}.vs-option .check{width:18px;text-align:center;}.vs-chips{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px;}.chip{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:#0f3460;border-radius:20px;font-size:12px;}.chip .remove{cursor:pointer;color:#e74c3c;margin-left:4px;font-weight:700;}.count{font-size:12px;color:#718096;margin-top:8px;}</style></head>\n<body>\n  <div class=\"app\">\n    <h2 style=\"margin-bottom:16px;\">VirtualSelect Demo</h2>\n    <div id=\"vs1\"></div>\n    <div class=\"count\" id=\"count\">0 selected</div>\n  </div>\n  <script>\n    class VirtualSelect {\n      constructor(containerId, options) {\n        this.container = document.getElementById(containerId);\n        this.allOptions = options;\n        this.selected = new Set();\n        this.highlightedIdx = 0;\n        this.open = false;\n        this.render();\n      }\n      render() {\n        this.container.innerHTML = '';\n        this.container.className = 'vs-container';\n        const trigger = document.createElement('div');\n        trigger.className = 'vs-trigger';\n        trigger.tabIndex = 0;\n        trigger.innerHTML = '<span id=\"vsLabel\">Select countries...</span><span class=\"arrow\">▼</span>';\n        trigger.onclick = () => this.toggle();\n        trigger.onkeydown = (e) => { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); this.toggle(); }};\n        this.container.appendChild(trigger);\n        const dropdown = document.createElement('div');\n        dropdown.className = 'vs-dropdown';\n        const search = document.createElement('input');\n        search.className = 'vs-search';\n        search.placeholder = 'Search...';\n        search.oninput = () => this.filter(search.value);\n        dropdown.appendChild(search);\n        this.listEl = document.createElement('div');\n        dropdown.appendChild(this.listEl);\n        this.container.appendChild(dropdown);\n        this.chipsEl = document.createElement('div');\n        this.chipsEl.className = 'vs-chips';\n        this.container.appendChild(this.chipsEl);\n        this.filteredOptions = [...this.allOptions];\n        this.renderList();\n      }\n      toggle() {\n        this.open = !this.open;\n        this.container.querySelector('.vs-dropdown').classList.toggle('open', this.open);\n        this.container.querySelector('.vs-trigger').classList.toggle('open', this.open);\n        if (this.open) this.container.querySelector('.vs-search').focus();\n      }\n      filter(q) {\n        this.filteredOptions = this.allOptions.filter(o => o.label.toLowerCase().includes(q.toLowerCase()));\n        this.highlightedIdx = 0;\n        this.renderList();\n      }\n      renderList() {\n        this.listEl.innerHTML = '';\n        this.filteredOptions.forEach((opt, i) => {\n          const div = document.createElement('div');\n          div.className = 'vs-option' + (this.selected.has(opt.value) ? ' selected' : '') + (i === this.highlightedIdx ? ' highlighted' : '');\n          div.innerHTML = `<span class=\"check\">${this.selected.has(opt.value) ? '✓' : ''}</span><span>${opt.label}</span>`;\n          div.onclick = () => this.toggleOption(opt.value);\n          div.onmouseenter = () => { this.highlightedIdx = i; this.renderList(); };\n          this.listEl.appendChild(div);\n        });\n      }\n      toggleOption(val) {\n        if (this.selected.has(val)) this.selected.delete(val);\n        else this.selected.add(val);\n        this.renderList();\n        this.updateChips();\n        document.getElementById('count').textContent = this.selected.size + ' selected';\n      }\n      updateChips() {\n        this.chipsEl.innerHTML = '';\n        this.selected.forEach(val => {\n          const label = this.allOptions.find(o => o.value === val).label;\n          const chip = document.createElement('span');\n          chip.className = 'chip';\n          chip.innerHTML = `${label}<span class=\"remove\" data-val=\"${val}\">×</span>`;\n          chip.querySelector('.remove').onclick = (e) => { e.stopPropagation(); this.toggleOption(val); };\n          this.chipsEl.appendChild(chip);\n        });\n      }\n    }\n    const countries = [\n      {value:'us',label:'United States'},{value:'ca',label:'Canada'},{value:'uk',label:'United Kingdom'},\n      {value:'de',label:'Germany'},{value:'fr',label:'France'},{value:'jp',label:'Japan'},{value:'cn',label:'China'},\n      {value:'in',label:'India'},{value:'br',label:'Brazil'},{value:'au',label:'Australia'},{value:'mx',label:'Mexico'},\n      {value:'kr',label:'South Korea'},{value:'sg',label:'Singapore'},{value:'nl',label:'Netherlands'},{value:'se',label:'Sweden'}\n    ];\n    new VirtualSelect('vs1', countries);\n  </script>\n</body>\n</html>"
  }
}
