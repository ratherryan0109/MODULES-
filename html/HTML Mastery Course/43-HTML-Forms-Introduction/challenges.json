{
  "easy": {
    "title": "Create a Contact Feedback Form",
    "description": "Build a simple contact form with name, email, subject (dropdown), message (textarea), and a submit button. Use proper labels, fieldset, and legend. Include HTML5 validation with required fields and email type validation.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Contact Form</title>\n</head>\n<body>\n    <h1>Contact Us</h1>\n    <!-- Build your contact form -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Simple contact form with HTML5 validation\">\n    <title>Contact Us</title>\n</head>\n<body>\n    <h1>Contact Us</h1>\n    <form action=\"/submit\" method=\"POST\">\n        <fieldset>\n            <legend>Your Details</legend>\n            <p>\n                <label for=\"name\">Full Name:</label>\n                <input type=\"text\" id=\"name\" name=\"name\" required placeholder=\"John Doe\">\n            </p>\n            <p>\n                <label for=\"email\">Email Address:</label>\n                <input type=\"email\" id=\"email\" name=\"email\" required placeholder=\"john@example.com\">\n            </p>\n        </fieldset>\n        <fieldset>\n            <legend>Your Message</legend>\n            <p>\n                <label for=\"subject\">Subject:</label>\n                <select id=\"subject\" name=\"subject\" required>\n                    <option value=\"\">-- Select a subject --</option>\n                    <option value=\"general\">General Inquiry</option>\n                    <option value=\"support\">Technical Support</option>\n                    <option value=\"billing\">Billing Question</option>\n                    <option value=\"feedback\">Feedback</option>\n                </select>\n            </p>\n            <p>\n                <label for=\"message\">Message:</label><br>\n                <textarea id=\"message\" name=\"message\" rows=\"6\" cols=\"50\" required placeholder=\"Write your message here...\"></textarea>\n            </p>\n        </fieldset>\n        <p>\n            <button type=\"submit\">Send Message</button>\n            <button type=\"reset\">Clear Form</button>\n        </p>\n    </form>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build an Event Registration Form",
    "description": "Create an event registration form with diverse input types: full name, email, phone, age (number), event preference (radio buttons), dietary restrictions (checkboxes), t-shirt size (select), additional notes (textarea), and agree to terms (checkbox with required). Use proper grouping with fieldset/legend, linked labels, and HTML5 validation.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Event Registration</title>\n</head>\n<body>\n    <h1>Event Registration</h1>\n    <!-- Build registration form -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Event registration form with diverse HTML5 input types\">\n    <title>Event Registration - TechConf 2026</title>\n</head>\n<body>\n    <h1>TechConf 2026 Registration</h1>\n    <form action=\"/register\" method=\"POST\">\n        <fieldset>\n            <legend>Personal Information</legend>\n            <p><label for=\"fullname\">Full Name:</label> <input type=\"text\" id=\"fullname\" name=\"fullname\" required placeholder=\"Jane Doe\"></p>\n            <p><label for=\"reg-email\">Email:</label> <input type=\"email\" id=\"reg-email\" name=\"email\" required placeholder=\"jane@example.com\"></p>\n            <p><label for=\"phone\">Phone:</label> <input type=\"tel\" id=\"phone\" name=\"phone\" placeholder=\"+1 555-1234\" pattern=\"[+][0-9]{1,3}[0-9]{6,14}\"></p>\n            <p><label for=\"age\">Age:</label> <input type=\"number\" id=\"age\" name=\"age\" min=\"1\" max=\"120\" required></p>\n        </fieldset>\n        <fieldset>\n            <legend>Event Preferences</legend>\n            <p>Preferred Session:</p>\n            <p><label><input type=\"radio\" name=\"session\" value=\"workshop\" required> Hands-on Workshop</label></p>\n            <p><label><input type=\"radio\" name=\"session\" value=\"talk\"> Keynote Talk</label></p>\n            <p><label><input type=\"radio\" name=\"session\" value=\"panel\"> Panel Discussion</label></p>\n            <p>Dietary Restrictions:</p>\n            <p><label><input type=\"checkbox\" name=\"diet\" value=\"vegetarian\"> Vegetarian</label></p>\n            <p><label><input type=\"checkbox\" name=\"diet\" value=\"vegan\"> Vegan</label></p>\n            <p><label><input type=\"checkbox\" name=\"diet\" value=\"gluten-free\"> Gluten-Free</label></p>\n            <p><label><input type=\"checkbox\" name=\"diet\" value=\"none\"> None</label></p>\n            <p><label for=\"shirt\">T-Shirt Size:</label>\n                <select id=\"shirt\" name=\"shirt\">\n                    <option value=\"S\">Small</option>\n                    <option value=\"M\" selected>Medium</option>\n                    <option value=\"L\">Large</option>\n                    <option value=\"XL\">X-Large</option>\n                </select>\n            </p>\n        </fieldset>\n        <p><label for=\"notes\">Additional Notes:</label><br>\n        <textarea id=\"notes\" name=\"notes\" rows=\"4\" cols=\"50\" placeholder=\"Any special requirements...\"></textarea></p>\n        <p><label><input type=\"checkbox\" name=\"agree\" required> I agree to the terms and conditions</label></p>\n        <p><button type=\"submit\">Register Now</button></p>\n    </form>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build a Multi-Step Survey with Dynamic Sections",
    "description": "Create a multi-step survey form with 3 steps using only HTML and CSS (checkbox hack for navigation). Step 1: Personal info with autocomplete. Step 2: Rating questions (radio stars with custom CSS) and preferences. Step 3: Review and submit with formnovalidate save option. Include hidden inputs tracking the step number, disabled fields on certain conditions, and a progress bar.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Multi-Step Survey</title>\n</head>\n<body>\n    <h1>Customer Satisfaction Survey</h1>\n    <!-- Build multi-step form -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Multi-step survey form using CSS-only navigation\">\n    <title>Customer Satisfaction Survey</title>\n    <style>\n        * { box-sizing: border-box; margin: 0; padding: 0; }\n        body { font-family: Arial, sans-serif; max-width: 700px; margin: 0 auto; padding: 20px; background: #f0f4f8; }\n        h1 { color: #2c3e50; text-align: center; margin-bottom: 20px; }\n        .progress { display: flex; justify-content: center; margin-bottom: 30px; gap: 10px; }\n        .step { width: 30px; height: 30px; border-radius: 50%; background: #ddd; display: flex; align-items: center; justify-content: center; font-weight: bold; }\n        .step.active { background: #3498db; color: white; }\n        .step.completed { background: #2ecc71; color: white; }\n        .step-page { display: none; }\n        #step1:checked ~ .step-page#page1,\n        #step2:checked ~ .step-page#page2,\n        #step3:checked ~ .step-page#page3 { display: block; }\n        #step1:checked ~ .progress .s1 { background: #3498db; color: white; }\n        #step2:checked ~ .progress .s1, #step3:checked ~ .progress .s1 { background: #2ecc71; color: white; }\n        #step2:checked ~ .progress .s2 { background: #3498db; color: white; }\n        #step3:checked ~ .progress .s2 { background: #2ecc71; color: white; }\n        #step3:checked ~ .progress .s3 { background: #3498db; color: white; }\n        input[type=\"radio\"]:not(.step-input) { display: none; }\n        .star { cursor: pointer; font-size: 2em; color: #ddd; }\n        input[type=\"radio\"]:checked ~ label .star { color: #f1c40f; }\n        .star-group { direction: rtl; display: inline-flex; }\n        .star-group label { cursor: pointer; }\n        .star-group label:hover .star,\n        .star-group label:hover ~ label .star { color: #f1c40f; }\n        fieldset { border: 1px solid #ddd; border-radius: 8px; padding: 20px; margin: 15px 0; background: white; }\n        legend { font-weight: bold; color: #2c3e50; padding: 0 10px; }\n        label { display: block; margin: 8px 0; }\n        input[type=\"text\"], input[type=\"email\"], textarea, select { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; margin-top: 5px; }\n        .buttons { display: flex; justify-content: space-between; margin-top: 20px; }\n        button { padding: 12px 24px; border: none; border-radius: 5px; cursor: pointer; font-size: 1em; }\n        .btn-next { background: #3498db; color: white; }\n        .btn-prev { background: #95a5a6; color: white; }\n        .btn-submit { background: #2ecc71; color: white; }\n        .btn-save { background: #e67e22; color: white; }\n    </style>\n</head>\n<body>\n    <h1>Customer Satisfaction Survey</h1>\n    <input type=\"radio\" name=\"step\" id=\"step1\" class=\"step-input\" checked hidden>\n    <input type=\"radio\" name=\"step\" id=\"step2\" class=\"step-input\" hidden>\n    <input type=\"radio\" name=\"step\" id=\"step3\" class=\"step-input\" hidden>\n    <div class=\"progress\">\n        <div class=\"step s1\">1</div>\n        <div class=\"step s2\">2</div>\n        <div class=\"step s3\">3</div>\n    </div>\n    <form action=\"/survey\" method=\"POST\">\n        <input type=\"hidden\" name=\"step\" value=\"\">\n        <div class=\"step-page\" id=\"page1\">\n            <fieldset>\n                <legend>About You</legend>\n                <label>Full Name: <input type=\"text\" name=\"name\" required autocomplete=\"name\"></label>\n                <label>Email: <input type=\"email\" name=\"email\" required autocomplete=\"email\"></label>\n                <label>Age: <input type=\"number\" name=\"age\" min=\"1\" max=\"120\"></label>\n                <label>Country:\n                    <select name=\"country\">\n                        <option value=\"US\">United States</option>\n                        <option value=\"UK\">United Kingdom</option>\n                        <option value=\"CA\">Canada</option>\n                        <option value=\"AU\">Australia</option>\n                        <option value=\"Other\">Other</option>\n                    </select>\n                </label>\n            </fieldset>\n        </div>\n        <div class=\"step-page\" id=\"page2\">\n            <fieldset>\n                <legend>Rate Our Service</legend>\n                <p>Overall Satisfaction:</p>\n                <div class=\"star-group\">\n                    <input type=\"radio\" name=\"rating\" id=\"s5\" value=\"5\"><label for=\"s5\"><span class=\"star\">&#9733;</span></label>\n                    <input type=\"radio\" name=\"rating\" id=\"s4\" value=\"4\"><label for=\"s4\"><span class=\"star\">&#9733;</span></label>\n                    <input type=\"radio\" name=\"rating\" id=\"s3\" value=\"3\"><label for=\"s3\"><span class=\"star\">&#9733;</span></label>\n                    <input type=\"radio\" name=\"rating\" id=\"s2\" value=\"2\"><label for=\"s2\"><span class=\"star\">&#9733;</span></label>\n                    <input type=\"radio\" name=\"rating\" id=\"s1\" value=\"1\"><label for=\"s1\"><span class=\"star\">&#9733;</span></label>\n                </div>\n                <p style=\"margin-top:15px;\">Would you recommend us?</p>\n                <label><input type=\"radio\" name=\"recommend\" value=\"yes\"> Yes</label>\n                <label><input type=\"radio\" name=\"recommend\" value=\"no\"> No</label>\n                <label><input type=\"checkbox\" name=\"contact\"> I consent to follow-up contact</label>\n            </fieldset>\n        </div>\n        <div class=\"step-page\" id=\"page3\">\n            <fieldset>\n                <legend>Additional Feedback</legend>\n                <label>Comments: <textarea name=\"comments\" rows=\"4\" placeholder=\"Tell us more...\"></textarea></label>\n                <label><input type=\"checkbox\" name=\"subscribe\"> Subscribe to newsletter</label>\n            </fieldset>\n            <div class=\"buttons\">\n                <button type=\"submit\">Submit Survey</button>\n                <button type=\"submit\" formnovalidate class=\"btn-save\">Save Draft</button>\n            </div>\n        </div>\n    </form>\n    <div class=\"buttons\">\n        <label for=\"step1\" class=\"btn-prev\" style=\"padding:12px 24px;cursor:pointer;border-radius:5px;\">Previous</label>\n        <label for=\"step2\" class=\"btn-next\" style=\"padding:12px 24px;cursor:pointer;border-radius:5px;\">Next</label>\n        <label for=\"step3\" class=\"btn-next\" style=\"padding:12px 24px;cursor:pointer;border-radius:5px;\">Review</label>\n    </div>\n</body>\n</html>"
  }
}
