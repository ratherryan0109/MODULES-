{
  "easy": {
    "title": "Embed a Google Map with a Responsive Iframe",
    "description": "Create an HTML page that embeds a Google Map location using an iframe. The iframe must be fully responsive (maintains aspect ratio on all screen sizes), has a proper title for accessibility, uses privacy-friendly settings, and provides fallback text.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Map Embed</title>\n</head>\n<body>\n  <h1>Our Location</h1>\n  <!-- Add your responsive map embed here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Map Embed</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 800px; margin: 40px auto; padding: 0 20px; }\n    .map-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }\n    .map-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }\n  </style>\n</head>\n<body>\n  <h1>Our Location</h1>\n  <p>Visit us at our office:</p>\n  <div class=\"map-wrap\">\n    <iframe \n      src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.966309591935!2d-73.9855!3d40.7484!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDQ0JzU0LjIiTiA3M8KwNTknMDcuOSJX!5e0!3m2!1sen!2sus!4v1\"\n      title=\"Google Map of our office location\"\n      allowfullscreen\n      loading=\"lazy\">\n      <p>Your browser does not support iframes. <a href=\"https://maps.google.com\">View on Google Maps</a></p>\n    </iframe>\n  </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "Interactive Iframe Chat Using postMessage",
    "description": "Build a two-way chat application where a parent page and an iframe communicate using postMessage. The parent has a list of predefined questions (buttons), and the iframe responds with answers. Both sides show a chat history. Include origin validation and a typing indicator.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Iframe Chat</title>\n</head>\n<body>\n  <div class=\"parent-chat\">\n    <div class=\"messages\" id=\"parentMessages\"></div>\n    <div class=\"questions\">\n      <button onclick=\"ask('What is your name?')\">What is your name?</button>\n      <button onclick=\"ask('What time is it?')\">What time is it?</button>\n      <button onclick=\"ask('Tell me a joke')\">Tell me a joke</button>\n    </div>\n  </div>\n  <iframe id=\"chatFrame\" srcdoc=\"<!-- iframe content -->\"></iframe>\n  <script>\n    // postMessage logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Iframe Chat</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; background: #1a1a2e; color: white; }\n    h1 { color: #6C63FF; }\n    .chat-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n    @media (max-width: 600px) { .chat-container { grid-template-columns: 1fr; } }\n    .chat-panel { background: #16213e; border-radius: 12px; padding: 16px; }\n    .chat-panel h3 { margin-bottom: 10px; font-size: 14px; color: rgba(255,255,255,0.6); }\n    .messages { height: 250px; overflow-y: auto; margin-bottom: 10px; padding: 8px; background: rgba(0,0,0,0.2); border-radius: 8px; }\n    .messages::-webkit-scrollbar { width: 4px; }\n    .messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 2px; }\n    .msg { margin: 6px 0; padding: 8px 12px; border-radius: 12px; font-size: 13px; max-width: 85%; }\n    .msg.sent { background: #6C63FF; margin-left: auto; text-align: right; }\n    .msg.received { background: rgba(255,255,255,0.1); }\n    .questions { display: flex; flex-direction: column; gap: 6px; }\n    .questions button { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 8px 12px; border-radius: 8px; cursor: pointer; font-size: 12px; text-align: left; transition: 0.2s; }\n    .questions button:hover { background: #6C63FF; border-color: #6C63FF; }\n    .typing { font-size: 12px; color: rgba(255,255,255,0.4); font-style: italic; display: none; }\n    iframe { width: 100%; height: 380px; border: none; border-radius: 12px; background: #16213e; }\n  </style>\n</head>\n<body>\n  <h1>Iframe Chat</h1>\n  <p style=\"margin-bottom:16px;font-size:14px;color:rgba(255,255,255,0.5);\">Click a question to send it to the iframe via postMessage</p>\n  \n  <div class=\"chat-container\">\n    <div class=\"chat-panel\">\n      <h3>🗣 Parent (You)</h3>\n      <div class=\"messages\" id=\"parentMessages\"></div>\n      <div class=\"questions\">\n        <button onclick=\"ask('What is your name?')\">❓ What is your name?</button>\n        <button onclick=\"ask('What time is it?')\">⏰ What time is it?</button>\n        <button onclick=\"ask('Tell me a joke')\">😂 Tell me a joke</button>\n        <button onclick=\"ask('What color is the sky?')\">🌈 What color is the sky?</button>\n        <button onclick=\"ask('What is 2+2?')\">🔢 What is 2+2?</button>\n      </div>\n      <div class=\"typing\" id=\"typingIndicator\">Iframe is typing...</div>\n    </div>\n    <div>\n      <iframe id=\"chatFrame\" srcdoc=\"\n        <style>\n          body{font-family:system-ui,sans-serif;background:#16213e;color:white;padding:12px;margin:0;}\n          h3{font-size:14px;color:rgba(255,255,255,0.6);margin-bottom:10px;}\n          .messages{height:200px;overflow-y:auto;padding:8px;background:rgba(0,0,0,0.2);border-radius:8px;}\n          .messages::-webkit-scrollbar{width:4px;}\n          .messages::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.2);border-radius:2px;}\n          .msg{margin:6px 0;padding:8px 12px;border-radius:12px;font-size:13px;max-width:85%;}\n          .msg.sent{background:#6C63FF;margin-left:auto;text-align:right;}\n          .msg.received{background:rgba(255,255,255,0.1);}\n          .typing{font-size:12px;color:rgba(255,255,255,0.4);font-style:italic;display:none;}\n          .quick-replies{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px;}\n          .quick-replies button{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;padding:4px 8px;border-radius:6px;cursor:pointer;font-size:11px;}\n        </style>\n        <h3>🤖 Iframe (Bot)</h3>\n        <div class='messages' id='iframeMessages'></div>\n        <div class='typing' id='iframeTyping'>Parent is typing...</div>\n        <div class='quick-replies'>\n          <button onclick='reply(\"Hello!\")'>Hello!</button>\n          <button onclick='reply(\"How are you?\")'>How are you?</button>\n          <button onclick='reply(\"I\\'m a bot\")'>I'm a bot</button>\n        </div>\n        <script>\n          function addMsg(text, type) {\n            const box = document.getElementById('iframeMessages');\n            const div = document.createElement('div');\n            div.className = 'msg ' + type;\n            div.textContent = text;\n            box.appendChild(div);\n            box.scrollTop = box.scrollHeight;\n          }\n          \n          const answers = {\n            'what is your name': 'My name is iFrame Bot! I was created with srcdoc.',\n            'what time is it': 'The current time is ' + new Date().toLocaleTimeString(),\n            'tell me a joke': 'Why do programmers prefer dark mode? Because light attracts bugs!',\n            'what color is the sky': 'The sky appears blue due to Rayleigh scattering of sunlight!',\n            'what is 2+2': '2 + 2 = 4. That was easy!',\n          };\n          \n          function reply(text) {\n            addMsg('You: ' + text, 'sent');\n            window.parent.postMessage({ type: 'chat', text: text, from: 'child' }, '*');\n          }\n          \n          window.addEventListener('message', function(e) {\n            const q = e.data.text.toLowerCase();\n            const typing = document.getElementById('iframeTyping');\n            typing.style.display = 'block';\n            addMsg('Parent: ' + e.data.text, 'received');\n            setTimeout(function() {\n              typing.style.display = 'none';\n              let answer = 'Interesting question! I don\\'t know how to answer that.';\n              for (const [key, val] of Object.entries(answers)) {\n                if (q.includes(key)) { answer = val; break; }\n              }\n              addMsg('🤖 ' + answer, 'sent');\n              window.parent.postMessage({ type: 'chat', text: answer, from: 'child' }, '*');\n            }, 1000 + Math.random() * 1500);\n          });\n          \n          addMsg('🤖 Hello! I am the iframe bot. Ask me something!', 'received');\n        <\\/script>\n      \" title=\"Chat iframe\"></iframe>\n    </div>\n  </div>\n\n  <script>\n    const chatFrame = document.getElementById('chatFrame');\n    const parentMessages = document.getElementById('parentMessages');\n    const typingIndicator = document.getElementById('typingIndicator');\n\n    function ask(question) {\n      addParentMsg('You: ' + question, 'sent');\n      typingIndicator.style.display = 'block';\n      chatFrame.contentWindow.postMessage({ type: 'chat', text: question, from: 'parent' }, '*');\n    }\n\n    function addParentMsg(text, type) {\n      const div = document.createElement('div');\n      div.className = 'msg ' + type;\n      div.textContent = text;\n      parentMessages.appendChild(div);\n      parentMessages.scrollTop = parentMessages.scrollHeight;\n    }\n\n    window.addEventListener('message', (e) => {\n      typingIndicator.style.display = 'none';\n      addParentMsg('🤖 ' + e.data.text, 'received');\n    });\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Multi-Frame Dashboard with Cross-Frame Communication",
    "description": "Build a dashboard page that contains 3 iframes (a clock, a calculator, and a todo list), all communicating with the parent via postMessage. The parent acts as a central hub, logging all actions, and providing a theme selector that broadcasts theme changes to all iframes using postMessage.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dashboard</title>\n</head>\n<body>\n  <div class=\"dashboard\">\n    <iframe id=\"clockFrame\" srcdoc=\"...\"></iframe>\n    <iframe id=\"calcFrame\" srcdoc=\"...\"></iframe>\n    <iframe id=\"todoFrame\" srcdoc=\"...\"></iframe>\n    <div class=\"log\"></div>\n  </div>\n  <script>\n    // Central communication hub\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Multi-Frame Dashboard</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; background: #0f0f14; color: white; margin: 0; padding: 20px; }\n    h1 { text-align: center; color: #6C63FF; margin-bottom: 20px; font-size: 22px; }\n    .dashboard { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 1000px; margin: 0 auto; }\n    @media (max-width: 700px) { .dashboard { grid-template-columns: 1fr; } }\n    .widget { background: #1a1a2e; border-radius: 12px; padding: 12px; border: 1px solid rgba(255,255,255,0.05); }\n    .widget h3 { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }\n    .widget iframe { width: 100%; height: 250px; border: none; border-radius: 8px; background: #16213e; }\n    .theme-bar { max-width: 1000px; margin: 20px auto; display: flex; justify-content: center; gap: 8px; }\n    .theme-bar button { padding: 8px 20px; border-radius: 20px; border: none; cursor: pointer; font-size: 13px; transition: 0.2s; }\n    .theme-bar button:hover { transform: scale(1.05); }\n    .log-panel { max-width: 1000px; margin: 16px auto; background: #1a1a2e; border-radius: 12px; padding: 16px; }\n    .log-panel h3 { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }\n    .log { max-height: 150px; overflow-y: auto; font-family: monospace; font-size: 12px; }\n    .log div { padding: 3px 0; color: rgba(255,255,255,0.6); }\n    .log div span.time { color: rgba(255,255,255,0.3); }\n  </style>\n</head>\n<body>\n  <h1>Multi-Frame Dashboard</h1>\n  \n  <div class=\"theme-bar\">\n    <button onclick=\"broadcastTheme('dark')\" style=\"background:#1a1a2e;color:white;border:1px solid rgba(255,255,255,0.2);\">🌙 Dark</button>\n    <button onclick=\"broadcastTheme('light')\" style=\"background:#ffffff;color:#333;\">☀️ Light</button>\n    <button onclick=\"broadcastTheme('neon')\" style=\"background:#00ff88;color:#0a0a1a;\">💚 Neon</button>\n    <button onclick=\"broadcastTheme('sunset')\" style=\"background:linear-gradient(90deg,#ff6b6b,#feca57);color:#fff;\">🌅 Sunset</button>\n  </div>\n\n  <div class=\"dashboard\">\n    <div class=\"widget\"><h3>⏰ Clock</h3><iframe id=\"clockFrame\" title=\"Clock widget\"></iframe></div>\n    <div class=\"widget\"><h3>🧮 Calculator</h3><iframe id=\"calcFrame\" title=\"Calculator widget\"></iframe></div>\n    <div class=\"widget\"><h3>📝 Todo List</h3><iframe id=\"todoFrame\" title=\"Todo list widget\"></iframe></div>\n  </div>\n\n  <div class=\"log-panel\">\n    <h3>📋 Activity Log</h3>\n    <div class=\"log\" id=\"activityLog\"></div>\n  </div>\n\n  <script>\n    const iframeSources = {\n      clockFrame: `\n        <style>\n          body{font-family:system-ui;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;margin:0;transition:all 0.5s;}\n          .clock{font-size:48px;font-weight:bold;font-variant-numeric:tabular-nums;}\n          .date{font-size:14px;margin-top:8px;opacity:0.6;}\n          .theme-msg{font-size:11px;margin-top:12px;opacity:0.3;}\n        </style>\n        <div class=\"clock\" id=\"clock\">00:00:00</div>\n        <div class=\"date\" id=\"date\">---</div>\n        <div class=\"theme-msg\" id=\"themeMsg\">Waiting for theme...</div>\n        <script>\n          function update() {\n            const now = new Date();\n            document.getElementById('clock').textContent = now.toLocaleTimeString();\n            document.getElementById('date').textContent = now.toLocaleDateString(undefined, { weekday: 'long', month: 'long', day: 'numeric' });\n          }\n          update(); setInterval(update, 1000);\n          \n          window.addEventListener('message', function(e) {\n            if (e.data.type === 'theme') {\n              const colors = {\n                dark: { bg: '#16213e', text: 'white' },\n                light: { bg: '#ffffff', text: '#333' },\n                neon: { bg: '#0a1a0a', text: '#00ff88' },\n                sunset: { bg: '#2d1b00', text: '#ffcc99' }\n              };\n              const c = colors[e.data.theme] || colors.dark;\n              document.body.style.background = c.bg;\n              document.body.style.color = c.text;\n              document.getElementById('themeMsg').textContent = 'Theme: ' + e.data.theme;\n              window.parent.postMessage({ type: 'log', text: 'Clock updated theme to: ' + e.data.theme }, '*');\n            }\n          });\n          window.parent.postMessage({ type: 'log', text: 'Clock loaded' }, '*');\n        <\\/script>\n      `,\n      calcFrame: `\n        <style>\n          body{font-family:system-ui;padding:16px;margin:0;transition:all 0.5s;}\n          .calc{max-width:200px;margin:0 auto;}\n          .display{background:rgba(0,0,0,0.3);padding:12px;text-align:right;font-size:24px;border-radius:8px;margin-bottom:8px;min-height:44px;font-variant-numeric:tabular-nums;}\n          .buttons{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;}\n          .buttons button{padding:10px;border:none;border-radius:6px;font-size:14px;cursor:pointer;background:rgba(255,255,255,0.1);color:inherit;transition:0.2s;}\n          .buttons button:hover{background:rgba(255,255,255,0.2);}\n          .buttons button.op{background:rgba(108,99,255,0.3);}\n          .buttons button.eq{background:rgba(108,99,255,0.6);}\n        </style>\n        <div class=\"calc\">\n          <div class=\"display\" id=\"display\">0</div>\n          <div class=\"buttons\">\n            <button onclick=\"press('7')\">7</button>\n            <button onclick=\"press('8')\">8</button>\n            <button onclick=\"press('9')\">9</button>\n            <button class=\"op\" onclick=\"press('/')\">÷</button>\n            <button onclick=\"press('4')\">4</button>\n            <button onclick=\"press('5')\">5</button>\n            <button onclick=\"press('6')\">6</button>\n            <button class=\"op\" onclick=\"press('*')\">×</button>\n            <button onclick=\"press('1')\">1</button>\n            <button onclick=\"press('2')\">2</button>\n            <button onclick=\"press('3')\">3</button>\n            <button class=\"op\" onclick=\"press('-')\">-</button>\n            <button onclick=\"press('0')\">0</button>\n            <button onclick=\"press('.')\">.</button>\n            <button onclick=\"press('=')\">=</button>\n            <button class=\"op\" onclick=\"press('+')\">+</button>\n          </div>\n          <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:4px;\">\n            <button onclick=\"press('C')\" style=\"padding:10px;border:none;border-radius:6px;cursor:pointer;background:rgba(255,107,107,0.3);\">C</button>\n            <button onclick=\"press('CE')\" style=\"padding:10px;border:none;border-radius:6px;cursor:pointer;background:rgba(255,107,107,0.5);\">CE</button>\n          </div>\n        </div>\n        <script>\n          let expr = '';\n          function press(val) {\n            if (val === 'C') { expr = ''; document.getElementById('display').textContent = '0'; return; }\n            if (val === 'CE') { expr = ''; document.getElementById('display').textContent = '0'; return; }\n            if (val === '=') {\n              try { expr = eval(expr).toString(); } catch { expr = 'Error'; }\n              document.getElementById('display').textContent = expr;\n              window.parent.postMessage({ type: 'log', text: 'Calc result: ' + expr }, '*');\n              return;\n            }\n            expr += val;\n            document.getElementById('display').textContent = expr;\n          }\n          window.addEventListener('message', function(e) {\n            if (e.data.type === 'theme') {\n              const colors = { dark: { bg: '#16213e', text: 'white' }, light: { bg: '#fff', text: '#333' }, neon: { bg: '#0a1a0a', text: '#00ff88' }, sunset: { bg: '#2d1b00', text: '#ffcc99' } };\n              const c = colors[e.data.theme] || colors.dark;\n              document.body.style.background = c.bg; document.body.style.color = c.text;\n            }\n          });\n          window.parent.postMessage({ type: 'log', text: 'Calculator loaded' }, '*');\n        <\\/script>\n      `,\n      todoFrame: `\n        <style>\n          body{font-family:system-ui;padding:16px;margin:0;transition:all 0.5s;}\n          .todo{max-width:250px;margin:0 auto;}\n          .add-row{display:flex;gap:4px;margin-bottom:8px;}\n          .add-row input{flex:1;padding:6px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.2);color:inherit;}\n          .add-row button{padding:6px 12px;border:none;border-radius:6px;cursor:pointer;background:rgba(108,99,255,0.5);color:inherit;}\n          #list{list-style:none;padding:0;margin:0;max-height:160px;overflow-y:auto;}\n          #list li{display:flex;align-items:center;gap:6px;padding:6px 4px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;}\n          #list li input[type='checkbox']{accent-color:#6C63FF;}\n          #list li .del{background:none;border:none;color:rgba(255,107,107,0.6);cursor:pointer;margin-left:auto;}\n          .counter{font-size:11px;opacity:0.5;margin-top:6px;}\n        </style>\n        <div class=\"todo\">\n          <div class=\"add-row\"><input type=\"text\" id=\"newItem\" placeholder=\"Add todo...\"><button onclick=\"addTodo()\">+</button></div>\n          <ul id=\"list\"><li style=\"opacity:0.4;font-size:12px;text-align:center;display:block;\">No items yet</li></ul>\n          <div class=\"counter\" id=\"counter\">0 items</div>\n        </div>\n        <script>\n          let todos = [];\n          function addTodo() {\n            const input = document.getElementById('newItem');\n            if (!input.value.trim()) return;\n            todos.push({ text: input.value.trim(), done: false });\n            input.value = '';\n            render();\n            window.parent.postMessage({ type: 'log', text: 'Todo added: ' + todos[todos.length-1].text }, '*');\n          }\n          function toggleTodo(idx) { todos[idx].done = !todos[idx].done; render(); }\n          function delTodo(idx) {\n            const text = todos[idx].text;\n            todos.splice(idx, 1); render();\n            window.parent.postMessage({ type: 'log', text: 'Todo removed: ' + text }, '*');\n          }\n          function render() {\n            const ul = document.getElementById('list');\n            if (todos.length === 0) { ul.innerHTML = '<li style=\"opacity:0.4;font-size:12px;text-align:center;display:block;\">No items yet</li>'; return; }\n            ul.innerHTML = todos.map((t, i) => '<li><input type=\"checkbox\" ' + (t.done ? 'checked' : '') + ' onchange=\"toggleTodo(' + i + ')\"><span style=\"' + (t.done ? 'text-decoration:line-through;opacity:0.5' : '') + '\">' + t.text + '</span><button class=\"del\" onclick=\"delTodo(' + i + ')\">×</button></li>').join('');\n            document.getElementById('counter').textContent = todos.length + ' item' + (todos.length !== 1 ? 's' : '');\n          }\n          window.addEventListener('message', function(e) {\n            if (e.data.type === 'theme') {\n              const colors = { dark: { bg: '#16213e', text: 'white' }, light: { bg: '#fff', text: '#333' }, neon: { bg: '#0a1a0a', text: '#00ff88' }, sunset: { bg: '#2d1b00', text: '#ffcc99' } };\n              const c = colors[e.data.theme] || colors.dark;\n              document.body.style.background = c.bg; document.body.style.color = c.text;\n            }\n          });\n          document.getElementById('newItem').addEventListener('keydown', (e) => { if (e.key === 'Enter') addTodo(); });\n          window.parent.postMessage({ type: 'log', text: 'Todo list loaded' }, '*');\n        <\\/script>\n      `\n    };\n\n    // Initialize iframes\n    for (const [id, src] of Object.entries(iframeSources)) {\n      document.getElementById(id).srcdoc = src;\n    }\n\n    // Theme broadcasting\n    function broadcastTheme(theme) {\n      const msg = { type: 'theme', theme };\n      document.querySelectorAll('iframe').forEach(f => f.contentWindow.postMessage(msg, '*'));\n      addLog('Theme changed to: ' + theme);\n    }\n\n    // Activity log\n    function addLog(text) {\n      const log = document.getElementById('activityLog');\n      const div = document.createElement('div');\n      const time = new Date().toLocaleTimeString();\n      div.innerHTML = '<span class=\"time\">[' + time + ']</span> ' + text;\n      log.appendChild(div);\n      log.scrollTop = log.scrollHeight;\n    }\n\n    window.addEventListener('message', (e) => {\n      if (e.data.type === 'log') {\n        addLog(e.data.text);\n      }\n    });\n\n    addLog('Dashboard initialized');\n  </script>\n</body>\n</html>"
  }
}
