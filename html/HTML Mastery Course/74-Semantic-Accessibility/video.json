{
  "courseInfo": {
    "title": "Semantic Accessibility - Mastering Meaningful HTML",
    "duration": "40 minutes",
    "difficulty": "Beginner to Intermediate",
    "prerequisites": [
      "Basic HTML knowledge",
      "Familiarity with div-based layouts"
    ],
    "segments": [
      {
        "title": "Why Semantic HTML Matters",
        "duration": "8 min",
        "topics": [
          "Built-in accessibility features",
          "Screen reader navigation",
          "SEO benefits",
          "Maintainability and code clarity"
        ]
      },
      {
        "title": "Document Structure Semantics",
        "duration": "10 min",
        "topics": [
          "header, nav, main, article, section, aside, footer",
          "Proper nesting and landmark creation",
          "Only one h1 rule",
          "Heading hierarchy best practices"
        ]
      },
      {
        "title": "Interactive Element Semantics",
        "duration": "8 min",
        "topics": [
          "button vs div onclick",
          "a vs span with click handler",
          "Native form elements",
          "details/summary for expandable content"
        ]
      },
      {
        "title": "Data Semantics (Tables, Lists, Figures)",
        "duration": "8 min",
        "topics": [
          "Semantic table elements (caption, thead, th scope)",
          "Ordered vs unordered lists",
          "Figure and figcaption",
          "Definition lists for metadata"
        ]
      },
      {
        "title": "Auditing and Validation",
        "duration": "6 min",
        "topics": [
          "Nu HTML Checker",
          "Testing with CSS disabled",
          "Lighthouse semantic checks",
          "Common semantic mistakes and fixes"
        ]
      }
    ],
    "resources": [
      "HTML5 Semantic Elements (MDN)",
      "Nu HTML Checker",
      "HTML Living Standard"
    ]
  },
  "videos": []
}
