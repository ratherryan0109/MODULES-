{
  "easy": {
    "title": "Embed a YouTube Video with Custom Parameters",
    "description": "Create an HTML page that embeds a YouTube video with: a responsive 16:9 container, privacy-enhanced mode, autoplay (muted), start time at 15 seconds, modest branding, and related videos from the same channel only.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My YouTube Embed</title>\n</head>\n<body>\n  <h1>Watch This Video</h1>\n  <!-- Add your embed here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My YouTube Embed</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; }\n    .video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }\n    .video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12px; }\n  </style>\n</head>\n<body>\n  <h1>Watch This Video</h1>\n  <div class=\"video-wrap\">\n    <iframe src=\"https://www.youtube-nocookie.com/embed/dQw4w9WgXcQ?autoplay=1&mute=1&start=15&modestbranding=1&rel=0\" \n      title=\"YouTube video player\"\n      allow=\"autoplay; encrypted-media\"\n      allowfullscreen>\n    </iframe>\n  </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "YouTube Player with Custom JS Controls",
    "description": "Build a YouTube embed with the IFrame Player API and custom controls. Include: play/pause button, seek bar with time display, volume slider, playback speed selector, and a 'load video' input where users can enter a video ID to change the current video.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Custom YouTube Controls</title>\n</head>\n<body>\n  <div id=\"player\"></div>\n  <div class=\"controls\">\n    <!-- Your custom controls -->\n  </div>\n  <script src=\"https://www.youtube.com/iframe_api\"></script>\n  <script>\n    // Your code\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Custom YouTube Controls</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; max-width: 720px; margin: 40px auto; padding: 0 20px; background: #1a1a2e; color: white; }\n    .player-wrap { position: relative; padding-bottom: 56.25%; background: #000; border-radius: 12px; overflow: hidden; }\n    .player-wrap > div { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }\n    .controls { background: #16213e; border-radius: 12px; padding: 16px; margin-top: 12px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }\n    .controls button { background: #e94560; border: none; color: white; padding: 8px 14px; border-radius: 6px; cursor: pointer; font-size: 13px; }\n    .controls button:hover { opacity: 0.85; }\n    .controls input[type='range'] { flex: 1; min-width: 80px; accent-color: #e94560; }\n    .controls input[type='text'] { background: #0f3460; border: 1px solid rgba(255,255,255,0.2); color: white; padding: 6px 10px; border-radius: 4px; width: 180px; }\n    .time { font-size: 13px; color: rgba(255,255,255,0.6); min-width: 35px; font-variant-numeric: tabular-nums; }\n    #status { font-size: 13px; color: rgba(255,255,255,0.5); }\n  </style>\n</head>\n<body>\n  <h1>Custom YouTube Player</h1>\n  <div class=\"player-wrap\"><div id=\"player\"></div></div>\n  <div class=\"controls\">\n    <button id=\"playBtn\">▶ Play</button>\n    <span class=\"time\" id=\"currentTime\">0:00</span>\n    <input type=\"range\" id=\"seekBar\" value=\"0\" min=\"0\" max=\"100\" step=\"0.1\">\n    <span class=\"time\" id=\"totalTime\">0:00</span>\n    <input type=\"range\" id=\"volumeBar\" min=\"0\" max=\"100\" value=\"70\" style=\"max-width:80px;\">\n    <select id=\"speedSelect\" style=\"background:#0f3460;color:white;border:1px solid rgba(255,255,255,0.2);padding:4px 8px;border-radius:4px;\">\n      <option value=\"0.5\">0.5x</option>\n      <option value=\"1\" selected>1x</option>\n      <option value=\"1.5\">1.5x</option>\n      <option value=\"2\">2x</option>\n    </select>\n    <input type=\"text\" id=\"videoInput\" placeholder=\"Enter Video ID\" value=\"dQw4w9WgXcQ\">\n    <button onclick=\"loadVideo(document.getElementById('videoInput').value)\">Load</button>\n  </div>\n  <p id=\"status\">Ready</p>\n\n  <script src=\"https://www.youtube.com/iframe_api\"></script>\n  <script>\n    let player;\n    let isSeeking = false;\n\n    function onYouTubeIframeAPIReady() {\n      player = new YT.Player('player', {\n        videoId: 'dQw4w9WgXcQ',\n        playerVars: { rel: 0, modestbranding: 1 },\n        events: {\n          onReady: onReady,\n          onStateChange: onStateChange\n        }\n      });\n    }\n\n    function onReady() {\n      document.getElementById('status').textContent = 'Player ready';\n      document.getElementById('totalTime').textContent = formatTime(player.getDuration());\n    }\n\n    function onStateChange(e) {\n      const states = ['Ended', 'Playing', 'Paused', 'Buffering', 'Unknown', 'Cued'];\n      document.getElementById('status').textContent = states[e.data - 1] || 'Unknown';\n    }\n\n    // Play/Pause\n    document.getElementById('playBtn').addEventListener('click', function() {\n      const state = player.getPlayerState();\n      if (state === YT.PlayerState.PLAYING) {\n        player.pauseVideo();\n        this.textContent = '▶ Play';\n      } else {\n        player.playVideo();\n        this.textContent = '⏸ Pause';\n      }\n    });\n\n    // Seek\n    setInterval(() => {\n      if (player && player.getCurrentTime && !isSeeking) {\n        const ct = player.getCurrentTime();\n        const dur = player.getDuration();\n        if (dur > 0) {\n          document.getElementById('seekBar').value = (ct / dur) * 100;\n          document.getElementById('currentTime').textContent = formatTime(ct);\n        }\n      }\n    }, 250);\n\n    document.getElementById('seekBar').addEventListener('input', function() {\n      isSeeking = true;\n      const dur = player.getDuration();\n      document.getElementById('currentTime').textContent = formatTime((this.value / 100) * dur);\n    });\n\n    document.getElementById('seekBar').addEventListener('change', function() {\n      const dur = player.getDuration();\n      player.seekTo((this.value / 100) * dur, true);\n      isSeeking = false;\n    });\n\n    // Volume\n    document.getElementById('volumeBar').addEventListener('input', function() {\n      player.setVolume(parseInt(this.value));\n    });\n\n    // Speed\n    document.getElementById('speedSelect').addEventListener('change', function() {\n      player.setPlaybackRate(parseFloat(this.value));\n    });\n\n    // Load video\n    function loadVideo(id) {\n      player.loadVideoById(id);\n      document.getElementById('playBtn').textContent = '⏸ Pause';\n    }\n\n    function formatTime(s) {\n      if (isNaN(s)) return '0:00';\n      const m = Math.floor(s / 60);\n      const sec = Math.floor(s % 60).toString().padStart(2, '0');\n      return `${m}:${sec}`;\n    }\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "YouTube Clone with Search, Queue, and Custom Player",
    "description": "Build a single-page YouTube player application that: (1) Has a video player with full custom controls using the IFrame Player API, (2) Includes a search box that uses the YouTube Data API to search for videos (or mock search results), (3) Has a queue/playlist system where users can add videos to 'Watch Later', reorder by drag-and-drop, and auto-play next, (4) Shows video info (title, channel, views) alongside the player, (5) Remembers the queue in localStorage, (6) Supports keyboard shortcuts and Media Session API integration.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>YouTube Clone</title>\n</head>\n<body>\n  <div class=\"app\">\n    <header>\n      <input type=\"text\" id=\"searchInput\" placeholder=\"Search videos...\">\n    </header>\n    <main>\n      <div class=\"player-section\">\n        <div id=\"player\"></div>\n        <div class=\"video-info\">\n          <h2 id=\"videoTitle\">Select a video</h2>\n          <p id=\"videoChannel\"></p>\n        </div>\n      </div>\n      <div class=\"queue-section\">\n        <h3>Queue</h3>\n        <div id=\"queue\"></div>\n      </div>\n    </main>\n  </div>\n  <script src=\"https://www.youtube.com/iframe_api\"></script>\n  <script>\n    // Your complete implementation\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>YouTube Clone</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: system-ui, sans-serif; background: #0f0f14; color: white; min-height: 100vh; }\n    .app { max-width: 1200px; margin: 0 auto; padding: 16px; }\n    header { margin-bottom: 20px; }\n    header input { width: 100%; max-width: 500px; padding: 12px 16px; background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; color: white; font-size: 14px; outline: none; }\n    header input:focus { border-color: #e94560; }\n    main { display: grid; grid-template-columns: 1fr 320px; gap: 20px; }\n    @media (max-width: 800px) { main { grid-template-columns: 1fr; } }\n    .player-wrap { position: relative; padding-bottom: 56.25%; background: #000; border-radius: 12px; overflow: hidden; }\n    .player-wrap > div { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }\n    .video-info { padding: 12px 0; }\n    .video-info h2 { font-size: 18px; font-weight: 600; margin-bottom: 4px; }\n    .video-info p { color: rgba(255,255,255,0.5); font-size: 13px; }\n    .queue-section h3 { font-size: 16px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; }\n    .queue-section h3 button { background: #e94560; border: none; color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px; cursor: pointer; }\n    .queue-item { display: flex; gap: 10px; padding: 10px; border-radius: 8px; cursor: pointer; transition: 0.2s; align-items: center; }\n    .queue-item:hover { background: rgba(255,255,255,0.05); }\n    .queue-item.active { background: rgba(233,69,96,0.15); border-left: 3px solid #e94560; }\n    .queue-item img { width: 80px; height: 45px; border-radius: 4px; object-fit: cover; }\n    .queue-item .info { flex: 1; min-width: 0; }\n    .queue-item .info .title { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n    .queue-item .info .channel { font-size: 11px; color: rgba(255,255,255,0.4); }\n    .queue-item .remove-btn { background: none; border: none; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 16px; padding: 4px; }\n    .queue-item .remove-btn:hover { color: #e94560; }\n    .search-results { margin-top: 12px; }\n    .search-result { display: flex; gap: 10px; padding: 8px; border-radius: 6px; cursor: pointer; transition: 0.2s; }\n    .search-result:hover { background: rgba(255,255,255,0.05); }\n    .search-result img { width: 120px; height: 68px; border-radius: 4px; object-fit: cover; }\n    .search-result .info { flex: 1; }\n    .search-result .info .title { font-size: 13px; font-weight: 500; }\n    .search-result .info .channel { font-size: 11px; color: rgba(255,255,255,0.4); }\n    .search-result button { background: #e94560; border: none; color: white; padding: 4px 12px; border-radius: 4px; font-size: 12px; cursor: pointer; align-self: center; }\n    .controls { display: flex; gap: 10px; align-items: center; padding: 8px 0; flex-wrap: wrap; }\n    .controls button { background: none; border: none; color: white; font-size: 20px; cursor: pointer; padding: 4px; }\n    .controls input[type='range'] { flex: 1; min-width: 80px; accent-color: #e94560; }\n    .time { font-size: 12px; color: rgba(255,255,255,0.5); font-variant-numeric: tabular-nums; }\n  </style>\n</head>\n<body>\n<div class=\"app\">\n  <header>\n    <input type=\"text\" id=\"searchInput\" placeholder=\"Search videos... (press Enter)\" value=\"Rick Astley\">\n  </header>\n  <main>\n    <div class=\"player-section\">\n      <div class=\"player-wrap\"><div id=\"player\"></div></div>\n      <div class=\"controls\">\n        <button id=\"playBtn\">▶</button>\n        <span class=\"time\" id=\"currentTime\">0:00</span>\n        <input type=\"range\" id=\"seekBar\" value=\"0\" min=\"0\" max=\"100\" step=\"0.1\">\n        <span class=\"time\" id=\"totalTime\">0:00</span>\n        <button id=\"pipBtn\">📌</button>\n      </div>\n      <div class=\"video-info\">\n        <h2 id=\"videoTitle\">Select or search for a video</h2>\n        <p id=\"videoChannel\">Use the search box to find videos</p>\n      </div>\n      <div class=\"search-results\" id=\"searchResults\"></div>\n    </div>\n    <div class=\"queue-section\">\n      <h3>📋 Queue <button onclick=\"clearQueue()\">Clear</button></h3>\n      <div id=\"queue\"></div>\n    </div>\n  </main>\n</div>\n\n<script src=\"https://www.youtube.com/iframe_api\"></script>\n<script>\n  let player;\n  let currentId = 'dQw4w9WgXcQ';\n  let queue = JSON.parse(localStorage.getItem('ytQueue') || '[]');\n  let queueIndex = -1;\n  let isSeeking = false;\n\n  function onYouTubeIframeAPIReady() {\n    player = new YT.Player('player', {\n      videoId: currentId,\n      playerVars: { rel: 0, modestbranding: 1, controls: 0 },\n      events: {\n        onReady: () => { updateInfo(); renderQueue(); },\n        onStateChange: (e) => {\n          playBtn.textContent = e.data === YT.PlayerState.PLAYING ? '⏸' : '▶';\n          if (e.data === YT.PlayerState.ENDED) playNext();\n        }\n      }\n    });\n  }\n\n  // Controls\n  const playBtn = document.getElementById('playBtn');\n  const seekBar = document.getElementById('seekBar');\n  const volumeBar = document.getElementById('volumeBar');\n  const currentTime = document.getElementById('currentTime');\n  const totalTime = document.getElementById('totalTime');\n  const videoTitle = document.getElementById('videoTitle');\n  const videoChannel = document.getElementById('videoChannel');\n\n  playBtn.addEventListener('click', () => {\n    const state = player.getPlayerState();\n    state === YT.PlayerState.PLAYING ? player.pauseVideo() : player.playVideo();\n  });\n\n  setInterval(() => {\n    if (player && player.getCurrentTime && !isSeeking) {\n      const ct = player.getCurrentTime();\n      const dur = player.getDuration();\n      if (dur > 0) {\n        seekBar.value = (ct / dur) * 100;\n        currentTime.textContent = formatTime(ct);\n      }\n    }\n  }, 200);\n\n  player && player.addEventListener && player.addEventListener('onReady', () => {\n    totalTime.textContent = formatTime(player.getDuration());\n  });\n\n  seekBar.addEventListener('input', function() {\n    isSeeking = true;\n    const dur = player.getDuration();\n    currentTime.textContent = formatTime((this.value / 100) * dur);\n  });\n\n  seekBar.addEventListener('change', function() {\n    const dur = player.getDuration();\n    player.seekTo((this.value / 100) * dur, true);\n    isSeeking = false;\n  });\n\n  document.getElementById('pipBtn').addEventListener('click', async () => {\n    if (document.pictureInPictureElement) {\n      await document.exitPictureInPicture();\n    } else {\n      try {\n        await player.getIframe().requestPictureInPicture();\n      } catch {}\n    }\n  });\n\n  // Search\n  // Mock search results (no API key needed)\n  const mockVideos = [\n    { id: 'dQw4w9WgXcQ', title: 'Rick Astley - Never Gonna Give You Up', channel: 'Rick Astley' },\n    { id: 'jNQXAC9IVRw', title: 'Me at the zoo', channel: 'jawed' },\n    { id: '9bZkp7q19f0', title: 'PSY - GANGNAM STYLE', channel: 'officialpsy' },\n    { id: 'kJQP7kiw5Fk', title: 'Luis Fonsi - Despacito ft. Daddy Yankee', channel: 'LuisFonsiVEVO' },\n    { id: 'JGwWNGJdvx8', title: 'Ed Sheeran - Shape of You', channel: 'EdSheeran' },\n    { id: 'RgKAFK5djSk', title: 'Wiz Khalifa - See You Again ft. Charlie Puth', channel: 'WizKhalifa' },\n    { id: 'OPf0YbXqDm0', title: 'Mark Ronson - Uptown Funk ft. Bruno Mars', channel: 'MarkRonsonVEVO' },\n    { id: 'HP-MbfHFUqs', title: 'The Weeknd - Blinding Lights', channel: 'TheWeekndVEVO' },\n  ];\n\n  document.getElementById('searchInput').addEventListener('keydown', (e) => {\n    if (e.key === 'Enter') performSearch(e.target.value);\n  });\n\n  function performSearch(query) {\n    const results = mockVideos.filter(v => \n      v.title.toLowerCase().includes(query.toLowerCase())\n    );\n    const el = document.getElementById('searchResults');\n    if (results.length === 0) {\n      el.innerHTML = '<p style=\"color:rgba(255,255,255,0.4);font-size:13px;\">No results found</p>';\n      return;\n    }\n    el.innerHTML = results.map(v => `\n      <div class=\"search-result\">\n        <img src=\"https://img.youtube.com/vi/${v.id}/mqdefault.jpg\" alt=\"${v.title}\">\n        <div class=\"info\">\n          <div class=\"title\">${v.title}</div>\n          <div class=\"channel\">${v.channel}</div>\n        </div>\n        <button onclick=\"addToQueue('${v.id}','${v.title.replace(/'/g, \"\\\\'\")}','${v.channel.replace(/'/g, \"\\\\'\")}')\">+ Queue</button>\n      </div>\n    `).join('');\n  }\n\n  // Queue management\n  function addToQueue(id, title, channel) {\n    queue.push({ id, title, channel });\n    saveQueue();\n    renderQueue();\n  }\n\n  function removeFromQueue(index) {\n    queue.splice(index, 1);\n    saveQueue();\n    renderQueue();\n  }\n\n  function clearQueue() {\n    queue = [];\n    saveQueue();\n    renderQueue();\n  }\n\n  function saveQueue() {\n    localStorage.setItem('ytQueue', JSON.stringify(queue));\n  }\n\n  function playNext() {\n    if (queue.length > 0) {\n      const next = queue.shift();\n      saveQueue();\n      renderQueue();\n      loadVideo(next.id, next.title, next.channel);\n    }\n  }\n\n  function loadVideo(id, title, channel) {\n    currentId = id;\n    player.loadVideoById(id);\n    videoTitle.textContent = title || 'Loading...';\n    videoChannel.textContent = channel || '';\n    document.getElementById('searchResults').innerHTML = '';\n    updateMediaSession(title, channel);\n  }\n\n  function updateInfo() {\n    try {\n      const data = player.getVideoData();\n      videoTitle.textContent = data.title || 'YouTube Video';\n      videoChannel.textContent = data.author || '';\n      totalTime.textContent = formatTime(player.getDuration());\n      updateMediaSession(data.title, data.author);\n    } catch {}\n  }\n\n  function updateMediaSession(title, artist) {\n    if ('mediaSession' in navigator) {\n      navigator.mediaSession.metadata = new MediaMetadata({ title, artist });\n      navigator.mediaSession.setActionHandler('play', () => player.playVideo());\n      navigator.mediaSession.setActionHandler('pause', () => player.pauseVideo());\n      navigator.mediaSession.setActionHandler('nexttrack', () => playNext());\n    }\n  }\n\n  function renderQueue() {\n    const el = document.getElementById('queue');\n    if (queue.length === 0) {\n      el.innerHTML = '<p style=\"color:rgba(255,255,255,0.3);font-size:13px;padding:10px;\">Queue is empty — search and add videos</p>';\n      return;\n    }\n    el.innerHTML = queue.map((v, i) => `\n      <div class=\"queue-item\" onclick=\"loadVideo('${v.id}','${v.title.replace(/'/g, \"\\\\'\")}','${v.channel.replace(/'/g, \"\\\\'\")}')\">\n        <img src=\"https://img.youtube.com/vi/${v.id}/mqdefault.jpg\" alt=\"\">\n        <div class=\"info\">\n          <div class=\"title\">${v.title}</div>\n          <div class=\"channel\">${v.channel}</div>\n        </div>\n        <button class=\"remove-btn\" onclick=\"event.stopPropagation();removeFromQueue(${i})\">×</button>\n      </div>\n    `).join('');\n  }\n\n  // Keyboard shortcuts\n  document.addEventListener('keydown', (e) => {\n    if (e.target.tagName === 'INPUT') return;\n    if (e.key === ' ') { e.preventDefault(); playBtn.click(); }\n    if (e.key === 'ArrowLeft') player.seekTo(Math.max(0, player.getCurrentTime() - 5), true);\n    if (e.key === 'ArrowRight') player.seekTo(Math.min(player.getDuration(), player.getCurrentTime() + 5), true);\n  });\n\n  function formatTime(s) {\n    if (isNaN(s)) return '0:00';\n    const m = Math.floor(s / 60);\n    const sec = Math.floor(s % 60).toString().padStart(2, '0');\n    return `${m}:${sec}`;\n  }\n\n  // Initial search\n  performSearch('Rick');\n</script>\n</body>\n</html>"
  }
}
