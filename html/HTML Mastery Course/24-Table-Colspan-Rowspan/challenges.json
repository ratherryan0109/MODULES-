{
  "easy": {
    "title": "Create a Simple Colspan Header",
    "description": "Build a table of monthly sales data with a header that uses colspan to group Q1 and Q2 quarters. Include columns for Product, Q1 Total, Q2 Total, and Year Total.",
    "starterCode": "<table border=\"1\">\n  <tr>\n    <th>Product</th>\n    <th>Q1 Total</th>\n    <th>Q2 Total</th>\n    <th>Year Total</th>\n  </tr>\n  <tr>\n    <td>Widget A</td>\n    <td>$12,000</td>\n    <td>$15,000</td>\n    <td>$27,000</td>\n  </tr>\n  <tr>\n    <td>Widget B</td>\n    <td>$8,000</td>\n    <td>$11,000</td>\n    <td>$19,000</td>\n  </tr>\n</table>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Sales Data with Colspan</title>\n  <style>\n    body { font-family: Arial, sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; }\n    table { width: 100%; border-collapse: collapse; }\n    th, td { border: 1px solid #ccc; padding: 10px 15px; text-align: center; }\n    th { background: #2c3e50; color: white; }\n    th[colspan] { background: #1a252f; }\n    td { background: #f9f9f9; }\n    td:last-child { font-weight: bold; color: #27ae60; }\n  </style>\n</head>\n<body>\n  <h1>Quarterly Sales Report</h1>\n  <table>\n    <tr>\n      <th rowspan=\"2\">Product</th>\n      <th colspan=\"2\">2025 Quarters</th>\n      <th rowspan=\"2\">Year Total</th>\n    </tr>\n    <tr>\n      <th>Q1</th>\n      <th>Q2</th>\n    </tr>\n    <tr>\n      <td>Widget A</td>\n      <td>$12,000</td>\n      <td>$15,000</td>\n      <td>$27,000</td>\n    </tr>\n    <tr>\n      <td>Widget B</td>\n      <td>$8,000</td>\n      <td>$11,000</td>\n      <td>$19,000</td>\n    </tr>\n  </table>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Weekly Class Schedule with Rowspan",
    "description": "Create a weekly schedule table where time slots use rowspan for multi-hour blocks. Include course names, instructors, and room numbers.",
    "starterCode": "<table>\n  <tr>\n    <th>Time</th>\n    <th>Monday</th>\n    <th>Tuesday</th>\n    <th>Wednesday</th>\n    <th>Thursday</th>\n    <th>Friday</th>\n  </tr>\n  <tr>\n    <td>9:00 - 10:30</td>\n    <td>Math 101</td>\n    <td>Physics</td>\n    <td>Math 101</td>\n    <td>Physics</td>\n    <td>English</td>\n  </tr>\n  <tr>\n    <td>10:45 - 12:15</td>\n    <td>History</td>\n    <td>Chemistry</td>\n    <td>History</td>\n    <td>Chemistry</td>\n    <td>—</td>\n  </tr>\n</table>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Weekly Schedule</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 900px; margin: 40px auto; padding: 0 20px; }\n    h1 { color: #2c3e50; }\n    table { width: 100%; border-collapse: collapse; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }\n    th { background: #8e44ad; color: white; padding: 14px 12px; }\n    td { border: 1px solid #ddd; padding: 12px; text-align: center; }\n    td:first-child { background: #f3e5f5; font-weight: bold; }\n    td[rowspan] { background: #e1bee7; font-weight: bold; }\n    .room { font-size: 12px; color: #666; display: block; }\n    .instructor { font-size: 11px; color: #999; display: block; }\n    .lunch { background: #fff9c4; font-weight: bold; color: #f57f17; }\n  </style>\n</head>\n<body>\n  <h1>Weekly Class Schedule</h1>\n  <table>\n    <tr>\n      <th>Time</th>\n      <th>Monday</th>\n      <th>Tuesday</th>\n      <th>Wednesday</th>\n      <th>Thursday</th>\n      <th>Friday</th>\n    </tr>\n    <tr>\n      <td rowspan=\"2\">Morning</td>\n      <td>Math 101 <span class=\"room\">Rm 204</span><span class=\"instructor\">Dr. Smith</span></td>\n      <td>Physics <span class=\"room\">Rm 101</span><span class=\"instructor\">Dr. Jones</span></td>\n      <td>Math 101 <span class=\"room\">Rm 204</span><span class=\"instructor\">Dr. Smith</span></td>\n      <td>Physics <span class=\"room\">Rm 101</span><span class=\"instructor\">Dr. Jones</span></td>\n      <td>English <span class=\"room\">Rm 305</span><span class=\"instructor\">Ms. Brown</span></td>\n    </tr>\n    <tr>\n      <td>History <span class=\"room\">Rm 302</span><span class=\"instructor\">Dr. Lee</span></td>\n      <td>Chemistry <span class=\"room\">Lab A</span><span class=\"instructor\">Dr. Kim</span></td>\n      <td>History <span class=\"room\">Rm 302</span><span class=\"instructor\">Dr. Lee</span></td>\n      <td>Chemistry <span class=\"room\">Lab A</span><span class=\"instructor\">Dr. Kim</span></td>\n      <td>—</td>\n    </tr>\n    <tr>\n      <td>12:15 - 1:15</td>\n      <td colspan=\"5\" class=\"lunch\">Lunch Break</td>\n    </tr>\n    <tr>\n      <td rowspan=\"2\">Afternoon</td>\n      <td>Computer Science <span class=\"room\">Lab B</span><span class=\"instructor\">Dr. Chen</span></td>\n      <td>Art <span class=\"room\">Studio 1</span><span class=\"instructor\">Ms. Davis</span></td>\n      <td>Computer Science <span class=\"room\">Lab B</span><span class=\"instructor\">Dr. Chen</span></td>\n      <td>Art <span class=\"room\">Studio 1</span><span class=\"instructor\">Ms. Davis</span></td>\n      <td>Music <span class=\"room\">Rm 401</span><span class=\"instructor\">Mr. Wilson</span></td>\n    </tr>\n    <tr>\n      <td>PE <span class=\"room\">Gym</span><span class=\"instructor\">Coach Taylor</span></td>\n      <td>—</td>\n      <td>PE <span class=\"room\">Gym</span><span class=\"instructor\">Coach Taylor</span></td>\n      <td>—</td>\n      <td>PE <span class=\"room\">Gym</span><span class=\"instructor\">Coach Taylor</span></td>\n    </tr>\n  </table>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build a Complex Employee Shift Calendar",
    "description": "Create a monthly employee shift calendar that combines colspan (for date headers) and rowspan (for employees working multiple consecutive days). Include shift types (Morning, Afternoon, Night, Off) with color coding. Use colspan for weekend date grouping and rowspan for employees on night shifts spanning multiple days.",
    "starterCode": "<table>\n  <tr>\n    <th rowspan=\"2\">Employee</th>\n    <th colspan=\"7\">Week 1</th>\n    <th colspan=\"7\">Week 2</th>\n  </tr>\n  <tr>\n    <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th>\n    <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th>\n  </tr>\n  <tr>\n    <td>Alice</td>\n    <td>M</td><td>M</td><td>M</td><td>M</td><td>M</td><td>O</td><td>O</td>\n    <td>N</td><td>N</td><td>N</td><td>O</td><td>O</td><td>O</td><td>O</td>\n  </tr>\n</table>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Employee Shift Calendar</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 1200px; margin: 40px auto; padding: 0 20px; background: #f0f2f5; }\n    h1 { color: #1a1a2e; text-align: center; }\n    .wrapper { overflow-x: auto; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }\n    table { width: 100%; border-collapse: collapse; font-size: 13px; background: white; }\n    th { background: #1a1a2e; color: white; padding: 8px 6px; text-align: center; font-size: 11px; text-transform: uppercase; }\n    th[colspan] { background: #16213e; }\n    td { border: 1px solid #e0e0e0; padding: 6px 4px; text-align: center; font-weight: bold; font-size: 11px; min-width: 28px; }\n    td:first-child { background: #f8f9fa; font-weight: bold; color: #1a1a2e; position: sticky; left: 0; z-index: 2; min-width: 80px; text-align: left; padding-left: 10px; }\n    .shift-M { background: #d4edda; color: #155724; }\n    .shift-A { background: #fff3cd; color: #856404; }\n    .shift-N { background: #cce5ff; color: #004085; }\n    .shift-O { background: #f8f9fa; color: #999; }\n    .weekend { background: #e8e8e8; }\n    td[rowspan] { vertical-align: middle; }\n    .merged-night { background: #cce5ff; color: #004085; font-weight: bold; }\n    .legend { display: flex; gap: 20px; margin: 20px 0; justify-content: center; flex-wrap: wrap; }\n    .legend span { padding: 4px 12px; border-radius: 4px; font-size: 13px; }\n    .legend .m { background: #d4edda; }\n    .legend .a { background: #fff3cd; }\n    .legend .n { background: #cce5ff; }\n    .legend .o { background: #f8f9fa; border: 1px solid #ddd; }\n  </style>\n</head>\n<body>\n  <h1>March 2025 — Employee Shift Calendar</h1>\n  <div class=\"legend\">\n    <span class=\"m\">M = Morning (6AM-2PM)</span>\n    <span class=\"a\">A = Afternoon (2PM-10PM)</span>\n    <span class=\"n\">N = Night (10PM-6AM)</span>\n    <span class=\"o\">O = Off</span>\n  </div>\n  <div class=\"wrapper\">\n    <table>\n      <tr>\n        <th rowspan=\"2\">Employee</th>\n        <th colspan=\"7\">Week 1 (Mar 3-9)</th>\n        <th colspan=\"7\">Week 2 (Mar 10-16)</th>\n        <th colspan=\"7\">Week 3 (Mar 17-23)</th>\n      </tr>\n      <tr>\n        <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th class=\"weekend\">Sat</th><th class=\"weekend\">Sun</th>\n        <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th class=\"weekend\">Sat</th><th class=\"weekend\">Sun</th>\n        <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th class=\"weekend\">Sat</th><th class=\"weekend\">Sun</th>\n      </tr>\n      <tr>\n        <td>Alice Johnson</td>\n        <td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n        <td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n        <td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n      </tr>\n      <tr>\n        <td>Bob Chen</td>\n        <td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-O\">O</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-O\">O</td>\n        <td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n        <td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-O\">O</td>\n      </tr>\n      <tr>\n        <td>Carol Davis</td>\n        <td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td>\n        <td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-O\">O</td>\n        <td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n      </tr>\n      <tr>\n        <td>Dan Wilson</td>\n        <td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td>\n        <td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td>\n        <td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td>\n      </tr>\n      <tr>\n        <td>Eve Martinez</td>\n        <td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-M\">M</td>\n        <td class=\"shift-M\">M</td><td class=\"shift-M\">M</td><td class=\"shift-O\">O</td><td class=\"shift-O\">O</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-N\">N</td>\n        <td class=\"shift-N\">N</td><td class=\"shift-N\">N</td><td class=\"shift-O\">O</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td><td class=\"shift-A\">A</td>\n      </tr>\n    </table>\n  </div>\n  <p style=\"text-align:center;margin-top:20px;color:#666;font-size:14px;\">Weekends (Sat/Sun) highlighted. Each employee has a consistent 5-day work week with 2 days off.</p>\n</body>\n</html>"
  }
}
