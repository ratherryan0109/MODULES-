{
  "easy": {
    "title": "Multi-Action Form Buttons",
    "description": "Create a form with three submit buttons: Save Draft (saves with formnovalidate), Publish (validates and submits), and Preview (opens in new tab with formmethod=GET). Style each button appropriately.",
    "starterCode": "<form>\n  <!-- Add three buttons with different actions -->\n</form>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Multi Action</title><style>body{font-family:system-ui;max-width:500px;margin:40px auto;padding:20px;}form{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}input,textarea{width:100%;padding:10px;margin-bottom:12px;border:2px solid #ddd;border-radius:6px;box-sizing:border-box;}.btn-group{display:flex;gap:8px;}button{flex:1;padding:12px;border:none;border-radius:6px;font-weight:600;cursor:pointer;}.save{background:#e2e8f0;color:#4a5568;}.publish{background:#2ecc71;color:white;}.preview{background:#f39c12;color:white;}</style></head>\n<body>\n  <form id=\"postForm\" onsubmit=\"event.preventDefault(); alert(document.activeElement.textContent + ' clicked!')\">\n    <h2>Create Post</h2>\n    <input type=\"text\" placeholder=\"Title\" required><textarea rows=\"4\" placeholder=\"Content\" required></textarea>\n    <div class=\"btn-group\">\n      <button type=\"submit\" class=\"save\" formnovalidate>💾 Save Draft</button>\n      <button type=\"submit\" class=\"publish\">📤 Publish</button>\n      <button type=\"submit\" class=\"preview\" formaction=\"/preview\" formmethod=\"GET\" formtarget=\"_blank\">👁 Preview</button>\n    </div>\n  </form>\n</body>\n</html>"
  },
  "medium": {
    "title": "Button Component Library",
    "description": "Build a reusable button component system with: primary, secondary, danger, ghost, outline, icon, loading, disabled, and size variants. Use CSS custom properties for theming and include focus-visible styles.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>Button Library</title></head>\n<body>\n  <!-- Build reusable button components -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Button Library</title><style>:root{--primary:#4a6cf7;--primary-hover:#3b5de7;--success:#2ecc71;--danger:#e74c3c;--warning:#f39c12;--gray:#e2e8f0;--dark:#2d3748;}body{font-family:system-ui;background:#f7f8fc;padding:40px;}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:30px;}h2{color:#2d3748;margin-bottom:16px;}.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 20px;border:none;border-radius:8px;font-size:14px;font-weight:600;font-family:inherit;cursor:pointer;transition:all 0.2s;text-decoration:none;}.btn:focus-visible{outline:3px solid var(--primary);outline-offset:2px;}.btn:active{transform:scale(0.97);}.btn:disabled{opacity:0.5;cursor:not-allowed;transform:none;}.btn-primary{background:var(--primary);color:white;}.btn-primary:hover{background:var(--primary-hover);}.btn-secondary{background:var(--gray);color:var(--dark);}.btn-secondary:hover{background:#cbd5e0;}.btn-success{background:var(--success);color:white;}.btn-danger{background:var(--danger);color:white;}.btn-ghost{background:transparent;color:var(--dark);}.btn-ghost:hover{background:var(--gray);}.btn-outline{background:transparent;border:2px solid var(--primary);color:var(--primary);}.btn-outline:hover{background:var(--primary);color:white;}.btn-sm{padding:6px 14px;font-size:12px;}.btn-lg{padding:14px 28px;font-size:16px;}.btn-icon{width:40px;height:40px;padding:0;border-radius:50%;}.btn-block{width:100%;}.spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.6s linear;}@keyframes spin{to{transform:rotate(360deg);}}</style></head>\n<body>\n  <h2>Variants</h2><div class=\"grid\"><button class=\"btn btn-primary\">Primary</button><button class=\"btn btn-secondary\">Secondary</button><button class=\"btn btn-success\">Success</button><button class=\"btn btn-danger\">Danger</button><button class=\"btn btn-ghost\">Ghost</button><button class=\"btn btn-outline\">Outline</button></div>\n  <h2>Sizes</h2><div class=\"grid\"><button class=\"btn btn-primary btn-sm\">Small</button><button class=\"btn btn-primary\">Default</button><button class=\"btn btn-primary btn-lg\">Large</button><button class=\"btn btn-primary btn-block\">Block</button></div>\n  <h2>Icon Buttons</h2><div class=\"grid\"><button class=\"btn btn-primary\">💾 Save</button><button class=\"btn btn-danger\">🗑 Delete</button><button class=\"btn btn-icon btn-primary\" aria-label=\"Settings\">⚙️</button></div>\n  <h2>States</h2><div class=\"grid\"><button class=\"btn btn-primary\">Normal</button><button class=\"btn btn-primary\" disabled>Disabled</button><button class=\"btn btn-primary\"><span class=\"spinner\"></span> Loading</button></div>\n</body>\n</html>"
  },
  "hard": {
    "title": "Interactive Button Playground",
    "description": "Build a button playground that lets users configure button properties in real-time: type (submit/reset/button), variant (primary/secondary/danger), state (normal/disabled/loading), size (small/medium/large), icon (select from list), text content, formaction URL, and whether to show a tooltip. Show the generated HTML code.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build interactive button configurator -->\n  <script>\n    // Implement button property controls\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Button Playground</title><style>*{box-sizing:border-box;margin:0;padding:0;}body{font-family:system-ui;background:#1a1a2e;color:#eee;padding:30px;}.app{display:grid;grid-template-columns:350px 1fr;gap:24px;max-width:1200px;margin:0 auto;}.panel{background:#16213e;border-radius:12px;padding:24px;}.panel h2{font-size:16px;color:#4fc3f7;margin-bottom:16px;border-bottom:1px solid #2a3a5e;padding-bottom:8px;}.ctrl{margin-bottom:14px;}.ctrl label{display:block;font-size:13px;color:#aaa;margin-bottom:3px;}.ctrl select,.ctrl input[type=text]{width:100%;padding:8px 12px;border:1px solid #2a3a5e;border-radius:6px;background:#0f3460;color:#eee;font-size:14px;}.ctrl input:focus,.ctrl select:focus{border-color:#4fc3f7;outline:none;}.ctrl input[type=checkbox]{margin-right:6px;}.ctrl .checkbox-label{display:flex;align-items:center;gap:6px;font-size:13px;color:#ccc;cursor:pointer;}.preview-area{background:#0f3460;border-radius:8px;padding:40px;display:flex;align-items:center;justify-content:center;min-height:200px;}.preview-area .btn{padding:12px 28px;border:none;border-radius:8px;font-size:15px;font-weight:600;font-family:inherit;cursor:pointer;transition:all 0.2s;}.preview-area .btn:active{transform:scale(0.97);}.code-output{background:#1a1a2e;color:#e2e8f0;padding:16px;border-radius:8px;font-family:monospace;font-size:13px;margin-top:16px;white-space:pre-wrap;}</style></head>\n<body>\n  <div class=\"app\"><div class=\"panel\"><h2>Button Controls</h2>\n      <div class=\"ctrl\"><label>Type</label><select id=\"bType\"><option value=\"submit\">submit</option><option value=\"reset\">reset</option><option value=\"button\" selected>button</option></select></div>\n      <div class=\"ctrl\"><label>Variant</label><select id=\"bVariant\"><option value=\"primary\" selected>Primary</option><option value=\"secondary\">Secondary</option><option value=\"danger\">Danger</option><option value=\"ghost\">Ghost</option><option value=\"outline\">Outline</option></select></div>\n      <div class=\"ctrl\"><label>Size</label><select id=\"bSize\"><option value=\"\">Normal</option><option value=\"btn-sm\">Small</option><option value=\"btn-lg\">Large</option></select></div>\n      <div class=\"ctrl\"><label>Button Text</label><input type=\"text\" id=\"bText\" value=\"Click Me\"></div>\n      <div class=\"ctrl\"><label>formaction (for submit)</label><input type=\"text\" id=\"bFormaction\" placeholder=\"/custom-endpoint\"></div>\n      <div class=\"ctrl\"><label class=\"checkbox-label\"><input type=\"checkbox\" id=\"bDisabled\"> Disabled</label></div>\n      <div class=\"ctrl\"><label class=\"checkbox-label\"><input type=\"checkbox\" id=\"bLoading\"> Loading state</label></div>\n      <div class=\"ctrl\"><label class=\"checkbox-label\"><input type=\"checkbox\" id=\"bFormnovalidate\"> formnovalidate</label></div>\n    </div>\n    <div><div class=\"panel\"><h2>Preview</h2><div class=\"preview-area\" id=\"previewArea\"><button id=\"previewBtn\" class=\"btn\">Click Me</button></div></div><div class=\"panel\"><h2>Generated HTML</h2><div class=\"code-output\" id=\"codeOutput\">&lt;button&gt;</div></div></div>\n  </div>\n  <script>\n    const colors={primary:'#4a6cf7',secondary:'#e2e8f0',danger:'#e74c3c',ghost:'transparent',outline:'transparent'};\n    const textColors={primary:'white',secondary:'#2d3748',danger:'white',ghost:'#2d3748',outline:'#4a6cf7'};\n    const hoverColors={primary:'#3b5de7',secondary:'#cbd5e0',danger:'#c0392b',ghost:'#e2e8f0',outline:'#4a6cf7'};\n    function updateButton(){\n      const type=document.getElementById('bType').value;\n      const variant=document.getElementById('bVariant').value;\n      const size=document.getElementById('bSize').value;\n      const text=document.getElementById('bText').value||'Button';\n      const formaction=document.getElementById('bFormaction').value;\n      const disabled=document.getElementById('bDisabled').checked;\n      const loading=document.getElementById('bLoading').checked;\n      const formnovalidate=document.getElementById('bFormnovalidate').checked;\n      const btn=document.getElementById('previewBtn');\n      btn.textContent=loading?'⏳ '+text:text;\n      btn.disabled=disabled;\n      btn.style.background=colors[variant];\n      btn.style.color=textColors[variant];\n      btn.style.border=(variant==='outline')?'2px solid #4a6cf7':'none';\n      btn.style.opacity=disabled?'0.5':'1';\n      btn.style.cursor=disabled?'not-allowed':'pointer';\n      btn.className='btn'+(size?' '+size:'');\n      let html='&lt;button type=\"'+type+'\"';\n      if(formaction)html+=' formaction=\"'+formaction+'\"';\n      if(formnovalidate)html+=' formnovalidate';\n      if(disabled)html+=' disabled';\n      if(size)html+=' class=\"'+size+'\"';\n      html+='&gt;'+text+'&lt;/button&gt;';\n      document.getElementById('codeOutput').textContent=html;\n      btn.onmouseenter=()=>{if(!disabled){btn.style.background=hoverColors[variant];btn.style.color=variant==='outline'?'white':textColors[variant];}};\n      btn.onmouseleave=()=>{if(!disabled){btn.style.background=colors[variant];btn.style.color=textColors[variant];btn.style.border=(variant==='outline')?'2px solid #4a6cf7':'none';}};\n    }\n    document.querySelectorAll('#bType,#bVariant,#bSize,#bText,#bFormaction,#bDisabled,#bLoading,#bFormnovalidate').forEach(el=>el.addEventListener('input',updateButton));\n    updateButton();\n  </script>\n</body>\n</html>"
  }
}
