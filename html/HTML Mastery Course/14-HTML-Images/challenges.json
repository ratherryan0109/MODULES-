{
  "easy": {
    "title": "Build a Photo Gallery Page",
    "description": "Create a simple photo gallery with at least 6 images displayed in a 3-column grid. Each image should have a figure caption. Use CSS grid or flexbox for layout. Ensure all images have proper alt text.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Photo Gallery</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; padding: 20px; background: #f0f2f5; }\n    h1 { text-align: center; margin-bottom: 30px; }\n    /* Add gallery styles here */\n  </style>\n</head>\n<body>\n  <h1>Photo Gallery</h1>\n  <div class=\"gallery\">\n    <!-- Add 6 figure elements here -->\n  </div>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Photo Gallery</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', sans-serif;\n      padding: 30px 20px;\n      background: #f0f2f5;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 40px;\n      color: #1a1a2e;\n      font-size: 2.5em;\n    }\n    .gallery {\n      display: grid;\n      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n      gap: 25px;\n      max-width: 1200px;\n      margin: 0 auto;\n    }\n    .gallery figure {\n      background: white;\n      border-radius: 12px;\n      overflow: hidden;\n      box-shadow: 0 4px 15px rgba(0,0,0,0.08);\n      transition: transform 0.3s, box-shadow 0.3s;\n    }\n    .gallery figure:hover {\n      transform: translateY(-5px);\n      box-shadow: 0 8px 25px rgba(0,0,0,0.15);\n    }\n    .gallery img {\n      width: 100%;\n      height: 220px;\n      object-fit: cover;\n      display: block;\n    }\n    .gallery figcaption {\n      padding: 12px 16px;\n      font-size: 14px;\n      color: #64748b;\n      text-align: center;\n    }\n  </style>\n</head>\n<body>\n  <h1>📷 Photo Gallery</h1>\n  <div class=\"gallery\">\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&q=80\" alt=\"Mountain range at sunset with colorful sky\">\n      <figcaption>Mountain Sunset</figcaption>\n    </figure>\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80\" alt=\"Portrait of a person smiling in natural light\">\n      <figcaption>Natural Portrait</figcaption>\n    </figure>\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1470071459604-7e39b0a1c0b5?w=400&q=80\" alt=\"Dense green forest with sunlight filtering through trees\">\n      <figcaption>Forest Light</figcaption>\n    </figure>\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=80\" alt=\"Lush green forest with tall trees and sun rays\">\n      <figcaption>Deep Forest</figcaption>\n    </figure>\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=400&q=80\" alt=\"Scenic landscape with rolling hills and a lake\">\n      <figcaption>Rolling Hills</figcaption>\n    </figure>\n    <figure>\n      <img src=\"https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=400&q=80\" alt=\"Beautiful mountain peak at sunrise with clouds\">\n      <figcaption>Mountain Peak</figcaption>\n    </figure>\n  </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Responsive Hero Section with Picture Element",
    "description": "Create a hero section for a travel website that shows different image crops at different viewport sizes using the <picture> element. Include a headline, subheading, and CTA button overlaid on the image.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Travel Hero</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    /* Add hero styles here */\n  </style>\n</head>\n<body>\n  <section class=\"hero\">\n    <!-- Add picture element with sources -->\n    <div class=\"hero-content\">\n      <h1>Explore the World</h1>\n      <p>Discover amazing destinations</p>\n      <a href=\"#\" class=\"cta\">Start Your Journey</a>\n    </div>\n  </section>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Travel Hero</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    .hero {\n      position: relative;\n      min-height: 100vh;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      overflow: hidden;\n    }\n    .hero picture,\n    .hero img {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      z-index: 1;\n    }\n    .hero::after {\n      content: '';\n      position: absolute;\n      top: 0; left: 0;\n      width: 100%; height: 100%;\n      background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.6));\n      z-index: 2;\n    }\n    .hero-content {\n      position: relative;\n      z-index: 3;\n      text-align: center;\n      color: white;\n      padding: 20px;\n    }\n    .hero-content h1 {\n      font-size: clamp(2rem, 6vw, 4.5rem);\n      font-weight: 800;\n      margin-bottom: 15px;\n      text-shadow: 0 4px 20px rgba(0,0,0,0.3);\n    }\n    .hero-content p {\n      font-size: clamp(1rem, 3vw, 1.5rem);\n      margin-bottom: 30px;\n      opacity: 0.9;\n    }\n    .cta {\n      display: inline-block;\n      padding: 16px 40px;\n      background: #e94560;\n      color: white;\n      text-decoration: none;\n      border-radius: 50px;\n      font-weight: 600;\n      font-size: 1.1rem;\n      transition: all 0.3s;\n    }\n    .cta:hover {\n      background: #c23152;\n      transform: translateY(-3px);\n      box-shadow: 0 10px 30px rgba(233,69,96,0.4);\n    }\n  </style>\n</head>\n<body>\n  <section class=\"hero\">\n    <picture>\n      <source media=\"(min-width: 1000px)\" srcset=\"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80&fit=crop&crop=center&h=1000\">\n      <source media=\"(min-width: 600px)\" srcset=\"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1000&q=80&fit=crop&crop=center&h=1200\">\n      <img src=\"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80&fit=crop&crop=center&h=900\" alt=\"Scenic mountain landscape with lake and forest\">\n    </picture>\n    <div class=\"hero-content\">\n      <h1>Explore the World</h1>\n      <p>Discover amazing destinations and create unforgettable memories</p>\n      <a href=\"#\" class=\"cta\">Start Your Journey</a>\n    </div>\n  </section>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build a Complete E-commerce Product Page with Image Features",
    "description": "Create a product page with: a main product image with zoom-on-hover effect, a thumbnail gallery for selecting different product views, responsive images using srcset for different screen sizes, lazy loading for thumbnails, and accessible alt text. Also include a simple image map on the product for interactive hotspots.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Product Page</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', sans-serif; padding: 30px; background: #f8f9fa; }\n    /* Add product page styles */\n  </style>\n</head>\n<body>\n  <div class=\"product\">\n    <div class=\"gallery\">\n      <!-- Main image container with zoom -->\n      <!-- Thumbnails -->\n    </div>\n    <div class=\"product-info\">\n      <h1>Product Name</h1>\n      <p class=\"price\">$49.99</p>\n      <p class=\"description\">Product description here.</p>\n      <button>Add to Cart</button>\n    </div>\n  </div>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Product Page</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n      padding: 30px;\n      background: #f8f9fa;\n      color: #333;\n    }\n    .product {\n      display: flex;\n      gap: 40px;\n      max-width: 1100px;\n      margin: 0 auto;\n      background: white;\n      border-radius: 16px;\n      padding: 40px;\n      box-shadow: 0 8px 30px rgba(0,0,0,0.06);\n    }\n    .gallery {\n      flex: 1;\n      min-width: 300px;\n    }\n    .main-image-container {\n      position: relative;\n      overflow: hidden;\n      border-radius: 12px;\n      cursor: crosshair;\n    }\n    .main-image-container img {\n      width: 100%;\n      height: 450px;\n      object-fit: cover;\n      display: block;\n      transition: transform 0.3s;\n    }\n    .main-image-container:hover img {\n      transform: scale(1.5);\n    }\n    .thumbnails {\n      display: flex;\n      gap: 10px;\n      margin-top: 15px;\n    }\n    .thumbnails img {\n      width: 80px;\n      height: 80px;\n      object-fit: cover;\n      border-radius: 8px;\n      cursor: pointer;\n      border: 2px solid transparent;\n      transition: border-color 0.3s;\n      opacity: 0.7;\n    }\n    .thumbnails img.active {\n      border-color: #2563eb;\n      opacity: 1;\n    }\n    .thumbnails img:hover {\n      opacity: 1;\n    }\n    .product-info {\n      flex: 1;\n      min-width: 280px;\n    }\n    .product-info h1 {\n      font-size: 2em;\n      margin-bottom: 10px;\n      color: #1a1a2e;\n    }\n    .price {\n      font-size: 1.8em;\n      font-weight: 700;\n      color: #2563eb;\n      margin-bottom: 20px;\n    }\n    .description {\n      color: #64748b;\n      line-height: 1.7;\n      margin-bottom: 25px;\n    }\n    .product-info button {\n      background: #2563eb;\n      color: white;\n      border: none;\n      padding: 16px 40px;\n      border-radius: 8px;\n      font-size: 1.1em;\n      font-weight: 600;\n      cursor: pointer;\n      transition: all 0.3s;\n    }\n    .product-info button:hover {\n      background: #1d4ed8;\n      transform: translateY(-2px);\n      box-shadow: 0 8px 20px rgba(37,99,235,0.3);\n    }\n    @media (max-width: 768px) {\n      .product { flex-direction: column; padding: 20px; }\n      .main-image-container img { height: 300px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"product\">\n    <div class=\"gallery\">\n      <div class=\"main-image-container\">\n        <img\n          id=\"mainImage\"\n          src=\"https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&q=80\"\n          srcset=\"\n            https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400&q=80 400w,\n            https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&q=80 600w,\n            https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=1200&q=80 1200w\n          \"\n          sizes=\"(max-width: 768px) 100vw, 50vw\"\n          alt=\"Red Nike sneaker shoe on white background - main product view\"\n          fetchpriority=\"high\"\n        >\n      </div>\n      <div class=\"thumbnails\">\n        <img src=\"https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=150&q=80\" alt=\"Red Nike sneaker - front view\" class=\"active\" onclick=\"changeImage(this, 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&q=80')\">\n        <img src=\"https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=150&q=80\" alt=\"Red Nike sneaker - side view\" onclick=\"changeImage(this, 'https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=600&q=80')\" loading=\"lazy\">\n        <img src=\"https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=150&q=80\" alt=\"Red Nike sneaker - back view\" onclick=\"changeImage(this, 'https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=600&q=80')\" loading=\"lazy\">\n        <img src=\"https://images.unsplash.com/photo-1579338553193-a98d062b3a15?w=150&q=80\" alt=\"Red Nike sneaker - detail view\" onclick=\"changeImage(this, 'https://images.unsplash.com/photo-1579338553193-a98d062b3a15?w=600&q=80')\" loading=\"lazy\">\n      </div>\n    </div>\n    <div class=\"product-info\">\n      <h1>Nike Air Zoom</h1>\n      <p class=\"price\">$189.99</p>\n      <p class=\"description\">Experience ultimate comfort and performance with the Nike Air Zoom sneaker. Featuring responsive cushioning, breathable mesh upper, and a durable rubber outsole for traction on any surface.</p>\n      <ul style=\"margin-bottom:20px;padding-left:20px;color:#64748b;line-height:2;\">\n        <li>Responsive Zoom Air cushioning</li>\n        <li>Breathable engineered mesh upper</li>\n        <li>Rubber outsole with flex grooves</li>\n        <li>Available in multiple colors</li>\n      </ul>\n      <button>Add to Cart</button>\n    </div>\n  </div>\n  <script>\n    function changeImage(el, src) {\n      document.getElementById('mainImage').src = src;\n      document.querySelectorAll('.thumbnails img').forEach(i => i.classList.remove('active'));\n      el.classList.add('active');\n    }\n  </script>\n</body>\n</html>"
  }
}
