{
  "easy": {
    "title": "Comment Box with Validation",
    "description": "Create a comment textarea with: 10-500 character limit, character counter showing remaining, submit button that shows the comment, and auto-resize as user types.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<body>\n  <!-- Build a comment textarea -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Comments</title><style>body{font-family:system-ui;max-width:500px;margin:40px auto;padding:20px;}textarea{width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;font-family:inherit;line-height:1.5;resize:none;overflow:hidden;min-height:80px;}textarea:focus{border-color:#4a6cf7;outline:none;}.count{text-align:right;font-size:13px;color:#718096;}.warn{color:#e53e3e;}button{margin-top:8px;padding:10px 20px;background:#4a6cf7;color:white;border:none;border-radius:6px;cursor:pointer;}.output{padding:12px;background:#f0f4ff;border-radius:6px;margin-top:12px;white-space:pre-wrap;}</style></head>\n<body>\n  <form onsubmit=\"event.preventDefault(); if(this.comment.value.length>=10) { document.getElementById('out').textContent = 'Comment: ' + this.comment.value; } else { alert('Min 10 chars'); }\">\n    <label for=\"comment\">Leave a comment (10-500 chars):</label>\n    <textarea id=\"comment\" name=\"comment\" required minlength=\"10\" maxlength=\"500\" placeholder=\"Share your thoughts...\" oninput=\"this.style.height='auto';this.style.height=this.scrollHeight+'px';updateChar(this)\"></textarea>\n    <div class=\"count\" id=\"charCount\">0 / 500</div>\n    <button type=\"submit\">Post Comment</button>\n    <div class=\"output\" id=\"out\"></div>\n  </form>\n  <script>function updateChar(el){const c=document.getElementById('charCount');c.textContent=el.value.length+' / 500';c.className='count'+(el.value.length>450?' warn':'');}</script>\n</body>\n</html>"
  },
  "medium": {
    "title": "Simple Markdown Editor",
    "description": "Build a split-pane markdown editor with a textarea on the left and a live preview on the right. Support: bold (**text**), italic (*text*), headings (#), lists (-), and links [text](url). The preview should update in real-time as the user types.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>MD Editor</title><style>body{margin:0;font-family:system-ui;}.editor{display:grid;grid-template-columns:1fr 1fr;height:100vh;}textarea{width:100%;height:100%;padding:20px;border:none;font-family:monospace;font-size:14px;resize:none;}.preview{padding:20px;overflow:auto;background:#f8f9fa;}</style></head>\n<body>\n  <div class=\"editor\">\n    <textarea id=\"input\"># Hello</textarea>\n    <div class=\"preview\" id=\"preview\"></div>\n  </div>\n  <script>\n    // Implement markdown parser\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>MD Editor</title><style>*{margin:0;box-sizing:border-box;}body{font-family:system-ui;}.editor{display:grid;grid-template-columns:1fr 1fr;height:100vh;}textarea{width:100%;height:100%;padding:20px;border:none;border-right:2px solid #e2e8f0;font-family:monospace;font-size:14px;line-height:1.6;resize:none;}textarea:focus{outline:none;}.preview{padding:20px;overflow:auto;background:#f8f9fa;line-height:1.6;}.preview h1{font-size:24px;margin:16px 0 8px;}.preview h2{font-size:20px;margin:12px 0 6px;}.preview ul{padding-left:20px;}.preview code{background:#e2e8f0;padding:2px 6px;border-radius:3px;font-size:13px;}.preview a{color:#4a6cf7;}</style></head>\n<body>\n  <div class=\"editor\">\n    <textarea id=\"input\" placeholder=\"Type markdown here...\"># Hello Markdown\n\nThis is **bold** and *italic* text.\n\n## Features\n- Lists with dashes\n- [Links](https://example.com)\n- `inline code`</textarea>\n    <div class=\"preview\" id=\"preview\"></div>\n  </div>\n  <script>\n    function parseMarkdown(md) {\n      return md\n        .replace(/^### (.+)/gm, '<h3>$1</h3>')\n        .replace(/^## (.+)/gm, '<h2>$1</h2>')\n        .replace(/^# (.+)/gm, '<h1>$1</h1>')\n        .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n        .replace(/\\*(.+?)\\*/g, '<em>$1</em>')\n        .replace(/`(.+?)`/g, '<code>$1</code>')\n        .replace(/\\[(.+?)\\]\\((.+?)\\)/g, '<a href=\"$2\" target=\"_blank\">$1</a>')\n        .replace(/^- (.+)/gm, '<li>$1</li>')\n        .replace(/(<li>.*<\\/li>\\n?)+/g, '<ul>$&</ul>')\n        .replace(/\\n/g, '<br>');\n    }\n    const input = document.getElementById('input');\n    const preview = document.getElementById('preview');\n    function update() { preview.innerHTML = parseMarkdown(input.value); }\n    input.addEventListener('input', update);\n    update();\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Code Editor with Syntax Highlighting",
    "description": "Build a code editor using a textarea with: line numbers, syntax highlighting overlay, tab-to-spaces, bracket matching, find/replace, and undo/redo history.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head><title>Code Editor</title></head>\n<body>\n  <div id=\"editor\"></div>\n  <script>\n    // Build code editor using textarea overlay technique\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Code Editor</title><style>*{margin:0;box-sizing:border-box;}body{background:#1a1a2e;padding:20px;font-family:'Courier New',monospace;}.editor-wrapper{max-width:800px;margin:0 auto;background:#16213e;border-radius:12px;overflow:hidden;border:1px solid #2a3a5e;}.toolbar{display:flex;gap:8px;padding:10px 16px;background:#0f3460;border-bottom:1px solid #2a3a5e;}.toolbar button{padding:6px 12px;background:#2a3a5e;color:#ccc;border:none;border-radius:4px;cursor:pointer;font-size:12px;font-family:system-ui;}.toolbar button:hover{background:#4a6cf7;color:white;}.editor-area{position:relative;display:flex;}.line-numbers{padding:16px 12px;background:#0f3460;color:#4a6cf7;text-align:right;user-select:none;font-size:14px;line-height:1.6;min-width:48px;}.code-wrapper{position:relative;flex:1;}.code-wrapper textarea,.code-wrapper .highlight{position:absolute;top:0;left:0;width:100%;height:100%;padding:16px;font-family:'Courier New',monospace;font-size:14px;line-height:1.6;border:none;overflow:auto;white-space:pre;tab-size:2;}.code-wrapper textarea{z-index:2;color:transparent;background:transparent;resize:none;caret-color:#fff;}.code-wrapper textarea:focus{outline:none;}.code-wrapper .highlight{z-index:1;color:#e2e8f0;pointer-events:none;}.code-wrapper .highlight .kw{color:#c792ea;}.code-wrapper .highlight .str{color:#c3e88d;}.code-wrapper .highlight .cm{color:#546e7a;font-style:italic;}.code-wrapper .highlight .fn{color:#82aaff;}.code-wrapper .highlight .num{color:#f78c6c;}.code-wrapper .highlight .tag{color:#f07178;}.find-bar{display:none;gap:8px;padding:8px 16px;background:#0f3460;border-top:1px solid #2a3a5e;align-items:center;font-size:13px;font-family:system-ui;}.find-bar.open{display:flex;}.find-bar input{padding:4px 8px;background:#16213e;border:1px solid #2a3a5e;border-radius:4px;color:#eee;font-size:13px;width:200px;}.find-bar input:focus{border-color:#4a6cf7;outline:none;}.find-bar .count{color:#718096;}.find-bar button{padding:4px 8px;background:#2a3a5e;color:#ccc;border:none;border-radius:4px;cursor:pointer;}</style></head>\n<body><div class=\"editor-wrapper\"><div class=\"toolbar\"><button onclick=\"insertTab()\">Tab → Spaces</button><button onclick=\"findReplace()\">🔍 Find</button><button onclick=\"undo()\">↩ Undo</button><button onclick=\"redo()\">↪ Redo</button></div><div class=\"editor-area\"><div class=\"line-numbers\" id=\"lineNum\">1</div><div class=\"code-wrapper\"><div class=\"highlight\" id=\"highlight\"></div><textarea id=\"codeArea\" spellcheck=\"false\" placeholder=\"// Write code here...\" onscroll=\"syncScroll()\" oninput=\"updateEditor()\" onkeydown=\"handleKeydown(event)\">function hello() {\n  console.log(\"Hello, World!\");\n}</textarea></div></div><div class=\"find-bar\" id=\"findBar\"><input type=\"text\" id=\"findInput\" placeholder=\"Find...\" oninput=\"findText()\"><span class=\"count\" id=\"findCount\">0</span><button onclick=\"findNext()\">↓</button><button onclick=\"findPrev()\">↑</button><button onclick=\"document.getElementById('findBar').classList.remove('open');document.getElementById('codeArea').focus()\">✕</button></div></div><script>const codeArea=document.getElementById('codeArea');const highlight=document.getElementById('highlight');const lineNum=document.getElementById('lineNum');let history=[codeArea.value];let historyIdx=0;function updateEditor(){const val=codeArea.value;highlight.innerHTML=syntaxHighlight(val);updateLineNumbers();history=history.slice(0,historyIdx+1);history.push(val);historyIdx=history.length-1;}function syntaxHighlight(code){const escaped=code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');return escaped.replace(/(\"[^\"]*\")/g,'<span class=\"str\">$1</span>').replace(/(\\'[^\\']*\\')/g,'<span class=\"str\">$1</span>').replace(/(//.*)/g,'<span class=\"cm\">$1</span>').replace(/\b(function|const|let|var|if|else|for|while|return|import|export|class|new|this|typeof|console)\b/g,'<span class=\"kw\">$1</span>').replace(/\b(\\d+)\b/g,'<span class=\"num\">$1</span>').replace(/\b([A-Z][a-zA-Z]+)\\(/g,'<span class=\"fn\">$1</span>(');}function updateLineNumbers(){const lines=codeArea.value.split('\\n').length;lineNum.textContent=Array.from({length:lines},(_,i)=>i+1).join('\\n');}function syncScroll(){highlight.scrollTop=codeArea.scrollTop;highlight.scrollLeft=codeArea.scrollLeft;lineNum.scrollTop=codeArea.scrollTop;}function handleKeydown(e){if(e.key==='Tab'){e.preventDefault();const start=codeArea.selectionStart;codeArea.setRangeText('  ',start,start,'end');updateEditor();}}function insertTab(){const start=codeArea.selectionStart;codeArea.setRangeText('  ',start,start,'end');updateEditor();}function findReplace(){document.getElementById('findBar').classList.toggle('open');if(document.getElementById('findBar').classList.contains('open'))document.getElementById('findInput').focus();}function findText(){const q=document.getElementById('findInput').value;const val=codeArea.value;if(!q){document.getElementById('findCount').textContent='0';return;}let count=0,idx=-1;const indices=[];while((idx=val.indexOf(q,idx+1))!==-1){indices.push(idx);count++;}document.getElementById('findCount').textContent=count;if(indices.length)codeArea.setSelectionRange(indices[0],indices[0]+q.length);}function findNext(){const q=document.getElementById('findInput').value;const idx=codeArea.value.indexOf(q,codeArea.selectionStart+1);if(idx!==-1)codeArea.setSelectionRange(idx,idx+q.length);}function findPrev(){const q=document.getElementById('findInput').value;const idx=codeArea.value.lastIndexOf(q,codeArea.selectionStart-1);if(idx!==-1)codeArea.setSelectionRange(idx,idx+q.length);}function undo(){if(historyIdx>0){historyIdx--;codeArea.value=history[historyIdx];updateEditor();}}function redo(){if(historyIdx<history.length-1){historyIdx++;codeArea.value=history[historyIdx];updateEditor();}}updateEditor();codeArea.focus();</script></body></html>"
  }
}
