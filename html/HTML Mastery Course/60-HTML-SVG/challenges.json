{
  "easy": {
    "title": "SVG Logo Design with Shapes and Text",
    "description": "Create an SVG logo for a fictional company called 'HexaTech' using only basic SVG shapes (rectangles, circles, polygons, and text). The logo should: include a geometric icon made of at least 3 shapes, display the company name in styled text, use gradients for coloring, and be responsive (viewBox-based).",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>HexaTech Logo</title>\n</head>\n<body>\n  <svg viewBox=\"0 0 400 200\" xmlns=\"http://www.w3.org/2000/svg\">\n    <!-- Add your shapes here -->\n  </svg>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>HexaTech Logo</title>\n  <style>\n    body { display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; background: #0f0f14; }\n    svg { max-width: 500px; width: 100%; padding: 20px; }\n  </style>\n</head>\n<body>\n  <svg viewBox=\"0 0 400 200\" xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n      <linearGradient id=\"logoGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#6C63FF\"/>\n        <stop offset=\"100%\" stop-color=\"#e94560\"/>\n      </linearGradient>\n      <linearGradient id=\"hexGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n        <stop offset=\"0%\" stop-color=\"#4ecdc4\"/>\n        <stop offset=\"100%\" stop-color=\"#6C63FF\"/>\n      </linearGradient>\n    </defs>\n    \n    <!-- Hexagon shape -->\n    <polygon points=\"100,20 170,55 170,125 100,160 30,125 30,55\" fill=\"url(#hexGrad)\" opacity=\"0.9\" />\n    \n    <!-- Inner hexagon -->\n    <polygon points=\"100,45 150,70 150,115 100,140 50,115 50,70\" fill=\"none\" stroke=\"white\" stroke-width=\"2\" opacity=\"0.4\" />\n    \n    <!-- Dots at vertices -->\n    <circle cx=\"100\" cy=\"20\" r=\"5\" fill=\"#4ecdc4\" />\n    <circle cx=\"170\" cy=\"55\" r=\"5\" fill=\"#6C63FF\" />\n    <circle cx=\"170\" cy=\"125\" r=\"5\" fill=\"#6C63FF\" />\n    <circle cx=\"100\" cy=\"160\" r=\"5\" fill=\"#e94560\" />\n    <circle cx=\"30\" cy=\"125\" r=\"5\" fill=\"#e94560\" />\n    <circle cx=\"30\" cy=\"55\" r=\"5\" fill=\"#4ecdc4\" />\n    \n    <!-- Connecting lines -->\n    <line x1=\"100\" y1=\"20\" x2=\"225\" y2=\"60\" stroke=\"#6C63FF\" stroke-width=\"1\" opacity=\"0.3\" />\n    <line x1=\"170\" y1=\"125\" x2=\"225\" y2=\"140\" stroke=\"#e94560\" stroke-width=\"1\" opacity=\"0.3\" />\n    \n    <!-- Text -->\n    <text x=\"240\" y=\"90\" font-family=\"'Segoe UI', Arial, sans-serif\" font-size=\"42\" font-weight=\"700\" fill=\"url(#logoGrad)\">Hexa</text>\n    <text x=\"240\" y=\"125\" font-family=\"'Segoe UI', Arial, sans-serif\" font-size=\"28\" font-weight=\"300\" fill=\"white\" opacity=\"0.7\">TECH</text>\n    <text x=\"240\" y=\"150\" font-family=\"Arial\" font-size=\"11\" fill=\"rgba(255,255,255,0.3)\">Scalable Solutions</text>\n  </svg>\n</body>\n</html>"
  },
  "medium": {
    "title": "Interactive SVG Dashboard Widgets",
    "description": "Build an interactive SVG dashboard with at least 3 widgets: (1) A circular progress ring (like a radial gauge) that fills to a percentage, (2) A clickable star rating widget (5 stars, toggles active state), (3) An interactive toggle switch (pill-shaped, toggle on/off with click or drag). All must use pure SVG with JavaScript interactivity.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>SVG Dashboard Widgets</title>\n</head>\n<body>\n  <div class=\"dashboard\">\n    <!-- Widget 1: Progress Ring -->\n    <svg viewBox=\"0 0 200 200\" class=\"widget\">\n    </svg>\n    <!-- Widget 2: Star Rating -->\n    <svg viewBox=\"0 0 300 100\" class=\"widget\">\n    </svg>\n    <!-- Widget 3: Toggle Switch -->\n    <svg viewBox=\"0 0 200 100\" class=\"widget\">\n    </svg>\n  </div>\n  <script>\n    // Your JavaScript here\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>SVG Dashboard Widgets</title>\n  <style>\n    body { font-family: system-ui, sans-serif; background: #1a1a2e; color: white; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; }\n    .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 800px; width: 100%; }\n    .widget { background: #16213e; border-radius: 16px; padding: 20px; aspect-ratio: 1; max-height: 250px; }\n    .widget svg { width: 100%; height: 100%; }\n  </style>\n</head>\n<body>\n  <div class=\"dashboard\">\n    <!-- Progress Ring -->\n    <div class=\"widget\">\n      <svg viewBox=\"0 0 200 200\">\n        <defs>\n          <linearGradient id=\"ringGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n            <stop offset=\"0%\" stop-color=\"#6C63FF\"/>\n            <stop offset=\"100%\" stop-color=\"#e94560\"/>\n          </linearGradient>\n        </defs>\n        <circle cx=\"100\" cy=\"100\" r=\"80\" fill=\"none\" stroke=\"rgba(255,255,255,0.1)\" stroke-width=\"12\" />\n        <circle id=\"progressRing\" cx=\"100\" cy=\"100\" r=\"80\" fill=\"none\" stroke=\"url(#ringGrad)\" stroke-width=\"12\" \n          stroke-linecap=\"round\" stroke-dasharray=\"502.65\" stroke-dashoffset=\"502.65\" \n          transform=\"rotate(-90, 100, 100)\" style=\"transition: stroke-dashoffset 0.5s ease;\" />\n        <text x=\"100\" y=\"90\" text-anchor=\"middle\" font-size=\"36\" font-weight=\"bold\" fill=\"white\" id=\"percentText\">0%</text>\n        <text x=\"100\" y=\"120\" text-anchor=\"middle\" font-size=\"12\" fill=\"rgba(255,255,255,0.5)\">Progress</text>\n        <g transform=\"translate(60, 145)\">\n          <rect x=\"0\" y=\"0\" width=\"80\" height=\"6\" rx=\"3\" style=\"cursor: pointer;\">\n            <title>Drag to change</title>\n          </rect>\n        </g>\n      </svg>\n    </div>\n\n    <!-- Star Rating -->\n    <div class=\"widget\">\n      <svg viewBox=\"0 0 300 120\" id=\"starWidget\">\n        <defs>\n          <symbol id=\"star\" viewBox=\"0 0 24 24\">\n            <path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/>\n          </symbol>\n        </defs>\n        <text x=\"150\" y=\"25\" text-anchor=\"middle\" font-size=\"14\" fill=\"rgba(255,255,255,0.5)\">Rate your experience</text>\n        <g id=\"stars\" transform=\"translate(30, 45)\">\n          <use href=\"#star\" x=\"0\" y=\"0\" width=\"40\" height=\"40\" class=\"star\" data-idx=\"0\" style=\"cursor:pointer;fill:rgba(255,255,255,0.15);transition:fill 0.2s;\" />\n          <use href=\"#star\" x=\"55\" y=\"0\" width=\"40\" height=\"40\" class=\"star\" data-idx=\"1\" style=\"cursor:pointer;fill:rgba(255,255,255,0.15);transition:fill 0.2s;\" />\n          <use href=\"#star\" x=\"110\" y=\"0\" width=\"40\" height=\"40\" class=\"star\" data-idx=\"2\" style=\"cursor:pointer;fill:rgba(255,255,255,0.15);transition:fill 0.2s;\" />\n          <use href=\"#star\" x=\"165\" y=\"0\" width=\"40\" height=\"40\" class=\"star\" data-idx=\"3\" style=\"cursor:pointer;fill:rgba(255,255,255,0.15);transition:fill 0.2s;\" />\n          <use href=\"#star\" x=\"220\" y=\"0\" width=\"40\" height=\"40\" class=\"star\" data-idx=\"4\" style=\"cursor:pointer;fill:rgba(255,255,255,0.15);transition:fill 0.2s;\" />\n        </g>\n        <text id=\"ratingText\" x=\"150\" y=\"110\" text-anchor=\"middle\" font-size=\"12\" fill=\"#feca57\">Click to rate</text>\n      </svg>\n    </div>\n\n    <!-- Toggle Switch -->\n    <div class=\"widget\">\n      <svg viewBox=\"0 0 200 120\" id=\"toggleWidget\">\n        <text x=\"100\" y=\"25\" text-anchor=\"middle\" font-size=\"14\" fill=\"rgba(255,255,255,0.5)\">Toggle Switch</text>\n        <g id=\"toggleGroup\" style=\"cursor:pointer;\">\n          <rect id=\"toggleBg\" x=\"30\" y=\"45\" width=\"140\" height=\"50\" rx=\"25\" fill=\"rgba(255,255,255,0.15)\" style=\"transition:fill 0.3s;\" />\n          <circle id=\"toggleThumb\" cx=\"55\" cy=\"70\" r=\"20\" fill=\"white\" style=\"transition:cx 0.3s;\" />\n        </g>\n        <text id=\"toggleText\" x=\"100\" y=\"110\" text-anchor=\"middle\" font-size=\"13\" fill=\"rgba(255,255,255,0.5)\">OFF</text>\n      </svg>\n    </div>\n  </div>\n\n  <script>\n    // Progress Ring\n    let progress = 0;\n    const ring = document.getElementById('progressRing');\n    const percentText = document.getElementById('percentText');\n    const circumference = 502.65;\n    \n    document.querySelectorAll('.widget')[0].addEventListener('click', (e) => {\n      progress = (progress + 10) % 110;\n      if (progress > 100) progress = 0;\n      const offset = circumference - (progress / 100) * circumference;\n      ring.setAttribute('stroke-dashoffset', offset);\n      percentText.textContent = Math.round(progress) + '%';\n    });\n\n    // Star Rating\n    let rating = 0;\n    const stars = document.querySelectorAll('.star');\n    const ratingText = document.getElementById('ratingText');\n    \n    stars.forEach((star, idx) => {\n      star.addEventListener('click', () => {\n        rating = idx + 1;\n        stars.forEach((s, i) => {\n          s.setAttribute('fill', i <= idx ? '#feca57' : 'rgba(255,255,255,0.15)');\n        });\n        ratingText.textContent = 'Rating: ' + rating + ' / 5';\n      });\n      star.addEventListener('mouseenter', () => {\n        stars.forEach((s, i) => {\n          s.setAttribute('fill', i <= idx ? '#feca57' : 'rgba(255,255,255,0.15)');\n        });\n      });\n      star.addEventListener('mouseleave', () => {\n        stars.forEach((s, i) => {\n          s.setAttribute('fill', i < rating ? '#feca57' : 'rgba(255,255,255,0.15)');\n        });\n      });\n    });\n\n    // Toggle Switch\n    let toggled = false;\n    const toggleBg = document.getElementById('toggleBg');\n    const toggleThumb = document.getElementById('toggleThumb');\n    const toggleText = document.getElementById('toggleText');\n    \n    document.getElementById('toggleGroup').addEventListener('click', () => {\n      toggled = !toggled;\n      if (toggled) {\n        toggleThumb.setAttribute('cx', '145');\n        toggleBg.setAttribute('fill', '#6C63FF');\n        toggleText.textContent = 'ON';\n        toggleText.setAttribute('fill', '#6C63FF');\n      } else {\n        toggleThumb.setAttribute('cx', '55');\n        toggleBg.setAttribute('fill', 'rgba(255,255,255,0.15)');\n        toggleText.textContent = 'OFF';\n        toggleText.setAttribute('fill', 'rgba(255,255,255,0.5)');\n      }\n    });\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "SVG Drawing Application with Path Creation and Export",
    "description": "Build a full SVG drawing application where users can: (1) Draw freeform paths by clicking and dragging on an SVG canvas, (2) Choose colors and stroke width from a palette, (3) Add basic shapes (rect, circle, line) by clicking buttons, (4) Undo the last action, (5) Export the drawing as an SVG file download, (6) Clear the canvas. All drawing tools must use SVG elements directly in the DOM.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>SVG Draw App</title>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"toolbar\">\n      <button onclick=\"setTool('pen')\">✏️ Pen</button>\n      <button onclick=\"setTool('rect')\">⬜ Rect</button>\n      <button onclick=\"setTool('circle')\">⭕ Circle</button>\n      <button onclick=\"setTool('line')\">📏 Line</button>\n      <input type=\"color\" id=\"colorPicker\" value=\"#6C63FF\">\n      <input type=\"range\" id=\"strokeWidth\" min=\"1\" max=\"20\" value=\"3\">\n      <button onclick=\"undo()\">↩ Undo</button>\n      <button onclick=\"clearCanvas()\">🗑 Clear</button>\n      <button onclick=\"exportSVG()\">💾 Export</button>\n    </div>\n    <svg id=\"drawCanvas\" viewBox=\"0 0 800 500\">\n      <rect width=\"100%\" height=\"100%\" fill=\"white\" rx=\"8\"/>\n      <g id=\"drawingLayer\"></g>\n    </svg>\n  </div>\n  <script>\n    // Your complete drawing logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>SVG Draw App</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; background: #1a1a2e; color: white; display: flex; justify-content: center; padding: 20px; margin: 0; }\n    .app { max-width: 900px; width: 100%; }\n    h1 { text-align: center; margin-bottom: 16px; font-size: 20px; color: #6C63FF; }\n    .toolbar { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; align-items: center; background: #16213e; padding: 10px 14px; border-radius: 12px; }\n    .toolbar button { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; transition: 0.2s; }\n    .toolbar button:hover { background: rgba(255,255,255,0.2); }\n    .toolbar button.active { background: #6C63FF; border-color: #6C63FF; }\n    .toolbar input[type='color'] { width: 36px; height: 32px; border: none; border-radius: 4px; cursor: pointer; background: transparent; }\n    .toolbar input[type='range'] { width: 80px; accent-color: #6C63FF; }\n    #drawCanvas { width: 100%; height: 500px; cursor: crosshair; background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }\n    .status { margin-top: 8px; font-size: 12px; color: rgba(255,255,255,0.4); text-align: center; }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <h1>✏️ SVG Drawing Application</h1>\n    <div class=\"toolbar\">\n      <button class=\"active\" onclick=\"setTool('pen')\" id=\"toolPen\">✏️ Pen</button>\n      <button onclick=\"setTool('rect')\" id=\"toolRect\">⬜ Rect</button>\n      <button onclick=\"setTool('circle')\" id=\"toolCircle\">⭕ Circle</button>\n      <button onclick=\"setTool('line')\" id=\"toolLine\">📏 Line</button>\n      <span style=\"color:rgba(255,255,255,0.3);\">|</span>\n      <input type=\"color\" id=\"colorPicker\" value=\"#6C63FF\">\n      <input type=\"range\" id=\"strokeWidthInput\" min=\"1\" max=\"20\" value=\"3\">\n      <span id=\"strokeLabel\" style=\"font-size:11px;color:rgba(255,255,255,0.4);\">3px</span>\n      <span style=\"color:rgba(255,255,255,0.3);\">|</span>\n      <button onclick=\"undo()\">↩ Undo</button>\n      <button onclick=\"clearCanvas()\">🗑 Clear</button>\n      <button onclick=\"exportSVG()\">💾 Export</button>\n    </div>\n    \n    <svg id=\"drawCanvas\" viewBox=\"0 0 800 500\" xmlns=\"http://www.w3.org/2000/svg\">\n      <rect width=\"800\" height=\"500\" fill=\"white\" rx=\"8\"/>\n      <g id=\"drawingLayer\"></g>\n    </svg>\n    <p class=\"status\" id=\"statusText\">Select a tool and start drawing!</p>\n  </div>\n\n  <script>\n    const SVG_NS = 'http://www.w3.org/2000/svg';\n    const canvas = document.getElementById('drawCanvas');\n    const layer = document.getElementById('drawingLayer');\n    const colorPicker = document.getElementById('colorPicker');\n    const strokeWidthInput = document.getElementById('strokeWidthInput');\n    const strokeLabel = document.getElementById('strokeLabel');\n    const statusText = document.getElementById('statusText');\n    \n    let currentTool = 'pen';\n    let isDrawing = false;\n    let startX, startY;\n    let currentElement = null;\n    let history = [];\n    let points = [];\n\n    // Tool setup\n    function setTool(tool) {\n      currentTool = tool;\n      document.querySelectorAll('.toolbar button').forEach(b => b.classList.remove('active'));\n      document.getElementById('tool' + tool.charAt(0).toUpperCase() + tool.slice(1)).classList.add('active');\n      statusText.textContent = 'Tool: ' + tool.charAt(0).toUpperCase() + tool.slice(1);\n    }\n\n    strokeWidthInput.addEventListener('input', () => {\n      strokeLabel.textContent = strokeWidthInput.value + 'px';\n    });\n\n    function getCoords(e) {\n      const rect = canvas.getBoundingClientRect();\n      const scaleX = 800 / rect.width;\n      const scaleY = 500 / rect.height;\n      const clientX = e.clientX || (e.touches && e.touches[0].clientX);\n      const clientY = e.clientY || (e.touches && e.touches[0].clientY);\n      return {\n        x: (clientX - rect.left) * scaleX,\n        y: (clientY - rect.top) * scaleY\n      };\n    }\n\n    function startDraw(e) {\n      e.preventDefault();\n      isDrawing = true;\n      const pos = getCoords(e);\n      startX = pos.x;\n      startY = pos.y;\n      points = [{ x: pos.x, y: pos.y }];\n      \n      const color = colorPicker.value;\n      const width = parseInt(strokeWidthInput.value);\n\n      if (currentTool === 'pen') {\n        currentElement = document.createElementNS(SVG_NS, 'path');\n        currentElement.setAttribute('d', `M ${pos.x} ${pos.y}`);\n        currentElement.setAttribute('stroke', color);\n        currentElement.setAttribute('stroke-width', width);\n        currentElement.setAttribute('fill', 'none');\n        currentElement.setAttribute('stroke-linecap', 'round');\n        currentElement.setAttribute('stroke-linejoin', 'round');\n        layer.appendChild(currentElement);\n      } else if (currentTool === 'rect') {\n        currentElement = document.createElementNS(SVG_NS, 'rect');\n        currentElement.setAttribute('x', pos.x);\n        currentElement.setAttribute('y', pos.y);\n        currentElement.setAttribute('width', 0);\n        currentElement.setAttribute('height', 0);\n        currentElement.setAttribute('fill', 'none');\n        currentElement.setAttribute('stroke', color);\n        currentElement.setAttribute('stroke-width', width);\n        layer.appendChild(currentElement);\n      } else if (currentTool === 'circle') {\n        currentElement = document.createElementNS(SVG_NS, 'circle');\n        currentElement.setAttribute('cx', pos.x);\n        currentElement.setAttribute('cy', pos.y);\n        currentElement.setAttribute('r', 0);\n        currentElement.setAttribute('fill', 'none');\n        currentElement.setAttribute('stroke', color);\n        currentElement.setAttribute('stroke-width', width);\n        layer.appendChild(currentElement);\n      } else if (currentTool === 'line') {\n        currentElement = document.createElementNS(SVG_NS, 'line');\n        currentElement.setAttribute('x1', pos.x);\n        currentElement.setAttribute('y1', pos.y);\n        currentElement.setAttribute('x2', pos.x);\n        currentElement.setAttribute('y2', pos.y);\n        currentElement.setAttribute('stroke', color);\n        currentElement.setAttribute('stroke-width', width);\n        currentElement.setAttribute('stroke-linecap', 'round');\n        layer.appendChild(currentElement);\n      }\n    }\n\n    function draw(e) {\n      if (!isDrawing || !currentElement) return;\n      e.preventDefault();\n      const pos = getCoords(e);\n      \n      if (currentTool === 'pen') {\n        points.push({ x: pos.x, y: pos.y });\n        const d = points.map((p, i) => (i === 0 ? 'M' : 'L') + ` ${p.x} ${p.y}`).join(' ');\n        currentElement.setAttribute('d', d);\n      } else if (currentTool === 'rect') {\n        const x = Math.min(startX, pos.x);\n        const y = Math.min(startY, pos.y);\n        const w = Math.abs(pos.x - startX);\n        const h = Math.abs(pos.y - startY);\n        currentElement.setAttribute('x', x);\n        currentElement.setAttribute('y', y);\n        currentElement.setAttribute('width', w);\n        currentElement.setAttribute('height', h);\n      } else if (currentTool === 'circle') {\n        const r = Math.sqrt((pos.x - startX) ** 2 + (pos.y - startY) ** 2);\n        currentElement.setAttribute('r', r);\n      } else if (currentTool === 'line') {\n        currentElement.setAttribute('x2', pos.x);\n        currentElement.setAttribute('y2', pos.y);\n      }\n    }\n\n    function endDraw(e) {\n      if (!isDrawing) return;\n      isDrawing = false;\n      if (currentElement) {\n        history.push(currentElement);\n        currentElement = null;\n        statusText.textContent = 'Element added. ' + history.length + ' total';\n      }\n    }\n\n    // Mouse events\n    canvas.addEventListener('mousedown', startDraw);\n    canvas.addEventListener('mousemove', draw);\n    canvas.addEventListener('mouseup', endDraw);\n    canvas.addEventListener('mouseleave', endDraw);\n\n    // Touch events\n    canvas.addEventListener('touchstart', startDraw, { passive: false });\n    canvas.addEventListener('touchmove', draw, { passive: false });\n    canvas.addEventListener('touchend', endDraw);\n\n    function undo() {\n      if (history.length === 0) return;\n      const last = history.pop();\n      if (last && last.parentNode) last.parentNode.removeChild(last);\n      statusText.textContent = 'Undo. ' + history.length + ' elements remaining';\n    }\n\n    function clearCanvas() {\n      while (layer.firstChild) layer.removeChild(layer.firstChild);\n      history = [];\n      statusText.textContent = 'Canvas cleared';\n    }\n\n    function exportSVG() {\n      const clone = canvas.cloneNode(true);\n      // Remove event handlers if any\n      const serializer = new XMLSerializer();\n      const svgString = serializer.serializeToString(clone);\n      const blob = new Blob([svgString], { type: 'image/svg+xml' });\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url;\n      a.download = 'drawing.svg';\n      a.click();\n      URL.revokeObjectURL(url);\n      statusText.textContent = 'SVG exported!';\n    }\n  </script>\n</body>\n</html>"
  }
}
