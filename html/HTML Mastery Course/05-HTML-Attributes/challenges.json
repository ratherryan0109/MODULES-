{
  "easy": {
    "title": "Create a Profile Card with Attributes",
    "description": "Build a personal profile card using various HTML attributes. Include an image with alt, width, height, and title attributes, a name heading, a paragraph with a style attribute, a link with href, target, and title, and a data-* attribute on the card div.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Profile Card</title>\n</head>\n<body>\n    <!-- Build a profile card using attributes -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Profile Card</title>\n</head>\n<body>\n    <div data-user-id=\"101\" data-role=\"student\" style=\"border: 2px solid #333; padding: 20px; max-width: 350px; border-radius: 10px;\">\n        <img src=\"https://via.placeholder.com/150\" alt=\"Profile photo of Jane Doe\" width=\"150\" height=\"150\" title=\"Jane Doe's Profile Photo\" style=\"border-radius: 50%;\">\n        <h1>Jane Doe</h1>\n        <p style=\"color: #666; font-style: italic;\">Web Development Student at HTML Mastery Course</p>\n        <p>I am passionate about learning HTML, CSS, and JavaScript to build amazing web experiences.</p>\n        <a href=\"https://example.com\" target=\"_blank\" rel=\"noopener\" title=\"Visit my portfolio\">View Portfolio</a>\n    </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Form with Various Input Attributes",
    "description": "Create a registration form that demonstrates at least 15 different HTML attributes. Include: placeholder, required, disabled, readonly, autofocus, maxlength, min, max, pattern, multiple, accept, autocomplete, checked, selected, and value attributes. The form should have fields for name, email, password, age, birthday, file upload, country selection, interests (checkboxes), gender (radio), bio, and a submit button.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Registration Form - Attributes Demo</title>\n</head>\n<body>\n    <!-- Build a form demonstrating HTML attributes -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Registration Form - Attributes Demo</title>\n</head>\n<body>\n    <h1>Registration Form</h1>\n    <form>\n        <fieldset>\n            <legend>Personal Information</legend>\n            <label for=\"name\">Full Name:</label>\n            <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"Enter your full name\" required autofocus maxlength=\"50\"><br><br>\n\n            <label for=\"email\">Email:</label>\n            <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"you@example.com\" required multiple><br><br>\n\n            <label for=\"password\">Password:</label>\n            <input type=\"password\" id=\"password\" name=\"password\" placeholder=\"At least 8 characters\" required minlength=\"8\" maxlength=\"20\" pattern=\"(?=.*\\d)(?=.*[a-z])(?=.*[A-Z]).{8,}\" title=\"Must contain uppercase, lowercase, and a number\"><br><br>\n\n            <label for=\"age\">Age:</label>\n            <input type=\"number\" id=\"age\" name=\"age\" min=\"18\" max=\"120\" value=\"25\"><br><br>\n\n            <label for=\"birthday\">Birthday:</label>\n            <input type=\"date\" id=\"birthday\" name=\"birthday\" min=\"1900-01-01\" max=\"2008-12-31\"><br><br>\n\n            <label for=\"photo\">Profile Photo:</label>\n            <input type=\"file\" id=\"photo\" name=\"photo\" accept=\"image/png, image/jpeg\" multiple><br><br>\n        </fieldset>\n\n        <fieldset>\n            <legend>Preferences</legend>\n            <label for=\"country\">Country:</label>\n            <select id=\"country\" name=\"country\">\n                <option value=\"\">-- Select --</option>\n                <option value=\"us\" selected>United States</option>\n                <option value=\"uk\">United Kingdom</option>\n                <option value=\"ca\">Canada</option>\n            </select><br><br>\n\n            <p>Interests:</p>\n            <label><input type=\"checkbox\" name=\"interests\" value=\"coding\" checked> Coding</label><br>\n            <label><input type=\"checkbox\" name=\"interests\" value=\"design\"> Design</label><br>\n            <label><input type=\"checkbox\" name=\"interests\" value=\"music\"> Music</label><br><br>\n\n            <p>Gender:</p>\n            <label><input type=\"radio\" name=\"gender\" value=\"male\" checked> Male</label><br>\n            <label><input type=\"radio\" name=\"gender\" value=\"female\"> Female</label><br>\n            <label><input type=\"radio\" name=\"gender\" value=\"other\"> Other</label><br><br>\n\n            <label for=\"bio\">Bio (readonly):</label><br>\n            <textarea id=\"bio\" name=\"bio\" rows=\"4\" cols=\"40\" readonly placeholder=\"This field is readonly\">Default bio text here.</textarea><br><br>\n\n            <input type=\"text\" value=\"This field is disabled\" disabled><br><br>\n        </fieldset>\n\n        <button type=\"submit\" disabled>Submit (disabled demo)</button>\n        <button type=\"reset\">Reset</button>\n    </form>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build a Data Dashboard with ARIA and Data Attributes",
    "description": "Create a data dashboard page that demonstrates advanced attribute usage. Include: a navigation with aria-current and aria-label, a data table with scope and aria-* attributes for accessibility, interactive elements with data-* attributes storing complex data, a progress bar with aria-valuenow, aria-valuemin, and aria-valuemax, a section using contenteditable, and hidden elements using the hidden attribute. Each element must use proper semantic attributes.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dashboard - Advanced Attributes</title>\n</head>\n<body>\n    <!-- Build a dashboard with ARIA and data attributes -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Advanced HTML attributes dashboard demo\">\n    <title>Dashboard - Advanced Attributes</title>\n</head>\n<body>\n    <header>\n        <h1>Data Dashboard</h1>\n        <nav aria-label=\"Main navigation\">\n            <a href=\"#overview\" aria-current=\"page\">Overview</a>\n            <a href=\"#analytics\">Analytics</a>\n            <a href=\"#settings\">Settings</a>\n        </nav>\n    </header>\n\n    <main>\n        <section id=\"overview\" aria-labelledby=\"overview-title\">\n            <h2 id=\"overview-title\">Overview</h2>\n\n            <div class=\"stats-grid\">\n                <div data-stat-type=\"users\" data-stat-value=\"1250\" data-stat-change=\"+12%\" aria-label=\"1250 total users, 12% increase\" style=\"border: 1px solid #ddd; padding: 15px; margin: 10px 0;\">\n                    <h3>Total Users</h3>\n                    <p aria-describedby=\"user-count-desc\"><strong>1,250</strong></p>\n                    <p id=\"user-count-desc\" style=\"color: green;\">↑ 12% from last month</p>\n                </div>\n\n                <div data-stat-type=\"revenue\" data-stat-value=\"45250\" data-stat-currency=\"USD\" style=\"border: 1px solid #ddd; padding: 15px; margin: 10px 0;\">\n                    <h3>Revenue</h3>\n                    <p><strong>$45,250</strong></p>\n                    <div role=\"progressbar\" aria-valuenow=\"75\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-label=\"75% of monthly goal\" style=\"background: #eee; height: 20px; width: 100%; border-radius: 10px;\">\n                        <div style=\"background: #3498db; width: 75%; height: 20px; border-radius: 10px;\"></div>\n                    </div>\n                    <p><small>75% of monthly goal</small></p>\n                </div>\n            </div>\n\n            <div contenteditable=\"true\" spellcheck=\"true\" style=\"border: 2px dashed #ccc; padding: 15px; margin: 10px 0;\" aria-label=\"Editable notes section\">\n                <p><strong>Notes (editable):</strong> Click here to add notes about the dashboard data...</p>\n            </div>\n\n            <div hidden aria-hidden=\"true\">\n                <p>This content is hidden and should not be visible.</p>\n            </div>\n        </section>\n\n        <section id=\"analytics\" aria-labelledby=\"analytics-title\">\n            <h2 id=\"analytics-title\">User Analytics</h2>\n            <table aria-label=\"User analytics data table\">\n                <thead>\n                    <tr>\n                        <th scope=\"col\">Name</th>\n                        <th scope=\"col\">Role</th>\n                        <th scope=\"col\" aria-sort=\"ascending\">Status</th>\n                        <th scope=\"col\">Actions</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr data-user-id=\"1\" data-user-role=\"admin\" data-user-active=\"true\">\n                        <td scope=\"row\">Alice Smith</td>\n                        <td>Admin</td>\n                        <td aria-label=\"Active status\">✅ Active</td>\n                        <td><button aria-label=\"Edit Alice Smith's profile\">Edit</button></td>\n                    </tr>\n                    <tr data-user-id=\"2\" data-user-role=\"editor\" data-user-active=\"false\">\n                        <td scope=\"row\">Bob Jones</td>\n                        <td>Editor</td>\n                        <td aria-label=\"Inactive status\">❌ Inactive</td>\n                        <td><button aria-label=\"Edit Bob Jones's profile\">Edit</button></td>\n                    </tr>\n                    <tr data-user-id=\"3\" data-user-role=\"viewer\" data-user-active=\"true\">\n                        <td scope=\"row\">Carol Lee</td>\n                        <td>Viewer</td>\n                        <td aria-label=\"Active status\">✅ Active</td>\n                        <td><button aria-label=\"Edit Carol Lee's profile\">Edit</button></td>\n                    </tr>\n                </tbody>\n            </table>\n\n            <br>\n            <details>\n                <summary>Accessibility Notes</summary>\n                <p>This table uses <code>scope</code>, <code>aria-label</code>, and <code>aria-sort</code> attributes for screen reader compatibility.</p>\n            </details>\n        </section>\n    </main>\n\n    <footer>\n        <p><small>&copy; 2026 Dashboard App. All data is for demonstration purposes.</small></p>\n    </footer>\n</body>\n</html>"
  }
}
