{
  "easy": {
    "title": "Optimize a Slow HTML Page",
    "description": "The following HTML page has multiple performance issues: render-blocking scripts in the head, missing image dimensions, no lazy loading, no resource hints, and inline CSS not separated. Fix all these issues to create a performance-optimized version.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Slow Page</title>\n  <script src=\"jquery.js\"></script>\n  <script src=\"app.js\"></script>\n  <link rel=\"stylesheet\" href=\"styles.css\">\n  <link rel=\"stylesheet\" href=\"theme.css\">\n</head>\n<body>\n  <h1>Welcome</h1>\n  <img src=\"hero.jpg\" alt=\"Hero\">\n  <img src=\"gallery1.jpg\" alt=\"Gallery\">\n  <img src=\"gallery2.jpg\" alt=\"Gallery\">\n  <script src=\"analytics.js\"></script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Optimized Page</title>\n  <meta name=\"description\" content=\"Performance optimized page\">\n  \n  <link rel=\"preconnect\" href=\"https://cdn.example.com\">\n  <link rel=\"preload\" href=\"hero.webp\" as=\"image\">\n  \n  <style>\n    body { font-family: sans-serif; margin: 0; padding: 20px; }\n    h1 { color: #333; }\n  </style>\n  \n  <link rel=\"preload\" href=\"styles.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n  <noscript><link rel=\"stylesheet\" href=\"styles.css\"></noscript>\n  <link rel=\"preload\" href=\"theme.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n  <noscript><link rel=\"stylesheet\" href=\"theme.css\"></noscript>\n</head>\n<body>\n  <h1>Welcome</h1>\n  <img src=\"hero.webp\" alt=\"Hero\" width=\"1200\" height=\"600\"\n       srcset=\"hero-600.webp 600w, hero-1200.webp 1200w\"\n       sizes=\"100vw\"\n       loading=\"eager\" decoding=\"async\">\n  <img src=\"gallery1.webp\" alt=\"Gallery image 1\" width=\"400\" height=\"300\" loading=\"lazy\" decoding=\"async\">\n  <img src=\"gallery2.webp\" alt=\"Gallery image 2\" width=\"400\" height=\"300\" loading=\"lazy\" decoding=\"async\">\n  \n  <script src=\"app.js\" defer></script>\n  <script src=\"analytics.js\" async></script>\n</body>\n</html>"
  },
  "medium": {
    "title": "Implement Critical CSS and Async Loading",
    "description": "You have a full CSS file (styles.css) at 120KB. Your above-the-fold critical CSS is approximately 8KB. Implement the critical CSS pattern: inline the critical CSS, load the full CSS asynchronously, add a noscript fallback, and also preload the hero image and a web font (Inter var woff2).",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Critical CSS Demo</title>\n  <!-- TODO: Preconnect to Google Fonts -->\n  \n  <!-- TODO: Preload hero image -->\n  \n  <!-- TODO: Preload Inter font -->\n  \n  <!-- TODO: Inline critical CSS here -->\n  \n  <!-- TODO: Async load full styles.css -->\n  \n  <!-- TODO: Noscript fallback -->\n</head>\n<body>\n  <header style=\"background: #333; color: white;\">\n    <h1>My App</h1>\n  </header>\n  <section class=\"hero\">\n    <img src=\"hero.jpg\" alt=\"Hero banner\" width=\"1200\" height=\"500\">\n    <h2>Welcome to My App</h2>\n    <p>This content is above the fold.</p>\n  </section>\n  <section class=\"content\" style=\"margin-top: 200vh;\">\n    <p>This content is below the fold.</p>\n  </section>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Critical CSS Demo</title>\n  \n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  \n  <link rel=\"preload\" href=\"hero.webp\" as=\"image\">\n  <link rel=\"preload\" href=\"/fonts/inter-var.woff2\" as=\"font\" type=\"font/woff2\" crossorigin>\n  \n  <style>\n    /* Critical CSS - above the fold only */\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: sans-serif; line-height: 1.6; }\n    header { background: #333; color: white; padding: 1rem; }\n    header h1 { font-size: 1.5rem; }\n    .hero { position: relative; text-align: center; padding: 4rem 1rem; }\n    .hero img { max-width: 100%; height: auto; }\n    .hero h2 { font-size: 2.5rem; margin: 1rem 0; }\n    .hero p { font-size: 1.125rem; max-width: 600px; margin: 0 auto; }\n  </style>\n  \n  <link rel=\"preload\" href=\"styles.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n  <noscript><link rel=\"stylesheet\" href=\"styles.css\"></noscript>\n  \n  <style>\n    @font-face {\n      font-family: 'Inter';\n      src: url('/fonts/inter-var.woff2') format('woff2');\n      font-display: swap;\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>My App</h1>\n  </header>\n  <main>\n    <section class=\"hero\">\n      <img src=\"hero.webp\" alt=\"Hero banner\" width=\"1200\" height=\"500\" loading=\"eager\" decoding=\"async\">\n      <h2>Welcome to My App</h2>\n      <p>This content is above the fold.</p>\n    </section>\n    <section class=\"content\" style=\"margin-top: 200vh;\">\n      <p>This content is below the fold. Its styles will be applied when the full CSS loads.</p>\n    </section>\n  </main>\n</body>\n</html>"
  },
  "hard": {
    "title": "Full Performance Audit and Optimization",
    "description": "You are given a complete e-commerce product page with severe performance issues. Perform a full audit and optimization: identify all render-blocking resources, implement critical CSS, defer scripts, add resource hints, optimize all images with responsive srcset and lazy loading, preload fonts, add proper font-display, set up caching headers (through meta equivalents), add performance monitoring markup, and ensure the page passes a Lighthouse performance budget. The page must score above 90 on Lighthouse Performance after optimization.",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Product Page</title>\n  <meta charset=\"UTF-8\">\n  <script src=\"https://cdn.example.com/slider.js\"></script>\n  <script src=\"https://cdn.example.com/analytics.js\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.example.com/framework.css\">\n  <link rel=\"stylesheet\" href=\"https://cdn.example.com/icons.css\">\n  <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Open+Sans\">\n  <script src=\"app.js\"></script>\n</head>\n<body>\n  <header>\n    <a href=\"/\"><img src=\"logo.png\" alt=\"Logo\"></a>\n    <nav>\n      <ul>\n        <li><a href=\"/\">Home</a></li>\n        <li><a href=\"/products\">Products</a></li>\n        <li><a href=\"/cart\">Cart</a></li>\n      </ul>\n    </nav>\n  </header>\n  <main>\n    <div class=\"product-hero\">\n      <img src=\"product-main.jpg\" alt=\"Product main image\">\n      <img src=\"product-thumb1.jpg\" alt=\"Product thumbnail\">\n      <img src=\"product-thumb2.jpg\" alt=\"Product thumbnail\">\n      <img src=\"product-thumb3.jpg\" alt=\"Product thumbnail\">\n      <img src=\"product-thumb4.jpg\" alt=\"Product thumbnail\">\n    </div>\n    <div class=\"product-info\">\n      <h1>Premium Headphones</h1>\n      <p class=\"price\">$129.99</p>\n      <p class=\"description\">High-quality wireless headphones with noise cancellation...</p>\n      <button>Add to Cart</button>\n    </div>\n    <div class=\"reviews\">\n      <h2>Customer Reviews</h2>\n      <div class=\"review\">Awesome product! - John</div>\n      <div class=\"review\">Great sound quality - Sarah</div>\n    </div>\n    <div class=\"related-products\">\n      <img src=\"related1.jpg\" alt=\"Related\">\n      <img src=\"related2.jpg\" alt=\"Related\">\n      <img src=\"related3.jpg\" alt=\"Related\">\n      <img src=\"related4.jpg\" alt=\"Related\">\n    </div>\n  </main>\n  <script src=\"gallery.js\"></script>\n  <script src=\"cart.js\"></script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Premium Headphones - Store Name</title>\n  <meta name=\"description\" content=\"Premium wireless headphones with noise cancellation - Shop now\">\n  \n  <link rel=\"preconnect\" href=\"https://cdn.example.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link rel=\"dns-prefetch\" href=\"https://cdn.example.com\">\n  \n  <link rel=\"preload\" href=\"product-main.webp\" as=\"image\">\n  <link rel=\"preload\" href=\"/fonts/inter.woff2\" as=\"font\" type=\"font/woff2\" crossorigin>\n  \n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; }\n    header { background: #fff; padding: 1rem; border-bottom: 1px solid #eee; }\n    header nav ul { list-style: none; display: flex; gap: 1rem; }\n    .product-hero { max-width: 1200px; margin: 0 auto; padding: 2rem; }\n    .product-hero img { max-width: 100%; height: auto; }\n    .product-info { max-width: 600px; margin: 0 auto; padding: 2rem; }\n    .product-info h1 { font-size: 2rem; margin-bottom: 1rem; }\n    .price { font-size: 1.5rem; color: #e74c3c; font-weight: bold; }\n    button { background: #2ecc71; color: white; border: none; padding: 1rem 2rem; font-size: 1.1rem; cursor: pointer; border-radius: 4px; }\n    .reviews, .related-products { max-width: 1200px; margin: 2rem auto; padding: 0 2rem; }\n  </style>\n  \n  <link rel=\"preload\" href=\"https://cdn.example.com/framework.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n  <noscript><link rel=\"stylesheet\" href=\"https://cdn.example.com/framework.css\"></noscript>\n  <link rel=\"preload\" href=\"https://cdn.example.com/icons.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n  <noscript><link rel=\"stylesheet\" href=\"https://cdn.example.com/icons.css\"></noscript>\n</head>\n<body>\n  <header>\n    <a href=\"/\"><img src=\"logo.svg\" alt=\"Store Name - Home\" width=\"120\" height=\"40\"></a>\n    <nav aria-label=\"Main navigation\">\n      <ul>\n        <li><a href=\"/\">Home</a></li>\n        <li><a href=\"/products\">Products</a></li>\n        <li><a href=\"/cart\">Cart</a></li>\n      </ul>\n    </nav>\n  </header>\n  \n  <main>\n    <div class=\"product-hero\">\n      <img src=\"product-main.webp\" alt=\"Premium Headphones - Main view\"\n           width=\"800\" height=\"800\"\n           srcset=\"product-main-400.webp 400w, product-main-800.webp 800w, product-main-1200.webp 1200w\"\n           sizes=\"(max-width: 600px) 100vw, 800px\"\n           loading=\"eager\" decoding=\"async\">\n      <div style=\"display: flex; gap: 0.5rem; margin-top: 1rem;\">\n        <img src=\"product-thumb1.webp\" alt=\"Headphones angle view\" width=\"100\" height=\"100\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"product-thumb2.webp\" alt=\"Headphones close up\" width=\"100\" height=\"100\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"product-thumb3.webp\" alt=\"Headphones with case\" width=\"100\" height=\"100\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"product-thumb4.webp\" alt=\"Headphones on stand\" width=\"100\" height=\"100\" loading=\"lazy\" decoding=\"async\">\n      </div>\n    </div>\n    \n    <div class=\"product-info\">\n      <h1>Premium Headphones</h1>\n      <p class=\"price\">$129.99</p>\n      <p class=\"description\">High-quality wireless headphones with active noise cancellation, 30-hour battery life, and premium comfort.</p>\n      <button>Add to Cart</button>\n    </div>\n    \n    <div class=\"reviews\">\n      <h2>Customer Reviews</h2>\n      <div class=\"review\">Awesome product! - John</div>\n      <div class=\"review\">Great sound quality - Sarah</div>\n    </div>\n    \n    <div class=\"related-products\">\n      <h2>Related Products</h2>\n      <div style=\"display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem;\">\n        <img src=\"related1.webp\" alt=\"Related product 1\" width=\"150\" height=\"150\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"related2.webp\" alt=\"Related product 2\" width=\"150\" height=\"150\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"related3.webp\" alt=\"Related product 3\" width=\"150\" height=\"150\" loading=\"lazy\" decoding=\"async\">\n        <img src=\"related4.webp\" alt=\"Related product 4\" width=\"150\" height=\"150\" loading=\"lazy\" decoding=\"async\">\n      </div>\n    </div>\n  </main>\n  \n  <!-- Deferred third-party scripts -->\n  <script src=\"https://cdn.example.com/slider.js\" defer></script>\n  <script src=\"https://cdn.example.com/analytics.js\" async></script>\n  <script src=\"app.js\" defer></script>\n  <script src=\"gallery.js\" defer></script>\n  <script src=\"cart.js\" defer></script>\n</body>\n</html>"
  }
}