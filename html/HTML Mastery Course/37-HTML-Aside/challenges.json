{
  "easy": {
    "title": "Blog Page with Sidebar Aside",
    "description": "Create a blog page with a main article and an <aside> sidebar containing related links, categories, and an author bio. Ensure the aside has an accessible name.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Blog with Sidebar</title>\n</head>\n<body>\n  <main>\n    <article>\n      <h1>Blog Post Title</h1>\n      <p>Content...</p>\n    </article>\n  </main>\n  <!-- Add aside here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Blog with Sidebar</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 1000px; margin: 0 auto; padding: 20px; }\n    .layout { display: grid; grid-template-columns: 1fr 300px; gap: 30px; }\n    aside { background: #f9f9f9; padding: 20px; border-radius: 8px; }\n    h2 { color: #e65100; }\n  </style>\n</head>\n<body>\n  <div class=\"layout\">\n    <main>\n      <article>\n        <h1>Understanding HTML Semantics</h1>\n        <p>Semantic HTML5 elements provide meaning to web content beyond simple presentation...</p>\n      </article>\n    </main>\n    <aside aria-labelledby=\"sidebar-heading\">\n      <h2 id=\"sidebar-heading\">Related Content</h2>\n      <section>\n        <h3>Popular Articles</h3>\n        <ul>\n          <li><a href=\"#\">CSS Grid Guide</a></li>\n          <li><a href=\"#\">JavaScript Basics</a></li>\n          <li><a href=\"#\">Web Accessibility</a></li>\n        </ul>\n      </section>\n      <section>\n        <h3>About the Author</h3>\n        <p>Jane Doe is a web developer and educator passionate about semantic HTML.</p>\n      </section>\n    </aside>\n  </div>\n</body>\n</html>"
  },
  "medium": {
    "title": "Article with Pull Quotes and Glossary",
    "description": "Create an article that uses <aside> for pull quotes (at least 2) and a glossary section. The article should be about a technical topic. Use CSS to style pull quotes with a distinct left border and italic text.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Article with Pull Quotes</title>\n  <style>\n    /* Style pull quotes */\n  </style>\n</head>\n<body>\n  <main>\n    <article>\n      <h1>Article Title</h1>\n      <!-- Content with pull quotes -->\n    </article>\n  </main>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Article with Pull Quotes</title>\n  <style>\n    body { font-family: Georgia, serif; max-width: 700px; margin: 0 auto; padding: 20px; line-height: 1.8; }\n    .pull-quote { background: #f9f9f9; border-left: 4px solid #e65100; padding: 15px 20px; margin: 20px 0; font-style: italic; font-size: 1.1em; }\n    .pull-quote cite { display: block; text-align: right; font-size: 0.9em; color: #666; }\n    .glossary-term { font-weight: bold; color: #e65100; }\n  </style>\n</head>\n<body>\n  <main>\n    <article>\n      <h1>The Art of Web Performance Optimization</h1>\n      <p>Web performance is critical for user experience and search engine rankings. Studies show that a 1-second delay in page load time can result in a 7% reduction in conversions.</p>\n      \n      <aside class=\"pull-quote\">\n        <blockquote>\n          \"Performance is not just a technical concern; it's a user experience and business imperative.\"\n          <cite>— Web Performance Expert</cite>\n        </blockquote>\n      </aside>\n      \n      <p>One of the most effective techniques is lazy loading, which defers the loading of non-critical resources...</p>\n      \n      <aside class=\"pull-quote\">\n        <blockquote>\n          \"The best optimization is the one the user never notices.\"\n          <cite>— Performance Engineer</cite>\n        </blockquote>\n      </aside>\n      \n      <p>Another key strategy is code splitting, which breaks your JavaScript bundle into smaller chunks...</p>\n      \n      <aside aria-label=\"Glossary\">\n        <h2>Key Terms</h2>\n        <dl>\n          <dt><span class=\"glossary-term\">Lazy Loading</span></dt>\n          <dd>Delaying loading of resources until they are needed.</dd>\n          <dt><span class=\"glossary-term\">Code Splitting</span></dt>\n          <dd>Breaking code into smaller bundles loaded on demand.</dd>\n        </dl>\n      </aside>\n    </article>\n  </main>\n</body>\n</html>"
  },
  "hard": {
    "title": "Responsive Dashboard with Accessible Sidebar",
    "description": "Build a dashboard layout with main content area and an <aside> that transforms from a visible sidebar on desktop to a toggle-able off-canvas panel on mobile. Include ARIA attributes for the toggle button, manage focus when the sidebar opens/closes, and ensure the aside has accessible naming.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Dashboard</title>\n  <style>\n    /* Responsive layout */\n  </style>\n</head>\n<body>\n  <header>Dashboard Header</header>\n  <div class=\"layout\">\n    <main>Main Content</main>\n    <aside>Sidebar</aside>\n  </div>\n  <script>\n    // Toggle logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Responsive Dashboard</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; min-height: 100vh; display: flex; flex-direction: column; }\n    header { background: #1a73e8; color: white; padding: 1rem; display: flex; justify-content: space-between; align-items: center; }\n    .layout { display: flex; flex: 1; }\n    main { flex: 1; padding: 20px; }\n    aside { width: 280px; background: #f5f5f5; padding: 20px; border-left: 1px solid #ddd; }\n    .toggle-btn { display: none; background: none; border: none; color: white; font-size: 1.5em; cursor: pointer; }\n    @media (max-width: 768px) {\n      .layout { position: relative; }\n      aside { position: fixed; top: 0; right: -280px; width: 280px; height: 100vh; z-index: 1000; transition: right 0.3s; border-left: none; box-shadow: -2px 0 5px rgba(0,0,0,0.1); }\n      aside.open { right: 0; }\n      .toggle-btn { display: block; }\n      .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999; }\n      .overlay.active { display: block; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Dashboard</h1>\n    <button class=\"toggle-btn\" id=\"sidebarToggle\" aria-label=\"Open sidebar\" aria-expanded=\"false\" aria-controls=\"dashboard-sidebar\">☰</button>\n  </header>\n  <div class=\"overlay\" id=\"overlay\"></div>\n  <div class=\"layout\">\n    <main>\n      <h2>Main Content</h2>\n      <p>Welcome to your dashboard. Use the sidebar to navigate.</p>\n    </main>\n    <aside id=\"dashboard-sidebar\" aria-labelledby=\"sidebar-title\">\n      <h2 id=\"sidebar-title\">Controls</h2>\n      <nav aria-label=\"Dashboard navigation\">\n        <ul>\n          <li><a href=\"#\">Overview</a></li>\n          <li><a href=\"#\">Analytics</a></li>\n          <li><a href=\"#\">Settings</a></li>\n          <li><a href=\"#\">Profile</a></li>\n        </ul>\n      </nav>\n    </aside>\n  </div>\n  <script>\n    const toggle = document.getElementById('sidebarToggle');\n    const sidebar = document.getElementById('dashboard-sidebar');\n    const overlay = document.getElementById('overlay');\n    function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('active'); toggle.setAttribute('aria-expanded', 'true'); toggle.setAttribute('aria-label', 'Close sidebar'); sidebar.querySelector('h2').focus(); }\n    function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('active'); toggle.setAttribute('aria-expanded', 'false'); toggle.setAttribute('aria-label', 'Open sidebar'); toggle.focus(); }\n    toggle.addEventListener('click', () => { sidebar.classList.contains('open') ? closeSidebar() : openSidebar(); });\n    overlay.addEventListener('click', closeSidebar);\n    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) closeSidebar(); });\n  </script>\n</body>\n</html>"
  }
}