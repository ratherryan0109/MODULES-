{
  "easy": {
    "title": "Profile Editor with Live Validation",
    "description": "Create a profile editor form with live validation feedback. Fields: Full Name (required, 2-50 chars, letters/spaces only), Email (required, valid format), Age (required, 13-120), Website (optional, valid URL), Bio (optional, max 500 chars, show remaining count). Each field should show a green checkmark when valid and a red error message when invalid. Validate on blur and clear errors on input.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Profile Editor</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; }\n    .field { margin-bottom: 15px; }\n    label { display: block; margin-bottom: 4px; font-weight: 500; }\n    input, textarea { width: 100%; padding: 8px; border: 2px solid #ddd; border-radius: 4px; box-sizing: border-box; }\n    .feedback { font-size: 12px; margin-top: 4px; }\n    .error { color: #e74c3c; display: none; }\n    .success { color: #4caf50; display: none; }\n    .char-count { font-size: 12px; color: #666; text-align: right; }\n    button { padding: 10px 25px; background: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer; }\n  </style>\n</head>\n<body>\n  <h1>Edit Profile</h1>\n  <form id=\"profileForm\" novalidate>\n    <!-- Add form fields here -->\n    <button type=\"submit\">Save Profile</button>\n  </form>\n  <script>\n    // Add validation logic here\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Profile Editor</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #f8f9fa; }\n    h1 { color: #2c3e50; }\n    .field { margin-bottom: 15px; }\n    label { display: block; margin-bottom: 4px; font-weight: 500; font-size: 14px; color: #333; }\n    input, textarea { width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 14px; transition: border-color 0.2s; }\n    input:focus, textarea:focus { outline: none; border-color: #3498db; }\n    .feedback { font-size: 12px; margin-top: 4px; min-height: 16px; }\n    .error { color: #e74c3c; display: none; }\n    .success { color: #4caf50; display: none; }\n    .char-count { font-size: 12px; color: #666; text-align: right; }\n    button { padding: 12px 30px; background: #3498db; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px; transition: background 0.2s; }\n    button:hover { background: #2980b9; }\n    .field.valid input, .field.valid textarea { border-color: #4caf50; }\n    .field.invalid input, .field.invalid textarea { border-color: #e74c3c; }\n    .success-msg { color: #4caf50; font-weight: 500; text-align: center; }\n  </style>\n</head>\n<body>\n  <h1>Edit Profile</h1>\n  <form id='profileForm' novalidate>\n    <div class='field'>\n      <label>Full Name</label>\n      <input type='text' id='name' required minlength='2' maxlength='50' pattern='[A-Za-z ]+' placeholder='John Doe'>\n      <div class='feedback'><span class='error'>Enter 2-50 letters and spaces only</span><span class='success'>✓ Looks good</span></div>\n    </div>\n    <div class='field'>\n      <label>Email</label>\n      <input type='email' id='email' required placeholder='john@example.com'>\n      <div class='feedback'><span class='error'>Enter a valid email address</span><span class='success'>✓ Valid email</span></div>\n    </div>\n    <div class='field'>\n      <label>Age</label>\n      <input type='number' id='age' required min='13' max='120' placeholder='25'>\n      <div class='feedback'><span class='error'>Must be between 13 and 120</span><span class='success'>✓ Valid age</span></div>\n    </div>\n    <div class='field'>\n      <label>Website (optional)</label>\n      <input type='url' id='website' placeholder='https://example.com'>\n      <div class='feedback'><span class='error'>Enter a valid URL</span><span class='success'>✓ Valid URL</span></div>\n    </div>\n    <div class='field'>\n      <label>Bio (max 500 chars)</label>\n      <textarea id='bio' maxlength='500' rows='4' placeholder='Tell us about yourself...'></textarea>\n      <div class='char-count'><span id='charCount'>0</span>/500</div>\n      <div class='feedback'><span class='success'>✓ Within limit</span></div>\n    </div>\n    <button type='submit'>Save Profile</button>\n    <p class='success-msg' id='successMsg' style='display:none;'>Profile saved successfully!</p>\n  </form>\n  <script>\n    document.querySelectorAll('.field input, .field textarea').forEach(input => {\n      const field = input.closest('.field');\n      const error = field.querySelector('.error');\n      const success = field.querySelector('.success');\n\n      input.addEventListener('blur', () => {\n        if (input.validity.valid) { field.classList.add('valid'); field.classList.remove('invalid'); error.style.display = 'none'; success.style.display = 'block'; }\n        else { field.classList.remove('valid'); field.classList.add('invalid'); error.style.display = 'block'; success.style.display = 'none'; }\n      });\n      input.addEventListener('input', () => {\n        if (input.validity.valid) { field.classList.add('valid'); field.classList.remove('invalid'); error.style.display = 'none'; success.style.display = 'block'; }\n        else { field.classList.remove('valid'); field.classList.add('invalid'); error.style.display = 'block'; success.style.display = 'none'; }\n      });\n    });\n    document.getElementById('bio').addEventListener('input', function() {\n      document.getElementById('charCount').textContent = this.value.length;\n    });\n    document.getElementById('profileForm').addEventListener('submit', function(e) {\n      e.preventDefault();\n      document.querySelectorAll('.field input, .field textarea').forEach(input => {\n        const field = input.closest('.field');\n        const error = field.querySelector('.error');\n        const success = field.querySelector('.success');\n        if (!input.validity.valid) { field.classList.add('invalid'); error.style.display = 'block'; success.style.display = 'none'; }\n        else { field.classList.add('valid'); error.style.display = 'none'; success.style.display = 'block'; }\n      });\n      if (this.checkValidity()) {\n        document.getElementById('successMsg').style.display = 'block';\n        setTimeout(() => document.getElementById('successMsg').style.display = 'none', 3000);\n      }\n    });\n  </script>\n</body>\n</html>"
  },
  "medium": {
    "title": "Credit Card Form with Smart Validation",
    "description": "Build a credit card payment form with smart validation: Card Number (16 digits, auto-format with spaces every 4 digits, validate Luhn algorithm), Expiry (MM/YY format, validate not in the past), CVC (3 or 4 digits depending on card type), Cardholder Name (required, letters/spaces only). Auto-detect card type (Visa, MasterCard, Amex, Discover) from the card number prefix and adjust validation rules accordingly. Show card type icon next to the card number field.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Payment Form</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #f5f7fa; }\n    .card-preview { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 25px; border-radius: 12px; margin-bottom: 20px; min-height: 150px; }\n    .form-row { margin-bottom: 15px; }\n    .form-row.half { display: inline-block; width: calc(50% - 8px); }\n    .form-row.half:first-child { margin-right: 16px; }\n    input { width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px; font-size: 16px; box-sizing: border-box; }\n    input:focus { border-color: #667eea; outline: none; }\n    button { width: 100%; padding: 14px; background: #667eea; color: white; border: none; border-radius: 8px; font-size: 18px; cursor: pointer; }\n  </style>\n</head>\n<body>\n  <div class=\"card-preview\" id=\"cardPreview\">\n    <div id=\"cardType\">💳</div>\n    <div id=\"cardDisplay\">•••• •••• •••• ••••</div>\n    <div id=\"cardExpiry\">MM/YY</div>\n    <div id=\"cardHolder\">CARDHOLDER NAME</div>\n  </div>\n  <form id=\"paymentForm\" novalidate>\n    <div class=\"form-row\">\n      <input type=\"text\" id=\"cardNumber\" placeholder=\"Card Number\" maxlength=\"19\" inputmode=\"numeric\">\n    </div>\n    <!-- Add expiry, cvc, name fields -->\n    <button type=\"submit\">Pay</button>\n  </form>\n  <script>\n    // Add validation and formatting logic\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Payment Form</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #f5f7fa; }\n    h1 { text-align: center; color: #2c3e50; }\n    .card-preview { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 25px; border-radius: 12px; margin-bottom: 20px; min-height: 160px; display: flex; flex-direction: column; justify-content: space-between; box-shadow: 0 4px 15px rgba(102,126,234,0.3); font-family: 'Courier New', monospace; }\n    .card-preview .type { text-align: right; font-size: 24px; }\n    .card-preview .number { font-size: 22px; letter-spacing: 3px; text-align: center; margin: 10px 0; }\n    .card-preview .bottom { display: flex; justify-content: space-between; font-size: 12px; letter-spacing: 1px; }\n    .form-row { margin-bottom: 15px; }\n    .row-group { display: flex; gap: 10px; }\n    .row-group .form-row { flex: 1; }\n    input { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; transition: border-color 0.2s; }\n    input:focus { border-color: #667eea; outline: none; }\n    input.error { border-color: #e74c3c; }\n    input.valid { border-color: #4caf50; }\n    .error-msg { color: #e74c3c; font-size: 12px; margin-top: 4px; display: none; }\n    button { width: 100%; padding: 14px; background: #667eea; color: white; border: none; border-radius: 8px; font-size: 18px; cursor: pointer; transition: background 0.2s; font-weight: 600; }\n    button:hover { background: #5a6fd6; }\n    .success { text-align: center; color: #4caf50; margin-top: 10px; display: none; }\n  </style>\n</head>\n<body>\n  <h1>Payment Details</h1>\n  <div class='card-preview' id='cardPreview'>\n    <div class='type' id='cardType'>💳</div>\n    <div class='number' id='cardDisplay'>•••• •••• •••• ••••</div>\n    <div class='bottom'><span id='cardHolder'>CARDHOLDER NAME</span><span id='cardExpiry'>MM/YY</span></div>\n  </div>\n  <form id='paymentForm' novalidate>\n    <div class='form-row'>\n      <input type='text' id='cardNumber' placeholder='Card Number' maxlength='19' inputmode='numeric' autocomplete='cc-number'>\n      <div class='error-msg' id='cardError'>Enter a valid card number</div>\n    </div>\n    <div class='row-group'>\n      <div class='form-row'>\n        <input type='text' id='cardExpiryInput' placeholder='MM/YY' maxlength='5' autocomplete='cc-exp'>\n        <div class='error-msg' id='expiryError'>Enter a valid expiry date</div>\n      </div>\n      <div class='form-row'>\n        <input type='text' id='cardCvc' placeholder='CVC' maxlength='4' inputmode='numeric' autocomplete='cc-csc'>\n        <div class='error-msg' id='cvcError'>Enter a valid CVC</div>\n      </div>\n    </div>\n    <div class='form-row'>\n      <input type='text' id='cardName' placeholder='Cardholder Name' autocomplete='cc-name'>\n      <div class='error-msg' id='nameError'>Enter the cardholder name</div>\n    </div>\n    <button type='submit'>Pay Now</button>\n    <div class='success' id='successMsg'>✓ Payment processed successfully!</div>\n  </form>\n  <script>\n    const cardNumber = document.getElementById('cardNumber');\n    const cardExpiry = document.getElementById('cardExpiryInput');\n    const cardCvc = document.getElementById('cardCvc');\n    const cardName = document.getElementById('cardName');\n\n    function detectCardType(num) {\n      const clean = num.replace(/\\s/g, '');\n      if (/^4/.test(clean)) return { type: 'Visa', icon: '💳', cvcLen: 3, format: [4,4,4,4] };\n      if (/^5[1-5]/.test(clean)) return { type: 'MasterCard', icon: '💳', cvcLen: 3, format: [4,4,4,4] };\n      if (/^3[47]/.test(clean)) return { type: 'Amex', icon: '🏆', cvcLen: 4, format: [4,6,5] };\n      if (/^6(?:011|5)/.test(clean)) return { type: 'Discover', icon: '💳', cvcLen: 3, format: [4,4,4,4] };\n      return { type: 'Unknown', icon: '💳', cvcLen: 3, format: [4,4,4,4] };\n    }\n\n    function formatCardNumber(value, format) {\n      const digits = value.replace(/\\D/g, '');\n      let result = ''; let idx = 0;\n      for (const len of format) {\n        if (idx >= digits.length) break;\n        result += digits.substring(idx, idx + len) + ' ';\n        idx += len;\n      }\n      return result.trim();\n    }\n\n    function luhnCheck(num) {\n      const digits = num.replace(/\\s/g, '');\n      let sum = 0; let double = false;\n      for (let i = digits.length - 1; i >= 0; i--) {\n        let d = parseInt(digits[i]);\n        if (double) { d *= 2; if (d > 9) d -= 9; }\n        sum += d; double = !double;\n      }\n      return sum % 10 === 0;\n    }\n\n    cardNumber.addEventListener('input', function() {\n      const info = detectCardType(this.value);\n      const clean = this.value.replace(/\\s/g, '').replace(/\\D/g, '');\n      this.value = formatCardNumber(clean, info.format);\n      document.getElementById('cardType').textContent = info.icon;\n      const display = this.value || '•••• •••• •••• ••••';\n      document.getElementById('cardDisplay').textContent = display;\n      cardCvc.maxLength = info.cvcLen;\n    });\n\n    cardExpiry.addEventListener('input', function() {\n      let v = this.value.replace(/\\D/g, '');\n      if (v.length >= 2) { v = v.substring(0,2) + '/' + v.substring(2); }\n      this.value = v;\n      document.getElementById('cardExpiry').textContent = v || 'MM/YY';\n    });\n\n    cardName.addEventListener('input', function() {\n      document.getElementById('cardHolder').textContent = this.value.toUpperCase() || 'CARDHOLDER NAME';\n    });\n\n    function validateField(input, errorId, checkFn) {\n      const error = document.getElementById(errorId);\n      const result = checkFn();\n      if (!result) { input.classList.add('error'); input.classList.remove('valid'); error.style.display = 'block'; }\n      else { input.classList.remove('error'); input.classList.add('valid'); error.style.display = 'none'; }\n      return result;\n    }\n\n    document.getElementById('paymentForm').addEventListener('submit', function(e) {\n      e.preventDefault();\n      const v1 = validateField(cardNumber, 'cardError', () => {\n        const clean = cardNumber.value.replace(/\\s/g, '');\n        return clean.length >= 13 && clean.length <= 19 && luhnCheck(cardNumber.value);\n      });\n      const v2 = validateField(cardExpiry, 'expiryError', () => {\n        const m = /^(0[1-9]|1[0-2])\\/([0-9]{2})$/.exec(cardExpiry.value);\n        if (!m) return false;\n        const now = new Date();\n        const exp = new Date(2000 + parseInt(m[2]), parseInt(m[1]), 0);\n        return exp >= now;\n      });\n      const v3 = validateField(cardCvc, 'cvcError', () => {\n        const info = detectCardType(cardNumber.value);\n        return /^[0-9]{3,4}$/.test(cardCvc.value) && cardCvc.value.length === info.cvcLen;\n      });\n      const v4 = validateField(cardName, 'nameError', () => {\n        return cardName.value.trim().length >= 2 && /^[A-Za-z .'-]+$/.test(cardName.value);\n      });\n      if (v1 && v2 && v3 && v4) {\n        document.getElementById('successMsg').style.display = 'block';\n      }\n    });\n\n    [cardNumber, cardExpiry, cardCvc, cardName].forEach(input => {\n      input.addEventListener('blur', () => {\n        const field = input.id;\n        const errorMap = { cardNumber: 'cardError', cardExpiryInput: 'expiryError', cardCvc: 'cvcError', cardName: 'nameError' };\n        const errorId = errorMap[field];\n        if (!input.value.trim()) {\n          document.getElementById(errorId).style.display = 'none';\n          input.classList.remove('error', 'valid');\n        }\n      });\n    });\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Dynamic Form Validator Library",
    "description": "Build a reusable JavaScript form validation library called 'FormValidator' that: (1) Accepts a form element and a configuration object with field rules, (2) Supports built-in rules: required, minLength, maxLength, pattern, email, url, number, min, max, match (cross-field), custom (function), (3) Provides real-time validation with configurable trigger (blur/input/submit), (4) Displays errors in configurable locations (inline, tooltip, summary list), (5) Supports async validation rules (returning a Promise), (6) Has a public API: validate(), validateField(name), reset(), setErrors(errors), getValues(), (7) Includes TypeScript-like JSDoc comments. The library should be vanilla JS with no dependencies.",
    "starterCode": "/*\n * FormValidator.js - Reusable form validation library\n * \n * Usage:\n *   const validator = new FormValidator('#myForm', {\n *     fields: {\n *       email: {\n *         rules: ['required', 'email'],\n *         messages: { required: 'Email is required', email: 'Invalid email' }\n *       },\n *       password: {\n *         rules: ['required', { name: 'minLength', value: 8 }],\n *         messages: { required: 'Password required', minLength: 'Min 8 chars' }\n *       }\n *     },\n *     onValidate: (valid, errors) => { console.log(valid, errors); }\n *   });\n */\n\nclass FormValidator {\n  constructor(formEl, config) {\n    // Your implementation\n  }\n  validate() {\n    // Returns Promise<{valid: boolean, errors: object}>\n  }\n  validateField(name) {\n    // Validate a single field\n  }\n  reset() {\n    // Clear all errors and reset form\n  }\n  setErrors(errors) {\n    // Set external errors (e.g., from server)\n  }\n  getValues() {\n    // Return form values as object\n  }\n  destroy() {\n    // Clean up event listeners\n  }\n}\n\n// Test the library\nconst form = document.getElementById('testForm');\nconst validator = new FormValidator(form, {\n  fields: {\n    username: {\n      rules: ['required', { name: 'minLength', value: 3 }, { name: 'maxLength', value: 20 }, { name: 'pattern', value: /^[A-Za-z0-9_]+$/ }],\n      messages: { required: 'Username is required', minLength: 'Min 3 characters', maxLength: 'Max 20 characters', pattern: 'Letters, numbers, underscores only' }\n    },\n    email: {\n      rules: ['required', 'email'],\n      messages: { required: 'Email is required', email: 'Enter a valid email' }\n    },\n    password: {\n      rules: ['required', { name: 'minLength', value: 8 }],\n      messages: { required: 'Password required', minLength: 'At least 8 characters' }\n    },\n    confirmPassword: {\n      rules: ['required', { name: 'match', field: 'password' }],\n      messages: { required: 'Confirm your password', match: 'Passwords must match' }\n    },\n    age: {\n      rules: [{ name: 'number' }, { name: 'min', value: 18 }, { name: 'max', value: 120 }],\n      messages: { number: 'Must be a number', min: 'Must be 18 or older', max: 'Max 120' }\n    }\n  },\n  realTime: true,\n  trigger: 'blur',\n  errorDisplay: 'inline'\n});",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>FormValidator Library Demo</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; max-width: 700px; margin: 40px auto; padding: 20px; background: #f8f9fa; }\n    h1 { color: #2c3e50; }\n    .form-group { margin-bottom: 16px; }\n    label { display: block; margin-bottom: 4px; font-weight: 500; font-size: 14px; color: #333; }\n    input { width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px; font-size: 15px; transition: border-color 0.2s; }\n    input:focus { outline: none; border-color: #6C63FF; }\n    input.error { border-color: #e74c3c; }\n    input.valid { border-color: #4caf50; }\n    .error-msg { color: #e74c3c; font-size: 12px; margin-top: 4px; display: none; }\n    .error-msg.show { display: block; }\n    .error-summary { background: #fff5f5; border: 1px solid #fecaca; border-radius: 8px; padding: 15px; margin-bottom: 20px; display: none; }\n    .error-summary h3 { color: #e74c3c; font-size: 14px; margin: 0 0 8px; }\n    .error-summary ul { margin: 0; padding-left: 20px; font-size: 13px; color: #c0392b; }\n    button { padding: 12px 30px; background: #6C63FF; color: white; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; transition: background 0.2s; margin-right: 10px; }\n    button:hover { background: #5a52e0; }\n    button.secondary { background: #95a5a6; }\n    button.secondary:hover { background: #7f8c8d; }\n    .result { margin-top: 20px; background: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 8px; font-family: monospace; font-size: 13px; white-space: pre; overflow-x: auto; }\n    .badge { display: inline-block; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; margin-left: 6px; }\n    .badge.blue { background: #dbeafe; color: #1e40af; }\n    .badge.green { background: #dcfce7; color: #166534; }\n    .badge.red { background: #fee2e2; color: #991b1b; }\n  </style>\n</head>\n<body>\n  <h1>FormValidator Library <span class='badge blue'>v1.0</span></h1>\n  <p style='color:#666;margin-bottom:20px;'>A reusable, zero-dependency form validation library.</p>\n\n  <div class='error-summary' id='errorSummary'>\n    <h3>Please fix the following errors:</h3>\n    <ul id='errorList'></ul>\n  </div>\n\n  <form id='testForm' novalidate>\n    <div class='form-group'>\n      <label>Username <span class='badge red'>required</span></label>\n      <input type='text' id='username' placeholder='3-20 chars, letters/numbers/underscores'>\n      <div class='error-msg' id='username-error'></div>\n    </div>\n    <div class='form-group'>\n      <label>Email <span class='badge red'>required</span></label>\n      <input type='email' id='email' placeholder='user@example.com'>\n      <div class='error-msg' id='email-error'></div>\n    </div>\n    <div class='form-group'>\n      <label>Password <span class='badge red'>required, min 8</span></label>\n      <input type='password' id='password' placeholder='At least 8 characters'>\n      <div class='error-msg' id='password-error'></div>\n    </div>\n    <div class='form-group'>\n      <label>Confirm Password <span class='badge red'>required</span></label>\n      <input type='password' id='confirmPassword' placeholder='Re-enter password'>\n      <div class='error-msg' id='confirmPassword-error'></div>\n    </div>\n    <div class='form-group'>\n      <label>Age <span class='badge green'>18-120</span></label>\n      <input type='number' id='age' placeholder='18-120'>\n      <div class='error-msg' id='age-error'></div>\n    </div>\n    <button type='submit'>Validate & Submit</button>\n    <button type='button' class='secondary' onclick='validator.reset()'>Reset</button>\n  </form>\n\n  <div class='result' id='result'>// Validation output will appear here</div>\n\n  <script>\n    // ===== FormValidator Library =====\n    class FormValidator {\n      constructor(formEl, config) {\n        this.form = typeof formEl === 'string' ? document.querySelector(formEl) : formEl;\n        this.config = config;\n        this.errors = {};\n        this.fieldConfigs = config.fields || {};\n        this.customRules = {};\n        this.handlers = {};\n\n        this._builtInRules = {\n          required: (val) => val.trim() !== '' ? null : (this.fieldConfigs[this._currentField]?.messages?.required || 'This field is required'),\n          email: (val) => /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(val) ? null : (this.fieldConfigs[this._currentField]?.messages?.email || 'Invalid email'),\n          url: (val) => /^https?:\\/\\/.+/.test(val) ? null : (this.fieldConfigs[this._currentField]?.messages?.url || 'Invalid URL'),\n          minLength: (val, rule) => val.length >= rule.value ? null : (this.fieldConfigs[this._currentField]?.messages?.minLength || `Min ${rule.value} characters`),\n          maxLength: (val, rule) => val.length <= rule.value ? null : (this.fieldConfigs[this._currentField]?.messages?.maxLength || `Max ${rule.value} characters`),\n          pattern: (val, rule) => rule.value.test(val) ? null : (this.fieldConfigs[this._currentField]?.messages?.pattern || 'Invalid format'),\n          number: (val) => !isNaN(parseFloat(val)) && isFinite(val) ? null : (this.fieldConfigs[this._currentField]?.messages?.number || 'Must be a number'),\n          min: (val, rule) => parseFloat(val) >= rule.value ? null : (this.fieldConfigs[this._currentField]?.messages?.min || `Minimum is ${rule.value}`),\n          max: (val, rule) => parseFloat(val) <= rule.value ? null : (this.fieldConfigs[this._currentField]?.messages?.max || `Maximum is ${rule.value}`),\n          match: (val, rule) => {\n            const target = this.form.querySelector(`[name=\"${rule.field}\"], #${rule.field}`);\n            return val === (target ? target.value : '') ? null : (this.fieldConfigs[this._currentField]?.messages?.match || 'Fields do not match');\n          }\n        };\n\n        this._setupFields();\n        if (config.realTime) this._setupRealTimeValidation();\n        this.form.addEventListener('submit', (e) => this._onSubmit(e));\n      }\n\n      addRule(name, fn) { this.customRules[name] = fn; }\n\n      _setupFields() {\n        Object.keys(this.fieldConfigs).forEach(name => {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (input) input.dataset.validatorField = name;\n        });\n      }\n\n      _setupRealTimeValidation() {\n        const trigger = this.config.trigger || 'blur';\n        Object.keys(this.fieldConfigs).forEach(name => {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (!input) return;\n          const handler = (e) => { this.validateField(name); };\n          this.handlers[name] = handler;\n          input.addEventListener(trigger, handler);\n          if (trigger === 'blur') {\n            input.addEventListener('input', () => {\n              const errorEl = this._getErrorEl(name);\n              if (errorEl) errorEl.classList.remove('show');\n              input.classList.remove('error', 'valid');\n            });\n          }\n        });\n      }\n\n      async validateField(name) {\n        const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n        if (!input) return { valid: true, errors: [] };\n        this._currentField = name;\n        const value = input.value;\n        const rules = this.fieldConfigs[name].rules || [];\n        const fieldErrors = [];\n\n        for (const rule of rules) {\n          let ruleName, ruleConfig = {};\n          if (typeof rule === 'string') { ruleName = rule; }\n          else if (typeof rule === 'object') { ruleName = rule.name; ruleConfig = rule; }\n          else continue;\n\n          const fn = this._builtInRules[ruleName] || this.customRules[ruleName];\n          if (fn) {\n            let error = fn(value, ruleConfig);\n            if (error && typeof error.then === 'function') error = await error;\n            if (error) fieldErrors.push(error);\n          }\n        }\n\n        this.errors[name] = fieldErrors;\n        this._updateFieldUI(name, fieldErrors.length === 0);\n        return { valid: fieldErrors.length === 0, errors: fieldErrors };\n      }\n\n      async validate() {\n        const fieldNames = Object.keys(this.fieldConfigs);\n        const allErrors = {};\n        let allValid = true;\n\n        for (const name of fieldNames) {\n          const result = await this.validateField(name);\n          if (!result.valid) { allErrors[name] = result.errors; allValid = false; }\n        }\n\n        this.errors = allErrors;\n        this._updateErrorSummary();\n        if (this.config.onValidate) this.config.onValidate(allValid, allErrors);\n        return { valid: allValid, errors: allErrors };\n      }\n\n      reset() {\n        this.errors = {};\n        this.form.reset();\n        Object.keys(this.fieldConfigs).forEach(name => {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (input) { input.classList.remove('error', 'valid'); }\n          const errEl = this._getErrorEl(name);\n          if (errEl) errEl.classList.remove('show');\n        });\n        document.getElementById('errorSummary').style.display = 'none';\n      }\n\n      getValues() {\n        const data = {};\n        Object.keys(this.fieldConfigs).forEach(name => {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (input) data[name] = input.value;\n        });\n        return data;\n      }\n\n      destroy() {\n        Object.keys(this.handlers).forEach(name => {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (input) input.removeEventListener(this.config.trigger || 'blur', this.handlers[name]);\n        });\n      }\n\n      _getErrorEl(name) {\n        let el = document.getElementById(name + '-error');\n        if (!el) {\n          const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n          if (input) el = input.parentElement.querySelector('.error-msg');\n        }\n        return el;\n      }\n\n      _updateFieldUI(name, isValid) {\n        const input = this.form.querySelector(`[name=\"${name}\"], #${name}`);\n        if (!input) return;\n        input.classList.remove('error', 'valid');\n        input.classList.add(isValid ? 'valid' : 'error');\n\n        const errorEl = this._getErrorEl(name);\n        if (errorEl) {\n          const msgs = this.errors[name] || [];\n          errorEl.textContent = msgs[0] || '';\n          errorEl.classList.toggle('show', msgs.length > 0);\n        }\n      }\n\n      _updateErrorSummary() {\n        const summary = document.getElementById('errorSummary');\n        const list = document.getElementById('errorList');\n        const hasErrors = Object.values(this.errors).some(e => e.length > 0);\n        summary.style.display = hasErrors ? 'block' : 'none';\n        list.innerHTML = '';\n        Object.entries(this.errors).forEach(([name, msgs]) => {\n          msgs.forEach(msg => {\n            const li = document.createElement('li');\n            li.textContent = `${name}: ${msg}`;\n            list.appendChild(li);\n          });\n        });\n      }\n\n      async _onSubmit(e) {\n        e.preventDefault();\n        const result = await this.validate();\n        document.getElementById('result').textContent = JSON.stringify({\n          valid: result.valid,\n          errors: result.errors,\n          values: result.valid ? this.getValues() : null\n        }, null, 2);\n        if (!result.valid) {\n          this.form.querySelector('.error')?.focus();\n        } else {\n          alert('Form submitted successfully! (Demo)');\n        }\n      }\n    }\n\n    // ===== Demo =====\n    const validator = new FormValidator('#testForm', {\n      fields: {\n        username: {\n          rules: ['required', { name: 'minLength', value: 3 }, { name: 'maxLength', value: 20 }, { name: 'pattern', value: /^[A-Za-z0-9_]+$/ }],\n          messages: { required: 'Username is required', minLength: 'Min 3 characters', maxLength: 'Max 20 characters', pattern: 'Letters, numbers, underscores only' }\n        },\n        email: {\n          rules: ['required', 'email'],\n          messages: { required: 'Email is required', email: 'Enter a valid email address' }\n        },\n        password: {\n          rules: ['required', { name: 'minLength', value: 8 }],\n          messages: { required: 'Password is required', minLength: 'At least 8 characters' }\n        },\n        confirmPassword: {\n          rules: ['required', { name: 'match', field: 'password' }],\n          messages: { required: 'Confirm your password', match: 'Passwords must match' }\n        },\n        age: {\n          rules: [{ name: 'number' }, { name: 'min', value: 18 }, { name: 'max', value: 120 }],\n          messages: { number: 'Must be a number', min: 'Must be 18 or older', max: 'Max 120' }\n        }\n      },\n      realTime: true,\n      trigger: 'blur',\n      onValidate: (valid, errors) => {\n        document.getElementById('result').textContent = JSON.stringify({ valid, errors }, null, 2);\n      }\n    });\n  </script>\n</body>\n</html>"
  }
}
