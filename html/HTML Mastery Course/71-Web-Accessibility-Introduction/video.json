{
  "courseInfo": {
    "title": "Web Accessibility Introduction - Full Course",
    "duration": "45 minutes",
    "difficulty": "All Levels",
    "prerequisites": [
      "Basic HTML understanding",
      "No prior accessibility knowledge needed"
    ],
    "segments": [
      {
        "title": "What is Web Accessibility?",
        "duration": "8 min",
        "topics": [
          "Definition and importance",
          "Statistics on disability",
          "Legal landscape (ADA, Section 508, EN 301 549)",
          "Business case for accessibility"
        ]
      },
      {
        "title": "WCAG 2.2 Explained",
        "duration": "12 min",
        "topics": [
          "POUR principles in depth",
          "Conformance levels A, AA, AAA",
          "Key success criteria",
          "Understanding documents"
        ]
      },
      {
        "title": "Semantic HTML & Accessibility",
        "duration": "10 min",
        "topics": [
          "Landmarks and structure",
          "Heading hierarchy",
          "Form accessibility",
          "Image alt text best practices"
        ]
      },
      {
        "title": "Testing for Accessibility",
        "duration": "10 min",
        "topics": [
          "Automated testing (axe, Lighthouse)",
          "Manual keyboard testing",
          "Screen reader testing demo",
          "Color contrast checking"
        ]
      },
      {
        "title": "Building an Accessible Workflow",
        "duration": "5 min",
        "topics": [
          "Accessibility-first development",
          "Continuous integration testing",
          "Team training and resources"
        ]
      }
    ],
    "resources": [
      "WCAG 2.2 Quick Reference",
      "WebAIM Contrast Checker",
      "A11y Project Checklist"
    ]
  },
  "videos": []
}
