{
  "easy": {
    "title": "Build a Simple Audio Player with Controls",
    "description": "Create an HTML page with an embedded audio player that includes native controls, supports both MP3 and OGG formats, and displays a fallback message. Use a free audio URL from the internet (like SoundHelix).",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Audio Player</title>\n</head>\n<body>\n  <h1>My Audio Player</h1>\n  <!-- Add your audio element here -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Audio Player</title>\n  <style>\n    body { font-family: system-ui, sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; text-align: center; }\n    audio { width: 100%; }\n    .fallback { background: #fff3cd; padding: 15px; border-radius: 8px; margin-top: 10px; }\n  </style>\n</head>\n<body>\n  <h1>My Audio Player</h1>\n  <audio controls preload=\"metadata\">\n    <source src=\"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3\" type=\"audio/mpeg\">\n    <source src=\"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.ogg\" type=\"audio/ogg\">\n    <div class=\"fallback\">\n      <p>Your browser does not support HTML5 audio.</p>\n      <a href=\"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3\" download>Download the audio file</a>\n    </div>\n  </audio>\n</body>\n</html>"
  },
  "medium": {
    "title": "Custom Audio Player with Playlist",
    "description": "Build a custom-styled audio player (no native controls) that includes: a play/pause button, a seek slider, current time and duration display, a volume slider, and a playlist of at least 4 tracks. Tracks should auto-advance to the next when one ends and wrap around from the last track to the first.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Custom Player with Playlist</title>\n  <style>\n    /* Style your custom player here */\n  </style>\n</head>\n<body>\n  <div class=\"player\">\n    <!-- Custom controls -->\n  </div>\n  <div class=\"playlist\">\n    <!-- Playlist items -->\n  </div>\n  <script>\n    // Your JavaScript here\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Custom Player with Playlist</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { font-family: system-ui, sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; background: #1a1a2e; color: white; }\n    .player { background: #16213e; border-radius: 16px; padding: 25px; margin-bottom: 20px; }\n    .controls { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }\n    .controls button { background: #0f3460; border: none; color: white; width: 48px; height: 48px; border-radius: 50%; font-size: 20px; cursor: pointer; transition: 0.2s; }\n    .controls button:hover { background: #1a5276; }\n    .controls input[type='range'] { flex: 1; min-width: 80px; accent-color: #e94560; }\n    .time { font-size: 13px; color: #a8a8b3; font-variant-numeric: tabular-nums; }\n    .playlist { background: #16213e; border-radius: 16px; padding: 10px; }\n    .track { padding: 12px 16px; border-radius: 8px; cursor: pointer; transition: 0.2s; display: flex; justify-content: space-between; }\n    .track:hover { background: #0f3460; }\n    .track.active { background: #e94560; color: white; }\n    .volume-wrap { display: flex; align-items: center; gap: 8px; }\n    .volume-wrap input { width: 80px; }\n  </style>\n</head>\n<body>\n  <div class=\"player\">\n    <div class=\"controls\">\n      <button id=\"playBtn\">▶</button>\n      <input type=\"range\" id=\"seekBar\" value=\"0\" min=\"0\" max=\"100\" step=\"0.1\">\n      <span class=\"time\"><span id=\"currentTime\">0:00</span> / <span id=\"totalDuration\">0:00</span></span>\n      <div class=\"volume-wrap\">\n        <span>🔊</span>\n        <input type=\"range\" id=\"volumeBar\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.7\">\n      </div>\n    </div>\n  </div>\n  <div class=\"playlist\" id=\"playlist\"></div>\n\n  <script>\n    const tracks = [\n      { title: 'Ambient Dream', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3' },\n      { title: 'Sunset Groove', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3' },\n      { title: 'Urban Flow', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3' },\n      { title: 'Ocean Waves', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3' }\n    ];\n    let currentTrack = 0;\n    const audio = new Audio(tracks[0].src);\n    let isSeeking = false;\n\n    const playBtn = document.getElementById('playBtn');\n    const seekBar = document.getElementById('seekBar');\n    const volumeBar = document.getElementById('volumeBar');\n    const currentTime = document.getElementById('currentTime');\n    const totalDuration = document.getElementById('totalDuration');\n    const playlistEl = document.getElementById('playlist');\n\n    function renderPlaylist() {\n      playlistEl.innerHTML = '';\n      tracks.forEach((track, i) => {\n        const div = document.createElement('div');\n        div.className = 'track' + (i === currentTrack ? ' active' : '');\n        div.innerHTML = `<span>${i + 1}. ${track.title}</span><span>♫</span>`;\n        div.addEventListener('click', () => loadTrack(i));\n        playlistEl.appendChild(div);\n      });\n    }\n\n    function loadTrack(index) {\n      currentTrack = index;\n      audio.src = tracks[index].src;\n      audio.currentTime = 0;\n      audio.play().catch(() => {});\n      playBtn.textContent = '⏸';\n      renderPlaylist();\n    }\n\n    playBtn.addEventListener('click', () => {\n      if (audio.paused) {\n        audio.play().catch(() => {});\n        playBtn.textContent = '⏸';\n      } else {\n        audio.pause();\n        playBtn.textContent = '▶';\n      }\n    });\n\n    audio.addEventListener('loadedmetadata', () => {\n      totalDuration.textContent = formatTime(audio.duration);\n    });\n\n    audio.addEventListener('timeupdate', () => {\n      if (!isSeeking) {\n        seekBar.value = (audio.currentTime / audio.duration) * 100 || 0;\n        currentTime.textContent = formatTime(audio.currentTime);\n      }\n    });\n\n    seekBar.addEventListener('input', () => {\n      isSeeking = true;\n      currentTime.textContent = formatTime((seekBar.value / 100) * audio.duration);\n    });\n\n    seekBar.addEventListener('change', () => {\n      audio.currentTime = (seekBar.value / 100) * audio.duration;\n      isSeeking = false;\n    });\n\n    volumeBar.addEventListener('input', () => { audio.volume = parseFloat(volumeBar.value); });\n\n    audio.addEventListener('ended', () => {\n      const next = (currentTrack + 1) % tracks.length;\n      loadTrack(next);\n    });\n\n    audio.addEventListener('play', () => { playBtn.textContent = '⏸'; });\n    audio.addEventListener('pause', () => { playBtn.textContent = '▶'; });\n\n    function formatTime(s) {\n      if (isNaN(s)) return '0:00';\n      const m = Math.floor(s / 60);\n      const sec = Math.floor(s % 60).toString().padStart(2, '0');\n      return `${m}:${sec}`;\n    }\n\n    renderPlaylist();\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Real-Time Audio Visualizer with Frequency Analysis",
    "description": "Build a full-screen audio visualizer that: (1) Loads an audio file and connects it to the Web Audio API, (2) Renders a real-time frequency bar visualization using Canvas, (3) Uses at least 128 frequency bins with color gradients based on frequency ranges, (4) Includes play/pause controls and a file input to load custom audio files, (5) Displays current playback info (time, frequency peak).",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Audio Visualizer</title>\n  <style>\n    body { margin: 0; background: #0a0a1a; overflow: hidden; font-family: monospace; }\n  </style>\n</head>\n<body>\n  <canvas id=\"visualizer\"></canvas>\n  <div id=\"controls\">\n    <input type=\"file\" id=\"fileInput\" accept=\"audio/*\">\n    <button id=\"playBtn\">▶</button>\n  </div>\n  <script>\n    // Your code here\n  </script>\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Audio Visualizer</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { margin: 0; background: #0a0a1a; overflow: hidden; font-family: 'Segoe UI', system-ui, sans-serif; }\n    canvas { display: block; width: 100vw; height: 100vh; }\n    #controls {\n      position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);\n      background: rgba(0,0,0,0.75); backdrop-filter: blur(10px);\n      padding: 16px 24px; border-radius: 50px; display: flex; align-items: center; gap: 16px;\n      border: 1px solid rgba(255,255,255,0.1); z-index: 10;\n    }\n    #controls button {\n      background: #e94560; border: none; color: white; width: 44px; height: 44px;\n      border-radius: 50%; font-size: 18px; cursor: pointer; transition: 0.2s;\n    }\n    #controls button:hover { transform: scale(1.1); }\n    #controls input[type='file'] { color: white; font-size: 13px; }\n    #controls input[type='file']::file-selector-button {\n      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);\n      color: white; padding: 6px 14px; border-radius: 20px; cursor: pointer;\n    }\n    #info {\n      position: fixed; top: 20px; left: 50%; transform: translateX(-50%);\n      color: rgba(255,255,255,0.6); font-size: 14px; text-align: center;\n      background: rgba(0,0,0,0.5); padding: 8px 18px; border-radius: 20px;\n      z-index: 10; pointer-events: none;\n    }\n    #peakInfo {\n      position: fixed; top: 60px; right: 20px; color: rgba(255,255,255,0.5);\n      font-size: 13px; text-align: right; z-index: 10; pointer-events: none;\n    }\n  </style>\n</head>\n<body>\n  <canvas id=\"visualizer\"></canvas>\n  <div id=\"info\">Select an audio file to visualize</div>\n  <div id=\"peakInfo\">Peak: 0 dB</div>\n  <div id=\"controls\">\n    <input type=\"file\" id=\"fileInput\" accept=\"audio/*\">\n    <button id=\"playBtn\" disabled>▶</button>\n  </div>\n\n  <script>\n    const canvas = document.getElementById('visualizer');\n    const ctx = canvas.getContext('2d');\n    const fileInput = document.getElementById('fileInput');\n    const playBtn = document.getElementById('playBtn');\n    const infoEl = document.getElementById('info');\n    const peakEl = document.getElementById('peakInfo');\n\n    let audioCtx, source, analyser, audioElement;\n    let animationId = null;\n    let isPlaying = false;\n\n    function resize() {\n      canvas.width = window.innerWidth * devicePixelRatio;\n      canvas.height = window.innerHeight * devicePixelRatio;\n      ctx.scale(devicePixelRatio, devicePixelRatio);\n    }\n    window.addEventListener('resize', resize);\n    resize();\n\n    fileInput.addEventListener('change', async (e) => {\n      const file = e.target.files[0];\n      if (!file) return;\n\n      if (audioElement) {\n        audioElement.pause();\n        audioElement = null;\n      }\n      if (audioCtx) {\n        audioCtx.close();\n      }\n\n      audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n      const url = URL.createObjectURL(file);\n      audioElement = new Audio(url);\n      source = audioCtx.createMediaElementSource(audioElement);\n      analyser = audioCtx.createAnalyser();\n      analyser.fftSize = 512;\n      source.connect(analyser);\n      analyser.connect(audioCtx.destination);\n\n      audioElement.addEventListener('canplay', () => {\n        playBtn.disabled = false;\n        infoEl.textContent = `Loaded: ${file.name}`;\n      });\n\n      audioElement.addEventListener('ended', () => {\n        playBtn.textContent = '▶';\n        isPlaying = false;\n        cancelAnimationFrame(animationId);\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n      });\n\n      playBtn.onclick = () => {\n        if (!isPlaying) {\n          audioCtx.resume().then(() => audioElement.play());\n          playBtn.textContent = '⏸';\n          isPlaying = true;\n          visualize();\n        } else {\n          audioElement.pause();\n          playBtn.textContent = '▶';\n          isPlaying = false;\n          cancelAnimationFrame(animationId);\n        }\n      };\n    });\n\n    function visualize() {\n      const w = window.innerWidth;\n      const h = window.innerHeight;\n      const bufferLength = analyser.frequencyBinCount;\n      const dataArray = new Uint8Array(bufferLength);\n\n      function draw() {\n        animationId = requestAnimationFrame(draw);\n        analyser.getByteFrequencyData(dataArray);\n\n        ctx.fillStyle = '#0a0a1a';\n        ctx.fillRect(0, 0, w, h);\n\n        const barCount = bufferLength;\n        const barWidth = w / barCount * 2.5;\n        let maxVal = 0;\n\n        for (let i = 0; i < barCount; i++) {\n          const val = dataArray[i];\n          if (val > maxVal) maxVal = val;\n          const barHeight = (val / 255) * h * 0.9;\n          const hue = (i / barCount) * 270 + 240;\n          const lightness = 40 + (val / 255) * 40;\n          ctx.fillStyle = `hsl(${hue % 360}, 100%, ${lightness}%)`;\n          ctx.fillRect(i * barWidth, h - barHeight, barWidth - 2, barHeight);\n        }\n\n        const peakDb = Math.round((maxVal / 255) * 60);\n        peakEl.textContent = `Peak: ${peakDb} dB`;\n      }\n\n      draw();\n    }\n\n    document.addEventListener('click', () => {\n      if (audioCtx && audioCtx.state === 'suspended') {\n        audioCtx.resume();\n      }\n    });\n  </script>\n</body>\n</html>"
  }
}
