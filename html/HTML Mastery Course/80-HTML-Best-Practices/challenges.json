{
  "easy": {
    "title": "Fix the Non-Semantic HTML",
    "description": "The following HTML uses only <div> elements. Convert it to use proper semantic HTML5 elements including header, nav, main, article, section, aside, and footer. Add proper heading hierarchy and ARIA landmarks where appropriate.",
    "starterCode": "<div class=\"page\">\n  <div class=\"top-bar\">\n    <div class=\"logo\">My Blog</div>\n    <div class=\"menu\">\n      <div class=\"menu-item\">Home</div>\n      <div class=\"menu-item\">Articles</div>\n      <div class=\"menu-item\">Contact</div>\n    </div>\n  </div>\n  <div class=\"content\">\n    <div class=\"main-area\">\n      <div class=\"post\">\n        <div class=\"post-title\">Learning HTML</div>\n        <div class=\"post-meta\">Posted on June 1, 2026</div>\n        <div class=\"post-body\">\n          <div class=\"section\">HTML is the foundation of the web.</div>\n          <div class=\"section\">Semantic elements make it better.</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"sidebar\">\n      <div class=\"widget\">Recent Posts</div>\n      <div class=\"widget\">Categories</div>\n    </div>\n  </div>\n  <div class=\"bottom-bar\">\n    <div>&copy; 2026 My Blog</div>\n  </div>\n</div>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Blog</title>\n</head>\n<body>\n  <header>\n    <a href=\"/\" class=\"logo\">My Blog</a>\n    <nav aria-label=\"Main navigation\">\n      <ul>\n        <li><a href=\"/\">Home</a></li>\n        <li><a href=\"/articles\">Articles</a></li>\n        <li><a href=\"/contact\">Contact</a></li>\n      </ul>\n    </nav>\n  </header>\n  <main>\n    <article>\n      <header>\n        <h1>Learning HTML</h1>\n        <p><time datetime=\"2026-06-01\">June 1, 2026</time></p>\n      </header>\n      <section>\n        <h2>The Foundation of the Web</h2>\n        <p>HTML is the foundation of the web.</p>\n      </section>\n      <section>\n        <h2>Semantic Elements</h2>\n        <p>Semantic elements make it better.</p>\n      </section>\n    </article>\n    <aside>\n      <section>\n        <h2>Recent Posts</h2>\n        <ul>\n          <li><a href=\"#\">Post 1</a></li>\n          <li><a href=\"#\">Post 2</a></li>\n        </ul>\n      </section>\n      <section>\n        <h2>Categories</h2>\n        <ul>\n          <li><a href=\"#\">HTML</a></li>\n          <li><a href=\"#\">CSS</a></li>\n        </ul>\n      </section>\n    </aside>\n  </main>\n  <footer>\n    <p>&copy; 2026 My Blog</p>\n  </footer>\n</body>\n</html>"
  },
  "medium": {
    "title": "Accessible Registration Form",
    "description": "Create an accessible user registration form with the following fields: Full Name, Email, Password (with show/hide toggle), Date of Birth, Country (dropdown), Terms checkbox, and Submit button. Implement proper labeling, error messages with aria-describedby, fieldset grouping, and keyboard navigation. Include client-side validation with aria-invalid attributes.",
    "starterCode": "<form id=\"registration\" action=\"/register\" method=\"POST\" novalidate>\n  <!-- TODO: Implement accessible registration form -->\n</form>",
    "solution": "<form id=\"registration\" action=\"/register\" method=\"POST\" novalidate>\n  <h1>Create Account</h1>\n  <p>Fields marked with <span aria-label=\"required\">*</span> are required.</p>\n  \n  <fieldset>\n    <legend>Personal Information</legend>\n    \n    <div class=\"form-group\">\n      <label for=\"full-name\">Full Name <span aria-hidden=\"true\">*</span></label>\n      <input type=\"text\" id=\"full-name\" name=\"fullName\" required \n             minlength=\"2\" maxlength=\"100\" \n             aria-describedby=\"name-help name-error\"\n             aria-required=\"true\"\n             autocomplete=\"name\">\n      <span id=\"name-help\" class=\"help-text\">Enter your first and last name</span>\n      <span id=\"name-error\" class=\"error-text\" role=\"alert\"></span>\n    </div>\n    \n    <div class=\"form-group\">\n      <label for=\"email\">Email Address <span aria-hidden=\"true\">*</span></label>\n      <input type=\"email\" id=\"email\" name=\"email\" required\n             aria-describedby=\"email-help email-error\"\n             aria-required=\"true\"\n             autocomplete=\"email\">\n      <span id=\"email-help\" class=\"help-text\">We will send a confirmation email</span>\n      <span id=\"email-error\" class=\"error-text\" role=\"alert\"></span>\n    </div>\n    \n    <div class=\"form-group\">\n      <label for=\"password\">Password <span aria-hidden=\"true\">*</span></label>\n      <div class=\"password-wrapper\">\n        <input type=\"password\" id=\"password\" name=\"password\" required\n               minlength=\"8\" pattern=\"^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).{8,}$\"\n               aria-describedby=\"password-help password-error\"\n               aria-required=\"true\"\n               autocomplete=\"new-password\">\n        <button type=\"button\" id=\"toggle-password\" aria-label=\"Toggle password visibility\">Show</button>\n      </div>\n      <span id=\"password-help\" class=\"help-text\">Min 8 characters, 1 uppercase, 1 lowercase, 1 number</span>\n      <span id=\"password-error\" class=\"error-text\" role=\"alert\"></span>\n    </div>\n    \n    <div class=\"form-group\">\n      <label for=\"dob\">Date of Birth</label>\n      <input type=\"date\" id=\"dob\" name=\"dob\"\n             aria-describedby=\"dob-help\"\n             autocomplete=\"bday\">\n      <span id=\"dob-help\" class=\"help-text\">You must be 13 or older</span>\n    </div>\n    \n    <div class=\"form-group\">\n      <label for=\"country\">Country</label>\n      <select id=\"country\" name=\"country\">\n        <option value=\"\">Select a country</option>\n        <option value=\"US\">United States</option>\n        <option value=\"CA\">Canada</option>\n        <option value=\"GB\">United Kingdom</option>\n        <option value=\"AU\">Australia</option>\n      </select>\n    </div>\n  </fieldset>\n  \n  <div class=\"form-group checkbox-group\">\n    <input type=\"checkbox\" id=\"terms\" name=\"terms\" required\n           aria-describedby=\"terms-error\">\n    <label for=\"terms\">I agree to the <a href=\"/terms\">Terms and Conditions</a> <span aria-hidden=\"true\">*</span></label>\n    <span id=\"terms-error\" class=\"error-text\" role=\"alert\"></span>\n  </div>\n  \n  <button type=\"submit\">Create Account</button>\n</form>"
  },
  "hard": {
    "title": "Complete Accessible Blog Template with Performance Optimization",
    "description": "Build a complete blog template that demonstrates all HTML best practices: semantic structure, accessibility (skip links, ARIA landmarks, proper heading hierarchy, alt text, form accessibility), performance optimization (lazy loading images, deferred scripts, responsive images with srcset), SEO metadata (Open Graph, Twitter Cards, structured data), and proper document structure. The blog should include a header with navigation, a featured article with comments section, a sidebar with recent posts and categories, and a footer.",
    "starterCode": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <!-- TODO: Add all required meta tags, SEO, and performance optimizations -->\n  <title>Blog Template</title>\n</head>\n<body>\n  <!-- TODO: Build complete accessible blog template -->\n</body>\n</html>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Web Dev Daily - Semantic HTML Guide</title>\n  <meta name=\"description\" content=\"A comprehensive guide to writing semantic HTML5 for better accessibility, SEO, and maintainability.\">\n  <meta name=\"author\" content=\"Web Dev Daily\">\n  <link rel=\"canonical\" href=\"https://webdevdaily.com/semantic-html-guide\">\n  \n  <!-- Open Graph -->\n  <meta property=\"og:title\" content=\"The Complete Guide to Semantic HTML\">\n  <meta property=\"og:description\" content=\"Learn how to write clean, semantic HTML5 for better accessibility, SEO, and code maintainability.\">\n  <meta property=\"og:image\" content=\"https://webdevdaily.com/images/semantic-html-hero.jpg\">\n  <meta property=\"og:url\" content=\"https://webdevdaily.com/semantic-html-guide\">\n  <meta property=\"og:type\" content=\"article\">\n  \n  <!-- Twitter Cards -->\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n  <meta name=\"twitter:title\" content=\"The Complete Guide to Semantic HTML\">\n  <meta name=\"twitter:description\" content=\"Learn how to write clean, semantic HTML5.\">\n  \n  <!-- Favicons -->\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\">\n  <link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">\n  \n  <!-- Preload critical CSS -->\n  <link rel=\"preload\" href=\"/css/critical.css\" as=\"style\">\n  <link rel=\"stylesheet\" href=\"/css/critical.css\">\n  \n  <!-- Structured Data -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Article\",\n    \"headline\": \"The Complete Guide to Semantic HTML\",\n    \"author\": {\n      \"@type\": \"Organization\",\n      \"name\": \"Web Dev Daily\"\n    },\n    \"datePublished\": \"2026-06-10\"\n  }\n  </script>\n</head>\n<body>\n  <a href=\"#main-content\" class=\"skip-link\">Skip to main content</a>\n  \n  <header>\n    <a href=\"/\" class=\"logo\" aria-label=\"Web Dev Daily - Home\">\n      <img src=\"/logo.svg\" alt=\"\" width=\"40\" height=\"40\">\n      <span>Web Dev Daily</span>\n    </a>\n    <nav aria-label=\"Main navigation\">\n      <button id=\"nav-toggle\" aria-expanded=\"false\" aria-controls=\"nav-menu\">\n        <span class=\"sr-only\">Menu</span>\n      </button>\n      <ul id=\"nav-menu\" role=\"list\">\n        <li><a href=\"/\" aria-current=\"page\">Home</a></li>\n        <li><a href=\"/articles\">Articles</a></li>\n        <li><a href=\"/about\">About</a></li>\n        <li><a href=\"/contact\">Contact</a></li>\n      </ul>\n    </nav>\n  </header>\n  \n  <main id=\"main-content\">\n    <article>\n      <header>\n        <h1>The Complete Guide to Semantic HTML</h1>\n        <p>\n          <time datetime=\"2026-06-10\">June 10, 2026</time>\n          <span aria-hidden=\"true\"> &middot; </span>\n          <span class=\"sr-only\">Category: </span><a href=\"/category/html\">HTML</a>\n        </p>\n      </header>\n      \n      <section>\n        <h2>Why Semantic HTML Matters</h2>\n        <p>Semantic HTML is the practice of using HTML elements that convey meaning...</p>\n        \n        <figure>\n          <img src=\"semantic-structure.png\" \n               alt=\"Diagram showing semantic HTML structure with header, nav, main, article, aside, and footer elements\"\n               width=\"800\" height=\"450\"\n               loading=\"lazy\" decoding=\"async\">\n          <figcaption>Figure 1: Semantic HTML5 document structure</figcaption>\n        </figure>\n      </section>\n      \n      <section>\n        <h2>Best Practices</h2>\n        <h3>Use Proper Heading Hierarchy</h3>\n        <p>Always maintain a logical heading hierarchy...</p>\n        \n        <h3>Provide Alt Text</h3>\n        <p>All images must have appropriate alt text...</p>\n      </section>\n    </article>\n    \n    <section id=\"comments\" aria-label=\"Comments\">\n      <h2>Comments (2)</h2>\n      \n      <article class=\"comment\">\n        <h3 class=\"sr-only\">Comment by Sarah</h3>\n        <p><strong>Sarah</strong> <time datetime=\"2026-06-11\">June 11, 2026</time></p>\n        <p>Great article! The semantic elements explanation is very clear.</p>\n      </article>\n      \n      <form id=\"comment-form\">\n        <h3>Leave a Comment</h3>\n        <div class=\"form-group\">\n          <label for=\"comment-name\">Name <span aria-hidden=\"true\">*</span></label>\n          <input type=\"text\" id=\"comment-name\" name=\"name\" required aria-required=\"true\">\n        </div>\n        <div class=\"form-group\">\n          <label for=\"comment-body\">Comment <span aria-hidden=\"true\">*</span></label>\n          <textarea id=\"comment-body\" name=\"body\" required rows=\"4\" aria-required=\"true\"></textarea>\n        </div>\n        <button type=\"submit\">Post Comment</button>\n      </form>\n    </section>\n  </main>\n  \n  <aside>\n    <section>\n      <h2>Recent Posts</h2>\n      <ul>\n        <li><a href=\"#\">CSS Grid vs Flexbox</a></li>\n        <li><a href=\"#\">JavaScript Fundamentals</a></li>\n        <li><a href=\"#\">Responsive Design Patterns</a></li>\n      </ul>\n    </section>\n    <section>\n      <h2>Categories</h2>\n      <ul>\n        <li><a href=\"#\">HTML</a> (12)</li>\n        <li><a href=\"#\">CSS</a> (8)</li>\n        <li><a href=\"#\">JavaScript</a> (15)</li>\n        <li><a href=\"#\">Accessibility</a> (6)</li>\n      </ul>\n    </section>\n  </aside>\n  \n  <footer>\n    <p>&copy; 2026 Web Dev Daily. All rights reserved.</p>\n    <nav aria-label=\"Footer navigation\">\n      <ul>\n        <li><a href=\"/privacy\">Privacy Policy</a></li>\n        <li><a href=\"/terms\">Terms of Service</a></li>\n        <li><a href=\"/sitemap.xml\">Sitemap</a></li>\n      </ul>\n    </nav>\n  </footer>\n  \n  <script src=\"/js/main.js\" defer></script>\n</body>\n</html>"
