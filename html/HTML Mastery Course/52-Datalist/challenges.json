{
  "easy": {
    "title": "City Autocomplete Form",
    "description": "Create a form with a city input that uses a datalist with 10+ major world cities. Include a label, submit button, and display the selected city after submission.",
    "starterCode": "<form>\n  <label for=\"city\">City</label>\n  <input list=\"cities\" id=\"city\" name=\"city\">\n  <datalist id=\"cities\">\n    <!-- Add cities here -->\n  </datalist>\n  <button type=\"submit\">Submit</button>\n</form>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>City Autocomplete</title><style>body{font-family:system-ui;max-width:400px;margin:40px auto;padding:20px;}form{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}label{display:block;font-weight:600;margin-bottom:4px;}input{width:100%;padding:10px;border:2px solid #e2e8f0;border-radius:6px;box-sizing:border-box;}button{margin-top:12px;padding:10px 24px;background:#4a6cf7;color:white;border:none;border-radius:6px;cursor:pointer;}#result{margin-top:12px;padding:10px;background:#f0fdf4;border:1px solid #86efac;border-radius:6px;display:none;}</style></head><body><form id=\"cityForm\"><label for=\"city\">Select a City</label><input list=\"cities\" id=\"city\" name=\"city\" placeholder=\"Start typing...\"><datalist id=\"cities\"><option value=\"London\"><option value=\"New York\"><option value=\"Tokyo\"><option value=\"Paris\"><option value=\"Sydney\"><option value=\"Dubai\"><option value=\"Singapore\"><option value=\"Mumbai\"><option value=\"Berlin\"><option value=\"Toronto\"><option value=\"Seoul\"><option value=\"Rio de Janeiro\"></datalist><button type=\"submit\">Submit</button></form><div id=\"result\"></div><script>document.getElementById('cityForm').addEventListener('submit',function(e){e.preventDefault();var city=document.getElementById('city').value;if(city){var r=document.getElementById('result');r.style.display='block';r.textContent='Selected: '+city;}});</script></body></html>"
  },
  "medium": {
    "title": "Dynamic Programming Language Selector",
    "description": "Build a form where the datalist options change based on a category select (frontend, backend, mobile). Selecting 'frontend' shows HTML, CSS, JS, React, Vue. 'backend' shows Python, Node, Go, Rust. 'mobile' shows Swift, Kotlin, Flutter, React Native.",
    "starterCode": "<!DOCTYPE html><html><body>\n  <select id=\"category\">\n    <option value=\"frontend\">Frontend</option>\n    <option value=\"backend\">Backend</option>\n    <option value=\"mobile\">Mobile</option>\n  </select>\n  <input list=\"langs\" id=\"language\" placeholder=\"Select language\">\n  <datalist id=\"langs\"></datalist>\n  <script>\n    // Implement dynamic datalist\n  </script>\n</body></html>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Dynamic Datalist</title><style>body{font-family:system-ui;max-width:400px;margin:40px auto;padding:20px;}.card{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}label{display:block;font-weight:600;margin-bottom:4px;}select,input{width:100%;padding:10px;border:2px solid #e2e8f0;border-radius:6px;margin-bottom:12px;font-family:inherit;}.pill{display:inline-block;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;}.pill-fe{background:#dbeafe;color:#1e40af;}.pill-be{background:#dcfce7;color:#166534;}.pill-mb{background:#fef3c7;color:#92400e;}</style></head><body><div class=\"card\"><label for=\"category\">Category</label><select id=\"category\"><option value=\"frontend\">Frontend</option><option value=\"backend\">Backend</option><option value=\"mobile\">Mobile</option></select><label for=\"language\">Language</label><input list=\"langs\" id=\"language\" placeholder=\"Select language\"><datalist id=\"langs\"></datalist><div id=\"selected\"></div></div><script>const data={frontend:['HTML','CSS','JavaScript','TypeScript','React','Vue','Angular','Svelte'],backend:['Python','Node.js','Go','Rust','Java','C#','PHP','Ruby'],mobile:['Swift','Kotlin','Flutter','React Native','Dart','Objective-C']};const cat=document.getElementById('category');const lang=document.getElementById('language');const dl=document.getElementById('langs');const sel=document.getElementById('selected');function update(){var items=data[cat.value];dl.innerHTML=items.map(function(i){return'<option value=\"'+i+'\">'}).join('');lang.value='';sel.innerHTML='';}function showSelected(){if(lang.value){var catLabel=cat.value==='frontend'?'Frontend':cat.value==='backend'?'Backend':'Mobile';var pill='pill-'+cat.value.substring(0,2);sel.innerHTML='<span class=\"pill '+pill+'\">'+catLabel+': '+lang.value+'</span>';}}cat.addEventListener('change',update);lang.addEventListener('change',showSelected);update();</script></body></html>"
  },
  "hard": {
    "title": "Custom Styled Autocomplete Combobox",
    "description": "Build a fully styled autocomplete combobox that: (a) shows a dropdown of options filtered by input, (b) allows free-text or selection from list, (c) has custom styling (not the native OS popup), (d) supports keyboard navigation (arrow keys, Enter, Escape), (e) falls back to native datalist when JavaScript is disabled.",
    "starterCode": "<!DOCTYPE html><html><body>\n  <form>\n    <label for=\"autocomplete\">Search Employee</label>\n    <div id=\"combobox-container\">\n      <input id=\"autocomplete\" autocomplete=\"off\">\n      <ul id=\"listbox\" role=\"listbox\" hidden></ul>\n    </div>\n  </form>\n  <script>\n    // Implement custom combobox with JS\n  </script>\n  <noscript>\n    <!-- Fallback to native datalist -->\n  </noscript>\n</body></html>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Custom Autocomplete</title><style>*{box-sizing:border-box;margin:0;padding:0;}body{font-family:system-ui;background:#f0f2f5;display:flex;justify-content:center;padding-top:80px;}.wrapper{width:350px;}label{display:block;font-weight:600;margin-bottom:4px;color:#333;}.combo{position:relative;}input{width:100%;padding:10px 14px;border:2px solid #d1d5db;border-radius:8px;font-size:15px;background:white;}.combo:focus-within input{outline:none;border-color:#4a6cf7;box-shadow:0 0 0 3px rgba(74,108,247,0.15);}.listbox{position:absolute;top:calc(100% + 4px);left:0;right:0;background:white;border:1px solid #d1d5db;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.1);max-height:250px;overflow-y:auto;z-index:100;list-style:none;padding:4px 0;}.listbox li{padding:8px 14px;cursor:pointer;font-size:14px;border-radius:4px;margin:0 4px;}.listbox li:hover,.listbox li.highlight{background:#eef2ff;color:#4a6cf7;}.listbox li[aria-selected=true]{background:#4a6cf7;color:white;}.listbox li:not(:last-child){border-bottom:1px solid #f3f4f6;}.no-results{padding:12px;text-align:center;color:#9ca3af;font-size:13px;}</style></head><body><div class=\"wrapper\"><form id=\"searchForm\"><label for=\"ac\">Search Employee</label><div class=\"combo\"><input id=\"ac\" type=\"text\" placeholder=\"Start typing name...\" autocomplete=\"off\" role=\"combobox\" aria-expanded=\"false\" aria-controls=\"listbox\" aria-activedescendant=\"\"><ul id=\"listbox\" role=\"listbox\" class=\"listbox\" hidden></ul></div></form></div><script>(function(){var employees=['Alice Johnson','Bob Smith','Carol Williams','David Brown','Eve Davis','Frank Miller','Grace Wilson','Hank Moore','Ivy Taylor','Jack Anderson','Kate Thomas','Leo Jackson','Mia White','Nate Harris','Olivia Martin','Paul Garcia','Quinn Clark','Rachel Lewis','Sam Allen','Tina Young','Uma King','Victor Wright','Wendy Lopez','Xander Hill','Yara Scott','Zane Green'];var input=document.getElementById('ac');var listbox=document.getElementById('listbox');var isOpen=false;var selectedIndex=-1;var filtered=[];function filterItems(query){return employees.filter(function(e){return e.toLowerCase().includes(query.toLowerCase());});}function renderList(items){listbox.innerHTML='';if(items.length===0){var li=document.createElement('li');li.className='no-results';li.textContent='No matches found';listbox.appendChild(li);return;}items.forEach(function(item,idx){var li=document.createElement('li');li.textContent=item;li.id='option-'+idx;li.role='option';li.setAttribute('aria-selected','false');li.addEventListener('click',function(){selectItem(item);});li.addEventListener('mousedown',function(e){e.preventDefault();selectItem(item);});listbox.appendChild(li);});}function openList(){if(filtered.length===0)renderList(filtered);listbox.removeAttribute('hidden');isOpen=true;input.setAttribute('aria-expanded','true');}function closeList(){listbox.setAttribute('hidden','');input.setAttribute('aria-expanded','false');input.removeAttribute('aria-activedescendant');isOpen=false;selectedIndex=-1;}function selectItem(value){input.value=value;closeList();}function updateHighlight(idx){var items=listbox.querySelectorAll('li[role=option]');items.forEach(function(li,i){li.classList.toggle('highlight',i===idx);li.setAttribute('aria-selected',i===idx?'true':'false');});if(idx>=0&&items[idx]){input.setAttribute('aria-activedescendant',items[idx].id);items[idx].scrollIntoView({block:'nearest'});}}input.addEventListener('input',function(){var query=input.value.trim();filtered=query?filterItems(query):[];renderList(filtered);if(filtered.length>0||query){openList();}else{closeList();}selectedIndex=-1;});input.addEventListener('focus',function(){if(input.value.trim()){filtered=filterItems(input.value.trim());renderList(filtered);if(filtered.length>0)openList();}});input.addEventListener('blur',function(){setTimeout(closeList,150);});input.addEventListener('keydown',function(e){if(!isOpen)return;var options=listbox.querySelectorAll('li[role=option]');if(e.key==='ArrowDown'){e.preventDefault();selectedIndex=Math.min(selectedIndex+1,options.length-1);updateHighlight(selectedIndex);}else if(e.key==='ArrowUp'){e.preventDefault();selectedIndex=Math.max(selectedIndex-1,-1);updateHighlight(selectedIndex);}else if(e.key==='Enter'&&selectedIndex>=0){e.preventDefault();selectItem(filtered[selectedIndex]);}else if(e.key==='Escape'){e.preventDefault();closeList();}});input.addEventListener('keydown',function(e){if(e.key==='Enter'&&selectedIndex<0){closeList();}});})();</script><noscript><style>.combo{position:static;}input[list]{width:100%;padding:10px;border:2px solid #d1d5db;border-radius:8px;}</style><input list=\"empFallback\" placeholder=\"Start typing name...\" style=\"width:100%\"><datalist id=\"empFallback\"><option value=\"Alice Johnson\"><option value=\"Bob Smith\"><option value=\"Carol Williams\"><option value=\"David Brown\"><option value=\"Eve Davis\"><option value=\"Frank Miller\"><option value=\"Grace Wilson\"><option value=\"Hank Moore\"><option value=\"Ivy Taylor\"><option value=\"Jack Anderson\"><option value=\"Kate Thomas\"><option value=\"Leo Jackson\"><option value=\"Mia White\"><option value=\"Nate Harris\"><option value=\"Olivia Martin\"><option value=\"Paul Garcia\"><option value=\"Quinn Clark\"><option value=\"Rachel Lewis\"><option value=\"Sam Allen\"><option value=\"Tina Young\"><option value=\"Uma King\"><option value=\"Victor Wright\"><option value=\"Wendy Lopez\"><option value=\"Xander Hill\"><option value=\"Yara Scott\"><option value=\"Zane Green\"></datalist></noscript></body></html>"
  }
}
