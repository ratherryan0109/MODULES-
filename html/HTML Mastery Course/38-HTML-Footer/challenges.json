{
  "easy": {
    "title": "Create a Basic Page Footer",
    "description": "Build a page with a complete footer containing copyright, a navigation link section (Privacy, Terms, Contact), and an address element with email and phone.",
    "starterCode": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Footer Challenge</title></head><body><main><h1>Welcome</h1><p>Content area</p></main><!-- Add footer here --></body></html>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><title>Footer Challenge</title><style>body{font-family:system-ui,sans-serif;margin:0;min-height:100vh;display:flex;flex-direction:column}main{flex:1;padding:20px}footer{background:#333;color:white;padding:20px;text-align:center}footer a{color:#bbdefb}address{font-style:normal}</style></head><body><main><h1>Welcome</h1><p>Content area</p></main><footer><nav aria-label=\"Footer\"><a href=\"#\">Privacy</a> | <a href=\"#\">Terms</a> | <a href=\"#\">Contact</a></nav><address>Email: <a href=\"mailto:info@example.com\">info@example.com</a> | Phone: (555) 123-4567</address><p><small>&copy; 2026 Company. All rights reserved.</small></p></footer></body></html>"
  },
  "medium": {
    "title": "Multi-Column Footer with Sections",
    "description": "Create a multi-column footer using CSS Grid with 4 columns: About (company description), Links (navigation), Contact (address), and Social (social media icons). Include a copyright bar at the bottom. Make it responsive so columns stack on mobile.",
    "starterCode": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>Multi-Column Footer</title><style>/* Add styles */</style></head><body><footer><!-- 4 columns + copyright bar --></footer></body></html>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>Multi-Column Footer</title><style>*{margin:0;box-sizing:border-box}body{font-family:system-ui,sans-serif;min-height:100vh;display:flex;flex-direction:column}main{flex:1;padding:40px}footer{background:#1a237e;color:white;padding:40px 20px 0}.footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;max-width:1200px;margin:0 auto}footer h3{color:#7986cb;margin-bottom:15px}footer ul{list-style:none;padding:0}footer li{margin-bottom:8px}footer a{color:#bbdefb;text-decoration:none}.copyright{text-align:center;padding:20px;margin-top:30px;border-top:1px solid #3949ab}@media(max-width:768px){.footer-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:480px){.footer-grid{grid-template-columns:1fr}}</style></head><body><main><h1>Main Content</h1></main><footer><div class=\"footer-grid\"><section><h3>About Us</h3><p>We are dedicated to providing the best web development education.</p></section><section><h3>Quick Links</h3><ul><li><a href=\"#\">Home</a></li><li><a href=\"#\">Courses</a></li><li><a href=\"#\">Blog</a></li></ul></section><section><h3>Contact</h3><address style=\"font-style:normal\">Email: <a href=\"mailto:info@example.com\">info@example.com</a><br>Phone: (555) 123-4567</address></section><section><h3>Follow Us</h3><ul><li><a href=\"#\">Twitter</a></li><li><a href=\"#\">GitHub</a></li><li><a href=\"#\">LinkedIn</a></li></ul></section></div><div class=\"copyright\"><p><small>&copy; 2026 Company. All rights reserved.</small></p></div></footer></body></html>"
  },
  "hard": {
    "title": "Full Page with Sticky Footer and Back-to-Top",
    "description": "Build a complete page with a sticky footer (always at the bottom even with little content), a back-to-top button that appears when scrolling down, and a multi-column footer with newsletter signup form. Implement smooth scrolling and proper ARIA attributes.",
    "starterCode": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>Sticky Footer</title><style>/* Sticky footer + back to top */</style></head><body><header>Header</header><main><h1>Content</h1><p>Scroll down to see back-to-top button.</p><div style=\"height:1500px\"></div></main><footer><!-- Multi-column footer with form --></footer><button id=\"back-to-top\" aria-label=\"Back to top\">&#8593;</button><script>// Scroll to top logic</script></body></html>",
    "solution": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>Sticky Footer Demo</title><style>*{margin:0;box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:system-ui,sans-serif;display:flex;flex-direction:column;min-height:100vh}header{background:#1565c0;color:white;padding:1rem;position:sticky;top:0;z-index:10}main{flex:1;padding:40px;max-width:800px;margin:0 auto}footer{background:#333;color:white;padding:40px 20px 0;margin-top:auto}.footer-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;max-width:1200px;margin:0 auto}footer h3{color:#90caf9;margin-bottom:15px}footer a{color:#bbdefb}footer input{padding:8px;border:none;border-radius:4px;width:100%;margin-bottom:8px}footer button{background:#1565c0;color:white;border:none;padding:8px 16px;border-radius:4px;cursor:pointer}.copyright{text-align:center;padding:20px;margin-top:30px;border-top:1px solid #555}#back-to-top{position:fixed;bottom:20px;right:20px;width:48px;height:48px;background:#1565c0;color:white;border:none;border-radius:50%;cursor:pointer;font-size:1.5em;display:none;z-index:100;box-shadow:0 2px 5px rgba(0,0,0,0.3);touch-action:manipulation}#back-to-top:hover{background:#0d47a1}@media(max-width:600px){.footer-grid{grid-template-columns:1fr}}</style></head><body><header><h1>My Website</h1></header><main><h1>Welcome</h1><p>This page demonstrates a sticky footer and back-to-top button. Scroll down to see the button appear.</p><div style=\"height:1500px\"></div><p id=\"bottom\">You reached the bottom!</p></main><footer><div class=\"footer-grid\"><section><h3>About</h3><p>We build amazing web experiences.</p></section><section><h3>Links</h3><ul><li><a href=\"#\">Home</a></li><li><a href=\"#\">Services</a></li></ul></section><section><h3>Newsletter</h3><form><label for=\"email\">Subscribe:</label><input type=\"email\" id=\"email\" name=\"email\" placeholder=\"your@email.com\" required><button type=\"submit\">Subscribe</button></form></section></div><div class=\"copyright\"><p><small>&copy; 2026 Company. All rights reserved.</small></p></div></footer><button id=\"back-to-top\" aria-label=\"Back to top\">&#8593;</button><script>const btn=document.getElementById('back-to-top');window.addEventListener('scroll',()=>{btn.style.display=window.scrollY>300?'block':'none'});btn.addEventListener('click',()=>{window.scrollTo({top:0,behavior:'smooth'});btn.focus()})</script></body></html>"
  }
}