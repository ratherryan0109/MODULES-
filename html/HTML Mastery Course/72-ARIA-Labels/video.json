{
  "courseInfo": {
    "title": "ARIA Labels - Complete Guide",
    "duration": "50 minutes",
    "difficulty": "Intermediate",
    "prerequisites": [
      "Basic HTML",
      "Understanding of web accessibility concepts",
      "Familiarity with JavaScript events"
    ],
    "segments": [
      {
        "title": "Introduction to ARIA",
        "duration": "8 min",
        "topics": [
          "What is ARIA? History and purpose",
          "The first rule of ARIA",
          "When to use ARIA vs semantic HTML",
          "ARIA specification versions"
        ]
      },
      {
        "title": "ARIA Roles in Depth",
        "duration": "12 min",
        "topics": [
          "Landmark roles",
          "Widget roles and required states",
          "Document structure roles",
          "Live region roles",
          "Abstract roles (for reference)"
        ]
      },
      {
        "title": "States and Properties",
        "duration": "12 min",
        "topics": [
          "State vs property distinction",
          "Essential states (expanded, selected, pressed)",
          "Form-related properties",
          "Relationship attributes",
          "Live region attributes"
        ]
      },
      {
        "title": "Design Patterns and Focus Management",
        "duration": "10 min",
        "topics": [
          "Roving tabindex pattern",
          "aria-activedescendant pattern",
          "Tab panel implementation",
          "Modal dialog pattern",
          "Menu and menubar patterns"
        ]
      },
      {
        "title": "Testing and Debugging ARIA",
        "duration": "8 min",
        "topics": [
          "Chrome Accessibility Inspector",
          "Firefox Accessibility Inspector",
          "axe DevTools for ARIA",
          "Screen reader testing with NVDA",
          "Common ARIA mistakes and how to fix them"
        ]
      }
    ],
    "resources": [
      "WAI-ARIA Authoring Practices Guide",
      "ARIA in HTML specification",
      "MDN ARIA documentation"
    ]
  },
  "videos": []
}
