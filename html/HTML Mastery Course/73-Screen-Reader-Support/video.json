{
  "courseInfo": {
    "title": "Screen Reader Support - Complete Guide",
    "duration": "45 minutes",
    "difficulty": "Intermediate",
    "prerequisites": [
      "Basic HTML knowledge",
      "Understanding of accessibility fundamentals",
      "Access to a screen reader for practice"
    ],
    "segments": [
      {
        "title": "Introduction to Screen Readers",
        "duration": "8 min",
        "topics": [
          "What screen readers are and how they work",
          "Popular screen readers (NVDA, JAWS, VoiceOver)",
          "The accessibility tree concept",
          "Browse mode vs focus mode"
        ]
      },
      {
        "title": "Navigation Patterns",
        "duration": "10 min",
        "topics": [
          "Quick navigation keys (H, L, D, T, F, B)",
          "Elements list (NVDA+F7) and Rotor (VO+U)",
          "Tab navigation vs browse mode",
          "Forms mode activation"
        ]
      },
      {
        "title": "Content Optimization",
        "duration": "10 min",
        "topics": [
          "Alt text best practices",
          "Link text optimization",
          "Heading hierarchy",
          "Table structure",
          "Form labels and descriptions"
        ]
      },
      {
        "title": "Dynamic Content and Live Regions",
        "duration": "10 min",
        "topics": [
          "aria-live politeness levels",
          "role=\"alert\" and role=\"status\"",
          "Focus management patterns",
          "Loading states and progress"
        ]
      },
      {
        "title": "Testing and Debugging",
        "duration": "7 min",
        "topics": [
          "Setting up testing environment",
          "Creating test scripts",
          "Common issues and fixes",
          "Cross-screen reader testing"
        ]
      }
    ],
    "resources": [
      "NVDA Screen Reader",
      "WebAIM Screen Reader Survey",
      "WAI Testing Guide"
    ]
  },
  "videos": []
}
