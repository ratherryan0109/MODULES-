{
  "easy": {
    "title": "Style a Product Description with Spans",
    "description": "Take a product description and use spans to highlight key features, apply color coding (positive = green, warning = orange, negative = red), add badges for 'New' and 'Sale', and use a tooltip span.",
    "starterCode": "<h2>SmartWatch Pro X2</h2>\n<p>The SmartWatch Pro X2 features a stunning AMOLED display with 24-hour battery life. It has water resistance up to 50 meters and includes GPS tracking. Available now in three colors. Price: $249.99. Limited time offer: Free shipping.</p>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Product Description</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; line-height: 1.8; }\n    .badge { background: #e74c3c; color: white; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }\n    .badge-sale { background: #f39c12; color: white; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }\n    .positive { color: #27ae60; font-weight: bold; }\n    .warning { color: #f39c12; font-weight: bold; }\n    .price { color: #e74c3c; font-size: 24px; font-weight: bold; }\n    .highlight { background: #fff3cd; padding: 2px 6px; border-radius: 3px; }\n    .tooltip-span { border-bottom: 1px dashed #2980b9; cursor: help; }\n    .tooltip-span:hover::after { content: attr(data-tip); position: absolute; background: #333; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px; white-space: nowrap; }\n  </style>\n</head>\n<body>\n  <h2>SmartWatch Pro X2 <span class=\"badge\">NEW</span></h2>\n  <p>The SmartWatch Pro X2 features a <span class=\"highlight\">stunning AMOLED display</span> with <span class=\"positive\">24-hour battery life</span>. It has <span class=\"warning\">water resistance</span> up to 50 meters and includes <span class=\"positive\">GPS tracking</span>. <span class=\"badge-sale\">SALE</span></p>\n  <p>Available now in <span class=\"tooltip-span\" data-tip=\"Black, Silver, Rose Gold\">three colors</span>.</p>\n  <p>Price: <span class=\"price\">$249.99</span> <span style=\"color:#999;font-size:14px;\">was $349.99</span></p>\n  <p><span style=\"color:#27ae60;\">✓</span> <span class=\"positive\">Free shipping</span> on all orders</p>\n</body>\n</html>"
  },
  "medium": {
    "title": "Build a Live Character Counter with Span",
    "description": "Create a text input with a live character counter that updates as the user types. Use a span to display the count, and change the span's color based on remaining characters (green > 50, yellow > 20, red < 20).",
    "starterCode": "<div>\n  <textarea id=\"text-input\" placeholder=\"Type something...\" maxlength=\"200\"></textarea>\n  <p>Characters: <span id=\"char-count\">0</span>/200</p>\n</div>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Character Counter</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; }\n    h2 { color: #2c3e50; }\n    textarea { width: 100%; height: 150px; padding: 16px; font-size: 16px; border: 2px solid #ddd; border-radius: 8px; resize: vertical; }\n    textarea:focus { border-color: #3498db; outline: none; }\n    .counter { margin-top: 12px; font-size: 16px; color: #666; }\n    #char-count { font-weight: bold; font-size: 20px; padding: 2px 8px; border-radius: 4px; }\n    .count-green { color: #27ae60; background: #d5f5e3; }\n    .count-yellow { color: #f39c12; background: #fef9e7; }\n    .count-red { color: #e74c3c; background: #fce4e4; }\n  </style>\n</head>\n<body>\n  <h2>Live Character Counter</h2>\n  <textarea id=\"text-input\" placeholder=\"Start typing...\" maxlength=\"200\"></textarea>\n  <p class=\"counter\">Characters: <span id=\"char-count\" class=\"count-green\">0</span> / 200</p>\n  <p id=\"words-display\" style=\"color:#666;font-size:14px;\">Words: <span id=\"word-count\">0</span></p>\n  <script>\n    const input = document.getElementById('text-input');\n    const countSpan = document.getElementById('char-count');\n    const wordSpan = document.getElementById('word-count');\n    input.addEventListener('input', function() {\n      const len = this.value.length;\n      countSpan.textContent = len;\n      countSpan.className = len > 150 ? 'count-red' : len > 100 ? 'count-yellow' : 'count-green';\n      wordSpan.textContent = this.value.trim() ? this.value.trim().split(/\\s+/).length : 0;\n    });\n  </script>\n</body>\n</html>"
  },
  "hard": {
    "title": "Build an Interactive Text Highlighter Tool",
    "description": "Create a tool that lets users select text in a paragraph and click a button to wrap the selected text in a highlighted span. Include options for yellow, green, and blue highlights, and a clear-all button. Uses the Selection API and DOM manipulation.",
    "starterCode": "<div id=\"text-content\">\n  <p>Select any text in this paragraph and click a highlight color button below. You can apply multiple highlights and clear them with the reset button.</p>\n</div>\n<div>\n  <button>Yellow</button>\n  <button>Green</button>\n  <button>Blue</button>\n  <button>Clear All</button>\n</div>",
    "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Text Highlighter</title>\n  <style>\n    body { font-family: 'Segoe UI', sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; background: #f5f7fa; }\n    h2 { color: #2c3e50; }\n    #text-content { background: white; padding: 24px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); line-height: 1.8; margin-bottom: 20px; }\n    .hl-yellow span { background: #fff3cd; padding: 2px 4px; border-radius: 2px; }\n    .hl-green span { background: #d5f5e3; padding: 2px 4px; border-radius: 2px; }\n    .hl-blue span { background: #d6eaf8; padding: 2px 4px; border-radius: 2px; }\n    .toolbar { display: flex; gap: 10px; flex-wrap: wrap; }\n    .toolbar button { padding: 10px 20px; border: 2px solid #ddd; border-radius: 6px; cursor: pointer; font-weight: bold; transition: all 0.2s; background: white; }\n    .toolbar button:hover { transform: translateY(-2px); }\n    .btn-yellow:hover { border-color: #f1c40f; background: #fff3cd; }\n    .btn-green:hover { border-color: #27ae60; background: #d5f5e3; }\n    .btn-blue:hover { border-color: #2980b9; background: #d6eaf8; }\n    .btn-clear { background: #e74c3c !important; color: white; border-color: #e74c3c !important; }\n  </style>\n</head>\n<body>\n  <h2>Text Highlighter Tool</h2>\n  <p style=\"color:#666;margin-bottom:16px;\">Select text in the box below and click a color to highlight it.</p>\n  <div id=\"text-content\" class=\"hl-yellow\">\n    <p>The quick brown fox jumps over the lazy dog. This is a sample paragraph for testing the highlight tool. Select any portion of text and apply a highlight color. You can apply multiple highlights in different colors. Click the clear button to reset all highlights.</p>\n  </div>\n  <div class=\"toolbar\">\n    <button class=\"btn-yellow\" onclick=\"highlight('hl-yellow', '#fff3cd')\">🟡 Yellow</button>\n    <button class=\"btn-green\" onclick=\"highlight('hl-green', '#d5f5e3')\">🟢 Green</button>\n    <button class=\"btn-blue\" onclick=\"highlight('hl-blue', '#d6eaf8')\">🔵 Blue</button>\n    <button class=\"btn-clear\" onclick=\"clearHighlights()\">🗑 Clear All</button>\n  </div>\n  <script>\n    function highlight(className, color) {\n      const selection = window.getSelection();\n      if (!selection.rangeCount || selection.isCollapsed) {\n        alert('Please select some text first!');\n        return;\n      }\n      const range = selection.getRangeAt(0);\n      const span = document.createElement('span');\n      span.style.background = color;\n      span.style.padding = '2px 4px';\n      span.style.borderRadius = '2px';\n      try {\n        range.surroundContents(span);\n      } catch(e) {\n        alert('Cannot highlight across multiple elements. Please select text within a single paragraph.');\n      }\n      selection.removeAllRanges();\n    }\n    function clearHighlights() {\n      const container = document.getElementById('text-content');\n      const spans = container.querySelectorAll('span');\n      spans.forEach(span => {\n        const parent = span.parentNode;\n        while (span.firstChild) {\n          parent.insertBefore(span.firstChild, span);\n        }\n        parent.removeChild(span);\n      });\n    }\n  </script>\n</body>\n</html>"
  }
}
